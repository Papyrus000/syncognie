---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface BreadcrumbParent {
  label: string;
  href: string;
}

const {
  title    = "Atelier",
  filename = "atelier",
  parent,          // optionnel : { label: "fondations", href: "/atelier/fondations" }
} = Astro.props as {
  title?:    string;
  filename?: string;
  parent?:   BreadcrumbParent;
};
---
<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Syncognie</title>
    <meta name="robots" content="noindex" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Mulish:wght@300;400&family=JetBrains+Mono:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />

    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      :root {
        --gold: #e8b832;
        --frame-bg:       #3d2510;
        --frame-titlebar: #331e0a;
      }
    </style>
  </head>
  <body class="atelier-body">
    <Header />
    <main class="atelier-main">
      <div class="atelier-wrap">

        <!-- Fil d'Ariane contextuel -->
        <nav class="breadcrumb" aria-label="Fil d'Ariane">
          <a href="/atelier" class="crumb crumb--link">✦ atelier</a>

          {parent && (
            <>
              <span class="crumb-sep">›</span>
              <a href={parent.href} class="crumb crumb--link">{parent.label}</a>
            </>
          )}

          <span class="crumb-sep">›</span>
          <span class="crumb crumb--current">{filename}</span>
          <span class="atelier-hint">jardin numérique</span>
        </nav>

        <!-- Cadre style éditeur -->
        <div class="atelier-frame">
          <div class="atelier-titlebar">
            <span class="atelier-filename">syncognie · atelier</span>
          </div>
          <div class="atelier-content">
            <slot />
          </div>
        </div>

      </div>
    </main>
    <Footer />

    <!-- Bouton scroll-to-top -->
    <button class="scroll-top" id="scrollTop" aria-label="Retour en haut">↑</button>
  </body>
</html>

<script>
  const btn = document.getElementById('scrollTop');
  if (btn) {
    window.addEventListener('scroll', () => {
      btn.classList.toggle('scroll-top--visible', window.scrollY > 400);
    }, { passive: true });
    btn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
</script>

<style>
  /* ── Fond gradient orange ── */
  .atelier-body {
    background: linear-gradient(135deg, #f5c842 0%, #f07c1e 50%, #e8572a 100%);
    background-attachment: fixed;
    min-height: 100vh;
  }

  .atelier-main {
    padding: 2.5rem 1.5rem 3rem;
    display: flex;
    justify-content: center;
  }

  .atelier-wrap {
    width: 100%;
    max-width: 820px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* ── Fil d'Ariane ── */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0 0.25rem;
  }
  .crumb {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    padding: 3px 12px;
    border-radius: 20px;
  }
  .crumb--link {
    background: rgba(255,255,255,0.9);
    color: #7a4a18;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
  }
  .crumb--link:hover {
    background: white;
    color: #4a2a08;
  }
  .crumb-sep {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: rgba(255,255,255,0.6);
  }
  .crumb--current {
    background: rgba(0,0,0,0.2);
    color: rgba(255,255,255,0.85);
  }
  .atelier-hint {
    margin-left: auto;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    color: rgba(255,255,255,0.4);
    letter-spacing: 0.04em;
  }

  /* ── Cadre ── */
  .atelier-frame {
    background: var(--frame-bg);
    border-radius: 12px;
    border-top: 1px solid rgba(232, 150, 60, 0.10);
    transform: translateY(-2px);
    box-shadow:
      0 2px 4px   rgba(20, 6, 0, 0.40),
      0 12px 24px  rgba(40, 12, 0, 0.45),
      0 45px 90px  rgba(30, 8, 0, 0.55),
      0 80px 120px rgba(180, 70, 10, 0.20);
    width: 100%;
    overflow: hidden;
  }

  /* ── Barre de titre ── */
  .atelier-titlebar {
    display: flex;
    align-items: center;
    padding: 12px 20px;
    background: var(--frame-titlebar);
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }
  .atelier-filename {
    margin: 0 auto;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    color: #8a6a4a;
    letter-spacing: 0.05em;
  }

  /* ── Contenu ── */
  .atelier-content {
    padding: 2.5rem 4rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.95rem;
    line-height: 1.9;
  }

  .atelier-content :global(p),
  .atelier-content :global(li) {
    color: #d4a878;
    margin-bottom: 1.2rem;
    font-family: 'Mulish', sans-serif;
    font-weight: 300;
    font-size: 1rem;
    line-height: 1.85;
    letter-spacing: 0.02em;
  }

  .atelier-content :global(h1) {
    color: #e8a050;
    font-size: 1.35rem;
    font-weight: 400;
    font-style: italic;
    margin-bottom: 1.6rem;
    font-family: 'Libre Baskerville', serif;
    letter-spacing: 0.01em;
  }
  .atelier-content :global(h2) {
    color: #c88840;
    font-size: 1.05rem;
    font-weight: 400;
    font-style: italic;
    margin: 2rem 0 0.8rem;
    font-family: 'Libre Baskerville', serif;
    letter-spacing: 0.01em;
  }
  .atelier-content :global(h3) {
    color: #b07030;
    font-size: 0.9rem;
    font-weight: 700;
    margin: 1.5rem 0 0.6rem;
    font-family: 'Libre Baskerville', serif;
  }

  .atelier-content :global(code) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.88em;
    color: #e07890;
    background: rgba(220,100,120,0.1);
    padding: 2px 6px;
    border-radius: 4px;
  }

  .atelier-content :global(pre) {
    background: #edebeb !important;
    border: 0px solid rgba(255, 150, 80, 0.12) !important;
    border-left: 3px solid rgba(200, 136, 64, 0.35) !important;
    padding: 1.4rem 1.8rem !important;
    border-radius: 8px !important;
    overflow-x: auto;
    margin: 1.8rem 0;
    box-shadow: inset 0 1px 0 rgba(255,150,80,0.04);
  }
  .atelier-content :global(pre code) {
    background: none !important;
    padding: 0 !important;
    color: #c8a06a !important;
    font-size: 0.88rem !important;
    font-family: 'JetBrains Mono', monospace !important;
    line-height: 1.9 !important;
  }
  .atelier-content :global(pre span) {
    color: #c8a06a !important;
    font-style: normal !important;
    font-weight: normal !important;
    background: none !important;
  }

  .atelier-content :global(a) {
    color: #e09050;
    text-decoration: none;
    transition: color 0.2s;
  }
  .atelier-content :global(a:hover) { color: #7abd6e; }

  .atelier-content :global(hr) {
    border: none;
    border-top: 1px solid rgba(255,150,80,0.1);
    margin: 2rem 0;
  }

  .atelier-content :global(ul),
  .atelier-content :global(ol) {
    padding-left: 1.5rem;
    margin: 0 0 1.2rem;
    font-family: 'Mulish', sans-serif;
    font-weight: 300;
  }
  .atelier-content :global(li) { margin-bottom: 0.4rem; }

  .atelier-content :global(blockquote) {
    border-left: 3px solid rgba(224,144,80,0.35);
    margin: 1.5rem 0;
    padding: 0.5rem 0 0.5rem 1.2rem;
    color: #a07850;
    font-style: italic;
    font-family: 'Libre Baskerville', serif;
    font-size: 0.95rem;
  }

  /* ── Tableaux ── */
  .atelier-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.8rem 0;
    font-family: 'Mulish', sans-serif;
    font-size: 0.92rem;
    overflow: hidden;
    border-radius: 6px;
  }
  .atelier-content :global(thead) {
    border-bottom: 2px solid rgba(232, 144, 80, 0.25);
  }
  .atelier-content :global(th) {
    color: #e8a050;
    font-weight: 700;
    text-align: left;
    padding: 0.65rem 1.1rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: rgba(255, 150, 80, 0.06);
  }
  .atelier-content :global(td) {
    color: #d4a878;
    padding: 0.55rem 1.1rem;
    border-bottom: 1px solid rgba(255, 150, 80, 0.07);
    font-weight: 300;
    line-height: 1.7;
  }
  .atelier-content :global(tbody tr:last-child td) { border-bottom: none; }
  .atelier-content :global(tbody tr:nth-child(even)) {
    background: rgba(255, 150, 80, 0.04);
  }
  .atelier-content :global(tbody tr:hover) {
    background: rgba(255, 150, 80, 0.08);
    transition: background 0.15s ease;
  }

  /* ── Scroll-to-top ── */
  .scroll-top {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.15);
    background: rgba(61, 37, 16, 0.85);
    backdrop-filter: blur(8px);
    color: #a07850;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.25s, transform 0.25s, color 0.2s, border-color 0.2s;
    pointer-events: none;
    z-index: 100;
  }
  .scroll-top--visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .scroll-top:hover {
    color: #e8a050;
    border-color: rgba(232, 160, 80, 0.4);
  }

  @media (max-width: 640px) {
    .atelier-content { padding: 1.8rem 2rem; }
    .atelier-hint { display: none; }
    .atelier-content :global(table) { font-size: 0.82rem; }
    .atelier-content :global(th),
    .atelier-content :global(td) { padding: 0.5rem 0.7rem; }
    .scroll-top { bottom: 1.2rem; right: 1.2rem; }
  }
</style>
