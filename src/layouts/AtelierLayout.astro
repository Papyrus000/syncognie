---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const { title = "Atelier", filename = "atelier" } = Astro.props;
---
<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Syncognie</title>
    <meta name="robots" content="noindex" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Mulish:wght@300;400&family=JetBrains+Mono:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />

    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      :root { --gold: #e8b832; }
    </style>
  </head>
  <body class="atelier-body">
    <Header />
    <main class="atelier-main">
      <div class="atelier-wrap">

        <!-- Fil d'Ariane -->
        <nav class="breadcrumb" aria-label="Fil d'Ariane">
          <a href="/atelier" class="crumb crumb--link">✦ atelier</a>
          <span class="crumb-sep">›</span>
          <span class="crumb crumb--current">{filename}</span>
          <span class="atelier-hint">jardin numérique</span>
        </nav>

        <!-- Cadre style éditeur -->
        <div class="atelier-frame">
          <div class="atelier-titlebar">
            <span class="atelier-filename">syncognie · atelier</span>
          </div>
          <div class="atelier-content">
            <slot />
          </div>
        </div>

      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  /* ── Fond gradient orange ── */
  .atelier-body {
    background: linear-gradient(135deg, #f5c842 0%, #f07c1e 50%, #e8572a 100%);
    min-height: 100vh;
  }

  .atelier-main {
    padding: 2.5rem 1.5rem 3rem;
    display: flex;
    justify-content: center;
  }

  .atelier-wrap {
    width: 100%;
    max-width: 820px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* ── Fil d'Ariane ── */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0 0.25rem;
  }
  .crumb {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    padding: 3px 12px;
    border-radius: 20px;
  }
  .crumb--link {
    background: rgba(255,255,255,0.9);
    color: #7a4a18;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
  }
  .crumb--link:hover {
    background: white;
    color: #4a2a08;
  }
  .crumb-sep {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: rgba(255,255,255,0.6);
  }
  .crumb--current {
    background: rgba(0,0,0,0.2);
    color: rgba(255,255,255,0.85);
  }
  .atelier-hint {
    margin-left: auto;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    color: rgba(255,255,255,0.4);
    letter-spacing: 0.04em;
  }

  /* ── Cadre — couleurs de la capture ── */
  .atelier-frame {
    background: #1e1108;
    border-radius: 12px;
    border-top: 1px solid rgba(232, 150, 60, 0.10);
    transform: translateY(-2px);
    box-shadow:
      0 2px 4px   rgba(20, 6, 0, 0.40),
      0 12px 24px  rgba(40, 12, 0, 0.45),
      0 45px 90px  rgba(30, 8, 0, 0.55),
      0 80px 120px rgba(180, 70, 10, 0.20);
    width: 100%;
    overflow: hidden;
  }

  /* ── Barre de titre ── */
  .atelier-titlebar {
    display: flex;
    align-items: center;
    padding: 12px 20px;
    background: #170d05;
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }
  .atelier-filename {
    margin: 0 auto;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    color: #8a6a4a;
    letter-spacing: 0.05em;
  }

  /* ── Contenu — palette exacte de la capture ── */
  .atelier-content {
    padding: 2.5rem 3rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.95rem;
    line-height: 1.9;
  }

  /* Texte principal — beige/crème chaud */
  .atelier-content :global(p),
  .atelier-content :global(li) {
    color: #d4a878;
    margin-bottom: 1.2rem;
    font-family: 'Mulish', sans-serif;
    font-weight: 300;
    font-size: 1rem;
    line-height: 1.85;
    letter-spacing: 0.02em;
  }

  /* Titres — orange doux */
  .atelier-content :global(h1) {
    color: #e8a050;
    font-size: 1.35rem;
    font-weight: 400;
    font-style: italic;
    margin-bottom: 1.6rem;
    font-family: 'Libre Baskerville', serif;
    letter-spacing: 0.01em;
  }
  .atelier-content :global(h2) {
    color: #c88840;
    font-size: 1.05rem;
    font-weight: 400;
    font-style: italic;
    margin: 2rem 0 0.8rem;
    font-family: 'Libre Baskerville', serif;
    letter-spacing: 0.01em;
  }
  .atelier-content :global(h3) {
    color: #b07030;
    font-size: 0.9rem;
    font-weight: 700;
    margin: 1.5rem 0 0.6rem;
    font-family: 'Libre Baskerville', serif;
  }

  /* Code inline — rose/saumon comme sur la capture */
  .atelier-content :global(code) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.88em;
    color: #e07890;
    background: rgba(220,100,120,0.1);
    padding: 2px 6px;
    border-radius: 4px;
  }

  /* Blocs de code */
  .atelier-content :global(pre) {
    background: #130b04;
    border: 1px solid rgba(255,150,80,0.06);
    padding: 1.5rem 1.8rem;
    border-radius: 8px;
    overflow-x: auto;
    margin: 1.5rem 0;
  }
  .atelier-content :global(pre code) {
    background: none;
    padding: 0;
    color: #d4a878;
    font-size: 0.9rem;
  }

  /* Liens */
  .atelier-content :global(a) {
    color: #e09050;
    text-decoration: none;
    transition: color 0.2s;
  }
  .atelier-content :global(a:hover) { color: #7abd6e; }

  /* Séparateur */
  .atelier-content :global(hr) {
    border: none;
    border-top: 1px solid rgba(255,150,80,0.1);
    margin: 2rem 0;
  }

  /* Listes */
  .atelier-content :global(ul),
  .atelier-content :global(ol) {
    padding-left: 1.5rem;
    margin: 0 0 1.2rem;
    font-family: 'Mulish', sans-serif;
    font-weight: 300;
  }
  .atelier-content :global(li) { margin-bottom: 0.4rem; }

  /* Citation */
  .atelier-content :global(blockquote) {
    border-left: 3px solid rgba(224,144,80,0.35);
    margin: 1.5rem 0;
    padding: 0.5rem 0 0.5rem 1.2rem;
    color: #a07850;
    font-style: italic;
    font-family: 'Libre Baskerville', serif;
    font-size: 0.95rem;
  }

  @media (max-width: 640px) {
    .atelier-content { padding: 1.8rem 1.5rem; }
    .atelier-hint { display: none; }
  }
</style>
