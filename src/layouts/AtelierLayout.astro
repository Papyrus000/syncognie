---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface BreadcrumbParent {
  label: string;
  href: string;
}

const {
  title         = "Atelier",
  filename      = "atelier",
  parent,
  description,
  ogTitle,
  ogDescription,
} = Astro.props as {
  title?:         string;
  filename?:      string;
  parent?:        BreadcrumbParent;
  description?:   string;
  ogTitle?:       string;
  ogDescription?: string;
};
---
<!DOCTYPE html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Syncognie</title>
    <meta name="robots" content="index, follow" />
    {description && <meta name="description" content={description} />}
    <meta property="og:title" content={ogTitle ?? title} />
    {(ogDescription ?? description) && (
      <meta property="og:description" content={ogDescription ?? description} />
    )}
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle ?? title} />
    {(ogDescription ?? description) && (
      <meta name="twitter:description" content={ogDescription ?? description} />
    )}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Mulish:wght@300;400&family=JetBrains+Mono:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />

    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      :root {
        --gold: #e8b832;
        --frame-bg:       #3d2510;
        --frame-titlebar: #331e0a;
      }

      /* ── Sommaire drawer — styles is:global car éléments créés par JS ── */

      /* Liste scrollable */
      .sommaire-liste {
        list-style: none;
        padding: 0.6rem 0 1rem;
        margin: 0;
        overflow-y: auto;
        flex: 1;
        scrollbar-width: thin;
        scrollbar-color: rgba(232,160,80,0.12) transparent;
      }
      .sommaire-liste::-webkit-scrollbar { width: 2px; }
      .sommaire-liste::-webkit-scrollbar-track { background: transparent; }
      .sommaire-liste::-webkit-scrollbar-thumb {
        background: rgba(232,160,80,0.15);
        border-radius: 2px;
      }

      /* Items */
      .sommaire-item {
        display: grid;
        grid-template-columns: 2.8rem 1fr;
        align-items: center;
        position: relative;
        transition: background 0.15s;
      }
      .sommaire-item:hover {
        background: rgba(255,150,60,0.06);
      }
      .sommaire-item--sep {
        border-top: 1px solid rgba(232,150,60,0.07);
        margin-top: 2px;
      }
      .sommaire-item--active {
        background: rgba(232,160,80,0.07);
      }
      .sommaire-item--active::before {
        content: '';
        position: absolute;
        left: 0; top: 10%; bottom: 10%;
        width: 2px;
        border-radius: 0 2px 2px 0;
        background: linear-gradient(180deg, #e85d20, #f5a623);
      }

      /* Numéro */
      .sommaire-num {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.56rem;
        color: rgba(138,100,55,0.28);
        letter-spacing: 0.06em;
        text-align: right;
        padding-right: 0.8rem;
        user-select: none;
        transition: color 0.18s;
      }
      .sommaire-item--active .sommaire-num {
        color: rgba(232,160,80,0.5);
      }

      /* Lien h2 */
      .sommaire-lien,
      .sommaire-lien:link,
      .sommaire-lien:visited {
        display: block;
        font-family: 'Libre Baskerville', serif !important;
        font-size: 0.83rem !important;
        font-style: italic;
        color: #8a6640 !important;
        text-decoration: none !important;
        letter-spacing: 0.01em;
        line-height: 1.35;
        padding: 0.5rem 1rem 0.5rem 0;
        transition: color 0.18s;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        cursor: pointer;
      }
      .sommaire-lien:hover {
        color: #d4904a !important;
        text-decoration: none !important;
      }
      .sommaire-item--active .sommaire-lien,
      .sommaire-item--active .sommaire-lien:link,
      .sommaire-item--active .sommaire-lien:visited {
        color: #e8a050 !important;
      }

      /* Item h3 */
      .sommaire-item--h3 {
        grid-template-columns: 3.4rem 1fr;
      }
      .sommaire-item--h3 .sommaire-num {
        font-size: 0.50rem;
        color: rgba(100,70,38,0.22);
      }
      .sommaire-item--h3.sommaire-item--active .sommaire-num {
        color: rgba(200,130,50,0.38);
      }
      .sommaire-item--h3 .sommaire-lien,
      .sommaire-item--h3 .sommaire-lien:link,
      .sommaire-item--h3 .sommaire-lien:visited {
        font-family: 'JetBrains Mono', monospace !important;
        font-size: 0.66rem !important;
        font-style: normal;
        color: #6a4828 !important;
        padding-top: 0.32rem;
        padding-bottom: 0.32rem;
        letter-spacing: 0.025em;
      }
      .sommaire-item--h3 .sommaire-lien:hover {
        color: #a87038 !important;
      }
      .sommaire-item--h3.sommaire-item--active .sommaire-lien {
        color: #c88040 !important;
      }
    </style>
  </head>
  <body class="atelier-body">
    <Header />
    <main class="atelier-main">
      <div class="atelier-wrap">

        <!-- Fil d'Ariane contextuel -->
        <nav class="breadcrumb" aria-label="Fil d'Ariane">
          <a href="/atelier" class="crumb crumb--link">✦ atelier</a>

          {parent && (
            <>
              <span class="crumb-sep">›</span>
              <a href={parent.href} class="crumb crumb--link">{parent.label}</a>
            </>
          )}

          <span class="crumb-sep">›</span>
          <span class="crumb crumb--current">{filename}</span>
          <span class="atelier-hint">jardin numérique</span>
        </nav>

        <!-- Cadre style éditeur — sticky -->
        <div class="atelier-frame" id="atelierFrame">

          <!-- Barre de titre cliquable -->
          <div class="atelier-titlebar" id="atelierTitlebar" role="button" aria-expanded="false" aria-haspopup="true" tabindex="0">
            <span class="atelier-filename" id="titlebarLabel">syncognie · atelier</span>
            <span class="titlebar-icon" id="titlebarIcon" aria-hidden="true">☰</span>
          </div>

          <!-- Voile — overlay semi-transparent sur le contenu quand le drawer est ouvert -->
          <div class="sommaire-veil" id="sommaireVeil" aria-hidden="true"></div>

          <!-- Drawer sommaire — tiroir latéral -->
          <div class="sommaire-drawer" id="sommaireDrawer" role="menu" aria-label="Sommaire">
            <div class="sommaire-drawer-header">
              <span class="sommaire-drawer-title">sommaire</span>
              <button class="sommaire-drawer-close" id="sommaireClose" aria-label="Fermer le sommaire">✕</button>
            </div>
            <ul class="sommaire-liste" id="sommaireList"></ul>
          </div>

          <!-- Contenu scrollable -->
          <div class="atelier-content" id="atelierContent">
            <slot />
          </div>

        </div>

      </div>
    </main>
    <Footer />

    <button class="scroll-top" id="scrollTop" aria-label="Retour en haut">↑</button>
  </body>
</html>

<script>
  // ── Scroll-to-top ────────────────────────────────────────────────────────────
  const btn       = document.getElementById('scrollTop');
  const contentEl = document.getElementById('atelierContent');

  if (btn && contentEl) {
    contentEl.addEventListener('scroll', () => {
      btn.classList.toggle('scroll-top--visible', contentEl.scrollTop > 400);
    }, { passive: true });
    btn.addEventListener('click', () => {
      contentEl.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }

  // ── Sommaire — tiroir latéral ─────────────────────────────────────────────
  const titlebar = document.getElementById('atelierTitlebar') as HTMLElement | null;
  const label    = document.getElementById('titlebarLabel')   as HTMLElement | null;
  const icon     = document.getElementById('titlebarIcon')    as HTMLElement | null;
  const drawer   = document.getElementById('sommaireDrawer')  as HTMLElement | null;
  const veil     = document.getElementById('sommaireVeil')    as HTMLElement | null;
  const closeBtn = document.getElementById('sommaireClose')   as HTMLElement | null;
  const liste    = document.getElementById('sommaireList')    as HTMLElement | null;
  const content  = document.getElementById('atelierContent')  as HTMLElement | null;

  if (!titlebar || !label || !drawer || !veil || !liste || !content) {
    // éléments absents — rien à faire
  } else {
    // 1. Collecter les headings h2 / h3 dans le contenu
    const headings = Array.from(
      content.querySelectorAll<HTMLElement>('h2, h3')
    );

    if (headings.length === 0) {
      // Pas de sommaire — titlebar décorative uniquement
      titlebar.style.cursor = 'default';
      if (icon) icon.style.opacity = '0';
    } else {
      // 2. S'assurer que chaque heading a un id
      headings.forEach((h, i) => {
        if (!h.id) h.id = `section-${i}`;
      });

      // 3. Label par défaut = titre de page
      const pageLabel = label.textContent ?? 'sommaire';

      // 4. Construire les items du drawer
      liste.innerHTML = '';
      let h2Counter = 0;
      let h3Counter = 0;
      let prevWasH2  = false;

      headings.forEach(h => {
        const isH2 = h.tagName === 'H2';
        if (isH2) { h2Counter++; h3Counter = 0; }
        else       { h3Counter++; }

        const li = document.createElement('li');
        li.className = `sommaire-item sommaire-item--${h.tagName.toLowerCase()}`;
        // Séparateur visuel entre blocs h2
        if (isH2 && prevWasH2) li.classList.add('sommaire-item--sep');
        li.dataset.headingId = h.id;

        const num = document.createElement('span');
        num.className = 'sommaire-num';
        num.textContent = isH2
          ? String(h2Counter).padStart(2, '0')
          : `${h2Counter}.${h3Counter}`;
        num.setAttribute('aria-hidden', 'true');

        const a = document.createElement('a');
        a.href = `#${h.id}`;
        a.className = 'sommaire-lien';
        a.textContent = (h.textContent ?? '').replace(/^[\d.]+\s*/, '').trim();
        a.setAttribute('role', 'menuitem');

        a.addEventListener('click', (e) => {
          e.preventDefault();
          fermerDrawer();
          const target = document.getElementById(h.id);
          if (target && content) {
            const containerRect = content.getBoundingClientRect();
            const targetRect    = target.getBoundingClientRect();
            const offset = targetRect.top - containerRect.top + content.scrollTop - 20;
            content.scrollTo({ top: offset, behavior: 'smooth' });
          }
        });

        li.appendChild(num);
        li.appendChild(a);
        liste.appendChild(li);
        prevWasH2 = isH2;
      });

      // 5. IntersectionObserver — heading actif
      let activeId = '';

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              activeId = entry.target.id;
              const activeHeading = document.getElementById(activeId);
              if (activeHeading && label) {
                label.textContent = (activeHeading.textContent ?? pageLabel)
                  .replace(/^[\d.]+\s*/, '').trim();
              }
              liste.querySelectorAll('.sommaire-item').forEach(item => {
                const el = item as HTMLElement;
                el.classList.toggle(
                  'sommaire-item--active',
                  el.dataset.headingId === activeId
                );
              });
            }
          });
        },
        {
          root: content,
          rootMargin: '-10% 0px -70% 0px',
          threshold: 0,
        }
      );

      headings.forEach(h => observer.observe(h));

      // 6. Ouvrir / fermer le drawer
      let isOpen = false;

      function ouvrirDrawer() {
        isOpen = true;
        drawer!.classList.add('sommaire-drawer--open');
        veil!.classList.add('sommaire-veil--visible');
        titlebar!.setAttribute('aria-expanded', 'true');
        if (icon) icon.textContent = '✕';
        // Scroll-lock du contenu pendant que le drawer est ouvert
        content!.style.overflow = 'hidden';
        // Focus premier item pour accessibilité clavier
        const first = drawer!.querySelector<HTMLElement>('.sommaire-lien');
        if (first) first.focus();
      }

      function fermerDrawer() {
        isOpen = false;
        drawer!.classList.remove('sommaire-drawer--open');
        veil!.classList.remove('sommaire-veil--visible');
        titlebar!.setAttribute('aria-expanded', 'false');
        if (icon) icon.textContent = '☰';
        content!.style.overflow = '';
      }

      titlebar.addEventListener('click', () => {
        isOpen ? fermerDrawer() : ouvrirDrawer();
      });

      titlebar.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          isOpen ? fermerDrawer() : ouvrirDrawer();
        }
        if (e.key === 'Escape') fermerDrawer();
      });

      // Fermer via le bouton ✕ dans le drawer
      closeBtn?.addEventListener('click', (e) => {
        e.stopPropagation();
        fermerDrawer();
      });

      // Fermer en cliquant sur le voile
      veil.addEventListener('click', () => fermerDrawer());

      // Fermer avec Échap depuis n'importe où
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && isOpen) fermerDrawer();
      });
    }
  }
</script>

<style>
  /* ── Fond gradient orange ── */
  .atelier-body {
    background: linear-gradient(135deg, #f5c842 0%, #f07c1e 50%, #e8572a 100%);
    background-attachment: fixed;
    min-height: 100vh;
  }

  .atelier-main {
    padding: 2.5rem 1.5rem 3rem;
    display: flex;
    justify-content: center;
  }

  .atelier-wrap {
    width: 100%;
    max-width: 820px;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    height: calc(120vh - 5rem);
  }

  /* ── Fil d'Ariane ── */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0 0.25rem;
    flex-shrink: 0;
  }
  .crumb {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.05em;
    padding: 3px 12px;
    border-radius: 20px;
  }
  .crumb--link {
    background: rgba(255,255,255,0.9);
    color: #7a4a18;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
  }
  .crumb--link:hover {
    background: white;
    color: #4a2a08;
  }
  .crumb-sep {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: rgba(255,255,255,0.6);
  }
  .crumb--current {
    background: rgba(0,0,0,0.2);
    color: rgba(255,255,255,0.85);
  }
  .atelier-hint {
    margin-left: auto;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    color: rgba(255,255,255,0.4);
    letter-spacing: 0.04em;
  }

  /* ── Cadre principal ── */
  .atelier-frame {
    background: var(--frame-bg);
    border-radius: 12px;
    border-top: 1px solid rgba(232,150,60,0.10);
    box-shadow:
      0 2px 4px   rgba(20, 6, 0, 0.40),
      0 12px 24px  rgba(40, 12, 0, 0.45),
      0 45px 90px  rgba(30, 8, 0, 0.55),
      0 80px 120px rgba(180, 70, 10, 0.20);
    width: 100%;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
    position: sticky;
    top: 1.5rem;
    /* Nécessaire pour que le drawer soit positionné par rapport au frame */
    isolation: isolate;
  }

  /* ── Barre de titre ── */
  .atelier-titlebar {
    display: flex;
    align-items: center;
    padding: 12px 20px;
    background: var(--frame-titlebar);
    border-bottom: 1px solid rgba(255,255,255,0.04);
    flex-shrink: 0;
    position: relative;
    z-index: 10; /* au-dessus du voile et du drawer */
    cursor: default;
    user-select: none;
    transition: background 0.2s;
  }

  .atelier-titlebar:hover:not([style*="cursor: default"]) {
    background: #3e2814;
    border-bottom-color: rgba(232,150,60,0.14);
  }

  .atelier-filename {
    margin: 0 auto;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    color: #9a7a5a;
    letter-spacing: 0.05em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: calc(100% - 3rem);
    text-align: center;
    transition: color 0.25s ease;
  }

  .atelier-titlebar:not([style*="cursor: default"]) {
    cursor: pointer;
  }

  .atelier-titlebar:not([style*="cursor: default"]) .atelier-filename {
    color: #b08860;
    cursor: pointer;
  }

  .atelier-titlebar:not([style*="cursor: default"]):hover .atelier-filename {
    color: #d4a070;
  }

  /* Icône hamburger / fermeture */
  .titlebar-icon {
    position: absolute;
    right: 16px;
    font-size: 1.05rem;
    color: rgba(200,150,80,0.75);
    transition: color 0.22s ease, opacity 0.22s ease, transform 0.22s ease;
    opacity: 0;
    line-height: 1;
  }

  .atelier-titlebar:not([style*="cursor: default"]) .titlebar-icon {
    opacity: 1;
  }

  .atelier-titlebar:not([style*="cursor: default"]):hover .titlebar-icon {
    color: #e8a050;
    transform: scale(1.15);
  }

  /* ── Voile ── */
  .sommaire-veil {
    position: absolute;
    /* commence juste sous la titlebar (hauteur de 41px) */
    top: 41px;
    left: 0; right: 0; bottom: 0;
    background: rgba(0, 0, 0, 0.25);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    z-index: 5;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
    border-radius: 0 0 12px 12px;
  }

  .sommaire-veil--visible {
    opacity: 1;
    pointer-events: auto;
  }

  /* ── Drawer ── */
  .sommaire-drawer {
    position: absolute;
    top: 41px;    /* sous la titlebar */
    left: 0;
    bottom: 0;
    width: 40%;
    background: linear-gradient(160deg, #1e0c04 0%, #2d1609 60%, #321c0c 100%);
    border-right: 1px solid rgba(232,150,60,0.12);
    border-radius: 0 0 0 12px;
    z-index: 8;   /* au-dessus du voile */
    display: flex;
    flex-direction: column;
    box-shadow: none;
    /* État fermé : hors écran à gauche */
    transform: translateX(-100%);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0s 0.3s;
    overflow: hidden;
  }

  .sommaire-drawer--open {
    transform: translateX(0);
    box-shadow: 8px 0 32px rgba(0,0,0,0.6), 2px 0 8px rgba(0,0,0,0.4);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0s;
  }

  /* En-tête du drawer */
  .sommaire-drawer-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.9rem 1.1rem 0.7rem;
    border-bottom: 1px solid rgba(232,150,60,0.08);
    flex-shrink: 0;
  }

  .sommaire-drawer-title {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.58rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(232,160,80,0.38);
  }

  /* Ligne déco sous le titre du drawer */
  .sommaire-drawer-header::after {
    display: none; /* géré par border-bottom */
  }

  .sommaire-drawer-close {
    background: none;
    border: none;
    color: rgba(138,106,74,0.4);
    font-size: 0.68rem;
    cursor: pointer;
    padding: 2px 4px;
    line-height: 1;
    transition: color 0.18s;
    font-family: 'JetBrains Mono', monospace;
  }
  .sommaire-drawer-close:hover { color: rgba(232,160,80,0.7); }

  /* ── Contenu scrollable ── */
  .atelier-content {
    padding: 2.5rem 4rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.95rem;
    line-height: 1.9;
    overflow-y: auto;
    flex: 1;
    min-height: 0;
    scrollbar-width: thin;
    scrollbar-color: rgba(232,160,80,0.15) transparent;
    /* Transition douce lors du scroll-lock */
    transition: overflow 0s;
  }

  .atelier-content::-webkit-scrollbar { width: 4px; }
  .atelier-content::-webkit-scrollbar-track { background: transparent; }
  .atelier-content::-webkit-scrollbar-thumb {
    background: rgba(232,160,80,0.15);
    border-radius: 2px;
  }
  .atelier-content::-webkit-scrollbar-thumb:hover {
    background: rgba(232,160,80,0.3);
  }

  .atelier-content :global(p),
  .atelier-content :global(li) {
    color: #d4a878;
    margin-bottom: 1.2rem;
    font-family: 'Mulish', sans-serif;
    font-weight: 300;
    font-size: 1rem;
    line-height: 1.85;
    letter-spacing: 0.02em;
  }

  .atelier-content :global(h1) {
    color: #e8a050;
    font-size: 1.35rem;
    font-weight: 400;
    font-style: italic;
    margin-bottom: 1.6rem;
    font-family: 'Libre Baskerville', serif;
    letter-spacing: 0.01em;
  }
  .atelier-content :global(h2) {
    color: #c88840;
    font-size: 1.05rem;
    font-weight: 400;
    font-style: italic;
    margin: 2rem 0 0.8rem;
    font-family: 'Libre Baskerville', serif;
    letter-spacing: 0.01em;
    scroll-margin-top: 1.5rem;
  }
  .atelier-content :global(h3) {
    color: #b07030;
    font-size: 0.9rem;
    font-weight: 700;
    margin: 1.5rem 0 0.6rem;
    font-family: 'Libre Baskerville', serif;
    scroll-margin-top: 1.5rem;
  }

  .atelier-content :global(code) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.88em;
    color: #e07890;
    background: rgba(220,100,120,0.1);
    padding: 2px 6px;
    border-radius: 4px;
