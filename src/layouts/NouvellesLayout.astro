---
// src/layouts/NouvellesLayout.astro
// Layout Nouvelles — identique à JournalLayout, adapté pour la fiction courte

import Base from './Base.astro';

export interface Props {
  title:         string;
  date:          Date;
  lecture?:      number;
  genre?:        string;
  stade?:        'graine' | 'pousse' | 'arbre';
  slug:          string;
  illustration?: string;
  prev?:         { slug: string; title: string };
  next?:         { slug: string; title: string };
}

const { title, date, lecture, genre, stade, slug, illustration, prev, next } = Astro.props;

function formatDate(d: Date) {
  return d.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
}
function stadeLabel(s?: string) {
  if (s === 'pousse') return '🌿 Pousse';
  if (s === 'arbre')  return '🌳 Arbre';
  return '🌱 Graine';
}

const genreLabels: Record<string, string> = {
  fragment: 'Fragment',
  conte:    'Conte',
  recit:    'Récit',
  fable:    'Fable',
  prose:    'Prose poétique',
};
const genreLabel = genre ? (genreLabels[genre] ?? genre) : undefined;
---

<Base title={`${title} — Nouvelles · Syncognie`}>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap"
  rel="stylesheet"
/>

<style is:global>
  html:has(.jl-wrap) {
    --jl-bg:        #F7F3EE;
    --jl-paper:     #FAF7F2;
    --jl-ink:       #1C1811;
    --jl-ink-soft:  #4A4237;
    --jl-ink-muted: #9A8F82;
    --jl-accent:    #B85C2A;
    --jl-accent-hl: #F0DDD0;
    --jl-border:    #E4DDD4;
    --jl-serif:     'Lora', Georgia, serif;
    --jl-sans:      'DM Sans', sans-serif;
    --jl-lh:        1.87;
    --jl-measure:   66ch;
    --jl-base:      19px;
  }

  body.jl-night-mode {
    --jl-bg:        #141210 !important;
    --jl-paper:     #1C1914 !important;
    --jl-ink:       #EDE8DF !important;
    --jl-ink-soft:  #BDB3A5 !important;
    --jl-ink-muted: #6E6458 !important;
    --jl-accent:    #C4773A !important;
    --jl-accent-hl: #2A2018 !important;
    --jl-border:    #2E2820 !important;
  }

  body:has(.jl-wrap) {
    background-color: var(--jl-bg) !important;
    background-image: none !important;
  }

  /* Supprimer les gradients de Base.astro en mode nuit et mode flat */
  body.jl-night-mode::before,
  body.jl-night-mode::after,
  body.jl-flat-mode::before,
  body.jl-flat-mode::after {
    display: none !important;
  }

  /* Mode flat : fond uni clair sans texture */
  body.jl-flat-mode {
    background-color: #F7F3EE !important;
    background-image: none !important;
  }

  /* Barre de progression */
  .jl-progress {
    position: fixed;
    top: 52px; left: 0;
    height: 3px; width: 0%;
    background: var(--pop-orange, #ff8000);
    box-shadow: 0 0 6px rgba(255,128,0,.5);
    z-index: 500;
    transition: width .08s linear;
  }

  /* ── Corps article ── */
  .jl-body p {
    font-family: var(--jl-serif) !important;
    font-size: var(--jl-base) !important;
    line-height: var(--jl-lh) !important;
    color: var(--jl-ink-soft) !important;
    max-width: var(--jl-measure);
    margin-bottom: 1.5rem !important;
    text-align: justify;
    hyphens: auto;
    -webkit-hyphens: auto;
  }

  /* Drop cap — désactivé sur mobile */
  @media (min-width: 521px) {
    .jl-body p:first-of-type::first-letter {
      font-size: 3.6em;
      font-weight: 600;
      line-height: .82;
      float: left;
      margin-right: .08em;
      margin-top: .05em;
      color: var(--jl-accent);
      font-family: var(--jl-serif) !important;
    }
  }

  /* Titres */
  .jl-body h2,
  .jl-body h3 { scroll-margin-top: 76px; }

  .jl-body h2 {
    font-family: var(--jl-serif) !important;
    font-size: 1.25rem !important;
    font-weight: 600 !important;
    color: var(--jl-ink) !important;
    margin: 3rem 0 1rem !important;
    letter-spacing: -.015em;
    line-height: 1.25 !important;
  }
  .jl-body h3 {
    font-family: var(--jl-sans) !important;
    font-size: .78rem !important;
    font-weight: 500 !important;
    letter-spacing: .13em;
    text-transform: uppercase;
    color: var(--jl-ink-muted) !important;
    margin: 2.5rem 0 .8rem !important;
  }

  /* Blockquote */
  .jl-body blockquote {
    border-left: 3px solid var(--jl-accent) !important;
    margin: 2.5rem 0 !important;
    padding: .4rem 0 .4rem 1.6rem !important;
    font-style: normal !important;
    color: inherit !important;
    opacity: 1 !important;
    background: transparent !important;
  }
  .jl-body blockquote p {
    font-style: italic !important;
    font-size: 1.05rem !important;
    color: var(--jl-ink) !important;
    margin-bottom: 0 !important;
    text-align: left !important;
  }
  .jl-body blockquote cite {
    display: block;
    font-family: var(--jl-sans) !important;
    font-size: .68rem !important;
    letter-spacing: .09em;
    text-transform: uppercase;
    color: var(--jl-ink-muted) !important;
    margin-top: .65rem;
    font-style: normal !important;
  }

  /* Listes */
  .jl-body ul,
  .jl-body ol {
    font-family: var(--jl-serif) !important;
    font-size: var(--jl-base) !important;
    line-height: var(--jl-lh) !important;
    color: var(--jl-ink-soft) !important;
    max-width: var(--jl-measure);
    padding-left: 1.6rem;
    margin-bottom: 1.5rem !important;
  }
  .jl-body li { margin-bottom: .4rem; }

  .jl-body a {
    color: var(--jl-accent) !important;
    text-decoration-color: var(--jl-accent-hl);
    text-underline-offset: .2em;
  }
  .jl-body a:hover { text-decoration-color: var(--jl-accent) !important; }

  .jl-body em     { font-style: italic !important; }
  .jl-body strong { font-weight: 600; color: var(--jl-ink) !important; }

  .jl-body hr {
    border: none !important;
    border-top: 1px solid var(--jl-border) !important;
    margin: 3rem 0 !important;
  }

  .jl-body code {
    font-size: .86em;
    background: var(--jl-accent-hl) !important;
    padding: .1em .35em;
    border-radius: 3px;
    font-family: 'JetBrains Mono', monospace !important;
    color: var(--jl-ink) !important;
  }

  /* ToC liens (créés en JS) */
  .jl-toc a {
    display: block;
    font-family: var(--jl-sans) !important;
    font-size: .67rem !important;
    line-height: 1.45;
    color: var(--jl-ink-muted) !important;
    text-decoration: none !important;
    padding: .28rem .5rem;
    border-left: 2px solid transparent;
    transition: color .18s, border-color .18s, background .18s;
    border-radius: 0 2px 2px 0;
  }
  .jl-toc a:hover {
    color: var(--jl-ink-soft) !important;
    border-left-color: var(--jl-border) !important;
    text-decoration: none !important;
  }
  .jl-toc a.jl-toc-active {
    color: var(--jl-accent) !important;
    border-left-color: var(--jl-accent) !important;
    background: var(--jl-accent-hl);
    text-decoration: none !important;
  }
</style>

<!-- Barre de progression -->
<div class="jl-progress" id="jl-progress" aria-hidden="true"></div>

<!-- Contrôles flottants -->
<div class="jl-controls" id="jl-controls">
  <button class="jl-ctrl-btn" id="jl-sz-down" aria-label="Réduire la taille">−</button>
  <span class="jl-ctrl-sep"></span>
  <button class="jl-ctrl-btn" id="jl-sz-up" aria-label="Agrandir la taille">+</button>
  <span class="jl-ctrl-sep jl-ctrl-sep--wide"></span>
  <!-- Interligne -->
  <button class="jl-ctrl-btn" id="jl-lh-down" aria-label="Réduire l'interligne" title="Interligne −">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
    </svg>
  </button>
  <button class="jl-ctrl-btn" id="jl-lh-up" aria-label="Augmenter l'interligne" title="Interligne +">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <line x1="3" y1="4" x2="21" y2="4"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="20" x2="21" y2="20"/>
    </svg>
  </button>
  <span class="jl-ctrl-sep jl-ctrl-sep--wide"></span>
  <!-- Mesure (largeur) -->
  <button class="jl-ctrl-btn" id="jl-w-down" aria-label="Réduire la largeur" title="Largeur −">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <polyline points="15 18 9 12 15 6"/><line x1="9" y1="12" x2="20" y2="12"/>
    </svg>
  </button>
  <button class="jl-ctrl-btn" id="jl-w-up" aria-label="Augmenter la largeur" title="Largeur +">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <polyline points="9 18 15 12 9 6"/><line x1="15" y1="12" x2="4" y2="12"/>
    </svg>
  </button>
  <span class="jl-ctrl-sep jl-ctrl-sep--wide"></span>
  <button class="jl-ctrl-btn jl-ctrl-btn--flat" id="jl-flat" aria-label="Mode clair sans gradient" title="Fond uni">
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
    </svg>
  </button>
  <button class="jl-ctrl-btn jl-ctrl-btn--night" id="jl-night" aria-label="Mode nuit" title="Mode nuit">
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
    </svg>
  </button>
</div>

<div class="jl-wrap" id="jl-wrap">

  <!-- Sidebar -->
  <aside class="jl-aside" aria-label="Navigation dans la nouvelle">
    <div class="jl-aside-inner">
      <a class="jl-back" href="/nouvelles">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
        Nouvelles
      </a>
      <div class="jl-aside-sep"></div>
      <nav class="jl-toc" id="jl-toc" aria-label="Sections"></nav>
      <div class="jl-aside-sep" style="margin-top:1.5rem"></div>
      <div class="jl-read-stat">
        <span class="jl-read-pct" id="jl-read-pct">0%</span>
        <span class="jl-read-label">lu</span>
      </div>
      <!-- Temps restant -->
      <div class="jl-time-left" id="jl-time-left" style="display:none">
        <span class="jl-time-val" id="jl-time-val">—</span>
        <span class="jl-read-label">restant</span>
      </div>
    </div>
  </aside>

  <!-- Article -->
  <article class="jl-article" id="jl-article">

    <header class="jl-header">
      <div class="jl-meta">
        {genreLabel && <span class="jl-tag">{genreLabel}</span>}
        <time class="jl-date" datetime={date.toISOString()}>{formatDate(date)}</time>
        {lecture && <span class="jl-read-time">· {lecture} min</span>}
        {stade && <span class="jl-stade">{stadeLabel(stade)}</span>}
      </div>
      <h1 class="jl-titre">{title}</h1>
      <div class="jl-rule"></div>
      {illustration && (
        <div class="jl-illustration">
          <img src={illustration} alt={title} />
        </div>
      )}
    </header>

    <div class="jl-body" id="jl-body">
      <slot />
    </div>

    <!-- Navigation prev/next -->
    {(prev || next) && (
      <nav class="jl-nav" aria-label="Nouvelles précédente et suivante">
        <div class="jl-nav-inner">
          {prev ? (
            <a class="jl-nav-item jl-nav-item--prev" href={`/nouvelles/${prev.slug}`}>
              <span class="jl-nav-dir">← Précédente</span>
              <span class="jl-nav-title">{prev.title}</span>
            </a>
          ) : <div />}
          {next ? (
            <a class="jl-nav-item jl-nav-item--next" href={`/nouvelles/${next.slug}`}>
              <span class="jl-nav-dir">Suivante →</span>
              <span class="jl-nav-title">{next.title}</span>
            </a>
          ) : <div />}
        </div>
      </nav>
    )}

    <footer class="jl-footer">
      <a class="jl-footer-back" href="/nouvelles">← Retour aux nouvelles</a>
    </footer>

  </article>
</div>

<!-- ── Barre de lecture mobile (portrait uniquement) ── -->
<div class="jl-mobile-toolbar" id="jl-mobile-toolbar" aria-label="Contrôles de lecture">

  <div class="jl-toolbar-group">
    <span class="jl-toolbar-lbl">Taille</span>
    <button class="jl-toolbar-btn" id="jl-mob-sz-down" aria-label="Réduire la taille du texte">A−</button>
    <button class="jl-toolbar-btn" id="jl-mob-sz-up"   aria-label="Agrandir la taille du texte">A+</button>
  </div>

  <div class="jl-toolbar-sep" aria-hidden="true"></div>

  <div class="jl-toolbar-group">
    <span class="jl-toolbar-lbl">Interligne</span>
    <button class="jl-toolbar-btn" id="jl-mob-lh-down" aria-label="Réduire l'interligne">
      <svg viewBox="0 0 24 24"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
    <button class="jl-toolbar-btn" id="jl-mob-lh-up" aria-label="Augmenter l'interligne">
      <svg viewBox="0 0 24 24"><line x1="3" y1="4" x2="21" y2="4"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="20" x2="21" y2="20"/></svg>
    </button>
  </div>

  <div class="jl-toolbar-sep" aria-hidden="true"></div>

  <button class="jl-toolbar-btn jl-toolbar-btn--flat" id="jl-mob-flat" aria-label="Mode clair sans gradient" title="Fond uni">
    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
  </button>

  <button class="jl-toolbar-btn jl-toolbar-btn--night" id="jl-mob-night" aria-label="Mode nuit" title="Mode nuit">
    <svg viewBox="0 0 24 24"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
  </button>

  <div class="jl-toolbar-sep" aria-hidden="true"></div>

  <button class="jl-toolbar-btn jl-toolbar-btn--toc" id="jl-mob-toc" aria-label="Ouvrir le sommaire" title="Sommaire">
    <svg viewBox="0 0 24 24"><line x1="3" y1="6" x2="10" y2="6"/><line x1="3" y1="12" x2="16" y2="12"/><line x1="3" y1="18" x2="13" y2="18"/></svg>
  </button>

</div>

<!-- ── Drawer sommaire mobile ── -->
<div class="jl-toc-drawer" id="jl-toc-drawer" role="dialog" aria-modal="true" aria-label="Sommaire">
  <div class="jl-toc-drawer-handle" id="jl-toc-drawer-handle" aria-hidden="true"></div>
  <div class="jl-toc-drawer-header">
    <span class="jl-toc-drawer-title">Sommaire</span>
    <button class="jl-toc-drawer-close" id="jl-toc-drawer-close" aria-label="Fermer le sommaire">
      <svg viewBox="0 0 11 11"><path d="M1.5 1.5l8 8M9.5 1.5l-8 8"/></svg>
    </button>
  </div>
  <div class="jl-toc-drawer-body" id="jl-toc-drawer-body"></div>
</div>

<style>
  /* ── CONTRÔLES FLOTTANTS ── */
  .jl-controls {
    position: fixed;
    top: 50%;
    right: 1.4rem;
    transform: translateY(-50%);
    z-index: 300;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .3rem;
    background: var(--jl-paper);
    border: 1px solid var(--jl-border);
    border-radius: 8px;
    padding: .5rem .35rem;
    box-shadow: 0 2px 12px rgba(28,24,17,.08);
  }
  .jl-ctrl-btn {
    width: 28px; height: 28px;
    border: none;
    background: transparent;
    color: var(--jl-ink-muted);
    cursor: pointer;
    font-size: 1rem;
    border-radius: 4px;
    display: flex; align-items: center; justify-content: center;
    transition: background .15s, color .15s;
    font-family: var(--jl-sans);
  }
  .jl-ctrl-btn:hover {
    background: var(--jl-accent-hl);
    color: var(--jl-accent);
  }
  .jl-ctrl-btn--flat.active,
  .jl-ctrl-btn--night.active {
    background: var(--jl-accent-hl);
    color: var(--jl-accent);
  }
  .jl-ctrl-sep {
    display: block;
    width: 16px; height: 1px;
    background: var(--jl-border);
    margin: .05rem auto;
  }
  .jl-ctrl-sep--wide { margin: .2rem auto; }

  /* ── WRAPPER ── */
  .jl-wrap {
    display: grid;
    grid-template-columns: 150px 1fr;
    gap: 0 3.5rem;
    max-width: 900px;
    margin: 0 auto;
    padding: 3rem 3rem 5rem 2rem;
    align-items: start;
    font-size: var(--jl-base);
  }

  /* ── SIDEBAR ── */
  .jl-aside {
    position: sticky;
    top: 5rem;
    padding-top: .4rem;
  }
  .jl-aside-inner {
    display: flex;
    flex-direction: column;
  }
  .jl-back {
    display: flex;
    align-items: center;
    gap: .4rem;
    font-family: var(--jl-sans);
    font-size: .68rem;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--jl-ink-muted);
    text-decoration: none;
    transition: color .2s;
  }
  .jl-back:hover { color: var(--jl-accent); }

  .jl-aside-sep {
    height: 1px;
    background: var(--jl-border);
    margin: .85rem 0;
  }

  .jl-toc {
    display: flex;
    flex-direction: column;
    gap: .1rem;
  }

  .jl-read-stat,
  .jl-time-left {
    display: flex;
    align-items: baseline;
    gap: .3rem;
    padding: .2rem .5rem;
  }
  .jl-read-pct,
  .jl-time-val {
    font-family: var(--jl-sans);
    font-size: .75rem;
    font-weight: 500;
    color: var(--jl-accent);
  }
  .jl-read-label {
    font-family: var(--jl-sans);
    font-size: .62rem;
    color: var(--jl-ink-muted);
    letter-spacing: .08em;
  }

  /* ── ARTICLE ── */
  .jl-article {
    background: var(--jl-paper);
    border: 1px solid var(--jl-border);
    border-radius: 4px;
    padding: 3.5rem 4rem;
    box-shadow: 0 2px 20px rgba(28,24,17,.05), 0 1px 3px rgba(28,24,17,.04);
    min-width: 0;
    font-family: var(--jl-serif);
    font-size: var(--jl-base);
    color: var(--jl-ink-soft);
  }

  /* ── EN-TÊTE ── */
  .jl-meta {
    display: flex;
    align-items: center;
    gap: .7rem;
    flex-wrap: wrap;
    margin-bottom: 1.8rem;
  }
  .jl-tag {
    font-family: var(--jl-sans);
    font-size: .6rem;
    font-weight: 500;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--jl-accent);
    background: var(--jl-accent-hl);
    padding: .28em .65em;
    border-radius: 2px;
  }
  .jl-date {
    font-family: var(--jl-sans);
    font-size: .7rem;
    font-weight: 300;
    color: var(--jl-ink-muted);
    letter-spacing: .06em;
  }
  .jl-read-time {
    font-family: var(--jl-sans);
    font-size: .67rem;
    color: var(--jl-ink-muted);
  }
  .jl-stade {
    font-family: var(--jl-sans);
    font-size: .64rem;
    color: var(--jl-ink-muted);
    margin-left: auto;
  }
  .jl-titre {
    font-family: var(--jl-serif);
    font-size: clamp(1.65rem, 2.8vw, 2.25rem);
    font-weight: 600;
    line-height: 1.18;
    color: var(--jl-ink);
    letter-spacing: -.022em;
    margin-bottom: .7rem;
  }
  .jl-subtitle {
    font-family: var(--jl-serif);
    font-style: italic;
    font-size: 1.05rem;
    color: var(--jl-ink-soft);
    line-height: 1.58;
    margin-bottom: 2rem;
    max-width: 50ch;
  }
  .jl-rule {
    width: 2.5rem;
    height: 1px;
    background: var(--jl-accent);
    opacity: .5;
    margin-bottom: 2.2rem;
  }
  .jl-illustration {
    margin-bottom: 2.8rem;
    overflow: hidden;
    border-radius: 3px;
    max-width: var(--jl-measure);
  }
  .jl-illustration img {
    display: block;
    width: 100%;
    height: auto;
    max-height: 480px;
    object-fit: cover;
    object-position: center top;
  }

  /* ── NAVIGATION PREV / NEXT ── */
  .jl-nav {
    margin-top: 3.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--jl-border);
  }
  .jl-nav-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .jl-nav-item {
    display: flex;
    flex-direction: column;
    gap: .35rem;
    padding: .9rem 1rem;
    border: 1px solid var(--jl-border);
    border-radius: 4px;
    text-decoration: none;
    background: var(--jl-bg);
    transition: border-color .2s, background .2s;
  }
  .jl-nav-item:hover {
    border-color: var(--jl-accent);
    background: var(--jl-accent-hl);
  }
  .jl-nav-item--next { text-align: right; }
  .jl-nav-dir {
    font-family: var(--jl-sans);
    font-size: .62rem;
    font-weight: 500;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--jl-ink-muted);
    transition: color .2s;
  }
  .jl-nav-item:hover .jl-nav-dir { color: var(--jl-accent); }
  .jl-nav-title {
    font-family: var(--jl-serif);
    font-size: .92rem;
    color: var(--jl-ink);
    line-height: 1.35;
  }

  /* ── PIED ── */
  .jl-footer {
    margin-top: 1.5rem;
    padding-top: 1.2rem;
    border-top: 1px solid var(--jl-border);
  }
  .jl-footer-back {
    font-family: var(--jl-sans);
    font-size: .7rem;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--jl-ink-muted);
    text-decoration: none;
    transition: color .2s;
  }
  .jl-footer-back:hover { color: var(--jl-accent); }

  /* ── RESPONSIVE ── */
  @media (max-width: 860px) {
    .jl-wrap {
      grid-template-columns: 1fr;
      padding: 2rem 1.5rem 4rem;
    }
    .jl-aside { display: none; }
    .jl-controls { right: .75rem; }
  }
  @media (max-width: 520px) {
    .jl-article { padding: 2rem 1.5rem; }
    .jl-controls { display: none; }
    .jl-nav-inner { grid-template-columns: 1fr; }
  }

  /* ── Barre de lecture mobile (portrait uniquement) ── */
  .jl-mobile-toolbar { display: none; }

  @media (max-width: 860px) and (orientation: portrait) {
    .jl-mobile-toolbar {
      display: flex;
      position: fixed;
      bottom: 0; left: 0; right: 0;
      z-index: 700;
      align-items: center;
      justify-content: center;
      gap: .5rem;
      padding: .55rem 1rem;
      padding-bottom: calc(.55rem + env(safe-area-inset-bottom, 0px));
      background: var(--jl-paper, #FAF7F2);
      border-top: 1px solid var(--jl-border, #E4DDD4);
      box-shadow: 0 -4px 16px rgba(28,24,17,.07);
    }
    /* Masquer les contrôles flottants quand la toolbar est visible */
    .jl-controls { display: none; }

    /* Décaler le bas du contenu */
    .jl-wrap {
      padding-bottom: calc(4.5rem + env(safe-area-inset-bottom, 0px)) !important;
    }

    .jl-toolbar-sep {
      width: 1px; height: 20px;
      background: var(--jl-border, #E4DDD4);
      flex-shrink: 0;
      margin: 0 .15rem;
    }
    .jl-toolbar-group {
      display: flex;
      align-items: center;
      gap: .3rem;
    }
    .jl-toolbar-lbl {
      font-family: var(--jl-sans, 'DM Sans', sans-serif);
      font-size: .58rem;
      font-weight: 500;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: var(--jl-ink-muted, #9A8F82);
    }
    .jl-toolbar-btn {
      width: 36px; height: 36px;
      border: 1px solid var(--jl-border, #E4DDD4);
      background: var(--jl-bg, #F7F3EE);
      color: var(--jl-ink-muted, #9A8F82);
      border-radius: 6px;
      cursor: pointer;
      font-size: .95rem;
      display: flex; align-items: center; justify-content: center;
      transition: background .15s, border-color .15s, color .15s;
      font-family: var(--jl-sans, 'DM Sans', sans-serif);
      line-height: 1;
      -webkit-tap-highlight-color: transparent;
      touch-action: manipulation;
    }
    .jl-toolbar-btn:active {
      background: var(--jl-accent-hl, #F0DDD0);
      border-color: var(--jl-accent, #B85C2A);
      color: var(--jl-accent, #B85C2A);
    }
    .jl-toolbar-btn.active {
      background: var(--jl-accent-hl, #F0DDD0);
      border-color: var(--jl-accent, #B85C2A);
      color: var(--jl-accent, #B85C2A);
    }
    .jl-toolbar-btn svg {
      width: 14px; height: 14px;
      stroke: currentColor; fill: none;
      stroke-width: 2; stroke-linecap: round; stroke-linejoin: round;
    }
  }

  /* Mode nuit — toolbar */
  body.jl-night-mode .jl-mobile-toolbar {
    background: #1C1914;
    border-top-color: #2E2820;
    box-shadow: 0 -4px 16px rgba(0,0,0,.3);
  }

  /* ── Drawer sommaire mobile (portrait uniquement) ── */
  .jl-toc-drawer { display: none; }

  @media (max-width: 860px) and (orientation: portrait) {
    .jl-toc-drawer {
      display: block;
      position: fixed;
      left: 0; right: 0; bottom: 0;
      z-index: 850;
      max-height: 70vh;
      background: var(--jl-paper, #FAF7F2);
      border-radius: 16px 16px 0 0;
      box-shadow: 0 -8px 40px rgba(28,24,17,.18);
      transform: translateY(100%);
      transition: transform .35s cubic-bezier(.32,.72,0,1);
      will-change: transform;
      overflow: hidden;
      padding-bottom: calc(52px + env(safe-area-inset-bottom, 0px));
    }
    .jl-toc-drawer.jl-toc-drawer--open {
      display: flex;
      flex-direction: column;
      transform: translateY(0);
    }
  }

  .jl-toc-drawer-handle {
    flex-shrink: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: .85rem 0 .5rem;
    cursor: grab;
    -webkit-tap-highlight-color: transparent;
  }
  .jl-toc-drawer-handle::before {
    content: '';
    display: block;
    width: 36px; height: 4px;
    background: var(--jl-border, #E4DDD4);
    border-radius: 2px;
  }
  .jl-toc-drawer-header {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1.25rem .75rem;
    border-bottom: 1px solid var(--jl-border, #E4DDD4);
  }
  .jl-toc-drawer-title {
    font-family: var(--jl-sans, 'DM Sans', sans-serif);
    font-size: .6rem;
    font-weight: 500;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--jl-ink-muted, #9A8F82);
  }
  .jl-toc-drawer-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px; height: 32px;
    background: none;
    border: 1px solid var(--jl-border, #E4DDD4);
    border-radius: 50%;
    cursor: pointer;
    color: var(--jl-ink-muted, #9A8F82);
    transition: color .15s, border-color .15s;
    -webkit-tap-highlight-color: transparent;
  }
  .jl-toc-drawer-close svg {
    width: 11px; height: 11px;
    stroke: currentColor; fill: none;
    stroke-width: 2; stroke-linecap: round;
  }
  .jl-toc-drawer-body {
    flex: 1;
    overflow-y: auto;
    padding: 1.1rem 1.25rem 1rem;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior: contain;
  }
  .jl-toc-drawer-body a {
    display: block;
    font-family: var(--jl-sans, 'DM Sans', sans-serif);
    font-size: .82rem;
    line-height: 1.5;
    color: var(--jl-ink-muted, #9A8F82);
    text-decoration: none;
    padding: .5rem .6rem;
    border-left: 2px solid transparent;
    border-radius: 0 3px 3px 0;
    transition: color .18s, border-color .18s, background .18s;
  }
  .jl-toc-drawer-body a:active {
    color: var(--jl-accent, #B85C2A);
    border-left-color: var(--jl-accent, #B85C2A);
    background: var(--jl-accent-hl, #F0DDD0);
  }
  .jl-toc-drawer-back {
    display: block;
    font-family: var(--jl-sans, 'DM Sans', sans-serif);
    font-size: .75rem;
    color: var(--jl-ink-muted, #9A8F82);
    text-decoration: none;
    margin-bottom: 1rem;
    padding-bottom: .9rem;
    border-bottom: 1px solid var(--jl-border, #E4DDD4);
  }

  /* Mode nuit — drawer sommaire */
  body.jl-night-mode .jl-toc-drawer {
    background: #1C1914;
    box-shadow: 0 -8px 40px rgba(0,0,0,.45);
  }
  body.jl-night-mode .jl-toc-drawer-handle::before { background: #2E2820; }
  body.jl-night-mode .jl-toc-drawer-header { border-bottom-color: #2E2820; }
  body.jl-night-mode .jl-toc-drawer-close { border-color: #2E2820; }
  body.jl-night-mode .jl-toc-drawer-body a { color: #6E6458; }
  body.jl-night-mode .jl-toc-drawer-back { color: #6E6458; border-bottom-color: #2E2820; }
</style>

<script define:vars={{ slug, lecture }}>
(function () {
  const body    = document.getElementById('jl-body');
  const toc     = document.getElementById('jl-toc');
  const bar     = document.getElementById('jl-progress');
  const pctEl   = document.getElementById('jl-read-pct');
  const timeEl  = document.getElementById('jl-time-left');
  const timeVal = document.getElementById('jl-time-val');
  const szDown  = document.getElementById('jl-sz-down');
  const szUp    = document.getElementById('jl-sz-up');
  const lhDown  = document.getElementById('jl-lh-down');
  const lhUp    = document.getElementById('jl-lh-up');
  const wDown   = document.getElementById('jl-w-down');
  const wUp     = document.getElementById('jl-w-up');
  const nightBtn= document.getElementById('jl-night');

  const STORAGE_KEY = 'nv_pos_' + slug;

  // ── Taille de texte ──
  let fontSize = parseInt(localStorage.getItem('jl_fontsize') || '19', 10);
  function applySize() {
    document.documentElement.style.setProperty('--jl-base', fontSize + 'px');
    localStorage.setItem('jl_fontsize', String(fontSize));
  }
  applySize();
  szDown?.addEventListener('click', () => { if (fontSize > 14) { fontSize--; applySize(); } });
  szUp?.addEventListener('click',   () => { if (fontSize < 24) { fontSize++; applySize(); } });

  // Boutons mobile toolbar
  const mobSzDown  = document.getElementById('jl-mob-sz-down');
  const mobSzUp    = document.getElementById('jl-mob-sz-up');
  const mobLhDown  = document.getElementById('jl-mob-lh-down');
  const mobLhUp    = document.getElementById('jl-mob-lh-up');
  const mobFlat    = document.getElementById('jl-mob-flat');
  const mobNight   = document.getElementById('jl-mob-night');
  const mobTocBtn  = document.getElementById('jl-mob-toc');

  mobSzDown?.addEventListener('click', () => { if (fontSize > 14) { fontSize--; applySize(); } });
  mobSzUp?.addEventListener('click',   () => { if (fontSize < 24) { fontSize++; applySize(); } });

  // ── Interligne ──
  const LH_STEPS = [1.6, 1.7, 1.87, 2.0, 2.15, 2.3];
  let lhIdx = parseInt(localStorage.getItem('jl_lh_idx') || '2', 10);
  function applyLH() {
    document.documentElement.style.setProperty('--jl-lh', String(LH_STEPS[lhIdx]));
    localStorage.setItem('jl_lh_idx', String(lhIdx));
  }
  applyLH();
  lhDown?.addEventListener('click', () => { if (lhIdx > 0) { lhIdx--; applyLH(); } });
  lhUp?.addEventListener('click',   () => { if (lhIdx < LH_STEPS.length - 1) { lhIdx++; applyLH(); } });
  mobLhDown?.addEventListener('click', () => { if (lhIdx > 0) { lhIdx--; applyLH(); } });
  mobLhUp?.addEventListener('click',   () => { if (lhIdx < LH_STEPS.length - 1) { lhIdx++; applyLH(); } });

  // ── Largeur de mesure ──
  const W_STEPS = ['52ch', '58ch', '66ch', '72ch', '78ch'];
  let wIdx = parseInt(localStorage.getItem('jl_w_idx') || '2', 10);
  function applyW() {
    document.documentElement.style.setProperty('--jl-measure', W_STEPS[wIdx]);
    localStorage.setItem('jl_w_idx', String(wIdx));
  }
  applyW();
  wDown?.addEventListener('click', () => { if (wIdx > 0) { wIdx--; applyW(); } });
  wUp?.addEventListener('click',   () => { if (wIdx < W_STEPS.length - 1) { wIdx++; applyW(); } });

  // ── Mode nuit / flat ──
  const flatBtn = document.getElementById('jl-flat');

  function applyMode(mode) {
    // mode: 'default' | 'flat' | 'night'
    document.body.classList.toggle('jl-flat-mode',  mode === 'flat');
    document.body.classList.toggle('jl-night-mode', mode === 'night');
    flatBtn?.classList.toggle('active',  mode === 'flat');
    nightBtn?.classList.toggle('active', mode === 'night');
    mobFlat?.classList.toggle('active',  mode === 'flat');
    mobNight?.classList.toggle('active', mode === 'night');
    localStorage.setItem('jl_mode', mode);
  }

  applyMode(localStorage.getItem('jl_mode') || 'default');

  flatBtn?.addEventListener('click', () => {
    const current = localStorage.getItem('jl_mode') || 'default';
    applyMode(current === 'flat' ? 'default' : 'flat');
  });
  nightBtn?.addEventListener('click', () => {
    const current = localStorage.getItem('jl_mode') || 'default';
    applyMode(current === 'night' ? 'default' : 'night');
  });
  mobFlat?.addEventListener('click', () => {
    const current = localStorage.getItem('jl_mode') || 'default';
    applyMode(current === 'flat' ? 'default' : 'flat');
  });
  mobNight?.addEventListener('click', () => {
    const current = localStorage.getItem('jl_mode') || 'default';
    applyMode(current === 'night' ? 'default' : 'night');
  });

  // ── Drawer sommaire mobile ──────────────────────────────────────────
  const tocDrawer      = document.getElementById('jl-toc-drawer');
  const tocDrawerBody  = document.getElementById('jl-toc-drawer-body');
  const tocDrawerClose = document.getElementById('jl-toc-drawer-close');
  const tocDrawerHand  = document.getElementById('jl-toc-drawer-handle');

  function tocOpen()  { tocDrawer?.classList.add('jl-toc-drawer--open');    document.body.style.overflow = 'hidden'; }
  function tocClose() { tocDrawer?.classList.remove('jl-toc-drawer--open'); document.body.style.overflow = ''; }

  mobTocBtn?.addEventListener('click', () => {
    if (tocDrawer?.classList.contains('jl-toc-drawer--open')) { tocClose(); return; }
    // Remplir au premier appel
    if (tocDrawerBody && tocDrawerBody.childElementCount === 0) {
      const backHref = window.location.pathname.startsWith('/journal') ? '/journal' : '/nouvelles';
      const back = document.createElement('a');
      back.href = backHref;
      back.className = 'jl-toc-drawer-back';
      back.textContent = '← ' + (backHref === '/journal' ? 'Journal' : 'Nouvelles');
      tocDrawerBody.appendChild(back);
      document.querySelectorAll('#jl-toc a').forEach(srcA => {
        const a = document.createElement('a');
        a.href = srcA.getAttribute('href') || '#';
        a.textContent = srcA.textContent || '';
        if (srcA.style.paddingLeft) a.style.paddingLeft = '1.4rem';
        a.addEventListener('click', (e) => {
          e.preventDefault();
          tocClose();
          const id = a.getAttribute('href')?.replace('#', '');
          if (id) setTimeout(() => {
            const el = document.getElementById(id);
            if (el) window.scrollTo({ top: el.getBoundingClientRect().top + window.scrollY - 76, behavior: 'smooth' });
          }, 320);
        });
        tocDrawerBody.appendChild(a);
      });
    }
    tocOpen();
  });

  tocDrawerClose?.addEventListener('click', tocClose);

  // Drag-to-dismiss
  let _td = 0, _tc = 0;
  tocDrawerHand?.addEventListener('touchstart', (e) => { _td = e.touches[0].clientY; _tc = 0; if (tocDrawer) tocDrawer.style.transition = 'none'; }, { passive: true });
  tocDrawerHand?.addEventListener('touchmove',  (e) => { const d = e.touches[0].clientY - _td; _tc = d; if (d > 0 && tocDrawer) tocDrawer.style.transform = `translateY(${d}px)`; }, { passive: true });
  tocDrawerHand?.addEventListener('touchend',   () => { if (tocDrawer) tocDrawer.style.transition = ''; if (_tc > 80) { tocClose(); if (tocDrawer) tocDrawer.style.transform = ''; } else { if (tocDrawer) tocDrawer.style.transform = ''; } });

  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') tocClose(); });

  // ── Mémorisation de position ──
  window.addEventListener('load', () => {
    const saved = sessionStorage.getItem(STORAGE_KEY);
    if (saved) {
      const pos = parseInt(saved, 10);
      if (pos > 200) window.scrollTo({ top: pos, behavior: 'instant' });
    }
  });
  let saveTimer;
  window.addEventListener('scroll', () => {
    clearTimeout(saveTimer);
    saveTimer = setTimeout(() => {
      sessionStorage.setItem(STORAGE_KEY, String(Math.round(window.scrollY)));
    }, 500);
  }, { passive: true });

  // ── Progression + temps restant ──
  const totalMin = lecture || 4;
  let readFired = false;

  function onScroll() {
    const article = document.getElementById('jl-article');
    let pct = 0;
    if (article) {
      const articleTop    = article.offsetTop;
      const articleBottom = articleTop + article.offsetHeight;
      const scrollable = articleBottom - articleTop - window.innerHeight;
      const scrolled   = Math.max(0, window.scrollY - articleTop);
      pct = scrollable > 0
        ? Math.min(100, Math.max(0, Math.round((scrolled / scrollable) * 100)))
        : (window.scrollY >= articleTop ? 100 : 0);
    } else {
      const total = document.body.scrollHeight - window.innerHeight;
      pct = total > 0 ? Math.round((window.scrollY / total) * 100) : 0;
    }
    if (bar)   bar.style.width = pct + '%';
    if (pctEl) pctEl.textContent = pct + '%';

    if (pct > 5 && timeEl && timeVal) {
      timeEl.style.display = 'flex';
      const remaining = Math.max(0, Math.round(totalMin * (1 - pct / 100)));
      timeVal.textContent = remaining < 1 ? '< 1 min' : remaining + ' min';
    }

    if (pct >= 80 && !readFired) {
      readFired = true;
      window.dispatchEvent(new CustomEvent('article:read', { detail: { slug: '/nouvelles/' + slug } }));
    }
  }
  window.addEventListener('scroll', onScroll, { passive: true });

  // ── ToC automatique ──
  if (body && toc) {
    const headings = body.querySelectorAll('h2, h3');
    const links = [];
    headings.forEach((h, i) => {
      if (!h.id) h.id = 'jl-h-' + i;
      const a = document.createElement('a');
      a.href = '#' + h.id;
      a.textContent = h.textContent || '';
      if (h.tagName === 'H3') a.style.paddingLeft = '.9rem';
      a.addEventListener('click', (e) => {
        e.preventDefault();
        const target = document.getElementById(h.id);
        if (target) {
          links.forEach(l => l.a.classList.remove('jl-toc-active'));
          a.classList.add('jl-toc-active');
          scrolling = true;
          clearTimeout(scrollingTimer);
          const top = target.getBoundingClientRect().top + window.scrollY - 52 - 24;
          window.scrollTo({ top, behavior: 'smooth' });
          scrollingTimer = setTimeout(() => { scrolling = false; }, 700);
        }
      });
      toc.appendChild(a);
      links.push({ el: h, a });
    });
    let scrolling = false;
    let scrollingTimer;
    const io = new IntersectionObserver(entries => {
      if (scrolling) return;
      entries.forEach(e => {
        if (e.isIntersecting) {
          links.forEach(l => l.a.classList.remove('jl-toc-active'));
          const found = links.find(l => l.el === e.target);
          if (found) found.a.classList.add('jl-toc-active');
        }
      });
    }, { rootMargin: '-20% 0px -70% 0px' });
    links.forEach(l => io.observe(l.el));
  }

  // ── Tracking 15s ──
  setTimeout(() => {
    window.dispatchEvent(new CustomEvent('article:read', { detail: { slug: '/nouvelles/' + slug } }));
  }, 15000);
})();
</script>
