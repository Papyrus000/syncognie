  }
  .sls-anno--fiche:hover,
  .sls-anno--fiche.sls-anno--hover {
    background: rgba(74,158,127,.16);
    border-color: #4a9e7f;
  }
  .sls-anno--fiche.sls-anno--active {
    background: rgba(74,158,127,.2);
    border-color: #4a9e7f;
    box-shadow: 0 1px 0 #4a9e7f;
  }

  /* ── Drawer mobile (concept panel) ── */

  .sls-drawer-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(28,24,17,0);
    z-index: 800;
    transition: background .3s ease;
    -webkit-tap-highlight-color: transparent;
  }
  .sls-drawer-overlay.sls-drawer--open {
    display: block;
    background: rgba(28,24,17,.45);
  }

  .sls-drawer {
    display: none;
    position: fixed;
    left: 0; right: 0; bottom: 0;
    z-index: 900;
    max-height: 82vh;
    background: var(--sls-paper, #FAF8F4);
    border-radius: 16px 16px 0 0;
    box-shadow: 0 -8px 40px rgba(28,24,17,.18);
    transform: translateY(100%);
    transition: transform .35s cubic-bezier(.32,.72,0,1);
    will-change: transform;
    overflow: hidden;
    padding-bottom: env(safe-area-inset-bottom, 0px);
  }
  .sls-drawer.sls-drawer--open {
    display: flex;
    flex-direction: column;
    transform: translateY(0);
  }

  .sls-drawer-handle {
    flex-shrink: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: .85rem 0 .5rem;
    cursor: grab;
    -webkit-tap-highlight-color: transparent;
  }
  .sls-drawer-handle::before {
    content: '';
    display: block;
    width: 36px;
    height: 4px;
    background: var(--sls-border, #E4DDD4);
    border-radius: 2px;
  }

  .sls-drawer-header {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1.25rem .75rem;
    border-bottom: 1px solid var(--sls-border, #E4DDD4);
  }
  .sls-drawer-label {
    font-family: 'DM Sans', sans-serif;
    font-size: .6rem;
    font-weight: 500;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--sls-ink-muted, #9A8F82);
  }
  .sls-drawer-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px; height: 32px;
    background: none;
    border: 1px solid var(--sls-border, #E4DDD4);
    border-radius: 50%;
    cursor: pointer;
    color: var(--sls-ink-muted, #9A8F82);
    transition: color .15s, border-color .15s, background .15s;
    -webkit-tap-highlight-color: transparent;
  }
  .sls-drawer-close:hover,
  .sls-drawer-close:active {
    color: var(--sls-ink, #1C1811);
    border-color: var(--sls-ink-soft, #4A4237);
    background: var(--sls-blue-hl, rgba(61,122,154,.08));
  }
  .sls-drawer-close svg {
    width: 11px; height: 11px;
    stroke: currentColor;
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
  }

  .sls-drawer-body {
    flex: 1;
    overflow-y: auto;
    padding: 1.25rem;
    -webkit-overflow-scrolling: touch;
    overscroll-behavior: contain;
  }

  body.sls-night-mode .sls-drawer {
    background: #2a2720;
    box-shadow: 0 -8px 40px rgba(0,0,0,.45);
  }
  body.sls-night-mode .sls-drawer-handle::before { background: #3e3830; }
  body.sls-night-mode .sls-drawer-header { border-bottom-color: #3e3830; }
  body.sls-night-mode .sls-drawer-close { border-color: #3e3830; color: #9a9080; }
  body.sls-night-mode .sls-drawer-overlay.sls-drawer--open { background: rgba(0,0,0,.6); }

  @media (min-width: 861px) {
    .sls-drawer, .sls-drawer-overlay { display: none !important; }
  }
</style>

<!-- Barre de progression -->
<div class="sls-progress" id="sls-progress" aria-hidden="true" data-slug={slug} data-lecture={lecture ?? 4}></div>

<div class="sls-wrap">

  <!-- ── Colonne gauche : ToC ── -->
  <aside class="sls-toc-col">
    <a href="/sous-la-surface" class="sls-toc-back">← Sous la surface</a>
    <div class="sls-toc-label">Dans cet article</div>
    <nav id="sls-toc" aria-label="Table des matières"></nav>

    <div class="sls-toc-sep"></div>

    {stade && (
      <div class="sls-toc-stade">
        <span class="sls-toc-stade-icon">{sl.icon}</span>
        <span class="sls-toc-stade-lbl">{sl.label}</span>
      </div>
    )}

    <div class="sls-toc-progress-wrap" id="sls-read-wrap" style="display:none">
      <div class="sls-toc-pct"><span id="sls-read-pct">0%</span> <span class="sls-toc-pct-lbl">lu</span></div>
      <div class="sls-toc-time"><span id="sls-time-val">—</span> <span class="sls-toc-pct-lbl">restant</span></div>
    </div>

  </aside>

  <!-- ── Centre : article ── -->
  <main class="sls-article" id="sls-article">

    <header class="sls-art-header">
      <p class="sls-art-eyebrow">Sous la surface</p>
      <h1 class="sls-art-titre">{title}</h1>
      {description && <p class="sls-art-desc">{description}</p>}
      <div class="sls-art-meta">
        <time class="sls-art-date" datetime={date.toISOString()}>{formatDate(date)}</time>
        {personnages && <span class="sls-art-perso">{personnages}</span>}
        {lecture && <span class="sls-art-lecture">{lecture} min de lecture</span>}
      </div>
    </header>



    <!-- Consigne interactive -->
    <div class="sls-hint" id="sls-hint">
      <span class="sls-hint-icon">◉</span>
      <span>
        Lisez la scène. Les <strong>passages soulignés</strong> sont cliquables —
        le concept associé s'ouvre à droite (ou en dessous sur mobile).
      </span>
    </div>

    <!-- Corps de l'article -->
    <div class="sls-body" id="sls-body">
      <slot />
    </div>

    <!-- Navigation -->
    {(prev || next) && (
      <nav class="sls-nav" aria-label="Navigation articles">
        <div class="sls-nav-grid">
          {prev ? (
            <a class="sls-nav-item" href={`/sous-la-surface/${prev.slug}`}>
              <span class="sls-nav-dir">← Précédent</span>
              <span class="sls-nav-titre">{prev.title}</span>
            </a>
          ) : <div />}
          {next ? (
            <a class="sls-nav-item sls-nav-item--next" href={`/sous-la-surface/${next.slug}`}>
              <span class="sls-nav-dir">Suivant →</span>
              <span class="sls-nav-titre">{next.title}</span>
            </a>
          ) : <div />}
        </div>
      </nav>
    )}

  </main>

  <!-- ── Colonne droite : panneau concept ── -->
  <aside class="sls-panel" id="sls-panel">

    <!-- Placeholder initial -->
    <div class="sls-panel-placeholder" id="sls-placeholder">
      <span class="sls-panel-placeholder-icon">◎</span>
      <p class="sls-panel-placeholder-txt">
        Touchez un passage souligné dans la scène pour voir le concept associé.
      </p>
    </div>

    <!-- Carte concept (injectée par JS) -->
    <div id="sls-concept-slot"></div>

    <!-- Jauges cérébrales (optionnelles, injectées par JS) -->
    <div id="sls-brain-slot"></div>

    <!-- Cadre de configuration -->
    <div class="sls-config" id="sls-config">
      <div class="sls-config-lbl">Lecture</div>
      <div class="sls-config-rows">

        <!-- Taille du texte -->
        <div class="sls-config-row">
          <span class="sls-config-row-lbl">Taille</span>
          <div class="sls-config-btns">
            <button class="sls-cfg-btn" id="sls-sz-down" aria-label="Réduire la taille">−</button>
            <button class="sls-cfg-btn" id="sls-sz-up"   aria-label="Agrandir la taille">+</button>
          </div>
        </div>

        <!-- Interligne -->
        <div class="sls-config-row">
          <span class="sls-config-row-lbl">Interligne</span>
          <div class="sls-config-btns">
            <button class="sls-cfg-btn" id="sls-lh-down" aria-label="Réduire l'interligne">
              <svg viewBox="0 0 24 24"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
            </button>
            <button class="sls-cfg-btn" id="sls-lh-up" aria-label="Augmenter l'interligne">
              <svg viewBox="0 0 24 24"><line x1="3" y1="4" x2="21" y2="4"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="20" x2="21" y2="20"/></svg>
            </button>
          </div>
        </div>

        <!-- Mode nuit -->
        <div class="sls-config-row">
          <span class="sls-config-row-lbl">Mode nuit</span>
          <div class="sls-config-btns">
            <button class="sls-cfg-btn sls-cfg-btn--night" id="sls-night" aria-label="Mode nuit">
              <svg viewBox="0 0 24 24"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
            </button>
          </div>
        </div>

      </div>
    </div>

  </aside>

</div>

<!-- ── Drawer mobile (concept) ── -->
<div class="sls-drawer-overlay" id="sls-drawer-overlay" aria-hidden="true"></div>
<div class="sls-drawer" id="sls-drawer" role="dialog" aria-modal="true" aria-label="Concept associé">
  <div class="sls-drawer-handle" id="sls-drawer-handle" aria-hidden="true"></div>
  <div class="sls-drawer-header">
    <span class="sls-drawer-label" id="sls-drawer-label">Concept</span>
    <button class="sls-drawer-close" id="sls-drawer-close" aria-label="Fermer">
      <svg viewBox="0 0 11 11"><path d="M1.5 1.5l8 8M9.5 1.5l-8 8"/></svg>
    </button>
  </div>
  <div class="sls-drawer-body" id="sls-drawer-body"></div>
</div>

<div id="sls-concepts-data" hidden set:text={conceptsJson}></div>
<div id="sls-registre-data" hidden set:text={slsRegistreJson}></div>

<script>
(function () {
  const _prog  = document.getElementById('sls-progress');
  const slug   = _prog ? _prog.dataset.slug : '';
  const lecture = _prog ? (parseInt(_prog.dataset.lecture) || 4) : 4;

  // ── Annotations : utiliser data-sls='concept-id' sur les spans du MDX ──

  const body        = document.getElementById('sls-body');
  const panel       = document.getElementById('sls-panel');
  const slot        = document.getElementById('sls-concept-slot');
  const brainSlot   = document.getElementById('sls-brain-slot');
  const placeholder = document.getElementById('sls-placeholder');
  const toc         = document.getElementById('sls-toc');
  const bar         = document.getElementById('sls-progress');

  // ── Drawer mobile ─────────────────────────────────────────────────────
  const drawer        = document.getElementById('sls-drawer');
  const drawerOverlay = document.getElementById('sls-drawer-overlay');
  const drawerBody    = document.getElementById('sls-drawer-body');
  const drawerClose   = document.getElementById('sls-drawer-close');
  const drawerHandle  = document.getElementById('sls-drawer-handle');
  const drawerLabel   = document.getElementById('sls-drawer-label');

  function isMobile() { return window.innerWidth <= 860; }

  // Sauvegarde de la position de scroll avant ouverture
  let _savedScrollY = 0;

  function drawerOpen(labelTxt) {
    _savedScrollY = window.scrollY;
    if (drawerLabel) drawerLabel.textContent = labelTxt || 'Concept';
    drawer?.classList.add('sls-drawer--open');
    drawerOverlay?.classList.add('sls-drawer--open');
    document.body.style.overflow = 'hidden';
  }

  function drawerClose_fn() {
    drawer?.classList.remove('sls-drawer--open');
    drawerOverlay?.classList.remove('sls-drawer--open');
    document.body.style.overflow = '';
    // Remettre exactement là où on était
    requestAnimationFrame(() => {
      window.scrollTo({ top: _savedScrollY, behavior: 'instant' });
    });
  }

  // Fermeture par bouton ×
  drawerClose?.addEventListener('click', () => {
    drawerClose_fn();
    // Désactiver l'annotation active
    if (activeId) {
      body?.querySelectorAll(`[data-sls="${activeId}"]`).forEach(s => {
        s.classList.remove('sls-anno--active');
      });
      activeId   = null;
      activeMode = null;
    }
    showPlaceholder();
  });

  // Fermeture par tap sur l'overlay
  drawerOverlay?.addEventListener('click', () => {
    drawerClose_fn();
    if (activeId) {
      body?.querySelectorAll(`[data-sls="${activeId}"]`).forEach(s => {
        s.classList.remove('sls-anno--active');
      });
      activeId   = null;
      activeMode = null;
    }
    showPlaceholder();
  });

  // Drag-to-dismiss sur le handle
  let _dragStart = 0;
  let _dragCurrent = 0;
  drawerHandle?.addEventListener('touchstart', (e) => {
    _dragStart = e.touches[0].clientY;
    _dragCurrent = 0;
    if (drawer) drawer.style.transition = 'none';
  }, { passive: true });
  drawerHandle?.addEventListener('touchmove', (e) => {
    const delta = e.touches[0].clientY - _dragStart;
    _dragCurrent = delta;
    if (delta > 0 && drawer) {
      drawer.style.transform = `translateY(${delta}px)`;
    }
  }, { passive: true });
  drawerHandle?.addEventListener('touchend', () => {
    if (drawer) drawer.style.transition = '';
    if (_dragCurrent > 80) {
      drawerClose_fn();
      if (activeId) {
        body?.querySelectorAll(`[data-sls="${activeId}"]`).forEach(s => {
          s.classList.remove('sls-anno--active');
        });
        activeId   = null;
        activeMode = null;
      }
      showPlaceholder();
      if (drawer) drawer.style.transform = '';
    } else {
      if (drawer) drawer.style.transform = '';
    }
  });

  // Fermeture par touche Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && drawer?.classList.contains('sls-drawer--open')) {
      drawerClose_fn();
      if (activeId) {
        body?.querySelectorAll(`[data-sls="${activeId}"]`).forEach(s => {
          s.classList.remove('sls-anno--active');
        });
        activeId   = null;
        activeMode = null;
      }
      showPlaceholder();
    }
  });

  // ── 0. Contrôles de configuration ────────────────────────────────────
  const szDown   = document.getElementById('sls-sz-down');
  const szUp     = document.getElementById('sls-sz-up');
  const lhDown   = document.getElementById('sls-lh-down');
  const lhUp     = document.getElementById('sls-lh-up');
  const nightBtn = document.getElementById('sls-night');

  // Taille de corps
  let fontSize = parseInt(localStorage.getItem('sls_fontsize') || '18', 10);
  function applySize() {
    document.documentElement.style.setProperty('--sls-base', fontSize + 'px');
    localStorage.setItem('sls_fontsize', String(fontSize));
  }
  applySize();
  szDown?.addEventListener('click', () => { if (fontSize > 14) { fontSize--; applySize(); } });
  szUp?.addEventListener('click',   () => { if (fontSize < 24) { fontSize++; applySize(); } });

  // Interligne
  const LH_STEPS = [1.55, 1.7, 1.87, 2.0, 2.15];
  let lhIdx = parseInt(localStorage.getItem('sls_lh_idx') || '2', 10);
  function applyLH() {
    document.documentElement.style.setProperty('--sls-lh', String(LH_STEPS[lhIdx]));
    localStorage.setItem('sls_lh_idx', String(lhIdx));
  }
  applyLH();
  lhDown?.addEventListener('click', () => { if (lhIdx > 0)                   { lhIdx--; applyLH(); } });
  lhUp?.addEventListener('click',   () => { if (lhIdx < LH_STEPS.length - 1) { lhIdx++; applyLH(); } });

  // Mode nuit
  function applyNight(on) {
    document.body.classList.toggle('sls-night-mode', on);
    nightBtn?.classList.toggle('active', on);
    localStorage.setItem('sls_night', on ? '1' : '0');
  }
  applyNight(localStorage.getItem('sls_night') === '1');
  nightBtn?.addEventListener('click', () => {
    applyNight(!document.body.classList.contains('sls-night-mode'));
  });

  // ── 1. Barre de progression ──────────────────────────────────────────
  const pctEl    = document.getElementById('sls-read-pct');
  const timeEl   = document.getElementById('sls-time-val');
  const readWrap = document.getElementById('sls-read-wrap');
  const totalMin = lecture || 4;

  let readFired = false;

  function updateProgress() {
    const article = document.getElementById('sls-article');
    if (!article || !bar) return;
    const top      = article.offsetTop;
    const bottom   = top + article.offsetHeight;
    const scrollable = bottom - top - window.innerHeight;
    const scrolled   = Math.max(0, window.scrollY - top);
    const pct = scrollable > 0 ? Math.min(100, (scrolled / scrollable) * 100) : 100;
    bar.style.width = pct + '%';

    if (pct > 2 && readWrap) readWrap.style.display = 'flex';
    if (pctEl) pctEl.textContent = Math.round(pct) + '%';
    if (timeEl) {
      const remaining = Math.max(0, Math.round(totalMin * (1 - pct / 100)));
      timeEl.textContent = remaining < 1 ? '< 1 min' : remaining + ' min';
    }

    if (pct >= 80 && !readFired) {
      readFired = true;
      window.dispatchEvent(new CustomEvent('article:read', {
        detail: { slug: '/sous-la-surface/' + slug }
      }));
    }
  }
  window.addEventListener('scroll', updateProgress, { passive: true });

  // Dispatch après 15s de présence
  setTimeout(() => {
    window.dispatchEvent(new CustomEvent('article:read', {
      detail: { slug: '/sous-la-surface/' + slug }
    }));
  }, 15000);

  // ── 2. Table des matières automatique ────────────────────────────────
  if (body && toc) {
    const headings = body.querySelectorAll('h2, h3');
    const links = [];
    headings.forEach((h, i) => {
      if (!h.id) h.id = 'sls-h-' + i;
      const a = document.createElement('a');
      a.href = '#' + h.id;
      a.textContent = h.textContent || '';
      if (h.tagName === 'H3') a.style.paddingLeft = '.85rem';
      a.addEventListener('click', (e) => {
        e.preventDefault();
        const target = document.getElementById(h.id);
        if (target) {
          const top = target.getBoundingClientRect().top + window.scrollY - 80;
          window.scrollTo({ top, behavior: 'smooth' });
        }
      });
      toc.appendChild(a);
      links.push({ el: h, a });
    });
    const io = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          links.forEach(l => l.a.classList.remove('sls-toc-active'));
          const found = links.find(l => l.el === e.target);
          if (found) found.a.classList.add('sls-toc-active');
        }
      });
    }, { rootMargin: '-20% 0px -70% 0px' });
    links.forEach(l => io.observe(l.el));
  }

  // ── 3. Système d'annotations ─────────────────────────────────────────

  let concepts = {};
  try {
    const el = document.getElementById('sls-concepts-data');
    concepts = JSON.parse(el ? el.textContent : '{}');
  } catch (e) { console.error('[sls] parse concepts:', e); }

  // Récupérer tous les spans annotés [data-sls]
  const annotations = body ? body.querySelectorAll('[data-sls]') : [];
  let activeId   = null;
  let activeMode = null;

  // Ajouter les classes visuelles
  annotations.forEach(el => {
    el.classList.add('sls-anno');
    const conceptId = el.getAttribute('data-sls');
    const isFiche   = el.getAttribute('data-sls-mode') === 'fiche';
    if (isFiche) el.classList.add('sls-anno--fiche');

    el.addEventListener('mouseenter', () => {
      el.classList.add('sls-anno--hover');
      // Illuminer tous les spans du même concept
      body.querySelectorAll(`[data-sls="${conceptId}"]`).forEach(s => {
        s.classList.add('sls-anno--hover');
      });
    });
    el.addEventListener('mouseleave', () => {
      body.querySelectorAll(`[data-sls="${conceptId}"]`).forEach(s => {
        s.classList.remove('sls-anno--hover');
      });
    });

    el.addEventListener('click', () => {
      // Désactiver le précédent
      if (activeId) {
        body.querySelectorAll(`[data-sls="${activeId}"]`).forEach(s => {
          s.classList.remove('sls-anno--active');
        });
      }
      // Si clic sur le même : fermer (+ fermer le drawer sur mobile)
      const clickedMode = el.getAttribute('data-sls-mode') || 'explain';
      if (activeId === conceptId && activeMode === clickedMode) {
        activeId   = null;
        activeMode = null;
        showPlaceholder();
        if (isMobile()) drawerClose_fn();
        return;
      }
      activeId   = conceptId;
      activeMode = clickedMode;
      body.querySelectorAll(`[data-sls="${conceptId}"]`).forEach(s => {
        s.classList.add('sls-anno--active');
      });
      showConcept(conceptId, clickedMode);
    });
  });

  function showPlaceholder() {
    if (placeholder) placeholder.style.display = '';
    if (slot) slot.innerHTML = '';
    if (brainSlot) brainSlot.innerHTML = '';
    if (drawerBody) drawerBody.innerHTML = '';
  }

  function showConcept(id, mode) {
    const data = concepts[id];
    if (!data) return;

    if (placeholder) placeholder.style.display = 'none';

    // ── Mode fiche synthèse (Partie II) ──────────────────────────────────
    if (mode === 'fiche' && data.fiche) {
      const f = data.fiche;

      const jaugesHtml = data.jauges ? `
        <div class="sls-fiche-jauges">
          <div class="sls-fiche-label">Dans la scène</div>
          ${Object.entries(data.jauges).map(([key, val]) => `
            <div class="sls-brain-row">
              <span class="sls-brain-key">${key}</span>
              <div class="sls-brain-track">
                <div class="sls-brain-fill" data-val="${val}" style="width:0%"></div>
              </div>
              <span class="sls-brain-val">${val}%</span>
            </div>
          `).join('')}
        </div>
      ` : '';

      const motsHtml = f.mots_cles && f.mots_cles.length ? `
        <div class="sls-fiche-mots">
          <div class="sls-fiche-label">Mots-clés</div>
          <ul class="sls-fiche-mots-list">
            ${f.mots_cles.map(m => `<li>${m}</li>`).join('')}
          </ul>
        </div>
      ` : '';

      const usagesHtml = f.usages && f.usages.length ? `
        <div class="sls-fiche-usages">
          <div class="sls-fiche-label">Dans votre vie</div>
          <ul class="sls-fiche-usages-list">
            ${f.usages.map(u => `<li>${u}</li>`).join('')}
          </ul>
        </div>
      ` : '';

      slot.innerHTML = `
        <div class="sls-fiche-card">
          <div class="sls-fiche-card-hd">
            <div class="sls-fiche-card-penseur">${data.penseur || ''}</div>
            <div class="sls-fiche-card-nom">${data.nom || id}</div>
            <div class="sls-fiche-badge">Fiche synthèse</div>
          </div>
          <div class="sls-fiche-essentiel">
            <div class="sls-fiche-label">À retenir</div>
            <p class="sls-fiche-essentiel-txt">${f.essentiel}</p>
          </div>
          ${motsHtml}
          ${jaugesHtml}
          ${usagesHtml}
        </div>
      `;

      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          slot.querySelectorAll('.sls-brain-fill[data-val]').forEach(el => {
            el.style.width = el.getAttribute('data-val') + '%';
          });
        });
      });

      // Sur mobile : ouvrir le drawer avec le contenu
      if (isMobile()) {
        if (drawerBody) {
          drawerBody.innerHTML = slot.innerHTML;
          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              drawerBody.querySelectorAll('.sls-brain-fill[data-val]').forEach(el => {
                el.style.width = el.getAttribute('data-val') + '%';
              });
            });
          });
          enrichirMotsCles(drawerBody);
        }
        drawerOpen(data.nom || 'Fiche synthèse');
      }
      // Enrichir les mots-clés avec le registre convergences (desktop)
      enrichirMotsCles(slot);
      return;
    }

    // ── Mode explication (Partie I) ───────────────────────────────────────
    const jaugesHtml = data.jauges ? `
      <div class="sls-brain-bar">
        <div class="sls-brain-bar-lbl">Ce qui se passe à cet instant</div>
        ${Object.entries(data.jauges).map(([key, val]) => `
          <div class="sls-brain-row">
            <span class="sls-brain-key">${key}</span>
            <div class="sls-brain-track">
              <div class="sls-brain-fill" data-val="${val}" style="width:0%"></div>
            </div>
            <span class="sls-brain-val">${val}%</span>
          </div>
        `).join('')}
      </div>
    ` : '';

    const vieHtml = data.vie ? `
      <div class="sls-card-vie-wrap">
        <div class="sls-card-vie-label">Dans la vraie vie</div>
        <p class="sls-card-vie-txt">${data.vie}</p>
      </div>
    ` : '';

    slot.innerHTML = `
      <div class="sls-concept-card">
        <div class="sls-concept-card-hd">
          <div class="sls-concept-card-penseur">${data.penseur || ''}</div>
          <div class="sls-concept-card-nom">${data.nom || id}</div>
        </div>
        <div class="sls-concept-card-body">
          <p>${data.corps || ''}</p>
          ${vieHtml}
        </div>
        ${data.extrait ? `
          <div class="sls-concept-card-extrait">
            <div class="sls-concept-card-extrait-lbl">Dans la scène</div>
            <div class="sls-concept-card-extrait-txt">${data.extrait}</div>
          </div>
        ` : ''}
      </div>
      ${jaugesHtml}
    `;

    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        slot.querySelectorAll('.sls-brain-fill[data-val]').forEach(el => {
          el.style.width = el.getAttribute('data-val') + '%';
        });
      });
    });

    // Sur mobile : ouvrir le drawer avec le contenu
    if (isMobile()) {
      if (drawerBody) {
        drawerBody.innerHTML = slot.innerHTML;
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            drawerBody.querySelectorAll('.sls-brain-fill[data-val]').forEach(el => {
              el.style.width = el.getAttribute('data-val') + '%';
            });
          });
        });
      }
      drawerOpen(data.nom || 'Concept');
    }
  }


  // ── 5. Système de matching mots-clés ↔ registre convergences ────────────

  // Charger le registre
  let SLS_REGISTRE = {};
  try {
    const regEl = document.getElementById('sls-registre-data');
    SLS_REGISTRE = JSON.parse(regEl ? regEl.textContent : '{}');
  } catch(e) { console.warn('[sls] registre:', e); }

  // Normalisation identique au script Python de génération
  function slsNorm(s) {
    return s.toLowerCase()
      .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
      .replace(/[''"()]/g, '')
      .replace(/\s+/g, ' ')
      .trim();
  }

  // Recherche dans le registre : exact d'abord, puis inclusion partielle
  function slsLookup(motcle) {
    const nk = slsNorm(motcle);
    // 1. Match exact
    if (SLS_REGISTRE[nk]) return SLS_REGISTRE[nk];
    // 2. Le mot-clé est contenu dans une clé du registre
    for (const [key, val] of Object.entries(SLS_REGISTRE)) {
      if (key.includes(nk) && nk.length > 3) return val;
    }
    // 3. Une clé du registre est contenue dans le mot-clé
    for (const [key, val] of Object.entries(SLS_REGISTRE)) {
      if (nk.includes(key) && key.length > 4) return val;
    }
    return null;
  }

  // ── Routing source → URL interne ───────────────────────────────────────
  const SLS_CONV_MAP = {
    'Système': '/bibliotheque#s1', 'Corps': '/bibliotheque#s2',
    'Émotion': '/bibliotheque#s3', 'Automatisme': '/bibliotheque#s4',
    'Attention': '/bibliotheque#s5', 'Sens': '/bibliotheque#s6',
    'Narration': '/bibliotheque#s7', 'Attachement': '/bibliotheque#s8',
    'Communication': '/bibliotheque#s9', 'Langage': '/bibliotheque#s10',
    'Désir': '/bibliotheque#s11', 'Identité': '/bibliotheque#s12',
    'Temps': '/bibliotheque#s13', 'Conflit': '/bibliotheque#s14',
    'Pouvoir': '/bibliotheque#s15', 'Fondements': '/bibliotheque#s16',
  };

  function slsSourceUrl(source) {
    if (!source) return null;
    // "Convergences · Fondements" → /bibliotheque#s16
    if (source.startsWith('Convergences')) {
      const conv = source.replace('Convergences · ', '').trim();
      return SLS_CONV_MAP[conv] || '/bibliotheque';
    }
    // Domaines YAML → bibliothèque générique
    return '/bibliotheque';
  }

  function slsSourceLabel(source) {
    if (!source) return '';
    if (source.startsWith('Convergences')) return source.replace('Convergences · ', '');
    // Domaine court
    return source.split('/')[0].trim();
  }

  // ── Enrichir les mots-clés d'une fiche ──────────────────────────────────
  // Panneau inséré directement dans .sls-fiche-mots, juste sous les badges
  function enrichirMotsCles(slotEl) {
    if (!slotEl) return;

    const motsWrap = slotEl.querySelector('.sls-fiche-mots');
    if (!motsWrap) return;

    // Panneau unique injecté dans le bloc mots-clés
    let defPanel = document.createElement('div');
    defPanel.className = 'sls-def-panel';
    defPanel.innerHTML = '<div class="sls-def-inner"></div>';
    motsWrap.appendChild(defPanel);

    const defInner   = defPanel.querySelector('.sls-def-inner');
    let activeMotcle = null;

    slotEl.querySelectorAll('.sls-fiche-mots-list li').forEach(li => {
      const motcle = li.textContent.trim();
      const entry  = slsLookup(motcle);
      if (!entry) return;  // neutre

      li.classList.add('sls-motcle-enrichi');
      li.setAttribute('role', 'button');
      li.setAttribute('tabindex', '0');
      li.setAttribute('aria-label', `Définition : ${entry.t}`);

      function openDef(e) {
        e.stopPropagation();
        const isSame = activeMotcle === motcle;

        slotEl.querySelectorAll('.sls-motcle--actif').forEach(el =>
          el.classList.remove('sls-motcle--actif')
        );

        if (isSame) {
          activeMotcle = null;
          defPanel.classList.remove('sls-def-panel--open');
          return;
        }

        activeMotcle = motcle;
        li.classList.add('sls-motcle--actif');

        // Construire le lien vers la source
        const url   = slsSourceUrl(entry.s);
        const label = slsSourceLabel(entry.s);
        const lienHtml = url ? `
          <a href="${url}" class="sls-def-lien" target="_blank" rel="noopener"
             title="Voir dans la bibliothèque">
            <svg viewBox="0 0 12 12">
              <path d="M5 2H2a1 1 0 00-1 1v7a1 1 0 001 1h7a1 1 0 001-1V7"/>
              <path d="M8 1h3m0 0v3m0-3L5.5 6.5"/>
            </svg>
            ${label}
          </a>` : '';

        defInner.innerHTML = `
          <div class="sls-def-header">
            <div class="sls-def-titre">${entry.t}</div>
            <button class="sls-def-close" aria-label="Fermer la définition">
              <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                <path d="M1.5 1.5l7 7M8.5 1.5l-7 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </button>
          </div>
          ${entry.p ? `<div class="sls-def-penseur">${entry.p}</div>` : ''}
          <div class="sls-def-body">${entry.d}</div>
          <div class="sls-def-source">
            <span class="sls-def-source-label">Source · ${entry.s.split('·').pop().trim()}</span>
            ${lienHtml}
          </div>
        `;

        defPanel.classList.add('sls-def-panel--open');

        defInner.querySelector('.sls-def-close')?.addEventListener('click', e => {
          e.stopPropagation();
          activeMotcle = null;
          li.classList.remove('sls-motcle--actif');
          defPanel.classList.remove('sls-def-panel--open');
        });
      }

      li.addEventListener('click', openDef);
      li.addEventListener('keydown', e => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openDef(e); }
      });
    });
  }

  // ── 4. Masquer la consigne après premier clic ─────────────────────────
  const hint = document.getElementById('sls-hint');
  if (hint && annotations.length > 0) {
    annotations[0].addEventListener('click', () => {
      hint.style.opacity = '0';
      hint.style.transition = 'opacity .4s';
      setTimeout(() => { hint.style.display = 'none'; }, 400);
    }, { once: true });
  }

})();
</script>
