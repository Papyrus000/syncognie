---
// src/layouts/SousLaSurfaceLayout.astro
// Format hybride interactif : scène + concepts annotés
// Les passages de la scène s'illuminent quand on explore un concept.
// Mobile-first, ToC latérale sur desktop.

import Base from './Base.astro';
import slsRegistreRaw from '../data/sls-registre.json';
const slsRegistreJson = JSON.stringify(slsRegistreRaw);

export interface Props {
  title:        string;
  date:         Date;
  description?: string;
  personnages?: string;
  concepts?:    string[];
  lecture?:     number;
  slug:         string;
  prev?:        { slug: string; title: string };
  next?:        { slug: string; title: string };
  conceptsJson?: string;
  stade?:       'graine' | 'pousse' | 'arbre';
  illustration?: string;
}

const {
  title, date, description, personnages,
  concepts, lecture, slug, prev, next,
  conceptsJson = '{}', stade, illustration
} = Astro.props;

function formatDate(d: Date) {
  return d.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
}
function stadeLabel(s?: string) {
  if (s === 'pousse') return { icon: '🌿', label: 'Pousse' };
  if (s === 'arbre')  return { icon: '🌳', label: 'Arbre' };
  return { icon: '🌱', label: 'Graine' };
}
const sl = stadeLabel(stade);
---

<Base title={`${title} — Sous la surface · Syncognie`}>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap"
  rel="stylesheet"
/>

<style>
  /* ── Variables ── */
  html:has(.sls-wrap) {
    --sls-bg:        #F5F2EE;
    --sls-paper:     #FAF8F4;
    --sls-ink:       #1C1811;
    --sls-ink-soft:  #4A4237;
    --sls-ink-muted: #9A8F82;
    --sls-blue:      #5a9ab8;
    --sls-blue-s:    #74aec8;
    --sls-blue-hl:   rgba(61,122,154,.08);
    --sls-blue-hl2:  rgba(61,122,154,.18);
    --sls-green:     #4a9e7f;
    --sls-green-s:   #6ab89a;
    --sls-green-hl:  rgba(74,158,127,.08);
    --sls-green-hl2: rgba(74,158,127,.18);
    --sls-border:    #E4DDD4;
    --sls-serif:     'Lora', Georgia, serif;
    --sls-sans:      'DM Sans', sans-serif;
    --sls-lh:        1.87;
    --sls-measure:   64ch;
    --sls-base:      18.5px;
  }
  body:has(.sls-wrap) {
    background-color: var(--sls-bg) !important;
    background-image: none !important;
  }

  /* ── Mode nuit ── */
  body.sls-night-mode:has(.sls-wrap) {
    --sls-bg:        #1a1915 !important;
    --sls-paper:     #2a2720 !important;
    --sls-ink:       #f0ece4 !important;
    --sls-ink-soft:  #d8d0c2 !important;
    --sls-ink-muted: #9a9080 !important;
    --sls-blue:      #5a9ab8 !important;
    --sls-blue-s:    #74aec8 !important;
    --sls-blue-hl:   rgba(90,154,184,.12) !important;
    --sls-blue-hl2:  rgba(90,154,184,.22) !important;
    --sls-green:     #3d8f6e !important;
    --sls-green-s:   #5aaa88 !important;
    --sls-green-hl:  rgba(61,143,110,.12) !important;
    --sls-green-hl2: rgba(61,143,110,.22) !important;
    --sls-border:    #3e3830 !important;
    background-color: #1a1915 !important;
  }

  /* ── Barre de progression ── */
  .sls-progress {
    position: fixed;
    top: 52px; left: 0;
    height: 2px; width: 0%;
    background: var(--sls-blue);
    box-shadow: 0 0 8px rgba(61,122,154,.4);
    z-index: 500;
    transition: width .08s linear;
  }

  /* ── Layout ── */
  .sls-wrap {
    display: grid;
    grid-template-columns: 200px 1fr 280px;
    grid-template-areas: "toc article panel";
    gap: 0 3rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 2.5rem 2rem 6rem;
    align-items: start;
  }

  /* ── Colonne ToC (gauche) ── */
  .sls-toc-col {
    grid-area: toc;
    position: sticky;
    top: 76px;
    max-height: calc(100vh - 96px);
    overflow-y: auto;
  }
  .sls-toc-label {
    font-family: var(--sls-sans);
    font-size: .65rem;
    font-weight: 500;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--sls-ink-muted);
    margin-bottom: .8rem;
  }
  .sls-toc-back {
    display: block;
    font-family: var(--sls-sans);
    font-size: .72rem;
    color: var(--sls-ink-muted);
    text-decoration: none;
    margin-bottom: 1.2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--sls-border);
    transition: color .18s;
  }
  .sls-toc-back:hover { color: var(--sls-blue); }

  .sls-toc-sep {
    height: 1px;
    background: var(--sls-border);
    margin: 1.2rem 0;
  }
  .sls-toc-stade {
    display: flex;
    align-items: center;
    gap: .4rem;
    margin-bottom: .6rem;
  }
  .sls-toc-stade-icon { font-size: .85rem; }
  .sls-toc-stade-lbl {
    font-family: var(--sls-sans);
    font-size: .62rem;
    color: var(--sls-ink-muted);
    letter-spacing: .06em;
  }
  .sls-toc-progress-wrap {
    display: flex;
    flex-direction: column;
    gap: .25rem;
  }
  .sls-toc-pct {
    font-family: var(--sls-sans);
    font-size: .75rem;
    font-weight: 500;
    color: var(--sls-blue);
  }
  .sls-toc-time {
    font-family: var(--sls-sans);
    font-size: .75rem;
    font-weight: 500;
    color: var(--sls-blue);
  }
  .sls-toc-pct-lbl {
    font-weight: 300;
    font-size: .68rem;
    color: var(--sls-ink-muted);
  }

  .sls-illustration {
    margin-bottom: 2rem;
    border-radius: 4px;
    overflow: hidden;
    max-width: var(--sls-measure);
  }
  .sls-illustration img {
    display: block;
    width: 100%;
    height: auto;
    max-height: 420px;
    object-fit: cover;
  }

  #sls-toc a {
    display: block;
    font-family: var(--sls-sans);
    font-size: .72rem;
    line-height: 1.5;
    color: var(--sls-ink-muted);
    text-decoration: none;
    padding: .26rem .5rem;
    border-left: 2px solid transparent;
    border-radius: 0 2px 2px 0;
    transition: color .18s, border-color .18s, background .18s;
    cursor: pointer;
  }
  #sls-toc a:hover {
    color: var(--sls-ink-soft);
    border-left-color: var(--sls-border);
  }
  #sls-toc a.sls-toc-active {
    color: var(--sls-blue);
    border-left-color: var(--sls-blue);
    background: var(--sls-blue-hl);
  }

  /* ── Article (centre) ── */
  .sls-article {
    grid-area: article;
    min-width: 0;
  }

  /* ── En-tête article ── */
  .sls-art-header {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--sls-border);
  }
  .sls-art-eyebrow {
    font-family: var(--sls-sans);
    font-size: .62rem;
    font-weight: 500;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--sls-blue-s);
    margin-bottom: .8rem;
    display: flex;
    align-items: center;
    gap: .5rem;
  }
  .sls-art-eyebrow::before {
    content: '';
    display: inline-block;
    width: 1.2rem;
    height: 1px;
    background: currentColor;
    opacity: .5;
  }
  .sls-art-titre {
    font-family: var(--sls-serif);
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 600;
    color: var(--sls-ink);
    letter-spacing: -.02em;
    line-height: 1.2;
    margin-bottom: .8rem;
  }
  .sls-art-desc {
    font-family: var(--sls-serif);
    font-style: italic;
    font-size: 1rem;
    color: var(--sls-ink-soft);
    line-height: 1.6;
    max-width: 54ch;
    margin-bottom: 1.2rem;
  }
  .sls-art-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: .5rem 1.2rem;
  }
  .sls-art-date {
    font-family: var(--sls-sans);
    font-size: .67rem;
    color: var(--sls-ink-muted);
    font-weight: 300;
  }
  .sls-art-perso {
    font-family: var(--sls-sans);
    font-size: .64rem;
    font-weight: 500;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--sls-blue-s);
    background: var(--sls-blue-hl2);
    padding: .18em .6em;
    border-radius: 2px;
  }
  .sls-art-lecture {
    font-family: var(--sls-sans);
    font-size: .65rem;
    color: var(--sls-ink-muted);
  }

  /* ── Consigne interactive ── */
  .sls-hint {
    display: flex;
    align-items: center;
    gap: .7rem;
    background: var(--sls-blue-hl);
    border: 1px solid rgba(61,122,154,.15);
    border-radius: 5px;
    padding: .75rem 1rem;
    margin-bottom: 2.5rem;
    font-family: var(--sls-sans);
    font-size: .75rem;
    color: var(--sls-blue);
    line-height: 1.5;
  }
  .sls-hint-icon { font-size: .9rem; flex-shrink: 0; }

  /* ── Corps : scène ── */
  .sls-body {
    font-family: var(--sls-serif);
    font-size: var(--sls-base);
    line-height: var(--sls-lh);
    color: var(--sls-ink-soft);
    max-width: var(--sls-measure);
  }
  .sls-body p {
    margin-bottom: 1.4rem;
    text-align: justify;
    hyphens: auto;
    -webkit-hyphens: auto;
  }
  .sls-body h2 {
    font-family: var(--sls-serif);
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--sls-ink);
    margin: 3rem 0 1rem;
    letter-spacing: -.015em;
    line-height: 1.25;
    scroll-margin-top: 80px;
  }
  .sls-body h3 {
    font-family: var(--sls-sans);
    font-size: .75rem;
    font-weight: 500;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--sls-ink-muted);
    margin: 2.5rem 0 .8rem;
    scroll-margin-top: 80px;
  }
  .sls-body blockquote {
    border-left: 2px solid var(--sls-blue);
    margin: 2rem 0;
    padding: .4rem 0 .4rem 1.4rem;
  }
  .sls-body blockquote p {
    font-style: italic;
    color: var(--sls-ink);
    margin: 0;
    text-align: left;
  }
  .sls-body em  { font-style: italic; }
  .sls-body strong { font-weight: 600; color: var(--sls-ink); }
  .sls-body hr {
    border: none;
    border-top: 1px solid var(--sls-border);
    margin: 2.5rem 0;
  }

  /* ── Passages annotés (spans injectés via JS) ── */
  .sls-anno {
    background: linear-gradient(120deg, rgba(61,122,154,0) 0%, rgba(61,122,154,.12) 100%);
    border-bottom: 1.5px solid rgba(61,122,154,.35);
    cursor: pointer;
    transition: background .2s, border-color .2s;
    border-radius: 1px;
    padding: 0 .05em;
  }
  .sls-anno:hover,
  .sls-anno.sls-anno--hover {
    background: rgba(61,122,154,.18);
    border-color: var(--sls-blue);
  }
  .sls-anno.sls-anno--active {
    background: rgba(61,122,154,.22);
    border-color: var(--sls-blue);
    box-shadow: 0 1px 0 var(--sls-blue);
  }

  /* ── Panneau concept (droite) ── */
  .sls-panel {
    grid-area: panel;
    position: sticky;
    top: 76px;
    max-height: calc(100vh - 96px);
    overflow-y: auto;
  }
  .sls-panel-placeholder {
    border: 1px dashed var(--sls-border);
    border-radius: 6px;
    padding: 1.75rem 1.25rem;
    text-align: center;
  }
  .sls-panel-placeholder-icon {
    font-size: 1.5rem;
    color: var(--sls-blue-s);
    opacity: .2;
    display: block;
    margin-bottom: .8rem;
  }
  .sls-panel-placeholder-txt {
    font-family: var(--sls-serif);
    font-style: italic;
    font-size: .9rem;
    color: var(--sls-ink-muted);
    line-height: 1.6;
  }

  /* Carte concept affichée */
  .sls-concept-card {
    background: var(--sls-paper);
    border: 1px solid var(--sls-border);
    border-radius: 6px;
    overflow: hidden;
    animation: sls-slide-in .25s cubic-bezier(.16,.84,.44,1) both;
  }
  @keyframes sls-slide-in {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .sls-concept-card-hd {
    background: var(--sls-blue-hl);
    border-bottom: 1px solid var(--sls-border);
    padding: 1rem 1.25rem .85rem;
  }
  .sls-concept-card-penseur {
    font-family: var(--sls-sans);
    font-size: .6rem;
    font-weight: 500;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--sls-blue-s);
    margin-bottom: .4rem;
  }
  .sls-concept-card-nom {
    font-family: var(--sls-serif);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--sls-ink);
    line-height: 1.2;
    letter-spacing: -.015em;
  }
  .sls-concept-card-body {
    padding: 1.1rem 1.25rem 1.25rem;
    font-family: var(--sls-serif);
    font-size: 1.02rem;
    color: var(--sls-ink-soft);
    line-height: 1.78;
  }
  .sls-concept-card-body p { margin-bottom: 1rem; }
  .sls-concept-card-body p:last-child { margin-bottom: 0; }

  /* Section "Dans la vraie vie" — générée par JS */
  .sls-card-vie-wrap {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--sls-border);
  }
  .sls-card-vie-label {
    font-family: var(--sls-sans);
    font-size: .6rem;
    font-weight: 500;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--sls-ink-muted);
    margin-bottom: .55rem;
  }
  .sls-card-vie-txt {
    font-family: var(--sls-serif);
    font-size: 1.02rem;
    color: var(--sls-ink-soft);
    line-height: 1.75;
    margin: 0;
  }

  .sls-concept-card-extrait {
    border-top: 1px solid var(--sls-border);
    padding: .9rem 1.25rem;
    background: rgba(250,248,244,.7);
  }
  .sls-concept-card-extrait-lbl {
    font-family: var(--sls-sans);
    font-size: .58rem;
    font-weight: 500;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--sls-ink-muted);
    margin-bottom: .45rem;
  }
  .sls-concept-card-extrait-txt {
    font-family: var(--sls-serif);
    font-style: italic;
    font-size: .96rem;
    color: var(--sls-ink-soft);
    line-height: 1.68;
    border-left: 2px solid var(--sls-blue-s);
    padding-left: .8rem;
  }
  .sls-concept-card-action {
    font-family: var(--sls-sans);
    font-size: .72rem;
    font-weight: 500;
    color: var(--sls-blue-s);
    background: var(--sls-blue-hl);
    border: 1px solid rgba(61,122,154,.18);
    border-radius: 3px;
    padding: .55rem 1rem;
    cursor: pointer;
    width: 100%;
    text-align: left;
    margin-top: .75rem;
    transition: background .18s, border-color .18s;
  }
  .sls-concept-card-action:hover {
    background: var(--sls-blue-hl2);
    border-color: var(--sls-blue-s);
  }

  /* Compteur d'activation */
  .sls-brain-bar {
    margin-top: 1rem;
    padding: 1rem 1.25rem;
    background: var(--sls-paper);
    border: 1px solid var(--sls-border);
    border-radius: 6px;
  }
  .sls-brain-bar-lbl {
    font-family: var(--sls-sans);
    font-size: .6rem;
    font-weight: 500;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--sls-ink-muted);
    margin-bottom: .7rem;
  }
  .sls-brain-row {
    display: flex;
    align-items: center;
    gap: .6rem;
    margin-bottom: .45rem;
  }
  .sls-brain-key {
    font-family: var(--sls-sans);
    font-size: .65rem;
    color: var(--sls-ink-muted);
    width: 100px;
    flex-shrink: 0;
  }
  .sls-brain-track {
    flex: 1;
    height: 4px;
    background: var(--sls-border);
    border-radius: 2px;
    overflow: hidden;
  }
  .sls-brain-fill {
    height: 100%;
    border-radius: 2px;
    background: var(--sls-blue);
    width: 0%;
    transition: width .6s cubic-bezier(.16,.84,.44,1);
  }
  .sls-brain-val {
    font-family: var(--sls-sans);
    font-size: .62rem;
    color: var(--sls-blue);
    width: 28px;
    text-align: right;
    flex-shrink: 0;
  }

  /* ── Navigation prev/next ── */
  .sls-nav {
    margin-top: 3.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--sls-border);
    max-width: var(--sls-measure);
  }
  .sls-nav-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .sls-nav-item {
    display: flex;
    flex-direction: column;
    gap: .3rem;
    padding: .9rem 1rem;
    border: 1px solid var(--sls-border);
    border-radius: 4px;
    text-decoration: none;
    background: var(--sls-bg);
    transition: border-color .2s, background .2s;
  }
  .sls-nav-item:hover {
    border-color: var(--sls-blue);
    background: var(--sls-blue-hl);
  }
  .sls-nav-item--next { text-align: right; }
  .sls-nav-dir {
    font-family: var(--sls-sans);
    font-size: .6rem;
    font-weight: 500;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--sls-ink-muted);
  }
  .sls-nav-titre {
    font-family: var(--sls-serif);
    font-size: .9rem;
    color: var(--sls-ink);
    line-height: 1.3;
  }

  /* ── Responsive ── */
  @media (max-width: 1080px) {
    .sls-wrap {
      grid-template-columns: 160px 1fr 240px;
      gap: 0 2rem;
    }
  }

  /* ── Tablette portrait (768px – 860px) ── */
  @media (max-width: 860px) {
    .sls-wrap {
      grid-template-columns: 1fr;
      grid-template-areas: "article";
      padding: 2rem 1.75rem 4rem;
      gap: 0;
    }
    .sls-toc-col,
    .sls-panel { display: none; }
  }

  /* ── Grand mobile / paysage (max 600px) ── */
  @media (max-width: 600px) {
    .sls-wrap {
      padding: 1.5rem 1.25rem 4rem;
    }
    .sls-hint {
      font-size: .8rem;
      padding: .7rem .9rem;
    }
    .sls-nav-grid {
      grid-template-columns: 1fr;
    }
    .sls-nav-item--next {
      text-align: left;
    }
  }

  /* ── Mobile portrait (max 430px) ── */
  @media (max-width: 430px) {
    .sls-wrap {
      padding: 1.25rem 1rem 3.5rem;
    }
    .sls-art-titre {
      font-size: clamp(1.2rem, 6vw, 1.5rem);
    }
    .sls-art-desc {
      font-size: .93rem;
    }
    .sls-art-meta {
      flex-wrap: wrap;
      gap: .4rem .8rem;
    }
    .sls-hint {
      font-size: .75rem;
      gap: .5rem;
    }
    /* Texte : désactiver justify sur petit écran (évite espaces disgracieux) */
    .sls-body p {
      text-align: left;
      hyphens: none;
      -webkit-hyphens: none;
    }
    /* Barre jauges : key moins large */
    .sls-brain-key {
      width: 90px;
      font-size: .6rem;
    }
    .sls-brain-val {
      width: 24px;
      font-size: .58rem;
    }
    /* Boutons config plus faciles à tapper */
    .sls-cfg-btn {
      width: 32px;
      height: 32px;
    }
  }



  /* ── Cadre de configuration ── */
  .sls-config {
    margin-top: 1rem;
    border: 1px solid var(--sls-border);
    border-radius: 6px;
    background: var(--sls-paper);
    padding: .85rem 1rem;
  }
  .sls-config-lbl {
    font-family: var(--sls-sans);
    font-size: .58rem;
    font-weight: 500;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--sls-ink-muted);
    margin-bottom: .75rem;
  }
  .sls-config-rows {
    display: flex;
