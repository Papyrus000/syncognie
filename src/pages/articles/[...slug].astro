---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map(article => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await article.render();

const date = article.data.date.toLocaleDateString('fr-FR', {
  month: 'long',
  year: 'numeric'
});
const wordCount = article.body.split(/\s+/).length;
const readTime = Math.max(1, Math.round(wordCount / 200));
---

<Base title={`${article.data.title} — Syncognie`}>
<style is:global> 
  
.wrap {
  max-width: var(--max);
  margin: 0 auto;
  padding: 0 1.75rem;
}
    .back {
      display: inline-flex;
      align-items: center;
      gap: .5rem;
      padding: 2.5rem 0 3rem;
      font-family: 'Mulish', sans-serif;
      font-size: .68rem;
      font-weight: 300;
      letter-spacing: .18em;
      text-transform: uppercase;
      color: var(--ink-soft);
      text-decoration: none;
      transition: color .2s, gap .2s;
      opacity: 0;
      animation: rise .8s .05s ease forwards;
    }
    .back:hover { color: var(--accent); gap: .75rem; }
    .back svg {
      width: 14px; height: 14px;
      stroke: currentColor; fill: none; stroke-width: 1.5;
      transition: transform .2s;
    }
    .back:hover svg { transform: translateX(-3px); }
    article {
      padding-bottom: 5rem;
      opacity: 0;
      animation: rise .9s .2s ease forwards;
    }
    .date {
      font-family: 'Mulish', sans-serif;
      font-size: .65rem;
      font-weight: 300;
      letter-spacing: .22em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 1.25rem;
    }
    h1 {
      font-size: 1.9rem;
      font-weight: 700;
      line-height: 1.3;
      color: var(--ink);
      margin-bottom: 2rem;
    }
    .rule {
      width: 2.5rem;
      height: 1px;
      background: var(--rule);
      margin-bottom: 2.5rem;
    }
    .content { 
      font-size: 1.05rem;
      color: var(--ink-mid);
      line-height: 1.85;
    }
    .content p { margin-bottom: 1.5rem; }
    .content h2 {
      font-size: 1.3rem;
      font-weight: 700;
      color: var(--ink);
      margin: 2.5rem 0 1rem;
    }
    .content h3 {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--ink);
      margin: 2rem 0 .75rem;
    }
    .content strong { color: var(--ink); font-weight: 700; }
    .content em { font-style: italic; }
    .content ul, .content ol {
      padding-left: 1.5rem;
      margin-bottom: 1.5rem;
    }
    .content li { margin-bottom: .4rem; }

    .content img {
    display: block;
    max-width: 100% !important; /* Force l'image à ne jamais dépasser */
    height: auto !important;     /* Garde les proportions */
    border-radius: 8px;
    margin: 2rem auto;
    box-shadow: 0 8px 30px rgba(0,0,0,.12);
  }

    footer {
      border-top: 1px solid var(--rule);
      padding: 2rem 0 3rem;
      font-family: 'Mulish', sans-serif;
      font-size: .65rem;
      font-weight: 300;
      letter-spacing: .1em;
      color: var(--ink-soft);
      opacity: 0;
      animation: rise .8s .4s ease forwards;
    }

  </style>

  <div class="wrap">
    <a class="back" href="/">
      <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
      Syncognie
    </a>

    <article>
      <p class="date">{date} · {readTime} min de lecture</p>
      <h1>{article.data.title}</h1>
      <div class="rule"></div>
      <div class="content">
        <Content />
      </div>
    </article>

    <footer>© 2026 Syncognie</footer>
  </div>
</Base>
