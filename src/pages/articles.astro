---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');
articles.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const total   = articles.length;
const nbSeries = [...new Set(articles.filter(a => a.data.serie).map(a => a.data.serie as string))].length;
const recits  = articles.filter(a => a.data.format === 'dialogue' || a.data.format === 'recit').length;
const notes   = total - recits;

function toSlug(str: string) {
  return str.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
}

// Familles de séries
const SERIE_RECIT    = "Les rencontres de Nathalie et Élodie";
const SERIE_MECA     = "Mécanique";
const SERIE_PRISMES  = "Notes d'un modèle en construction";

const byEpisode = (a: any, b: any) => (a.data.episode ?? 0) - (b.data.episode ?? 0);

const artRecits  = articles.filter(a => a.data.serie === SERIE_RECIT).sort(byEpisode);
const artMeca    = articles.filter(a => a.data.serie === SERIE_MECA).sort(byEpisode);
const artPrismes = articles.filter(a => a.data.serie === SERIE_PRISMES).sort(byEpisode);

// Séries dynamiques pour l'onglet Séries
const seriesData = [
  { name: SERIE_RECIT,   slug: toSlug(SERIE_RECIT),   label: 'Récit',    cls: 'recit',   count: artRecits.length,  articles: artRecits  },
  { name: SERIE_MECA,    slug: toSlug(SERIE_MECA),    label: 'Mécanique', cls: 'meca',   count: artMeca.length,    articles: artMeca    },
  { name: SERIE_PRISMES, slug: toSlug(SERIE_PRISMES), label: 'Prismes',  cls: 'prismes', count: artPrismes.length, articles: artPrismes },
].filter(s => s.count > 0 || true); // toujours afficher les 3 même vides

function familleClass(article: any): string {
  if (article.data.serie === SERIE_RECIT)   return 'recit';
  if (article.data.serie === SERIE_MECA)    return 'meca';
  if (article.data.serie === SERIE_PRISMES) return 'prismes';
  if (article.data.format === 'dialogue' || article.data.format === 'recit') return 'recit';
  return '';
}

function badgeFormat(article: any) {
  const s = article.data.serie;
  if (s === SERIE_RECIT)   return { cls: 'b-recit',   label: '◈ Récit' };
  if (s === SERIE_MECA)    return { cls: 'b-meca',    label: '◈ Mécanique' };
  if (s === SERIE_PRISMES) return { cls: 'b-prismes', label: '◈ Prismes' };
  if (article.data.format === 'dialogue' || article.data.format === 'recit') return { cls: 'b-recit', label: '◈ Récit' };
  if (article.data.format === 'analyse') return { cls: 'b-analyse', label: '◈ Analyse' };
  return null;
}

function lireLabel(article: any): string {
  const f = article.data.format;
  if (f === 'dialogue' || f === 'recit') return 'Lire le récit →';
  return 'Lire →';
}
