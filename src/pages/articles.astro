---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');
articles.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const total = articles.length;
const recits = articles.filter(a => a.data.format === 'dialogue' || a.data.format === 'recit').length;
const notes  = total - recits;

function toSlug(str: string) {
  return str.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
}
const seriesUniques = [...new Set(articles.filter(a => a.data.serie).map(a => a.data.serie as string))];
const nbSeries = seriesUniques.length;
const serieSlugUnique = nbSeries === 1 ? toSlug(seriesUniques[0]) : null;
---

<Base title="Articles — Syncognie">
  <Header />

  <div class="page-wrap">

    <!-- En-tête -->

<header class="page-header" style="position:relative; overflow:visible;">

  <svg class="header-filigrane" viewBox="0 0 420 420" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <circle cx="210" cy="210" r="185"
      stroke="#8b5e3c" stroke-width=".6"
      stroke-dasharray="2 10"
      opacity=".15"
      class="fil-rotate"/>
    <path d="M210 210
             C210 188, 224 174, 240 174
             C270 174, 295 199, 295 230
             C295 272, 260 305, 210 305
             C148 305, 96 253, 96 190
             C96 116, 151 62, 225 62"
          stroke="#c4993a" stroke-width="1.2"
          stroke-linecap="round" opacity=".22"/>
    <path d="M225 62
             C272 62, 332 98, 358 155
             C384 210, 370 285, 322 324"
          stroke="#c4993a" stroke-width=".8"
          stroke-linecap="round" opacity=".12"/>
    <line x1="210" y1="210" x2="240" y2="174" stroke="#8b5e3c" stroke-width=".7" opacity=".18"/>
    <line x1="210" y1="210" x2="295" y2="230" stroke="#8b5e3c" stroke-width=".7" opacity=".15"/>
    <line x1="210" y1="210" x2="210" y2="305" stroke="#8b5e3c" stroke-width=".7" opacity=".15"/>
    <line x1="210" y1="210" x2="96"  y2="190" stroke="#8b5e3c" stroke-width=".7" opacity=".13"/>
    <line x1="210" y1="210" x2="225" y2="62"  stroke="#8b5e3c" stroke-width=".7" opacity=".13"/>
    <circle cx="240" cy="174" r="4.5" fill="#c4993a" class="fil-pulse"/>
    <circle cx="295" cy="230" r="3.5" fill="#8b5e3c" class="fil-pulse-2"/>
    <circle cx="210" cy="305" r="4"   fill="#c4993a" class="fil-pulse-3"/>
    <circle cx="96"  cy="190" r="3.5" fill="#8b5e3c" class="fil-pulse"/>
    <circle cx="225" cy="62"  r="4"   fill="#c4993a" class="fil-pulse-2"/>
    <circle cx="210" cy="210" r="28"
      stroke="#8b5e3c" stroke-width="1"
      opacity=".15" class="fil-pulse"/>
    <circle cx="210" cy="210" r="52"
      stroke="#8b5e3c" stroke-width=".5"
      opacity=".08" class="fil-pulse-2"/>
    <circle cx="210" cy="210" r="5"
      fill="#8b5e3c" opacity=".2"
      class="fil-float"/>
    <circle cx="210" cy="210" r="2.5"
      fill="#f5f0e8" opacity=".6"
      class="fil-float"/>
  </svg>

      <p class="page-eyebrow">Publications</p>
      <h1 class="page-titre">Articles</h1>
      <p class="page-sous">
        Fragments de réflexion, récits et analyses 
        où les idées se confrontent pour faire émerger 
        de nouveaux sens.<br> 
        Un espace dédié à la cognition et au dialogue, 
        conçu pour être exploré au rythme de la pensée.

      </p>
      <div class="page-stats">
        <span class="stat">
          <span class="stat-n">{total}</span>
          <span class="stat-label">publication{total > 1 ? 's' : ''}</span>
        </span>
        <span class="stat-sep">·</span>
        <span class="stat">
          <span class="stat-n">{recits}</span>
          <span class="stat-label">récit{recits > 1 ? 's' : ''}</span>
        </span>
        <span class="stat-sep">·</span>
        <span class="stat">
          <span class="stat-n">{notes}</span>
          <span class="stat-label">note{notes > 1 ? 's' : ''}</span>
        </span>
      </div>
    </header>

    <div class="ornament-sep">
      <div class="orn-line"></div>
      <div class="orn-centre">
        <div class="orn-diamond"></div>
        <span class="orn-label">Toutes les publications</span>
        <div class="orn-diamond"></div>
      </div>
      <div class="orn-line"></div>
    </div>

    <!-- Grille : liste gauche + légende droite -->
    <div class="contenu-wrap">

      <!-- Liste articles -->
      <div class="articles-list">
        {articles.map((article, i) => {
          const estRecit = article.data.format === 'dialogue' || article.data.format === 'recit';
          return (
            <a
              class={`article-item${estRecit ? ' est-recit' : ''}`}
              href={`/articles/${article.slug}`}
              style={`animation-delay: ${0.15 + i * 0.08}s`}
            >
              <div class="article-aside">
                <span class="article-date">
                  {article.data.date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}
                </span>
                <div class="article-badges">
                  {estRecit && <span class="badge badge-recit">◈ Récit</span>}
                  {article.data.format === 'analyse' && <span class="badge badge-analyse">◈ Analyse</span>}
                  {article.data.statut === 'en-cours' && <span class="badge badge-wip">En cours</span>}
                  {article.data.stade === 'graine' && <span class="badge badge-graine badge-stade"><span class="badge-stade-icon">🌱</span> Graine</span>}
                  {article.data.stade === 'pousse' && <span class="badge badge-pousse badge-stade"><span class="badge-stade-icon">🌿</span> Pousse</span>}
                  {article.data.stade === 'arbre'  && <span class="badge badge-arbre  badge-stade"><span class="badge-stade-icon">🌳</span> Arbre</span>}
                  {article.data.serie && article.data.episode && (
                    <span
                      class="badge badge-serie"
                      data-tooltip={article.data.serie}
                    >
                      <span class="badge-serie-bulles" aria-hidden="true">
                        <span class="bulle bulle-1"></span>
                        <span class="bulle bulle-2"></span>
                      </span>
                      <span class="badge-serie-ep">ép. {article.data.episode}</span>
                    </span>
                  )}
                </div>
              </div>
              <div class="article-body">
                <p class="article-titre">{article.data.title}</p>
                {article.data.description && (
                  <p class="article-desc">{article.data.description}</p>
                )}
                <span class="article-lire">
                  {estRecit ? 'Lire le récit →' : 'Lire →'}
                </span>
              </div>
            </a>
          );
        })}
      </div>

      <!-- Colonne droite : série + stades -->
      <aside class="legende-col">

        {nbSeries > 0 && seriesUniques.map((serieName) => {
          const slug = toSlug(serieName);
          const nbEp = articles.filter(a => a.data.serie === serieName).length;
          return (
            <a href={`/series/${slug}`} class="legende-card legende-card--serie">
              <div class="legende-serie-top">
                <svg class="legende-serie-svg" viewBox="0 0 38 38" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <rect x="1" y="1" width="24" height="16" rx="4" stroke="#c4993a" stroke-width="1" fill="rgba(196,153,58,.04)" opacity=".7"/>
                  <circle cx="7"  cy="9" r="1.5" fill="#c4993a" opacity=".5" class="sdot-a"/>
                  <circle cx="13" cy="9" r="1.5" fill="#c4993a" opacity=".5" class="sdot-b"/>
                  <circle cx="19" cy="9" r="1.5" fill="#c4993a" opacity=".5" class="sdot-c"/>
                  <path d="M7 17 L4 22 L11 17" fill="rgba(196,153,58,.04)" stroke="#c4993a" stroke-width=".8" opacity=".5" stroke-linejoin="round"/>
                  <rect x="13" y="21" width="24" height="16" rx="4" stroke="#8b5e3c" stroke-width="1" fill="rgba(139,94,60,.03)" opacity=".55"/>
                  <circle cx="20" cy="29" r="1.5" fill="#8b5e3c" opacity=".4" class="sdot-d"/>
                  <circle cx="26" cy="29" r="1.5" fill="#8b5e3c" opacity=".4" class="sdot-e"/>
                  <circle cx="32" cy="29" r="1.5" fill="#8b5e3c" opacity=".4" class="sdot-f"/>
                  <path d="M31 21 L34 16 L27 21" fill="rgba(139,94,60,.03)" stroke="#8b5e3c" stroke-width=".8" opacity=".4" stroke-linejoin="round"/>
                </svg>
                <div>
                  <p class="legende-serie-eyebrow">Série · {nbEp} ép.</p>
                  <p class="legende-titre">{serieName}</p>
                </div>
              </div>
              <div class="legende-serie-voix">
                <div class="voix-i voix-e">É</div>
                <div class="voix-i voix-n">N</div>
                <span class="voix-label">Élodie & Nathalie</span>
              </div>
              <span class="legende-cta">Lire la série →</span>
            </a>
          );
        })}

        <a href="/stades" class="legende-card legende-card--link">
          <p class="legende-titre">Stades de maturité</p>
          <ul class="legende-list">
            <li>
              <span class="badge badge-graine badge-stade"><span class="badge-stade-icon">🌱</span> Graine</span>
              <span class="legende-desc">Idée posée, peu développée</span>
            </li>
            <li>
              <span class="badge badge-pousse badge-stade"><span class="badge-stade-icon">🌿</span> Pousse</span>
              <span class="legende-desc">En cours d'exploration</span>
            </li>
            <li>
              <span class="badge badge-arbre badge-stade"><span class="badge-stade-icon">🌳</span> Arbre</span>
              <span class="legende-desc">Consolidé, dense</span>
            </li>
          </ul>
          <p class="legende-note">
            Syncognie est un jardin numérique — les notes évoluent, se ramifient, mûrissent avec le temps.
          </p>
          <span class="legende-cta">En savoir plus →</span>
        </a>

      </aside>

    </div>

  </div>

  <Footer />
</Base>

<style>
  .page-wrap {
    max-width: var(--max);
    margin: 0 auto;
    padding: 0 1.75rem 5rem;
  }

  /* ── EN-TÊTE ── */
  .page-header {
    padding: 4rem 0 2.5rem;
    opacity: 0;
    animation: rise .9s .05s ease forwards;
  }

  .page-eyebrow {
    font-family: 'Mulish', sans-serif;
    font-size: .6rem;
    font-weight: 300;
    letter-spacing: .32em;
    text-transform: uppercase;
    color: var(--accent);
    opacity: .7;
    margin-bottom: 1rem;
  }

  .page-titre {
    font-size: clamp(1.8rem, 3.5vw, 2.4rem);
    font-weight: 700;
    color: var(--ink);
    line-height: 1.15;
    letter-spacing: -.02em;
    margin-bottom: .9rem;
  }

  .page-sous {
    font-family: 'Mulish', sans-serif;
    font-size: .875rem;
    font-weight: 300;
    color: var(--ink-soft);
    line-height: 1.8;
    max-width: 52ch;
    margin-bottom: 1.75rem;
  }

  /* Compteurs stats */
  .page-stats {
    display: flex;
    align-items: baseline;
    gap: .75rem;
  }

  .stat {
    display: flex;
    align-items: baseline;
    gap: .35rem;
  }

  .stat-n {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--blue-slate, #6b7fb8);
    line-height: 1;
    letter-spacing: -.02em;
  }

  .stat-label {
    font-family: 'Mulish', sans-serif;
    font-size: .62rem;
    font-weight: 300;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  .stat-sep {
    color: var(--rule);
    font-size: .9rem;
    line-height: 1;
  }

  .stat-serie-link {
    display: inline-flex;
    align-items: baseline;
    gap: .35rem;
    text-decoration: none;
    transition: opacity .2s;
  }
  .stat-serie-link:hover { opacity: .7; }
  .stat-serie-link:hover .stat-label { text-decoration: underline; text-underline-offset: 3px; }

  .stat-n-serie {
    color: #c4993a;
  }

  /* ── SÉPARATEUR ── */
  .ornament-sep {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: .25rem;
    opacity: 0;
    animation: rise .9s .2s ease forwards;
  }

  .orn-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--rule), transparent);
  }

  .orn-centre {
    display: flex;
    align-items: center;
    gap: .55rem;
  }

  .orn-diamond {
    width: 5px;
    height: 5px;
    background: var(--rule);
    transform: rotate(45deg);
  }

  .orn-label {
    font-family: 'Mulish', sans-serif;
    font-size: .58rem;
    font-weight: 700;
    letter-spacing: .25em;
    text-transform: uppercase;
    color: var(--ink-soft);
    opacity: .45;
  }

  /* ── GRILLE CONTENU (liste + légende) ── */
  .contenu-wrap {
    display: grid;
    grid-template-columns: 1fr 168px;
    gap: 2.5rem;
    align-items: start;
  }

  @media (max-width: 600px) {
    .contenu-wrap { grid-template-columns: 1fr; }
    .legende-col  { display: none; }
  }

  /* ── LISTE ARTICLES ── */
  .articles-list {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .article-item {
    display: grid;
    grid-template-columns: 148px 1fr;
    gap: 1.75rem;
    text-decoration: none;
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--rule);
    opacity: 0;
    position: relative;
    animation: rise .6s ease forwards;
    transition: background .15s;
  }

  .article-item:last-child { border-bottom: none; }

  .article-item::before {
    content: '';
    position: absolute;
    left: -1.75rem;
    top: 0; bottom: 0;
    width: 2px;
    background: var(--accent);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform .28s ease;
    opacity: .5;
  }

  .article-item:hover::before { transform: scaleY(1); }

  .article-aside {
    padding-top: .15rem;
    display: flex;
    flex-direction: column;
    gap: .5rem;
    align-items: flex-start;
  }

  .article-date {
    font-family: 'Mulish', sans-serif;
    font-size: .6rem;
    font-weight: 300;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--ink-soft);
    opacity: .55;
    line-height: 1.5;
  }

  .article-badges {
    display: flex;
    flex-direction: column;
    gap: .3rem;
  }

  .badge {
    font-family: 'Mulish', sans-serif;
    font-size: .52rem;
    font-weight: 700;
    letter-spacing: .13em;
    text-transform: uppercase;
    padding: .15rem .45rem;
    border-radius: 3px;
    display: inline-block;
  }

  .badge-recit {
    background: rgba(196, 153, 58, .1);
    color: #c4993a;
    border: 1px solid rgba(196, 153, 58, .25);
  }

  .badge-analyse {
    background: rgba(107, 127, 184, .1);
    color: #6b7fb8;
    border: 1px solid rgba(107, 127, 184, .25);
  }

  .badge-wip {
    background: rgba(139, 94, 60, .07);
    color: var(--accent);
    border: 1px solid rgba(139, 94, 60, .2);
  }

  /* Badges maturité */
  .badge-stade {
    display: inline-flex !important;
    align-items: center;
    gap: .28rem;
  }

  .badge-stade-icon { font-size: .62rem; line-height: 1; }

  .badge-graine {
    background: rgba(46, 125, 78, .07);
    color: #2e7d4e;
    border: 1px solid rgba(46, 125, 78, .2);
  }

  .badge-pousse {
    background: rgba(56, 120, 60, .09);
    color: #38783c;
    border: 1px solid rgba(56, 120, 60, .22);
  }

  .badge-arbre {
  background: rgba(46, 125, 78, .18);
    color: #224422;
    border: 1px solid rgba(34, 68, 34, .2);
  }

  .article-body {
    display: flex;
    flex-direction: column;
    gap: .45rem;
  }

  .article-titre {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--ink);
    line-height: 1.35;
    transition: color .2s;
  }

  .article-item:hover .article-titre { color: var(--accent); }

  .est-recit .article-titre {
    font-style: italic;
    font-weight: 400;
    font-size: 1rem;
  }

  .article-desc {
    font-family: 'Mulish', sans-serif;
    font-size: .82rem;
    font-weight: 300;
    color: var(--ink-soft);
    line-height: 1.65;
    max-width: 58ch;
  }

  .article-lire {
    display: inline-flex;
    align-items: center;
    gap: .35rem;
    font-family: 'Mulish', sans-serif;
    font-size: .65rem;
    font-weight: 600;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: #148EFF;
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity .2s, transform .2s;
    margin-top: .1rem;
  }

  .article-item:hover .article-lire {
    opacity: 1;
    transform: translateX(0);
  }

  /* ── LÉGENDE MATURITÉ ── */
  .legende-col {
    padding-top: .25rem;
    position: sticky;
    top: 4.5rem;
    align-self: start;
  }

  .legende-card {
    padding: 1rem;
    border: 1px solid var(--rule);
    border-radius: 6px;
    background: rgba(245, 240, 232, .6);
    box-shadow: 0 2px 12px rgba(44, 36, 22, .05);
  }

   .legende-titre {
    font-family: 'Mulish', sans-serif;
    font-size: .55rem;
    font-weight: 700;
    letter-spacing: .22em;
    text-transform: uppercase;
  color: var(--ink-mid);
    opacity: .75;
    margin-bottom: .75rem;
    padding-bottom: .5rem;
    border-bottom: 1px solid var(--rule);
  }

  .legende-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: .6rem;
    margin-bottom: .85rem;
  }

  .legende-list li {
    display: flex;
    flex-direction: column;
    gap: .25rem;
  }

  .legende-desc {
    font-family: 'Mulish', sans-serif;
    font-size: .62rem;
    font-weight: 300;
    font-style: italic;
  color: var(--ink-mid);
    opacity: .9;
    padding-left: .2rem;
  }

  .legende-note {
    font-family: 'Mulish', sans-serif;
    font-size: .72rem;
    font-weight: 300;
    font-style: italic;
  color: var(--ink-mid);
    opacity: .75;
    line-height: 1.6;
    padding-top: .75rem;
    border-top: 1px solid var(--rule);
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 600px) {
    .article-item {
      grid-template-columns: 1fr;
      gap: .6rem;
    }
    .article-aside {
      flex-direction: row;
      align-items: center;
      gap: .75rem;
    }
    .article-badges { flex-direction: row; }
  }

/* ── FILIGRANE EN-TÊTE ── */
.header-filigrane {
  position: absolute;
  top: 50%;
  right: -60px;
  transform: translateY(-50%);
  width: 340px;
  height: 340px;
  pointer-events: none;
  z-index: 0;
  opacity: .85;
}

@media (max-width: 600px) {
  .header-filigrane { display: none; }
}

.fil-rotate {
  transform-origin: 210px 210px;
  animation: fil-spin 32s linear infinite;
}
@keyframes fil-spin { to { transform: rotate(360deg); } }

.fil-pulse   { animation: fil-p 6s ease-in-out infinite; }
.fil-pulse-2 { animation: fil-p 6s ease-in-out infinite; animation-delay: 1.5s; }
.fil-pulse-3 { animation: fil-p 6s ease-in-out infinite; animation-delay: 3s; }
@keyframes fil-p {
  0%,100% { opacity: .18; }
  50%      { opacity: .55; }
}

.fil-float {
  animation: fil-f 8s ease-in-out infinite;
  transform-origin: 210px 210px;
}
@keyframes fil-f {
  0%,100% { transform: translateY(0); }
  50%      { transform: translateY(-6px); }
}


  @keyframes rise {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── BADGE SÉRIE ── */
  .badge-serie {
    display: inline-flex;
    align-items: center;
    gap: .32rem;
    background: rgba(107, 127, 184, .08);
    color: #4a5a8a;
    border: 1px solid rgba(107, 127, 184, .22);
    border-radius: 3px;
    padding: .15rem .42rem .15rem .32rem;
    font-family: 'Mulish', sans-serif;
    font-size: .52rem;
    font-weight: 700;
    letter-spacing: .11em;
    text-transform: uppercase;
    cursor: default;
    position: relative;
    transition: background .2s, border-color .2s;
  }

  .badge-serie:hover {
    background: rgba(107, 127, 184, .14);
    border-color: rgba(107, 127, 184, .38);
  }

  /* Tooltip nom de la série au survol */
  .badge-serie::after {
    content: attr(data-tooltip);
    position: absolute;
    bottom: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%);
    background: #2c2416;
    color: #f5f0e8;
    font-family: 'Mulish', sans-serif;
    font-size: .58rem;
    font-weight: 400;
    letter-spacing: .06em;
    text-transform: none;
    white-space: nowrap;
    padding: .3rem .55rem;
    border-radius: 3px;
    opacity: 0;
    pointer-events: none;
    transition: opacity .18s ease;
  }

  .badge-serie:hover::after {
    opacity: 1;
  }

  /* Les deux bulles qui évoquent le dialogue */
