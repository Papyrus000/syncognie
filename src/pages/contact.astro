---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
---

<Base title="Contact — Syncognie">
  <Header />

  <div class="contact-wrap">
    <div class="contact-header">
      <p class="contact-surtitre">Écrire</p>
      <h1 class="contact-titre">Une pensée à partager ?</h1>
      <p class="contact-sous">Une question, une réaction, une contradiction bienvenue.</p>
    </div>

    <form
  class="contact-form"
  action="https://api.web3forms.com/submit"
  method="POST"
>
  <!-- Clé Web3Forms — invisible pour le visiteur -->
  <input type="hidden" name="access_key" value="414ffc9f-3748-4dfe-bf17-2e9428e80c4c" />
  
<input
  type="checkbox"
  name="botcheck"
  style="display:none"
  tabindex="-1"
  autocomplete="off"
/>

  <!-- Sujet du mail que tu recevras -->
  <input type="hidden" name="subject" value="Nouveau message — Syncognie" />
  
  <!-- Redirige vers une page de confirmation après envoi -->
  <input type="hidden" name="redirect" value="https://syncognie.pages.dev/merci" /> 

  <div class="field">
    <label for="name">Nom</label>
    <input type="text" id="name" name="name" placeholder="Ton prénom" required />
  </div>

  <div class="field">
    <label for="email">Email</label>
    <input type="email" id="email" name="email" placeholder="ton@email.com" required />
  </div>

  <div class="field">
    <label for="message">Message</label>
    <textarea id="message" name="message" rows="6" placeholder="Ce que tu veux me dire..." required></textarea>
  </div>

  
<div class="h-captcha" data-captcha="true"></div>
  <button type="submit" class="contact-btn">Envoyer →</button>
</form>

  </div>

  <footer class="contact-footer">© 2026 Syncognie · <span class="version">v0.2</span></footer>
</Base>

<style>
  .contact-wrap {
    max-width: var(--max);
    margin: 0 auto;
    padding: 4rem 1.75rem 5rem;
  }

  .contact-header {
    margin-bottom: 3rem;
    opacity: 0;
    animation: rise .9s .1s ease forwards;
  }

  .contact-surtitre {
    font-family: 'Mulish', sans-serif;
    font-size: .65rem;
    font-weight: 300;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: .75rem;
  }

  .contact-titre {
    font-size: 1.9rem;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 1rem;
  }

  .contact-sous {
    font-family: 'Mulish', sans-serif;
    font-size: .9rem;
    font-weight: 300;
    color: var(--ink-soft);
    line-height: 1.7;
  }

  .contact-form {
    opacity: 0;
    animation: rise .9s .25s ease forwards;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: .5rem;
  }

  label {
    font-family: 'Mulish', sans-serif;
    font-size: .68rem;
    font-weight: 300;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  input, textarea {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: .95rem;
    color: var(--ink);
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--rule);
    padding: .6rem 0;
    outline: none;
    transition: border-color .2s;
    resize: none;
  }

  input::placeholder, textarea::placeholder {
    color: var(--ink-soft);
    opacity: .5;
  }

  input:focus, textarea:focus {
    border-bottom-color: var(--accent);
  }

  .contact-btn {
    align-self: flex-start;
    font-family: 'Mulish', sans-serif;
    font-size: .68rem;
    font-weight: 300;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--bg);
    background: var(--ink);
    border: none;
    padding: .8rem 1.75rem;
    border-radius: 2px;
    cursor: pointer;
    transition: background .2s, transform .15s;
  }

  .contact-btn:hover {
    background: var(--accent);
    transform: translateX(3px);
  }

  .contact-footer {
    max-width: var(--max);
    margin: 0 auto;
    padding: 2rem 1.75rem 3rem;
    border-top: 1px solid var(--rule);
    font-family: 'Mulish', sans-serif;
    font-size: .65rem;
    font-weight: 300;
    letter-spacing: .1em;
    color: var(--ink-soft);
  }

  .version {
    opacity: .5;
  }
</style>