<script>
(function () {

  /* ══ 0. AUTOMATISATIONS AU CHARGEMENT ══ */

  // Utilitaire : extraire les noms de famille depuis une cellule penseur
  function extractNoms(text) {
    return text.split(/·|,/).map(p => {
      const t = p.trim();
      if (!t) return null;
      // Dernier mot = nom de famille (ex: "Donella Meadows" → "Meadows")
      const parts = t.split(/\s+/);
      return parts[parts.length - 1].replace(/\.$/, '');
    }).filter(Boolean);
  }

  // A — Décompte dynamique penseurs uniques + concepts
  const allConcepts  = document.querySelectorAll('.bib-concept');
  const penseurNoms  = new Set();
  document.querySelectorAll('.bib-penseur').forEach(el => {
    extractNoms(el.textContent).forEach(n => penseurNoms.add(n.toLowerCase()));
  });
  const chipPenseurs = document.getElementById('chip-penseurs');
  const chipConcepts = document.getElementById('chip-concepts');
  if (chipPenseurs) chipPenseurs.textContent = `${penseurNoms.size} penseurs`;
  if (chipConcepts) chipConcepts.textContent = `${allConcepts.length} concepts`;

  // B — Bulles : statiques, pas besoin de les recalculer

  // C — Badge ⌃K : masquer quand input actif ou rempli
  const kbdEl = document.getElementById('bib-search-kbd');
  const input = document.getElementById('bib-search');
  if (kbdEl && input) {
    const updateKbd = () => {
      kbdEl.hidden = document.activeElement === input || input.value.length > 0;
    };
    input.addEventListener('focus',  updateKbd);
    input.addEventListener('blur',   updateKbd);
    input.addEventListener('input',  updateKbd);
  }

  /* ══ 1. SCROLL SPY ══ */
  const sections  = document.querySelectorAll('.bib-section[data-s]');
  const navLinks  = document.querySelectorAll('.bib-nav-lien[data-s]');
  if (sections.length && navLinks.length) {
    const spy = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          const s = e.target.dataset.s;
          navLinks.forEach(l => l.classList.toggle('active', l.dataset.s === s));
        }
      });
    }, { rootMargin: '-15% 0px -70% 0px' });
    sections.forEach(s => spy.observe(s));
  }

  /* ══ 2. INDEX — construire une fois au chargement ══ */
  // Pour chaque <tr> on stocke : l'élément DOM, les textes searchables,
  // et les innerHTML originaux des 3 cellules (pour restauration après highlight)
  const rows = [];
  sections.forEach(sec => {
    sec.querySelectorAll('tbody tr').forEach(tr => {
      const cEl = tr.querySelector('.bib-concept');
      const pEl = tr.querySelector('.bib-penseur');
      const dEl = tr.querySelector('.bib-def');
      if (!cEl) return;
      rows.push({
        tr,
        section: sec,
        // textes normalisés pour la recherche
        cText: normalise(cEl.textContent || ''),
        pText: normalise(pEl?.textContent || ''),
        dText: normalise(dEl?.textContent  || ''),
        // innerHTML originaux pour restauration
        cHTML: cEl.innerHTML,
        pHTML: pEl?.innerHTML || '',
        dHTML: dEl?.innerHTML  || '',
        cEl, pEl, dEl,
      });
    });
  });

  /* ══ 3. UTILITAIRES ══ */
  function normalise(str) {
    return str.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
  }

  function escapeRe(str) {
    return str.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
  }

  // Highlight : remplace dans le textContent uniquement (pas dans les balises HTML)
  // pour ne pas casser les <ul><li><strong> des définitions enrichies
  function highlightHTML(originalHTML, raw) {
    if (!raw) return originalHTML;
    // On wrap dans un div temporaire, on traverse les TextNode, on remplace
    const tmp = document.createElement('div');
    tmp.innerHTML = originalHTML;
    highlightNode(tmp, new RegExp(`(${escapeRe(normalise(raw))})`, 'gi'), raw);
    return tmp.innerHTML;
  }

  function highlightNode(node, reNorm, raw) {
    node.childNodes.forEach(child => {
      if (child.nodeType === Node.TEXT_NODE) {
        const norm = normalise(child.textContent);
        if (reNorm.test(norm)) {
          // Reconstruire en préservant la casse originale
          const re = new RegExp(`(${escapeRe(raw)})`, 'gi');
          const wrapped = child.textContent.replace(re, '<mark class="bib-hl">$1</mark>');
          const frag = document.createRange().createContextualFragment(wrapped);
          child.replaceWith(frag);
        }
      } else if (child.nodeType === Node.ELEMENT_NODE && child.tagName !== 'MARK') {
        highlightNode(child, reNorm, raw);
      }
    });
  }

  /* ══ 4. DOM ══ */
  const clearBtn = document.getElementById('bib-search-clear');
  const status   = document.getElementById('bib-search-status');
  const emptyEl  = document.getElementById('bib-search-empty');
  const emptyMsg = document.getElementById('bib-empty-msg');
  const kbd      = document.getElementById('bib-search-kbd');
  if (!input) return;

  /* ══ 5. ÉTAT ══ */
  let activeQuery = '';

  /* ══ 6. RESET — restaure le DOM à l'état original ══ */
  function reset() {
    rows.forEach(r => {
      r.tr.classList.remove('bib-row-hidden');
      r.cEl.innerHTML = r.cHTML;
      if (r.pEl) r.pEl.innerHTML = r.pHTML;
      if (r.dEl) r.dEl.innerHTML = r.dHTML;
    });
    sections.forEach(s => s.classList.remove('bib-section-hidden'));
    emptyEl.hidden = true;
    status.textContent = '';
    clearBtn.hidden = true;
    if (kbd) kbd.hidden = false;
    activeQuery = '';
  }

  /* ══ 7. SEARCH ══ */
  function search(raw) {
    const q   = raw.trim();
    const qn  = normalise(q);

    // Toujours d'abord restaurer les HTML originaux
    rows.forEach(r => {
      r.cEl.innerHTML = r.cHTML;
      if (r.pEl) r.pEl.innerHTML = r.pHTML;
      if (r.dEl) r.dEl.innerHTML = r.dHTML;
    });

    if (!qn) { reset(); return; }

    clearBtn.hidden = false;
    if (kbd) kbd.hidden = true;
    activeQuery = q;

    let visibleCount = 0;

    rows.forEach(r => {
      const matches = r.cText.includes(qn)
                   || r.pText.includes(qn)
                   || r.dText.includes(qn);

      if (matches) {
        r.tr.classList.remove('bib-row-hidden');
        visibleCount++;
        // Highlight dans chaque cellule
        r.cEl.innerHTML = highlightHTML(r.cHTML, q);
        if (r.pEl) r.pEl.innerHTML = highlightHTML(r.pHTML, q);
        if (r.dEl) r.dEl.innerHTML = highlightHTML(r.dHTML, q);
      } else {
        r.tr.classList.add('bib-row-hidden');
      }
    });

    // Masquer les sections entières sans résultat visible
    sections.forEach(sec => {
      const hasVisible = sec.querySelector('tbody tr:not(.bib-row-hidden)');
      sec.classList.toggle('bib-section-hidden', !hasVisible);
    });

    // Statut
    if (visibleCount === 0) {
      emptyMsg.textContent = `Aucun résultat pour « ${q} ».`;
      emptyEl.hidden = false;
      status.textContent = '0 résultat';
    } else {
      emptyEl.hidden = true;
      status.textContent = visibleCount === 1 ? '1 résultat' : `${visibleCount} résultats`;
    }
  }

  /* ══ 8. ÉVÉNEMENTS ══ */
  input.addEventListener('input', e => search(e.target.value));

  clearBtn.addEventListener('click', () => {
    input.value = '';
    input.focus();
    reset();
  });

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && input.value) {
      input.value = '';
      reset();
    }
    if ((e.key === '/' || (e.ctrlKey && e.key === 'k')) && document.activeElement !== input) {
      e.preventDefault();
      input.focus();
      input.select();
    }
  });

  /* ══ 9. CONNEXIONS — panneau latéral ══ */

  // Map concept-id → { tr, sectionColor }
  const conceptMap = new Map();
  document.querySelectorAll('tr[data-concept-id]').forEach(tr => {
    const section = tr.closest('.bib-section');
    const sNum    = section?.dataset.s;
    // Récupérer la couleur CSS de la section (--dim0..10)
    const dimVar  = sNum != null ? `var(--dim${Number(sNum) - 1})` : 'var(--border2)';
    conceptMap.set(tr.dataset.conceptId, { tr, dimVar });
  });

  let activeCxPanel = null;
  let activeSrcTr   = null;

  function closeCxPanel() {
    if (activeCxPanel) { activeCxPanel.remove(); activeCxPanel = null; }
    if (activeSrcTr)   { activeSrcTr.classList.remove('bib-row-active'); activeSrcTr = null; }
  }

  // Résoudre une var CSS depuis .bib-wrap
  const bibWrap = document.querySelector('.bib-wrap');
  function cssVar(name) {
    return bibWrap ? getComputedStyle(bibWrap).getPropertyValue(name).trim() : '';
  }

  function openCxPanel(srcTr) {
    if (activeSrcTr === srcTr) { closeCxPanel(); return; }
    closeCxPanel();

    let links;
    try { links = JSON.parse(srcTr.dataset.links); } catch { return; }
    if (!links?.length) return;

    const section = srcTr.closest('.bib-section');
    const sNum    = section?.dataset.s;
    const dimIdx  = sNum != null ? Number(sNum) - 1 : 0;
    const color   = cssVar(`--dim${dimIdx}`) || '#6366f1';
    const surface  = cssVar('--surface')  || '#fdfcfa';
    const surface2 = cssVar('--surface2') || '#f0ece5';
    const border   = cssVar('--border')   || '#ddd6c8';
    const inkSoft  = cssVar('--ink-soft') || '#7a736a';
    const ink      = cssVar('--ink')      || '#2c2820';

    const isMobile = window.innerWidth < 560;
    const itemsHTML = links.map(link => {
      const target    = conceptMap.get(link.id);
      const tSNum     = target ? target.tr.closest('.bib-section')?.dataset.s : null;
      const tDimIdx   = tSNum != null ? Number(tSNum) - 1 : 0;
      const tColor    = target ? (cssVar(`--dim${tDimIdx}`) || color) : color;
      const gridCols  = isMobile ? '1fr' : '160px 1fr auto';
      return `<div class="bib-cx-item" data-cx-target="${link.id}"
        style="display:grid;grid-template-columns:${gridCols};align-items:${isMobile ? 'start' : 'center'};
               gap:${isMobile ? '4px 10px' : '12px'};cursor:pointer;border-radius:5px;
               padding:${isMobile ? '10px 11px' : '8px 11px'};
               background:${surface};border:1px solid ${border};
               transition:border-color .12s,background .12s,transform .1s;">
        <div style="display:flex;flex-direction:${isMobile ? 'row' : 'column'};
                    align-items:${isMobile ? 'baseline' : 'flex-start'};
                    gap:${isMobile ? '.4rem' : '2px'};min-width:0;
                    ${isMobile ? 'grid-column:1;' : ''}">
          <span style="font-size:.79rem;font-weight:700;color:${ink};
                       font-family:'Mulish',sans-serif;
                       ${isMobile ? '' : 'white-space:nowrap;overflow:hidden;text-overflow:ellipsis;'}">${link.label}</span>
          <span style="font-size:.62rem;font-weight:700;letter-spacing:.06em;
                       text-transform:uppercase;color:${tColor};white-space:nowrap;
                       font-family:'Mulish',sans-serif;">${link.conv}</span>
        </div>
        <span style="font-size:.73rem;color:${inkSoft};line-height:1.45;
                     font-family:'Mulish',sans-serif;
                     ${isMobile ? 'grid-column:1;' : ''}">${link.note}</span>
        ${isMobile ? '' : `<svg width="13" height="13" viewBox="0 0 13 13" fill="none"
             style="flex-shrink:0;opacity:.4;transition:opacity .12s,transform .12s;"
             class="bib-cx-arr" aria-hidden="true">
          <path d="M2.5 6.5h8M7 3l3.5 3.5L7 10" stroke="${inkSoft}"
                stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>`}
      </div>`;
    }).join('');

    // Insérer un <tr> après srcTr, avec styles forcés inline
    const colCount = srcTr.querySelectorAll('td').length || 3;
    const cxTr = document.createElement('tr');
    cxTr.style.cssText = 'background:transparent!important;border:none!important;';
    const td = document.createElement('td');
    td.colSpan = colCount;
    td.style.cssText = `padding:0!important;border:none!important;background:transparent!important;`;

    const panel = document.createElement('div');
    panel.style.cssText = `
      margin:2px 0 8px 0;
      padding:13px 15px 15px;
      background:${surface2};
      border-left:3px solid ${color};
      border-radius:0 6px 6px 0;
      animation:bib-cx-in .18s ease both;
    `;
    panel.innerHTML = `
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;">
        <span style="font-size:.65rem;font-weight:700;letter-spacing:.09em;
                     text-transform:uppercase;color:${color};
                     font-family:'Mulish',sans-serif;">Connexions</span>
        <button class="bib-cx-close"
          style="margin-left:auto;background:none;border:none;cursor:pointer;
                 color:${border};padding:2px 5px;line-height:1;border-radius:3px;">
          <svg width="11" height="11" viewBox="0 0 11 11" fill="none">
            <path d="M1.5 1.5l8 8M9.5 1.5l-8 8" stroke="currentColor"
                  stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
      <div style="display:flex;flex-direction:column;gap:5px;">${itemsHTML}</div>`;

    td.appendChild(panel);
    cxTr.appendChild(td);
    srcTr.after(cxTr);
    srcTr.classList.add('bib-row-active');
    activeCxPanel = cxTr;
    activeSrcTr   = srcTr;

    // Hover sur les items
    panel.querySelectorAll('.bib-cx-item').forEach(item => {
      item.addEventListener('mouseenter', () => {
        item.style.borderColor = color;
        item.style.background  = '#fff';
        item.style.transform   = 'translateX(3px)';
        const arr = item.querySelector('.bib-cx-arr');
        if (arr) { arr.style.opacity = '1'; arr.style.transform = 'translateX(2px)'; }
      });
      item.addEventListener('mouseleave', () => {
        item.style.borderColor = border;
        item.style.background  = surface;
        item.style.transform   = '';
        const arr = item.querySelector('.bib-cx-arr');
        if (arr) { arr.style.opacity = '.4'; arr.style.transform = ''; }
      });
    });

    panel.querySelector('.bib-cx-close').addEventListener('click', e => {
      e.stopPropagation(); closeCxPanel();
    });

    panel.querySelectorAll('.bib-cx-item[data-cx-target]').forEach(item => {
      item.addEventListener('click', () => {
        const entry = conceptMap.get(item.dataset.cxTarget);
        if (!entry) return;
        const targetTr  = entry.tr;
        const tSNum     = targetTr.closest('.bib-section')?.dataset.s;
        const tDimIdx   = tSNum != null ? Number(tSNum) - 1 : 0;
        const flashHex  = cssVar(`--dim${tDimIdx}`).replace('#','') || '6366f1';
        const r = parseInt(flashHex.substring(0,2),16);
        const g = parseInt(flashHex.substring(2,4),16);
        const b = parseInt(flashHex.substring(4,6),16);
        closeCxPanel();
        targetTr.scrollIntoView({ behavior:'smooth', block:'center' });
        setTimeout(() => {
          targetTr.style.setProperty('--cx-flash-bg', `rgba(${r},${g},${b},0.15)`);
          targetTr.classList.remove('bib-flash-target');
          void targetTr.offsetWidth;
          targetTr.classList.add('bib-flash-target');
          setTimeout(() => targetTr.classList.remove('bib-flash-target'), 1300);
        }, 350);
      });
    });
  }

  // Délégation sur les tbody — clic sur .bib-concept d'une tr[data-links]
  document.querySelectorAll('.bib-table tbody').forEach(tbody => {
    tbody.addEventListener('click', e => {
      const conceptCell = e.target.closest('.bib-concept');
      if (!conceptCell) return;
      const tr = conceptCell.closest('tr[data-links]');
      if (!tr) return;
      openCxPanel(tr);
    });
  });

  // Escape ferme aussi le panneau ouvert
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && activeCxPanel) {
      closeCxPanel();
    }
  });

})();
</script>

</BaseLayout>
