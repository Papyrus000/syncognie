  .bib-concept::before { display: none; }
  .bib-penseur { padding: 0 .7rem .28rem .9rem; font-size: .70rem; }
  .bib-def { padding: .28rem .7rem .55rem .9rem; font-size: .86rem; }
}

/* ══ RECHERCHE ══ */
.bib-search-wrap {
  display: flex;
  align-items: center;
  gap: .75rem;
  padding: .9rem 0 .85rem;
  border-bottom: 1px solid var(--border);
}
.bib-search-field {
  display: flex; align-items: center; gap: .5rem;
  flex: 1;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: .5rem .75rem;
  transition: border-color .18s, box-shadow .18s;
}
.bib-search-field:focus-within {
  border-color: var(--border2);
  box-shadow: 0 0 0 3px rgba(139,94,60,.08);
}
.bib-search-ico {
  color: var(--ink-soft); opacity: .45; flex-shrink: 0;
}
.bib-search-input {
  flex: 1; border: none; background: transparent;
  font-family: 'Mulish', sans-serif;
  font-size: .86rem; font-weight: 300;
  color: var(--ink); outline: none;
  min-width: 0;
}
.bib-search-input::placeholder { color: var(--ink-soft); opacity: .5; }
.bib-search-input::-webkit-search-cancel-button { display: none; }
.bib-search-kbd {
  font-family: 'Mulish', sans-serif;
  font-size: .60rem; font-weight: 600;
  letter-spacing: .04em;
  color: var(--ink-soft); opacity: .45;
  background: var(--surface2);
  border: 1px solid var(--border);
  border-radius: 3px;
  padding: .12rem .32rem;
  flex-shrink: 0;
  pointer-events: none;
  transition: opacity .15s;
}
.bib-search-kbd[hidden] { display: none; }
.bib-search-clear {
  background: none; border: none; cursor: pointer; padding: 0;
  color: var(--ink-soft); opacity: .45;
  display: flex; align-items: center;
  transition: opacity .15s;
  flex-shrink: 0;
}
.bib-search-clear:hover { opacity: .8; }
.bib-search-status {
  font-family: 'Mulish', sans-serif;
  font-size: .70rem; font-weight: 400;
  color: var(--ink-soft); opacity: .6;
  white-space: nowrap; flex-shrink: 0;
}

/* ══ RÉSULTATS — filtrage in-place ══ */

/* Ligne masquée par la recherche */
.bib-row-hidden { display: none !important; }

/* Section entière masquée si aucun résultat dedans */
.bib-section-hidden { display: none !important; }

/* Highlight des termes trouvés */
mark.bib-hl {
  background: rgba(232,184,50,.38);
  color: inherit; border-radius: 2px; padding: 0 .06em;
}

/* Message aucun résultat / nb résultats */
.bib-search-empty {
  padding: .75rem 0 0 1.75rem;
  font-family: 'Mulish', sans-serif;
  font-size: .84rem; font-weight: 300; font-style: italic;
  color: #9a9189;
}
.bib-search-empty[hidden] { display: none; }


.bib-nav-lien[data-s="1"] { --sc: var(--dim0); }
.bib-nav-lien[data-s="2"] { --sc: var(--dim1); }
.bib-nav-lien[data-s="3"] { --sc: var(--dim2); }
.bib-nav-lien[data-s="4"] { --sc: var(--dim3); }
.bib-nav-lien[data-s="5"] { --sc: var(--dim4); }
.bib-nav-lien[data-s="6"] { --sc: var(--dim5); }
.bib-nav-lien[data-s="7"] { --sc: var(--dim6); }
.bib-nav-lien[data-s="8"] { --sc: var(--dim7); }
</style>

<script>
(function () {

  /* ══ 0. AUTOMATISATIONS AU CHARGEMENT ══ */

  // Utilitaire : extraire les noms de famille depuis une cellule penseur
  function extractNoms(text) {
    return text.split(/·|,/).map(p => {
      const t = p.trim();
      if (!t) return null;
      // Dernier mot = nom de famille (ex: "Donella Meadows" → "Meadows")
      const parts = t.split(/\s+/);
      return parts[parts.length - 1].replace(/\.$/, '');
    }).filter(Boolean);
  }

  // A — Décompte dynamique penseurs uniques + concepts
  const allConcepts  = document.querySelectorAll('.bib-concept');
  const penseurNoms  = new Set();
  document.querySelectorAll('.bib-penseur').forEach(el => {
    extractNoms(el.textContent).forEach(n => penseurNoms.add(n.toLowerCase()));
  });
  const chipPenseurs = document.getElementById('chip-penseurs');
  const chipConcepts = document.getElementById('chip-concepts');
  if (chipPenseurs) chipPenseurs.textContent = `${penseurNoms.size} penseurs`;
  if (chipConcepts) chipConcepts.textContent = `${allConcepts.length} concepts`;

  // B — Bulles : statiques, pas besoin de les recalculer

  // C — Badge ⌃K : masquer quand input actif ou rempli
  const kbdEl = document.getElementById('bib-search-kbd');
  const input = document.getElementById('bib-search');
  if (kbdEl && input) {
    const updateKbd = () => {
      kbdEl.hidden = document.activeElement === input || input.value.length > 0;
    };
    input.addEventListener('focus',  updateKbd);
    input.addEventListener('blur',   updateKbd);
    input.addEventListener('input',  updateKbd);
  }

  /* ══ 1. SCROLL SPY ══ */
  const sections  = document.querySelectorAll('.bib-section[data-s]');
  const navLinks  = document.querySelectorAll('.bib-nav-lien[data-s]');
  if (sections.length && navLinks.length) {
    const spy = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          const s = e.target.dataset.s;
          navLinks.forEach(l => l.classList.toggle('active', l.dataset.s === s));
        }
      });
    }, { rootMargin: '-15% 0px -70% 0px' });
    sections.forEach(s => spy.observe(s));
  }

  /* ══ 2. INDEX — construire une fois au chargement ══ */
  // Pour chaque <tr> on stocke : l'élément DOM, les textes searchables,
  // et les innerHTML originaux des 3 cellules (pour restauration après highlight)
  const rows = [];
  sections.forEach(sec => {
    sec.querySelectorAll('tbody tr').forEach(tr => {
      const cEl = tr.querySelector('.bib-concept');
      const pEl = tr.querySelector('.bib-penseur');
      const dEl = tr.querySelector('.bib-def');
      if (!cEl) return;
      rows.push({
        tr,
        section: sec,
        // textes normalisés pour la recherche
        cText: normalise(cEl.textContent || ''),
        pText: normalise(pEl?.textContent || ''),
        dText: normalise(dEl?.textContent  || ''),
        // innerHTML originaux pour restauration
        cHTML: cEl.innerHTML,
        pHTML: pEl?.innerHTML || '',
        dHTML: dEl?.innerHTML  || '',
        cEl, pEl, dEl,
      });
    });
  });

  /* ══ 3. UTILITAIRES ══ */
  function normalise(str) {
    return str.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
  }

  function escapeRe(str) {
    return str.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
  }

  // Highlight : remplace dans le textContent uniquement (pas dans les balises HTML)
  // pour ne pas casser les <ul><li><strong> des définitions enrichies
  function highlightHTML(originalHTML, raw) {
    if (!raw) return originalHTML;
    // On wrap dans un div temporaire, on traverse les TextNode, on remplace
    const tmp = document.createElement('div');
    tmp.innerHTML = originalHTML;
    highlightNode(tmp, new RegExp(`(${escapeRe(normalise(raw))})`, 'gi'), raw);
    return tmp.innerHTML;
  }

  function highlightNode(node, reNorm, raw) {
    node.childNodes.forEach(child => {
      if (child.nodeType === Node.TEXT_NODE) {
        const norm = normalise(child.textContent);
        if (reNorm.test(norm)) {
          // Reconstruire en préservant la casse originale
          const re = new RegExp(`(${escapeRe(raw)})`, 'gi');
          const wrapped = child.textContent.replace(re, '<mark class="bib-hl">$1</mark>');
          const frag = document.createRange().createContextualFragment(wrapped);
          child.replaceWith(frag);
        }
      } else if (child.nodeType === Node.ELEMENT_NODE && child.tagName !== 'MARK') {
        highlightNode(child, reNorm, raw);
      }
    });
  }

  /* ══ 4. DOM ══ */
  const clearBtn = document.getElementById('bib-search-clear');
  const status   = document.getElementById('bib-search-status');
  const emptyEl  = document.getElementById('bib-search-empty');
  const emptyMsg = document.getElementById('bib-empty-msg');
  const kbd      = document.getElementById('bib-search-kbd');
  if (!input) return;

  /* ══ 5. ÉTAT ══ */
  let activeQuery = '';

  /* ══ 6. RESET — restaure le DOM à l'état original ══ */
  function reset() {
    rows.forEach(r => {
      r.tr.classList.remove('bib-row-hidden');
      r.cEl.innerHTML = r.cHTML;
      if (r.pEl) r.pEl.innerHTML = r.pHTML;
      if (r.dEl) r.dEl.innerHTML = r.dHTML;
    });
    sections.forEach(s => s.classList.remove('bib-section-hidden'));
    emptyEl.hidden = true;
    status.textContent = '';
    clearBtn.hidden = true;
    if (kbd) kbd.hidden = false;
    activeQuery = '';
  }

  /* ══ 7. SEARCH ══ */
  function search(raw) {
    const q   = raw.trim();
    const qn  = normalise(q);

    // Toujours d'abord restaurer les HTML originaux
    rows.forEach(r => {
      r.cEl.innerHTML = r.cHTML;
      if (r.pEl) r.pEl.innerHTML = r.pHTML;
      if (r.dEl) r.dEl.innerHTML = r.dHTML;
    });

    if (!qn) { reset(); return; }

    clearBtn.hidden = false;
    if (kbd) kbd.hidden = true;
    activeQuery = q;

    let visibleCount = 0;

    rows.forEach(r => {
      const matches = r.cText.includes(qn)
                   || r.pText.includes(qn)
                   || r.dText.includes(qn);

      if (matches) {
        r.tr.classList.remove('bib-row-hidden');
        visibleCount++;
        // Highlight dans chaque cellule
        r.cEl.innerHTML = highlightHTML(r.cHTML, q);
        if (r.pEl) r.pEl.innerHTML = highlightHTML(r.pHTML, q);
        if (r.dEl) r.dEl.innerHTML = highlightHTML(r.dHTML, q);
      } else {
        r.tr.classList.add('bib-row-hidden');
      }
    });

    // Masquer les sections entières sans résultat visible
    sections.forEach(sec => {
      const hasVisible = sec.querySelector('tbody tr:not(.bib-row-hidden)');
      sec.classList.toggle('bib-section-hidden', !hasVisible);
    });

    // Statut
    if (visibleCount === 0) {
      emptyMsg.textContent = `Aucun résultat pour « ${q} ».`;
      emptyEl.hidden = false;
      status.textContent = '0 résultat';
    } else {
      emptyEl.hidden = true;
      status.textContent = visibleCount === 1 ? '1 résultat' : `${visibleCount} résultats`;
    }
  }

  /* ══ 8. ÉVÉNEMENTS ══ */
  input.addEventListener('input', e => search(e.target.value));

  clearBtn.addEventListener('click', () => {
    input.value = '';
    input.focus();
    reset();
  });

  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && input.value) {
      input.value = '';
      reset();
    }
    if ((e.key === '/' || (e.ctrlKey && e.key === 'k')) && document.activeElement !== input) {
      e.preventDefault();
      input.focus();
      input.select();
    }
  });

})();
</script>

</BaseLayout>
