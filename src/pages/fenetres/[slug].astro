---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const fenetres = await getCollection('fenetres');
  return fenetres.map(f => ({
    params: { slug: f.slug },
    props: { fenetre: f },
  }));
}

const { fenetre } = Astro.props;
const { Content } = await fenetre.render();

// Dialogue lié si défini
let dialogueLie = null;
if (fenetre.data.lien_dialogue) {
  try {
    dialogueLie = await getEntry('articles', fenetre.data.lien_dialogue);
  } catch(e) {}
}
---

<Base title={`${fenetre.data.personnage} — ${fenetre.data.heure} — Syncognie`}>
  <Header />

  <div class="page-wrap">

    <!-- ✦ RETOUR -->
    <a href="/fenetres" class="back">
      <span class="back-arrow">
        <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
      </span>
      Fenêtres
    </a>

    <article class="fenetre" style={`animation-delay: .1s`}>

      <!-- ✦ EN-TÊTE -->
      <header class="fenetre-header">

        <!-- Filigrane cadre de fenêtre -->
        <svg class="header-filigrane" viewBox="0 0 420 420" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect x="60" y="60" width="300" height="300" rx="4"
            stroke="#8b5e3c" stroke-width=".7" opacity=".1" class="f-breathe"/>
          <line x1="60" y1="210" x2="360" y2="210" stroke="#8b5e3c" stroke-width=".5" opacity=".08" class="f-breathe"/>
          <line x1="210" y1="60" x2="210" y2="360" stroke="#8b5e3c" stroke-width=".5" opacity=".08" class="f-breathe"/>
          <rect x="90" y="90" width="240" height="240" rx="3"
            stroke="#c4993a" stroke-width=".5" opacity=".08" class="f-breathe-slow"/>
          <path d="M60 90 L60 60 L90 60"   stroke="#c4993a" stroke-width="1.2" opacity=".2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M330 60 L360 60 L360 90" stroke="#c4993a" stroke-width="1.2" opacity=".2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M360 330 L360 360 L330 360" stroke="#c4993a" stroke-width="1.2" opacity=".2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M90 360 L60 360 L60 330" stroke="#c4993a" stroke-width="1.2" opacity=".2" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="210" cy="210" r="3"  fill="#8b5e3c" opacity=".15" class="f-pulse"/>
          <circle cx="210" cy="210" r="9"  fill="none" stroke="#8b5e3c" stroke-width=".6" opacity=".08" class="f-pulse"/>
        </svg>

        <div class="header-content">
          <p class="page-eyebrow">Fenêtre</p>
          <div class="fenetre-meta">
            <span class="fenetre-heure">{fenetre.data.heure}</span>
            <span class="meta-sep">·</span>
            <span class="fenetre-lieu">{fenetre.data.lieu}</span>
          </div>
          <h1>{fenetre.data.personnage}</h1>
        </div>

      </header>

      <!-- ✦ ORNEMENT SEUIL -->
      <div class="article-seuil">
        <div class="seuil-line seuil-line--left"></div>
        <svg class="seuil-svg" width="48" height="20" viewBox="0 0 48 20" fill="none" aria-hidden="true">
          <path d="M24 2 L38 10 L24 18 L10 10 Z" stroke="#8b5e3c" stroke-width="1" fill="none" opacity=".35"/>
          <line x1="24" y1="5"  x2="24" y2="15" stroke="#8b5e3c" stroke-width=".7" opacity=".25"/>
          <line x1="14" y1="10" x2="34" y2="10" stroke="#8b5e3c" stroke-width=".7" opacity=".25"/>
          <circle cx="24" cy="2"  r="1.2" fill="#8b5e3c" opacity=".4"/>
          <circle cx="38" cy="10" r="1.2" fill="#8b5e3c" opacity=".4"/>
          <circle cx="24" cy="18" r="1.2" fill="#8b5e3c" opacity=".4"/>
          <circle cx="10" cy="10" r="1.2" fill="#8b5e3c" opacity=".4"/>
          <line x1="0"  y1="10" x2="7"  y2="10" stroke="#8b5e3c" stroke-width=".7" opacity=".2" stroke-linecap="round"/>
          <line x1="41" y1="10" x2="48" y2="10" stroke="#8b5e3c" stroke-width=".7" opacity=".2" stroke-linecap="round"/>
        </svg>
        <div class="seuil-line"></div>
      </div>

      <!-- ✦ CONTENU -->
      <div class="contenu">
        <Content />
      </div>

      <!-- ✦ DIALOGUE LIÉ -->
      {dialogueLie && (
        <aside class="suite">
          <div class="suite-ornement">
            <div class="suite-line"></div>
            <span class="suite-glyph">✦</span>
            <div class="suite-line"></div>
          </div>
          <p class="suite-label">Ce moment continue ailleurs</p>
          <a href={`/articles/${dialogueLie.slug}`} class="suite-lien">
            <div class="suite-lien-inner">
              <span class="suite-eyebrow">Dialogue</span>
              <span class="suite-titre">{dialogueLie.data.title}</span>
            </div>
            <span class="suite-fleche">→</span>
          </a>
        </aside>
      )}

    </article>

    <!-- ✦ NAVIGATION BAS -->
    <nav class="nav-bas">
      <a href="/fenetres" class="nav-retour">
        <span class="back-arrow back-arrow--sm">
          <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
        </span>
        Toutes les fenêtres
      </a>
    </nav>

    <Footer />
  </div>

</Base>

<style>
  /* ── WRAP ── */
  .page-wrap {
    max-width: 660px;
    margin: 0 auto;
    padding: 0 1.75rem 5rem;
  }

  /* ── RETOUR ── */
  .back {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    padding: 2.5rem 0 2.75rem;
    font-family: 'Mulish', sans-serif;
    font-size: .6rem;
    font-weight: 700;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--ink-soft);
    text-decoration: none;
    opacity: 0;
    animation: rise .8s .05s ease forwards;
    transition: color .2s, gap .2s;
  }
  .back:hover { color: var(--accent); gap: .7rem; }

  .back-arrow {
    width: 18px; height: 18px;
    border: 1px solid var(--rule);
    border-radius: 3px;
    display: flex; align-items: center; justify-content: center;
    transition: border-color .2s, background .2s;
    flex-shrink: 0;
  }
  .back:hover .back-arrow { border-color: var(--accent); background: rgba(139,94,60,.06); }
  .back-arrow svg {
    width: 10px; height: 10px;
    stroke: currentColor; fill: none; stroke-width: 2;
    transition: transform .2s;
  }
  .back:hover .back-arrow svg { transform: translateX(-2px); }

  /* ── ARTICLE ── */
  .fenetre {
    opacity: 0;
    animation: rise .9s .15s ease forwards;
  }

  /* ── EN-TÊTE ── */
  .fenetre-header {
    position: relative;
    overflow: visible;
    padding: 1.5rem 0 2.5rem;
  }

  .header-filigrane {
    position: absolute;
    top: 50%;
    right: -80px;
    transform: translateY(-50%);
    width: 260px; height: 260px;
    pointer-events: none;
    z-index: 0;
  }

  @media (max-width: 600px) { .header-filigrane { display: none; } }

  .f-breathe      { animation: f-breathe 6s ease-in-out infinite; }
  .f-breathe-slow { animation: f-breathe 10s ease-in-out infinite; }
  .f-pulse        { animation: f-pulse 3s ease-in-out infinite; }

  @keyframes f-breathe {
    0%, 100% { opacity: 1; }
    50%       { opacity: .4; }
  }
  @keyframes f-pulse {
    0%, 100% { opacity: .15; transform: scale(1); }
    50%       { opacity: .4;  transform: scale(1.3); }
  }

  .header-content {
    position: relative;
    z-index: 1;
  }

  .page-eyebrow {
    font-family: 'Mulish', sans-serif;
    font-size: .6rem;
    font-weight: 300;
    letter-spacing: .32em;
    text-transform: uppercase;
    color: var(--accent);
    opacity: .7;
    margin-bottom: .75rem;
  }

  .fenetre-meta {
    display: flex;
    align-items: center;
    gap: .5rem;
    margin-bottom: .6rem;
  }

  .fenetre-heure {
    font-family: 'Mulish', sans-serif;
    font-size: .72rem;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .meta-sep {
    font-size: .7rem;
    color: var(--rule);
  }

  .fenetre-lieu {
    font-family: 'Mulish', sans-serif;
    font-size: .72rem;
    font-weight: 300;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  h1 {
    font-family: 'Libre Baskerville', serif;
    font-size: clamp(2rem, 5vw, 2.8rem);
    font-weight: 400;
    color: var(--ink);
    line-height: 1.15;
    letter-spacing: -.01em;
  }

  /* ── ORNEMENT SEUIL ── */
  .article-seuil {
    display: flex;
    align-items: center;
    gap: .75rem;
    margin-bottom: 2.5rem;
  }
  .seuil-svg { flex-shrink: 0; overflow: visible; }
  .seuil-line {
    flex: 1; height: 1px;
    background: linear-gradient(to right, var(--rule), transparent);
    opacity: .6;
  }
  .seuil-line--left {
    background: linear-gradient(to left, var(--rule), transparent);
  }

  /* ── CONTENU ── */
  .contenu {
    font-family: 'Libre Baskerville', serif;
    font-size: 1.05rem;
    line-height: 1.88;
    color: var(--ink-mid);
  }

  .contenu :global(p) {
    margin-bottom: 1.5em;
  }

  /* Paragraphes en italique seul → didascalies / pensées intérieures */
  .contenu :global(p:has(> em:only-child)),
  .contenu :global(p:has(> em:only-child) em) {
    font-family: 'Mulish', sans-serif;
    font-size: .92rem;
    font-weight: 300;
    font-style: italic;
    color: var(--ink-soft);
    line-height: 1.7;
  }

  .contenu :global(hr) {
    border: none;
    border-top: 1px solid var(--rule);
    margin: 2.5rem 0;
    opacity: .5;
  }

  /* ── DIALOGUE LIÉ ── */
  .suite {
    margin-top: 3.5rem;
  }

  .suite-ornement {
    display: flex;
    align-items: center;
    gap: .75rem;
    margin-bottom: 1.25rem;
  }
  .suite-line {
    flex: 1; height: 1px;
    background: var(--rule);
    opacity: .5;
  }
  .suite-glyph {
    font-size: .65rem;
    color: var(--accent);
    opacity: .5;
  }

  .suite-label {
    font-family: 'Mulish', sans-serif;
    font-size: .6rem;
    font-weight: 300;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--ink-soft);
    opacity: .6;
    margin-bottom: .75rem;
  }

  .suite-lien {
    display: flex;
    align-items: center;
    justify-content: space-between;
    text-decoration: none;
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--rule);
    border-left: 3px solid var(--accent);
    border-radius: 0 6px 6px 0;
    background: color-mix(in srgb, var(--accent) 3%, var(--bg, #f5f0e8));
    transition: background .2s, border-color .2s, box-shadow .2s;
  }

  .suite-lien:hover {
    background: color-mix(in srgb, var(--accent) 6%, var(--bg, #f5f0e8));
    border-color: color-mix(in srgb, var(--accent) 30%, var(--rule));
    box-shadow: 0 4px 16px color-mix(in srgb, var(--accent) 10%, transparent);
  }

  .suite-lien-inner {
    display: flex;
    flex-direction: column;
    gap: .3rem;
  }

  .suite-eyebrow {
    font-family: 'Mulish', sans-serif;
    font-size: .52rem;
    font-weight: 700;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--accent);
    opacity: .7;
  }

  .suite-titre {
    font-family: 'Libre Baskerville', serif;
    font-size: 1rem;
    font-weight: 400;
    color: var(--ink);
    line-height: 1.3;
  }

  .suite-fleche {
    font-family: 'Mulish', sans-serif;
    color: var(--accent);
    font-size: 1.1rem;
    flex-shrink: 0;
    transition: transform .2s;
  }
  .suite-lien:hover .suite-fleche { transform: translateX(5px); }

  /* ── NAV BAS ── */
  .nav-bas {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--rule);
    opacity: 0;
    animation: rise .8s .4s ease forwards;
  }

  .nav-retour {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    font-family: 'Mulish', sans-serif;
    font-size: .6rem;
    font-weight: 700;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--ink-soft);
    text-decoration: none;
    transition: color .2s, gap .2s;
  }
  .nav-retour:hover { color: var(--accent); gap: .7rem; }

  .back-arrow--sm {
    width: 16px; height: 16px;
    border: 1px solid var(--rule);
    border-radius: 3px;
    display: flex; align-items: center; justify-content: center;
    transition: border-color .2s, background .2s;
    flex-shrink: 0;
  }
  .nav-retour:hover .back-arrow--sm {
    border-color: var(--accent);
    background: rgba(139,94,60,.06);
  }
  .back-arrow--sm svg {
    width: 9px; height: 9px;
    stroke: currentColor; fill: none; stroke-width: 2;
    transition: transform .2s;
  }
  .nav-retour:hover .back-arrow--sm svg { transform: translateX(-2px); }

  /* ── ANIMATIONS ── */
  @keyframes rise {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 600px) {
    .page-wrap { padding: 0 1rem 4rem; }
    h1 { font-size: 1.9rem; }
  }
</style>
