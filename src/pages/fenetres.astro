---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const toutes = await getCollection('fenetres');
const vivantes = toutes.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const fantomes = [
  { personnage: 'Élodie',   heure: '21h47',       lieu: 'Chez elle',     amorce: 'Elle relit le même message depuis deux heures. Six mots. Elle sait exactement ce qu\'ils signifient.' },
  { personnage: 'Nathalie', heure: '6h14',         lieu: 'Chez elle',     amorce: 'Elle est debout avant tout le monde. Le café, le ciel qui pâlit. Et des mots qu\'elle aurait préféré ne pas avoir.' },
  { personnage: 'Rayan',    heure: '2h04',         lieu: 'Sa chambre',    amorce: 'Il parle à une IA à deux heures du matin. Pas parce qu\'il est seul. Parce que certaines choses se disent mieux sans témoin.' },
  { personnage: 'Isabelle', heure: 'Jeudi soir',   lieu: 'La cuisine',    amorce: 'Elle a tout préparé. Il a dit c\'est sympa.' },
  { personnage: 'Thomas',   heure: 'Samedi matin', lieu: 'Dans la rue',   amorce: 'Il est allé chercher le pain. Il pense à elle pendant tout le trajet.' },
];
---

<Base title="Fenêtres — Syncognie">
  <Header />

  <div class="page-wrap">

    <!-- ✦ EN-TÊTE -->
    <header class="page-header">

      <!-- Filigrane : cadre de fenêtre / regard -->
      <svg class="header-filigrane" viewBox="0 0 420 420" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <!-- Cadre extérieur -->
        <rect x="60" y="60" width="300" height="300" rx="4"
          stroke="#8b5e3c" stroke-width=".7" opacity=".12" class="f-breathe"/>
        <!-- Croisillon -->
        <line x1="60" y1="210" x2="360" y2="210" stroke="#8b5e3c" stroke-width=".5" opacity=".1" class="f-breathe"/>
        <line x1="210" y1="60" x2="210" y2="360" stroke="#8b5e3c" stroke-width=".5" opacity=".1" class="f-breathe"/>
        <!-- Cadre intérieur -->
        <rect x="90" y="90" width="240" height="240" rx="3"
          stroke="#c4993a" stroke-width=".5" opacity=".1" class="f-breathe-slow"/>
        <!-- Coins marqués -->
        <path d="M60 90 L60 60 L90 60"   stroke="#c4993a" stroke-width="1.2" opacity=".22" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M330 60 L360 60 L360 90" stroke="#c4993a" stroke-width="1.2" opacity=".22" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M360 330 L360 360 L330 360" stroke="#c4993a" stroke-width="1.2" opacity=".22" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M90 360 L60 360 L60 330" stroke="#c4993a" stroke-width="1.2" opacity=".22" stroke-linecap="round" stroke-linejoin="round"/>
        <!-- Point focal central -->
        <circle cx="210" cy="210" r="3"  fill="#8b5e3c" opacity=".2" class="f-pulse"/>
        <circle cx="210" cy="210" r="8"  fill="none" stroke="#8b5e3c" stroke-width=".6" opacity=".1" class="f-pulse"/>
        <circle cx="210" cy="210" r="20" fill="none" stroke="#c4993a" stroke-width=".4" opacity=".08" class="f-breathe-slow"/>
        <!-- Lignes de regard -->
        <line x1="210" y1="210" x2="90"  y2="90"  stroke="#c4993a" stroke-width=".4" opacity=".08"/>
        <line x1="210" y1="210" x2="330" y2="90"  stroke="#c4993a" stroke-width=".4" opacity=".08"/>
        <line x1="210" y1="210" x2="330" y2="330" stroke="#c4993a" stroke-width=".4" opacity=".08"/>
        <line x1="210" y1="210" x2="90"  y2="330" stroke="#c4993a" stroke-width=".4" opacity=".08"/>
      </svg>

      <p class="page-eyebrow">Fenêtres</p>
      <h1 class="page-titre">Des instants ordinaires.<br><em>Ce qui se passe à l'intérieur.</em></h1>
      <p class="page-sous">Chaque fenêtre ouvre sur un moment précis dans une vie. Aucun concept nommé. Juste ce qui est là — et ce que ça fait.</p>

      <div class="page-stats">
        <span class="stat">
          <span class="stat-n">{vivantes.length}</span>
          <span class="stat-label">ouvert{vivantes.length > 1 ? 'es' : 'e'}</span>
        </span>
        <span class="stat-sep">·</span>
        <span class="stat">
          <span class="stat-n">{fantomes.length}</span>
          <span class="stat-label">à venir</span>
        </span>
      </div>

    </header>

    <!-- ✦ FENÊTRES VIVANTES -->
    {vivantes.length > 0 && (
      <>
        <div class="ornament-sep">
          <div class="orn-line"></div>
          <div class="orn-centre">
            <div class="orn-diamond"></div>
            <span class="orn-label">Ouvertes</span>
            <div class="orn-diamond"></div>
          </div>
          <div class="orn-line"></div>
        </div>

        <div class="fenetres-grille">
          {vivantes.map((f, i) => (
            <a
              href={`/fenetres/${f.slug}`}
              class="fenetre-card fenetre-card--vive"
              style={`animation-delay:${0.15 + i * 0.1}s`}
            >
              <div class="fenetre-card-top">
                <div class="fenetre-card-temps">
                  <span class="fenetre-heure">{f.data.heure}</span>
                  <span class="fenetre-sep">·</span>
                  <span class="fenetre-lieu">{f.data.lieu}</span>
                </div>
                <span class="fenetre-badge">Lire</span>
              </div>
              <h2 class="fenetre-personnage">{f.data.personnage}</h2>
              <p class="fenetre-amorce">{f.data.amorce ?? f.data.description}</p>
              <span class="fenetre-cta">Ouvrir la fenêtre →</span>
            </a>
          ))}
        </div>
      </>
    )}

    <!-- ✦ FENÊTRES FANTÔMES -->
    <div class="ornament-sep ornament-sep--mid">
      <div class="orn-line"></div>
      <div class="orn-centre">
        <div class="orn-diamond"></div>
        <span class="orn-label">En préparation</span>
        <div class="orn-diamond"></div>
      </div>
      <div class="orn-line"></div>
    </div>

    <div class="fenetres-grille fenetres-grille--fantome">
      {fantomes.map((f, i) => (
        <div
          class="fenetre-card fenetre-card--fantome"
          style={`animation-delay:${0.3 + i * 0.07}s`}
        >
          <div class="fenetre-card-top">
            <div class="fenetre-card-temps">
              <span class="fenetre-heure">{f.heure}</span>
              <span class="fenetre-sep">·</span>
              <span class="fenetre-lieu">{f.lieu}</span>
            </div>
            <span class="fenetre-badge fenetre-badge--soon">Bientôt</span>
          </div>
          <h2 class="fenetre-personnage">{f.personnage}</h2>
          <p class="fenetre-amorce">{f.amorce}</p>
        </div>
      ))}
    </div>

    <!-- ✦ NOTE DE BAS -->
    <div class="fenetres-note">
      <div class="note-dot"></div>
      <p>Les fenêtres naissent des dialogues — chaque personnage rencontré en terrasse continue d'exister la nuit.</p>
    </div>

  </div>

  <Footer />
</Base>

<style>
  .page-wrap {
    max-width: var(--max);
    margin: 0 auto;
    padding: 0 1.75rem 5rem;
  }

  /* ── EN-TÊTE ── */
  .page-header {
    padding: 4rem 0 2.5rem;
    position: relative;
    overflow: visible;
    opacity: 0;
    animation: rise .9s .05s ease forwards;
  }

  .page-eyebrow {
    font-family: 'Mulish', sans-serif;
    font-size: .6rem;
    font-weight: 300;
    letter-spacing: .32em;
    text-transform: uppercase;
    color: var(--accent);
    opacity: .7;
    margin-bottom: 1rem;
    position: relative;
    z-index: 1;
  }

  .page-titre {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: clamp(1.7rem, 3.5vw, 2.4rem);
    font-weight: 400;
    color: var(--ink);
    line-height: 1.2;
    letter-spacing: -.01em;
    margin-bottom: .9rem;
    position: relative;
    z-index: 1;
  }

  .page-titre em {
    font-style: italic;
    color: var(--accent);
  }

  .page-sous {
    font-family: 'Mulish', sans-serif;
    font-size: .95rem;
    font-weight: 300;
    color: var(--ink-soft);
    line-height: 1.8;
    max-width: 52ch;
    margin-bottom: 1.5rem;
    position: relative;
    z-index: 1;
  }

  .page-stats {
    display: flex;
    align-items: baseline;
    gap: .75rem;
    position: relative;
    z-index: 1;
  }

  .stat { display: flex; align-items: baseline; gap: .35rem; }

  .stat-n {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
    letter-spacing: -.02em;
  }

  .stat-label {
    font-family: 'Mulish', sans-serif;
    font-size: .62rem;
    font-weight: 300;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  .stat-sep { color: var(--rule); font-size: .9rem; }

  /* ── FILIGRANE ── */
  .header-filigrane {
    position: absolute;
    top: 50%;
    right: -60px;
    transform: translateY(-50%);
    width: 300px;
    height: 300px;
    pointer-events: none;
    z-index: 0;
  }

  @media (max-width: 600px) { .header-filigrane { display: none; } }

  .f-breathe      { animation: f-breathe 6s ease-in-out infinite; }
  .f-breathe-slow { animation: f-breathe 10s ease-in-out infinite; }
  .f-pulse        { animation: f-pulse 3s ease-in-out infinite; }

  @keyframes f-breathe {
    0%, 100% { opacity: 1; }
    50%       { opacity: .5; }
  }
  @keyframes f-pulse {
    0%, 100% { opacity: .2; transform: scale(1); }
    50%       { opacity: .5; transform: scale(1.3); }
  }

  /* ── SÉPARATEURS ── */
  .ornament-sep {
    display: flex;
    align-items: center;
    gap: 1rem;
    opacity: 0;
    animation: rise .9s .2s ease forwards;
  }
  .ornament-sep--mid {
    margin: 2.5rem 0 0;
    animation-delay: .35s;
  }
  .orn-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--rule), transparent);
  }
  .orn-centre { display: flex; align-items: center; gap: .55rem; }
  .orn-diamond {
    width: 5px; height: 5px;
    background: var(--rule);
    transform: rotate(45deg);
  }
  .orn-label {
    font-family: 'Mulish', sans-serif;
    font-size: .58rem;
    font-weight: 700;
    letter-spacing: .25em;
    text-transform: uppercase;
    color: var(--ink-soft);
    opacity: .45;
  }

  /* ── GRILLE ── */
  .fenetres-grille {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.1rem;
    margin-top: 1.5rem;
    opacity: 0;
    animation: rise .9s .25s ease forwards;
  }

  .fenetres-grille--fantome {
    animation-delay: .4s;
  }

  @media (max-width: 580px) {
    .fenetres-grille { grid-template-columns: 1fr; }
  }

  /* ── CARTE FENÊTRE ── */
  .fenetre-card {
    border: 1px solid var(--rule);
    border-radius: 8px;
    padding: 1.35rem 1.35rem 1.1rem;
    background: rgba(245, 240, 232, .4);
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    transition: box-shadow .22s, transform .22s, border-color .22s;
  }

  /* Barre supérieure terracotta */
  .fenetre-card--vive::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--accent);
    border-radius: 8px 8px 0 0;
    opacity: .6;
    transition: height .2s, opacity .2s;
  }

  .fenetre-card--vive {
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    background: color-mix(in srgb, var(--accent) 3%, var(--bg, #f5f0e8));
  }

  .fenetre-card--vive:hover {
    box-shadow: 0 6px 24px color-mix(in srgb, var(--accent) 12%, transparent);
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--accent) 28%, var(--rule));
  }

  .fenetre-card--vive:hover::before {
    height: 3px;
    opacity: 1;
  }

  .fenetre-card--vive:hover .fenetre-cta {
    opacity: 1;
    transform: translateX(0);
  }

  /* Fantôme */
  .fenetre-card--fantome {
    opacity: .35;
    filter: grayscale(.3);
    cursor: default;
  }

  /* Contenu */
  .fenetre-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: .9rem;
  }

  .fenetre-card-temps {
    display: flex;
    align-items: center;
    gap: .4rem;
  }

  .fenetre-heure {
    font-family: 'Mulish', sans-serif;
    font-size: .62rem;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .fenetre-sep {
    font-size: .7rem;
    color: var(--rule);
  }

  .fenetre-lieu {
    font-family: 'Mulish', sans-serif;
    font-size: .62rem;
    font-weight: 300;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  .fenetre-badge {
    font-family: 'Mulish', sans-serif;
    font-size: .52rem;
    font-weight: 700;
    letter-spacing: .16em;
    text-transform: uppercase;
    padding: .18rem .48rem;
    border-radius: 3px;
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    color: var(--accent);
    border: 1px solid color-mix(in srgb, var(--accent) 26%, transparent);
  }

  .fenetre-badge--soon {
    background: rgba(154, 145, 137, .07);
    color: var(--ink-soft);
    border-color: var(--rule);
  }

  .fenetre-personnage {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--ink);
    line-height: 1.2;
    margin-bottom: .55rem;
    letter-spacing: -.01em;
  }

  .fenetre-amorce {
    font-family: 'Mulish', sans-serif;
    font-size: .82rem;
    font-weight: 300;
    color: var(--ink-mid);
    line-height: 1.7;
    font-style: italic;
    flex: 1;
    margin-bottom: .85rem;
  }

  .fenetre-cta {
    display: inline-flex;
    align-items: center;
    font-family: 'Mulish', sans-serif;
    font-size: .6rem;
    font-weight: 600;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--accent);
    opacity: 0;
    transform: translateX(-3px);
    transition: opacity .2s, transform .2s;
    margin-top: auto;
  }

  /* ── NOTE ── */
  .fenetres-note {
    display: flex;
    align-items: flex-start;
    gap: .75rem;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--rule);
  }

  .note-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
    margin-top: .3rem;
    animation: pulse 2s ease-in-out infinite;
  }

  .fenetres-note p {
    font-family: 'Mulish', sans-serif;
    font-size: .82rem;
    font-weight: 300;
    color: var(--ink-soft);
    line-height: 1.7;
    font-style: italic;
  }

  /* ── ANIMATIONS ── */
  @keyframes rise {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%       { opacity: .3; }
  }
</style>
