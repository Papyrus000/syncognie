---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Base title="À propos — Syncognie">
  <Header />
  <div class="page-wrap">
    <header class="page-header">

      <svg class="header-filigrane" viewBox="0 0 420 420" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <line x1="210" y1="30" x2="210" y2="390" stroke="#8b5e3c" stroke-width=".5" opacity=".1"/>
        <path d="M210 50 C160 80, 260 120, 210 150 C160 180, 260 220, 210 250 C160 280, 260 320, 210 350"
              stroke="#c4993a" stroke-width="1.2" stroke-linecap="round" opacity=".25" class="helix-a"/>
        <path d="M210 50 C260 80, 160 120, 210 150 C260 180, 160 220, 210 250 C260 280, 160 320, 210 350"
              stroke="#8b5e3c" stroke-width="1.2" stroke-linecap="round" opacity=".2" class="helix-b"/>
        <line x1="160" y1="100" x2="260" y2="100" stroke="#c4993a" stroke-width=".6" opacity=".15"/>
        <line x1="160" y1="200" x2="260" y2="200" stroke="#c4993a" stroke-width=".6" opacity=".15"/>
        <line x1="160" y1="300" x2="260" y2="300" stroke="#c4993a" stroke-width=".6" opacity=".15"/>
        <circle cx="210" cy="150" r="4.5" fill="#c4993a" opacity=".3" class="noeud-pulse"/>
        <circle cx="210" cy="250" r="4.5" fill="#8b5e3c" opacity=".25" class="noeud-pulse-2"/>
        <circle cx="210" cy="50"  r="3"   fill="#c4993a" opacity=".2"  class="noeud-pulse"/>
        <circle cx="210" cy="350" r="3"   fill="#8b5e3c" opacity=".2"  class="noeud-pulse-2"/>
        <circle cx="210" cy="200" r="175" stroke="#8b5e3c" stroke-width=".4" stroke-dasharray="3 12" opacity=".08" class="helix-halo"/>
        <circle cx="210" cy="200" r="130" stroke="#c4993a" stroke-width=".3" stroke-dasharray="2 14" opacity=".07" class="helix-halo-2"/>
      </svg>

      <p class="page-eyebrow">Le laboratoire</p>
      <h1 class="page-titre">À propos de Syncognie</h1>
      <p class="page-sous">Un espace vivant, imparfait et curieux — entre carnet de bord et laboratoire cognitif.</p>
    </header>

    <!-- ── L'ORIGINE ── -->
    <div class="ornament-sep"><div class="orn-line"></div><div class="orn-centre"><div class="orn-diamond"></div><span class="orn-label">L'origine</span><div class="orn-diamond"></div></div><div class="orn-line"></div></div>

    <section class="section-deux-col">
      <div class="col-texte">
        <p class="texte-chapeau">Un curieux qui essaie de comprendre le monde qui l'entoure.</p>
        <p class="texte-corps">Les comportements, les situations, ce qui se passe vraiment sous la surface. Pourquoi on fait ce qu'on fait. Pourquoi on continue ce qui ne satisfait plus. Pourquoi certaines choses tiennent et d'autres s'effondrent.</p>
        <p class="texte-corps">Avec pour compagnons tous ceux qui ont pensé avant — philosophes, neuroscientifiques, romanciers, théoriciens des systèmes. Pas pour trouver des réponses définitives. Pour affiner les questions.</p>
        <p class="texte-corps">Le nom est une invention : <em>syn</em> pour la synergie, <em>cognie</em> pour la cognition. La conviction que les grandes idées se rejoignent — que ce qui vaut pour un cerveau vaut souvent pour un système social, et que les penseurs d'horizons différents parlent parfois le même langage sans le savoir.</p>
      </div>
      <div class="col-encart">
        <div class="encart-etymologie">
          <p class="encart-label">Étymologie inventée</p>
          <div class="etym-ligne"><span class="etym-mot">syn·</span><span class="etym-def">synergie — l'union qui amplifie</span></div>
          <div class="etym-sep"></div>
          <div class="etym-ligne"><span class="etym-mot">·cognie</span><span class="etym-def">cognition — la pensée en acte</span></div>
          <div class="etym-sep"></div>
          <div class="etym-ligne etym-ligne--result"><span class="etym-mot etym-mot--full">Syncognie</span><span class="etym-def">penser ensemble, autrement</span></div>
        </div>
      </div>
    </section>

    <!-- ── COMMENT ÇA FONCTIONNE ── -->
    <div class="ornament-sep ornament-sep--mid"><div class="orn-line"></div><div class="orn-centre"><div class="orn-diamond"></div><span class="orn-label">Comment ça fonctionne</span><div class="orn-diamond"></div></div><div class="orn-line"></div></div>

    <section class="section-niveaux">
      <p class="niveaux-intro">Syncognie est organisé en trois niveaux — trois façons d'entrer dans une même idée, selon où on en est.</p>
      <div class="niveaux-grille">
        <div class="niveau-carte niveau-carte--1">
          <div class="niveau-num">1</div>
          <div class="niveau-corps">
            <p class="niveau-label">Les Fenêtres</p>
            <p class="niveau-texte">Des scènes courtes. Un personnage, une heure, 200 mots. Rayan à 2h du matin. Nathalie à 6h14. On entre par la reconnaissance — pas besoin de connaître Berridge pour se reconnaître dans un geste.</p>
            <a href="/fenetres" class="niveau-lien">Voir les fenêtres →</a>
          </div>
        </div>
        <div class="niveau-carte niveau-carte--2">
          <div class="niveau-num">2</div>
          <div class="niveau-corps">
            <p class="niveau-label">Les Dialogues</p>
            <p class="niveau-texte">Élodie apporte un livre. Nathalie apporte sa vie. Quelque chose émerge entre les deux. C'est là que les auteurs arrivent — pas comme références à citer, mais comme outils qui tombent au bon moment.</p>
            <a href="/articles" class="niveau-lien">Lire les dialogues →</a>
          </div>
        </div>
        <div class="niveau-carte niveau-carte--3">
          <div class="niveau-num">3</div>
          <div class="niveau-corps">
            <p class="niveau-label">Les Analyses</p>
            <p class="niveau-texte">Pour ceux qui veulent aller plus loin. Les mécanismes expliqués, les auteurs présentés, les liens entre les idées tracés rigoureusement. Chaque analyse est liée à une fenêtre — elle a un point de départ narratif, pas abstrait.</p>
            <a href="/articles" class="niveau-lien">Lire les analyses →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ── LA MÉTHODE ── -->
    <div class="ornament-sep ornament-sep--mid"><div class="orn-line"></div><div class="orn-centre"><div class="orn-diamond"></div><span class="orn-label">La méthode</span><div class="orn-diamond"></div></div><div class="orn-line"></div></div>

    <section class="section-blocs">
      <div class="bloc-methode">
        <div class="bloc-icone">✦</div>
        <div class="bloc-corps">
          <p class="bloc-label">Hypothèses, pas vérités</p>
          <p class="bloc-texte">Chaque article est une expérience. Pas de certitudes définitives — des hypothèses testées, des concepts explorés, des liens tracés entre des phénomènes qui semblent sans rapport. Le lecteur est invité à questionner, pas à suivre.</p>
        </div>
      </div>
      <div class="bloc-methode">
        <div class="bloc-icone">◈</div>
        <div class="bloc-corps">
          <p class="bloc-label">Le jardin numérique</p>
          <p class="bloc-texte">Les notes ici ne sont pas publiées, elles sont plantées. Elles germent, poussent, se ramifient. Certaines restent des graines longtemps. C'est voulu — montrer la pensée en train de se faire est une forme d'honnêteté.</p>
          <a href="/stades" class="bloc-lien">Comprendre les stades →</a>
        </div>
      </div>
      <div class="bloc-methode">
        <div class="bloc-icone">⊗</div>
        <div class="bloc-corps">
          <p class="bloc-label">Ce que ce n'est pas</p>
          <p class="bloc-texte">Pas un blog médical. Pas un manuel scientifique. Pas de vérité absolue. Les contenus ici n'ont aucune valeur médicale et ne remplacent pas un avis professionnel. C'est le carnet d'un curieux — rien de plus, et peut-être rien de moins.</p>
        </div>
      </div>
    </section>

    <!-- ── EXPLORER ── -->
    <div class="ornament-sep ornament-sep--mid"><div class="orn-line"></div><div class="orn-centre"><div class="orn-diamond"></div><span class="orn-label">Explorer</span><div class="orn-diamond"></div></div><div class="orn-line"></div></div>

    <section class="section-portails">
      <a href="/fenetres" class="portail portail--fenetres"><div class="portail-dot"></div><div class="portail-corps"><p class="portail-label">Fenêtres</p><p class="portail-desc">Des instants ordinaires. L'entrée la plus directe dans le corpus.</p></div><span class="portail-cta">Entrer →</span></a>
      <a href="/articles" class="portail portail--articles"><div class="portail-dot"></div><div class="portail-corps"><p class="portail-label">Articles</p><p class="portail-desc">Dialogues, récits et analyses — la pensée en construction.</p></div><span class="portail-cta">Lire →</span></a>
      <a href="/outils"   class="portail portail--outils"><div class="portail-dot"></div><div class="portail-corps"><p class="portail-label">Outils</p><p class="portail-desc">Des instruments pratiques nés des articles.</p></div><span class="portail-cta">Explorer →</span></a>
      <a href="/carte"    class="portail portail--carte"><div class="portail-dot"></div><div class="portail-corps"><p class="portail-label">Carte</p><p class="portail-desc">La topographie des idées — naviguer par concept.</p></div><span class="portail-cta">Naviguer →</span></a>
    </section>

    <div class="note-vivante"><div class="note-dot"></div><p>Cette page continue de s'écrire — comme le reste.</p></div>
  </div>
  <Footer />
</Base>

<style>
  .page-wrap{max-width:var(--max);margin:0 auto;padding:0 1.75rem 5rem}
  .page-header{padding:4rem 0 2.5rem;position:relative;overflow:visible;opacity:0;animation:rise .9s .05s ease forwards}
  .page-eyebrow{font-family:'Mulish',sans-serif;font-size:.6rem;font-weight:300;letter-spacing:.32em;text-transform:uppercase;color:var(--accent);opacity:.7;margin-bottom:1rem;position:relative;z-index:1}
  .page-titre{font-size:clamp(1.8rem,3.5vw,2.4rem);font-weight:700;color:var(--ink);line-height:1.15;letter-spacing:-.02em;margin-bottom:.9rem;position:relative;z-index:1}
  .page-sous{font-family:'Mulish',sans-serif;font-size:.95rem;font-weight:400;color:var(--ink-soft);line-height:1.8;max-width:48ch;position:relative;z-index:1}

  /* ── FILIGRANE HÉLICE ── */
  .header-filigrane{position:absolute;top:50%;right:-60px;transform:translateY(-50%);width:300px;height:300px;pointer-events:none;z-index:0}
  @media(max-width:600px){.header-filigrane{display:none}}
  .helix-a{animation:helix-breathe 7s ease-in-out infinite}
  .helix-b{animation:helix-breathe 7s ease-in-out infinite;animation-delay:3.5s}
  @keyframes helix-breathe{0%,100%{opacity:.25}50%{opacity:.45}}
  .noeud-pulse  {animation:np 5s ease-in-out infinite}
  .noeud-pulse-2{animation:np 5s ease-in-out infinite;animation-delay:2.5s}
  @keyframes np{0%,100%{opacity:.2;r:3.5}50%{opacity:.55;r:5.5}}
  .helix-halo  {animation:hh 20s linear infinite;transform-origin:210px 200px}
  .helix-halo-2{animation:hh 30s linear infinite reverse;transform-origin:210px 200px}
  @keyframes hh{to{transform:rotate(360deg)}}

  /* Séparateurs */
  .ornament-sep{display:flex;align-items:center;gap:1rem;opacity:0;animation:rise .9s .2s ease forwards}
  .ornament-sep--mid{margin:3rem 0 0;animation-delay:.3s}
  .orn-line{flex:1;height:1px;background:linear-gradient(to right,transparent,var(--rule),transparent)}
  .orn-centre{display:flex;align-items:center;gap:.55rem}
  .orn-diamond{width:5px;height:5px;background:var(--rule);transform:rotate(45deg)}
  .orn-label{font-family:'Mulish',sans-serif;font-size:.58rem;font-weight:700;letter-spacing:.25em;text-transform:uppercase;color:var(--ink-soft);opacity:.45}

  /* Deux colonnes */
  .section-deux-col{display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:start;padding:2.5rem 0 0;opacity:0;animation:rise .9s .25s ease forwards}
  @media(max-width:580px){.section-deux-col{grid-template-columns:1fr;gap:1.5rem}}
  .texte-chapeau{font-family:'Libre Baskerville',Georgia,serif;font-size:1.05rem;font-weight:400;font-style:italic;color:var(--accent);line-height:1.55;margin-bottom:1.2rem}
  .texte-corps{font-family:'Mulish',sans-serif;font-size:.88rem;font-weight:400;color:var(--ink-soft);line-height:1.85;margin-bottom:.9rem}
  .texte-corps:last-child{margin-bottom:0}
  .texte-corps em{font-style:italic;color:var(--accent)}
  .encart-etymologie{padding:1.5rem;border:1px solid rgba(196,153,58,.2);border-radius:6px;background:rgba(196,153,58,.04)}
  .encart-label{font-family:'Mulish',sans-serif;font-size:.55rem;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:var(--gold,#c4993a);opacity:.7;margin-bottom:1rem;padding-bottom:.65rem;border-bottom:1px solid rgba(196,153,58,.15)}
  .etym-ligne{display:flex;flex-direction:column;gap:.2rem;padding:.55rem 0}
  .etym-ligne--result{padding-top:.7rem}
  .etym-sep{height:1px;background:rgba(196,153,58,.1)}
  .etym-mot{font-family:'Libre Baskerville',Georgia,serif;font-size:1rem;font-weight:700;color:var(--ink)}
  .etym-mot--full{color:var(--gold,#c4993a);font-size:1.1rem}
  .etym-def{font-family:'Mulish',sans-serif;font-size:.72rem;font-weight:300;font-style:italic;color:var(--ink-soft);opacity:.8}

  /* Blocs méthode */
  .section-blocs{display:flex;flex-direction:column;padding-top:2rem;opacity:0;animation:rise .9s .35s ease forwards}
  .bloc-methode{display:flex;gap:1.5rem;align-items:flex-start;padding:1.75rem 0;border-bottom:1px solid var(--rule)}
  .bloc-methode:last-child{border-bottom:none}
  .bloc-icone{font-size:.9rem;color:var(--gold,#c4993a);opacity:.5;flex-shrink:0;margin-top:.15rem;width:1.2rem;text-align:center}
  .bloc-label{font-family:'Mulish',sans-serif;font-size:.62rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--ink-mid);margin-bottom:.6rem;opacity:.8}
  .bloc-texte{font-family:'Mulish',sans-serif;font-size:.88rem;font-weight:400;color:var(--ink-soft);line-height:1.8;margin-bottom:.6rem}
  .bloc-texte:last-child{margin-bottom:0}
  .bloc-lien{display:inline-flex;align-items:center;font-family:'Mulish',sans-serif;font-size:.62rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--blizzard,#148EFF);text-decoration:none;transition:opacity .2s,transform .2s}
  .bloc-lien:hover{opacity:.7;transform:translateX(2px)}

  /* Portails */
  .section-portails{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;padding-top:2rem;opacity:0;animation:rise .9s .45s ease forwards}
  @media(max-width:760px){.section-portails{grid-template-columns:repeat(2,1fr)}}
  @media(max-width:480px){.section-portails{grid-template-columns:1fr}}
  .portail{display:flex;flex-direction:column;gap:.6rem;padding:1.1rem;border:1px solid var(--rule);border-radius:6px;background:rgba(245,240,232,.5);text-decoration:none;color:inherit;position:relative;overflow:hidden;transition:transform .22s,box-shadow .22s,border-color .22s}
  .portail::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;border-radius:6px 6px 0 0}
  .portail--articles::before{background:#6b7fb8}
  .portail--outils::before{background:var(--orange,#e8724a)}
  .portail--stades::before{background:#2e7d4e}
  .portail--fenetres::before{background:#8b6fc4}
  .portail--carte::before{background:#c4993a}
  .portail:hover{transform:translateY(-2px);box-shadow:0 5px 16px rgba(44,36,22,.08)}
  .portail--articles:hover{border-color:rgba(107,127,184,.28)}
  .portail--outils:hover{border-color:rgba(232,114,74,.28)}
  .portail--stades:hover{border-color:rgba(46,125,78,.28)}
  .portail--fenetres:hover{border-color:rgba(139,111,196,.28)}
  .portail--carte:hover{border-color:rgba(196,153,58,.28)}
  .portail-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
  .portail--articles .portail-dot{background:#6b7fb8}
  .portail--outils   .portail-dot{background:var(--orange,#e8724a)}
  .portail--stades   .portail-dot{background:#2e7d4e}
  .portail--fenetres .portail-dot{background:#8b6fc4}
  .portail--carte    .portail-dot{background:#c4993a}

  /* ── SECTION NIVEAUX ── */
  .section-niveaux{padding-top:2rem;opacity:0;animation:rise .9s .3s ease forwards}
  .niveaux-intro{font-family:'Mulish',sans-serif;font-size:.9rem;font-weight:400;color:var(--ink-soft);line-height:1.8;max-width:58ch;margin-bottom:1.75rem}
  .niveaux-grille{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem}
  @media(max-width:680px){.niveaux-grille{grid-template-columns:1fr}}
  .niveau-carte{padding:1.4rem;border:1px solid var(--rule);border-radius:6px;position:relative;overflow:hidden;transition:transform .2s,box-shadow .2s}
  .niveau-carte:hover{transform:translateY(-2px);box-shadow:0 5px 16px rgba(44,36,22,.07)}
  .niveau-carte--1{border-top:3px solid #8b6fc4}
  .niveau-carte--2{border-top:3px solid #c4993a}
  .niveau-carte--3{border-top:3px solid #6b7fb8}
  .niveau-num{font-family:'Libre Baskerville',Georgia,serif;font-size:2rem;font-weight:700;line-height:1;margin-bottom:.75rem;opacity:.12;color:var(--ink)}
  .niveau-carte--1 .niveau-num{color:#8b6fc4;opacity:.25}
  .niveau-carte--2 .niveau-num{color:#c4993a;opacity:.25}
  .niveau-carte--3 .niveau-num{color:#6b7fb8;opacity:.25}
  .niveau-label{font-family:'Mulish',sans-serif;font-size:.65rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;margin-bottom:.65rem}
  .niveau-carte--1 .niveau-label{color:#8b6fc4}
  .niveau-carte--2 .niveau-label{color:#c4993a}
  .niveau-carte--3 .niveau-label{color:#6b7fb8}
  .niveau-texte{font-family:'Mulish',sans-serif;font-size:.82rem;font-weight:300;color:var(--ink-soft);line-height:1.75;margin-bottom:.9rem}
  .niveau-lien{display:inline-flex;align-items:center;font-family:'Mulish',sans-serif;font-size:.6rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--blizzard,#148EFF);text-decoration:none;transition:opacity .2s,transform .2s}
  .niveau-lien:hover{opacity:.7;transform:translateX(2px)}
  .portail-label{font-family:'Mulish',sans-serif;font-size:.68rem;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--ink-mid)}
  .portail-desc{font-family:'Mulish',sans-serif;font-size:.75rem;font-weight:300;color:var(--ink-soft);line-height:1.6;flex:1}
  .portail-cta{font-family:'Mulish',sans-serif;font-size:.6rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--blizzard,#148EFF);opacity:0;transform:translateX(-3px);transition:opacity .2s,transform .2s}
  .portail:hover .portail-cta{opacity:1;transform:translateX(0)}

  /* Note vivante */
  .note-vivante{display:flex;align-items:center;gap:.75rem;margin-top:3rem;padding:1rem 1.25rem;border:1px solid var(--rule);border-radius:6px;background:rgba(26,23,20,.02);opacity:0;animation:rise .9s .55s ease forwards}
  .note-dot{width:6px;height:6px;border-radius:50%;background:var(--accent);flex-shrink:0;animation:pulse 2s ease-in-out infinite}
  @keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
  .note-vivante p{font-family:'Mulish',sans-serif;font-size:.8rem;font-weight:300;color:var(--ink-soft);font-style:italic}
  @keyframes rise{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
</style>
