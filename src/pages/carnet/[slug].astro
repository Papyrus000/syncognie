---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import '../../styles/carnet.css';

export async function getStaticPaths() {
  const notes = await getCollection('carnet');
  return notes.map(note => ({
    params: { slug: note.slug },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await note.render();

const date = note.data.date.toLocaleDateString('fr-FR', {
  day: 'numeric', month: 'long', year: 'numeric'
});

const wordCount = note.body.split(/\s+/).length;
const readTime  = Math.max(1, Math.round(wordCount / 170));

// Config des types
const TYPE_CONFIG: Record<string, { label: string; couleur: string; glyph: string }> = {
  dialogue: { label: 'Dialogue', couleur: '#ea580c', glyph: '◈' },
  note:     { label: 'Note',     couleur: '#b45309', glyph: '◇' },
  essai:    { label: 'Essai',    couleur: '#8b5e3c', glyph: '◉' },
  fragment: { label: 'Fragment', couleur: '#9a7a5a', glyph: '◌' },
};
const typeCfg = TYPE_CONFIG[note.data.type ?? 'note'] ?? TYPE_CONFIG['note'];

// Stade de maturité
const stadeConfig: Record<string, { emoji: string; label: string; color: string }> = {
  graine: { emoji: '🌱', label: 'Graine', color: '#2e7d4e' },
  pousse: { emoji: '🌿', label: 'Pousse', color: '#38783c' },
  arbre:  { emoji: '🌳', label: 'Arbre',  color: '#224422' },
};
const stadeInfo = note.data.stade ? stadeConfig[note.data.stade] : null;

// Navigation entre notes (par date)
const toutesNotes = await getCollection('carnet');
const parDate = [...toutesNotes].sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const idx       = parDate.findIndex(n => n.slug === note.slug);
const precedent = idx < parDate.length - 1 ? parDate[idx + 1] : null;
const suivant   = idx > 0                  ? parDate[idx - 1]  : null;

// Numéro de la note (ordre chronologique, la plus ancienne = 01)
const numNote = parDate.length - idx;

// Indicateur engagement
const engagementRank: Record<string, number> = { pause: 1, lecture: 2, immersion: 3 };
const eng = engagementRank[note.data.engagement ?? ''] ?? 0;
---

<Base title={`${note.data.title} — Carnet · Syncognie`}>

<div class="progress-bar" id="progress" aria-hidden="true"></div>

<div class="wrap">

  <!-- Fil d'Ariane -->
  <nav class="breadcrumb" aria-label="Fil d'Ariane">
    <a href="/" class="breadcrumb-link">Accueil</a>
    <span class="breadcrumb-sep" aria-hidden="true">›</span>
    <a href="/carnet" class="breadcrumb-link">Carnet</a>
    <span class="breadcrumb-sep" aria-hidden="true">›</span>
    <span class="breadcrumb-current">{note.data.title}</span>
  </nav>

  <article>

    <!-- Méta supérieure -->
    <div class="article-meta-top">
      <span class="note-type-badge" style={`color:${typeCfg.couleur}; background:${typeCfg.couleur}12; border-color:${typeCfg.couleur}30`}>
        <span class="note-glyph">{typeCfg.glyph}</span>
        {typeCfg.label}
      </span>
      <span class="meta-sep">·</span>
      <span class="date">{date}</span>
      <span class="meta-sep">·</span>
      <span class="readtime">{readTime} min</span>
      {eng > 0 && (
        <>
          <span class="meta-sep">·</span>
          <span class="eng-meta" title={`Niveau de lecture : ${note.data.engagement}`}>
            <span class="eng-meta-indicator">
              <span class={`eng-meta-bar eng-meta-b1${eng >= 1 ? ' on' : ''}`}></span>
              <span class={`eng-meta-bar eng-meta-b2${eng >= 2 ? ' on' : ''}`}></span>
              <span class={`eng-meta-bar eng-meta-b3${eng >= 3 ? ' on' : ''}`}></span>
            </span>
            <span class="eng-meta-label">{note.data.engagement}</span>
          </span>
        </>
      )}
      {stadeInfo && (
        <>
          <span class="meta-sep">·</span>
          <a href="/stades" class="badge-stade"
            style={`color:${stadeInfo.color}; background:${stadeInfo.color}12; border-color:${stadeInfo.color}28`}
            title={`${stadeInfo.emoji} ${stadeInfo.label}`}
          >
            {stadeInfo.emoji} {stadeInfo.label}
          </a>
        </>
      )}
      <span class="meta-sep">·</span>
      <span class="note-num">#{String(numNote).padStart(2, '0')}</span>
    </div>

    <h1>{note.data.title}</h1>

    <!-- Ornement seuil -->
    <div class="article-seuil">
      <div class="seuil-line seuil-line--left"></div>
      <svg class="seuil-svg" width="48" height="20" viewBox="0 0 48 20" fill="none" aria-hidden="true">
        <path d={`M24 2 L38 10 L24 18 L10 10 Z`} stroke={typeCfg.couleur} stroke-width="1" fill="none" opacity=".35"/>
        <line x1="24" y1="5"  x2="24" y2="15" stroke={typeCfg.couleur} stroke-width=".7" opacity=".25"/>
        <line x1="14" y1="10" x2="34" y2="10" stroke={typeCfg.couleur} stroke-width=".7" opacity=".25"/>
        <circle cx="24" cy="2"  r="1.2" fill={typeCfg.couleur} opacity=".4"/>
        <circle cx="38" cy="10" r="1.2" fill={typeCfg.couleur} opacity=".4"/>
        <circle cx="24" cy="18" r="1.2" fill={typeCfg.couleur} opacity=".4"/>
        <circle cx="10" cy="10" r="1.2" fill={typeCfg.couleur} opacity=".4"/>
        <line x1="0"  y1="10" x2="7"  y2="10" stroke={typeCfg.couleur} stroke-width=".7" opacity=".2" stroke-linecap="round"/>
        <line x1="41" y1="10" x2="48" y2="10" stroke={typeCfg.couleur} stroke-width=".7" opacity=".2" stroke-linecap="round"/>
      </svg>
      <div class="seuil-line"></div>
    </div>

    <!-- Corps -->
    <div class="content">
      <Content />
    </div>

    <!-- Partage -->
    <div class="partage-wrap">
      <span class="partage-label">Partager</span>
      <button class="btn-copier" id="btn-copier" type="button" aria-label="Copier le lien">
        <svg viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
        <span class="label-default">Copier le lien</span>
        <span class="label-copie">✓ Lien copié</span>
      </button>
    </div>

    <!-- Tags -->
    {note.data.tags && note.data.tags.length > 0 && (
      <div class="codex">
        <div class="codex-header">
          <span class="codex-icon">◆</span>
          <span class="codex-label">Codex</span>
        </div>
        <ul class="codex-tags">
          {note.data.tags.map((tag: string) => (
            <li class="codex-tag">{tag}</li>
          ))}
        </ul>
      </div>
    )}

  </article>

  <!-- Navigation -->
  <nav class="nav-article">
    <div class="nav-item nav-item--prev">
      {precedent ? (
        <a href={`/carnet/${precedent.slug}`} class="nav-lien">
          <span class="nav-dir">← Note précédente</span>
          <span class="nav-titre">{precedent.data.title}</span>
        </a>
      ) : <div />}
    </div>

    <a href="/carnet" class="nav-tous">
      <svg viewBox="0 0 16 16" fill="none" width="12" height="12">
        <rect x="1" y="1" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.2"/>
        <rect x="9" y="1" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.2"/>
        <rect x="1" y="9" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.2"/>
        <rect x="9" y="9" width="6" height="6" rx="1" stroke="currentColor" stroke-width="1.2"/>
      </svg>
      Carnet
    </a>

    <div class="nav-item nav-item--next">
      {suivant ? (
        <a href={`/carnet/${suivant.slug}`} class="nav-lien nav-lien--right">
          <span class="nav-dir">Note suivante →</span>
          <span class="nav-titre">{suivant.data.title}</span>
        </a>
      ) : <div />}
    </div>
  </nav>

</div>

<!-- Bouton remonter -->
<button class="btn-top-float" id="btn-top" aria-label="Remonter en haut">
  <svg viewBox="0 0 24 24"><polyline points="18 15 12 9 6 15"/></svg>
</button>

<style>
  /* ── Progression ── */
  .progress-bar {
    position: fixed; top: 52px; left: 0;
    height: 3px; width: 0%;
    background: #ea580c;
    box-shadow: 0 0 6px rgba(234,88,12,.5);
    z-index: 99; transition: width .08s linear;
  }

  /* ── Wrap ── */
  .wrap { max-width: 680px; margin: 0 auto; padding: 0 1.75rem; }

  /* ── Fil d'Ariane ── */
  .breadcrumb {
    display: flex; align-items: center; gap: .55rem;
    padding: 3.5rem 0 1rem;
    opacity: 0; animation: rise .8s .05s ease forwards;
  }
  .breadcrumb-link {
    font-family: 'Mulish', sans-serif; font-size: .82rem;
    letter-spacing: .04em; color: var(--ink-soft);
    text-decoration: none; opacity: .85;
    border-bottom: 1px dotted transparent; padding-bottom: 1px;
    transition: color .2s, opacity .2s, border-color .2s;
  }
  .breadcrumb-link:hover { color: var(--accent); opacity: 1; border-bottom-color: var(--accent); }
  .breadcrumb-sep { font-size: .75rem; color: var(--rule); opacity: .65; user-select: none; }
  .breadcrumb-current {
    font-family: 'Mulish', sans-serif; font-size: .82rem; font-weight: 600;
    color: var(--ink); opacity: .85;
    white-space: nowrap; overflow: hidden;
    text-overflow: ellipsis; max-width: 28ch;
  }

  /* ── Article ── */
  article { padding-bottom: 1rem; opacity: 0; animation: rise .9s .15s ease forwards; }

  /* ── Méta ── */
  .article-meta-top {
    display: flex; align-items: center; gap: .65rem;
    flex-wrap: wrap; margin-bottom: 1.1rem;
  }
  .note-type-badge {
    display: inline-flex; align-items: center; gap: .3rem;
    font-family: 'Mulish', sans-serif;
    font-size: .6rem; font-weight: 700;
    letter-spacing: .12em; text-transform: uppercase;
    padding: .18rem .45rem; border-radius: 3px; border: 1px solid;
  }
  .note-glyph { font-size: .85rem; line-height: 1; }
  .date {
    font-family: 'Mulish', sans-serif; font-size: .62rem;
    font-weight: 300; letter-spacing: .2em;
    text-transform: uppercase; color: var(--accent); opacity: .8;
  }
  .readtime {
    font-family: 'Mulish', sans-serif; font-size: .62rem;
    font-weight: 500; letter-spacing: .1em; color: var(--ink-soft);
  }
  .meta-sep { color: var(--rule); font-size: .7rem; }
  .badge-stade {
    display: inline-flex; align-items: center; gap: .25rem;
    font-family: 'Mulish', sans-serif; font-size: .55rem; font-weight: 700;
    letter-spacing: .13em; text-transform: uppercase;
    padding: .15rem .4rem; border-radius: 3px; border: 1px solid;
    text-decoration: none;
    transition: opacity .2s;
  }
  .badge-stade:hover { opacity: .75; }
  .note-num {
    font-family: 'Mulish', sans-serif; font-size: .72rem;
    font-weight: 700; letter-spacing: .12em;
    color: #ea580c; opacity: .75;
  }

  /* ── Indicateur engagement ── */
  .eng-meta { display: inline-flex; align-items: center; gap: .28rem; }
  .eng-meta-indicator { display: inline-flex; align-items: flex-end; gap: 3px; }
  .eng-meta-bar { display: inline-block; width: 3px; border-radius: 2px 2px 1px 1px; background: var(--rule); }
  .eng-meta-b1 { height: 5px; } .eng-meta-b2 { height: 8px; } .eng-meta-b3 { height: 12px; }
  .eng-meta-bar.on { background: #7c5cbf; }
  .eng-meta-label { font-family: 'Mulish', sans-serif; font-size: .52rem; font-weight: 300; letter-spacing: .04em; color: var(--ink-soft); opacity: .5; }

  /* ── Titre ── */
  h1 {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: clamp(1.6rem, 3vw, 2.1rem);
    font-weight: 700; line-height: 1.2;
    letter-spacing: -.02em; color: var(--ink);
    margin-bottom: .9rem;
  }

  /* ── Chapeau ── */
  .article-chapeau {
    font-family: 'Mulish', sans-serif;
    font-size: .97rem; font-weight: 300;
    font-style: italic; color: var(--ink-soft);
    line-height: 1.8; max-width: 58ch;
    margin-bottom: 1.5rem;
    border-left: 2px solid var(--rule);
    padding-left: 1rem;
  }

  /* ── Ornement seuil ── */
  .article-seuil {
    display: flex; align-items: center; gap: .75rem;
    margin: 1.5rem 0 2rem;
  }
  .seuil-line {
    flex: 1; height: 1px;
    background: linear-gradient(to right, var(--rule), transparent);
  }
  .seuil-line--left {
    background: linear-gradient(to left, var(--rule), transparent);
  }

  /* ── Contenu — voir src/styles/carnet.css ── */

  /* ── Partage ── */
  .partage-wrap {
    display: flex; align-items: center; justify-content: flex-end;
    gap: .75rem; padding: 1.25rem 0;
    border-top: 1px solid var(--rule); margin-top: 1rem;
    opacity: 0; animation: rise .8s .4s ease forwards;
  }
  .partage-label {
    font-family: 'Mulish', sans-serif; font-size: .62rem;
    font-weight: 300; letter-spacing: .1em; text-transform: uppercase;
    color: var(--ink-soft); opacity: .45;
  }
  .btn-copier {
    display: inline-flex; align-items: center; gap: .5rem;
    font-family: 'Mulish', sans-serif; font-size: .62rem;
    font-weight: 700; letter-spacing: .16em; text-transform: uppercase;
    color: var(--ink-soft); background: transparent;
    border: 1px solid var(--rule); border-radius: 4px;
    padding: .55rem 1rem; cursor: pointer;
    transition: border-color .2s, color .2s, background .2s;
  }
  .btn-copier svg { width: 12px; height: 12px; stroke: currentColor; fill: none; stroke-width: 1.8; flex-shrink: 0; transition: transform .2s; }
  .btn-copier:hover { border-color: var(--accent); color: var(--accent); background: rgba(139,94,60,.04); }
  .btn-copier:hover svg { transform: scale(1.15); }
  .btn-copier.copie { border-color: #2e7d4e; color: #2e7d4e; background: rgba(46,125,78,.05); }
  .btn-copier.copie svg { display: none; }
  .btn-copier .label-copie { display: none; }
  .btn-copier.copie .label-copie { display: inline; }
  .btn-copier .label-default { display: inline; }
  .btn-copier.copie .label-default { display: none; }

  /* ── Codex tags ── */
  .codex {
    margin: 1.5rem 0; padding: 1.25rem 1.5rem;
    border: 1px solid var(--rule);
    border-left: 3px solid var(--gold, #c4993a);
    border-radius: 0 6px 6px 0;
    background: rgba(196,153,58,.03);
    opacity: 0; animation: rise .8s .5s ease forwards;
  }
  .codex-header {
    display: flex; align-items: center; gap: .5rem;
    margin-bottom: 1rem; padding-bottom: .6rem;
    border-bottom: 1px solid var(--rule);
  }
  .codex-icon { color: var(--gold, #c4993a); opacity: .55; font-size: .75rem; }
  .codex-label {
    font-family: 'Mulish', sans-serif; font-size: .55rem;
    font-weight: 700; letter-spacing: .22em; text-transform: uppercase;
    color: var(--ink-soft); opacity: .6;
  }
  .codex-tags { list-style: none; display: flex; flex-wrap: wrap; gap: .5rem; }
  .codex-tag {
    font-family: 'Mulish', sans-serif; font-size: .7rem;
    font-weight: 400; color: var(--ink-mid);
    padding: .3rem .75rem;
    border-radius: 4px; border: 1px solid var(--rule);
    background: rgba(245,240,232,.7);
    transition: border-color .2s, color .2s, transform .15s;
  }
  .codex-tag:hover { border-color: var(--gold, #c4993a); color: var(--gold, #c4993a); transform: translateY(-1px); }

  /* ── Navigation ── */
  .nav-article {
    display: flex; align-items: center; justify-content: space-between;
    gap: 1rem; padding: 2rem 0 4rem;
    border-top: 1px solid var(--rule);
    opacity: 0; animation: rise .8s .55s ease forwards;
  }
  .nav-item { flex: 1; }
  .nav-item--next { text-align: right; }
  .nav-lien {
    display: flex; flex-direction: column; gap: .25rem;
    text-decoration: none; color: inherit;
    transition: opacity .2s;
  }
  .nav-lien--right { align-items: flex-end; }
  .nav-lien:hover { opacity: .7; }
  .nav-dir {
    font-family: 'Mulish', sans-serif; font-size: .65rem;
    font-weight: 700; letter-spacing: .12em; text-transform: uppercase;
    color: var(--ink-soft);
  }
  .nav-titre {
    font-family: 'Libre Baskerville', serif;
    font-size: .88rem; font-style: italic; color: var(--ink);
    line-height: 1.35; max-width: 24ch;
  }
  .nav-tous {
    display: flex; flex-direction: column; align-items: center;
    gap: .4rem; text-decoration: none; color: var(--ink-soft);
    font-family: 'Mulish', sans-serif; font-size: .62rem;
    font-weight: 700; letter-spacing: .15em; text-transform: uppercase;
    transition: color .2s;
  }
  .nav-tous:hover { color: var(--accent); }
  .nav-tous svg { stroke: currentColor; }

  /* ── Btn top ── */
  .btn-top-float {
    position: fixed; bottom: 2rem; right: 1.5rem;
    width: 36px; height: 36px; border-radius: 50%;
    background: var(--bg); border: 1px solid var(--rule);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; opacity: 0; transform: translateY(8px);
    transition: opacity .3s, transform .3s, background .2s;
    z-index: 50;
  }
  .btn-top-float svg { width: 16px; height: 16px; stroke: var(--ink-mid); stroke-width: 2; fill: none; }
  .btn-top-float.visible { opacity: 1; transform: translateY(0); }
  .btn-top-float:hover { background: var(--rule); }

  @media (max-width: 600px) { .wrap { padding: 0 1rem; } }

  @keyframes rise {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  // Barre de progression
  const bar = document.getElementById('progress');
  if (bar) {
    let articleTracked = false;
    window.addEventListener('scroll', () => {
      const doc = document.documentElement;
      const total = doc.scrollHeight - doc.clientHeight;
      if (total > 0) {
        const pct = (doc.scrollTop / total) * 100;
        bar.style.width = `${pct}%`;
        if (pct >= 80 && !articleTracked) {
          articleTracked = true;
          window.dispatchEvent(new CustomEvent('article:read', {
            detail: { slug: window.location.pathname }
          }));
        }
      }
    }, { passive: true });
  }

  // Copier le lien
  const btn = document.getElementById('btn-copier');
  if (btn) {
    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        btn.classList.add('copie');
        setTimeout(() => btn.classList.remove('copie'), 2200);
      } catch {
        const input = document.createElement('input');
        input.value = window.location.href;
        document.body.appendChild(input);
        input.select();
        document.execCommand('copy');
        document.body.removeChild(input);
        btn.classList.add('copie');
        setTimeout(() => btn.classList.remove('copie'), 2200);
      }
    });
  }

  // Bouton remonter
  const btnTop = document.getElementById('btn-top');
  if (btnTop) {
    window.addEventListener('scroll', () => {
      btnTop.classList.toggle('visible', window.scrollY > 400);
    }, { passive: true });
    btnTop.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
  }
</script>

</Base>
