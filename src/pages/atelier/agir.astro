<script>
  // ── Cartes 3 modes ────────────────────────────────────────────────────────
  let carteOuverte: HTMLElement | null = null;

  function ouvrirCarte(carte: HTMLElement) {
    if (carteOuverte && carteOuverte !== carte) fermerCarte(carteOuverte);
    const mode2 = carte.querySelector<HTMLElement>('.a-c-mode2');
    if (!mode2) return;
    carte.classList.add('a-carte--open');
    mode2.hidden = false;
    carteOuverte = carte;
    setTimeout(() => {
      const scroller = document.getElementById('atelierContent');
      if (scroller) {
        const top = carte.getBoundingClientRect().top - scroller.getBoundingClientRect().top + scroller.scrollTop - 24;
        scroller.scrollTo({ top, behavior: 'smooth' });
      } else {
        carte.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }, 60);
  }

  function fermerCarte(carte: HTMLElement) {
    const mode2 = carte.querySelector<HTMLElement>('.a-c-mode2');
    carte.classList.remove('a-carte--open');
    if (mode2) mode2.hidden = true;
    if (carteOuverte === carte) carteOuverte = null;
  }

  document.querySelectorAll<HTMLElement>('.a-carte[data-has-detail="true"]').forEach(carte => {
    carte.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.closest('.a-c-fermer')) return;
      carte.classList.contains('a-carte--open') ? fermerCarte(carte) : ouvrirCarte(carte);
    });
    carte.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); carte.click(); }
      if (e.key === 'Escape' && carte.classList.contains('a-carte--open')) fermerCarte(carte);
    });
  });

  document.querySelectorAll<HTMLElement>('.a-c-fermer').forEach(btn => {
    btn.addEventListener('click', () => {
      const carte = btn.closest<HTMLElement>('.a-carte');
      if (carte) fermerCarte(carte);
    });
  });

  // ── Filtres chips ─────────────────────────────────────────────────────────
  const chips    = document.querySelectorAll<HTMLButtonElement>('.a-chip[data-filtre]');
  const sections = document.querySelectorAll<HTMLElement>('.a-section');
  let filtreActif = 'tout';

  function appliquerFiltres() {
    sections.forEach(sec => {
      const f = sec.dataset.filtre ?? '';
      sec.style.display = (filtreActif === 'tout' || filtreActif === f) ? '' : 'none';
    });
  }

  chips.forEach(chip => {
    chip.addEventListener('click', () => {
      filtreActif = chip.dataset.filtre ?? 'tout';
      chips.forEach(c => c.classList.toggle('a-chip--active', c === chip));
      appliquerFiltres();
    });
  });

  // ── Boot sequence ─────────────────────────────────────────────────────────
  const line1El   = document.getElementById('aLine1');
  const cursor1El = document.getElementById('aCursor1');
  const line2Wrap = document.getElementById('aLine2Wrap');
  const line2El   = document.getElementById('aLine2');
  const cursor2El = document.getElementById('aCursor2');
  const introEl   = document.getElementById('aIntro');

  const phrase1 = "chargement des outils d'action...";
  const phrase2 = "décision · jeu · stratégie · coopération";

  function typePhrase(
    textEl: HTMLElement | null,
    cursorEl: HTMLElement | null,
    phrase: string,
    delay: number,
    onDone?: () => void
  ) {
    if (!textEl || !cursorEl) return;
    let i = 0;
    cursorEl.style.opacity = '0';
    setTimeout(() => {
      const tick = () => {
        if (i < phrase.length) {
          textEl.textContent += phrase[i];
          i++;
          setTimeout(tick, 22 + Math.random() * 20);
        } else {
          cursorEl.style.opacity = '1';
          if (onDone) setTimeout(onDone, 320);
        }
      };
      tick();
    }, delay);
  }

  typePhrase(line1El, cursor1El, phrase1, 400, () => {
    if (cursor1El) { cursor1El.style.animation = 'none'; cursor1El.style.opacity = '0.3'; }
    if (line2Wrap) line2Wrap.style.opacity = '1';
    typePhrase(line2El, cursor2El, phrase2, 0, () => {
      if (introEl) {
        introEl.classList.remove('a-intro--hidden');
        introEl.classList.add('a-intro--visible');
      }
    });
  });
</script>

