<script>
  const STEP_ORDER = ['step1','step2','step3','step4','step5'];

  let currentDepth = 0;
  let history: string[] = ['step1'];

  function showStep(id: string, depth: number) {
    // Masquer l'étape courante
    const currentId = history[history.length - 1];
    const current = document.getElementById(currentId);
    if (current) {
      current.classList.add('ge-step--exit');
      setTimeout(() => {
        current.classList.add('ge-step--hidden');
        current.classList.remove('ge-step--exit');
      }, 260);
    }

    // Afficher la nouvelle étape
    setTimeout(() => {
      const next = document.getElementById(id);
      if (!next) return;
      next.classList.remove('ge-step--hidden');
      next.classList.add('ge-step--enter');
      setTimeout(() => next.classList.remove('ge-step--enter'), 460);
    }, 270);

    history.push(id);
    updateProgress(depth);
  }

  function updateProgress(depth: number) {
    const dots = document.querySelectorAll('.ge-progress-dot');
    dots.forEach((dot, i) => {
      dot.classList.toggle('ge-progress-dot--active', i <= depth);
      dot.classList.toggle('ge-progress-dot--done', i < depth);
    });
  }

  function reset() {
    // Masquer toutes les étapes
    document.querySelectorAll('.ge-step').forEach(s => {
      s.classList.add('ge-step--hidden');
      s.classList.remove('ge-step--exit', 'ge-step--enter');
    });
    history = ['step1'];
    currentDepth = 0;

    setTimeout(() => {
      const first = document.getElementById('step1');
      if (first) {
        first.classList.remove('ge-step--hidden');
        first.classList.add('ge-step--enter');
        setTimeout(() => first.classList.remove('ge-step--enter'), 350);
      }
      updateProgress(0);
    }, 50);
  }

  // Délégation d'événements sur le funnel
  document.getElementById('geFunnel')?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-next],[data-word]') as HTMLElement | null;
    if (!btn) return;

    if (btn.dataset.next) {
      // Navigation vers étape suivante
      const nextId = btn.dataset.next;
      // Calculer la profondeur selon le préfixe
      const depth = nextId.startsWith('step5') ? 4
        : nextId.startsWith('step4') ? 3
        : nextId.startsWith('step3') ? 2
        : nextId.startsWith('step2') ? 1 : 0;
      showStep(nextId, depth);

    } else if (btn.dataset.word) {
      // Résolution finale
      const word = btn.dataset.word!;
      const resolveText = btn.dataset.resolve!;

      const wordEl = document.getElementById('geWord');
      const textEl = document.getElementById('geResolveText');
      if (wordEl) wordEl.textContent = word;
      if (textEl) textEl.textContent = resolveText;

      showStep('step5', 4);
    }
  });

  document.getElementById('geRestart')?.addEventListener('click', reset);
</script>

