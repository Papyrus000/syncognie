---
import AtelierLayout from '../../layouts/AtelierLayout.astro';
---

<AtelierLayout
  title="Outil de Granularité Émotionnelle"
  filename="granularite-emotionnelle"
  description="Un outil neurobiologique pour nommer précisément ce que vous ressentez et reprendre le contrôle de vos émotions."
>

<div class="ge-wrap">

  <header class="ge-header">
    <p class="ge-surtitle">outil · neuro-ergonomie</p>
    <h1 class="ge-title">Granularité Émotionnelle</h1>
    <p class="ge-subtitle">
      Nommer précisément ce que vous ressentez, c'est déjà reprendre le contrôle.
    </p>
  </header>

  <!-- ── ENTONNOIR ── -->
  <div class="ge-funnel" id="geFunnel">

    <!-- Étape 1 : Énergie corporelle -->
    <div class="ge-step" id="step1">
      <p class="ge-question">En ce moment, mon corps est…</p>
      <div class="ge-choices">
        <button class="ge-btn" data-next="step2-haute">
          <span class="ge-btn-icon">⚡</span>
          <span class="ge-btn-label">Agité, tendu, activé</span>
          <span class="ge-btn-sub">énergie haute</span>
        </button>
        <button class="ge-btn" data-next="step2-basse">
          <span class="ge-btn-icon">🌑</span>
          <span class="ge-btn-label">Lourd, vide, ralenti</span>
          <span class="ge-btn-sub">énergie basse</span>
        </button>
      </div>
    </div>

    <!-- Étape 2a : Valence — Énergie haute -->
    <div class="ge-step ge-step--hidden" id="step2-haute">
      <p class="ge-question">Cette agitation est…</p>
      <div class="ge-choices">
        <button class="ge-btn" data-next="step3-haute-agreable">
          <span class="ge-btn-icon">✦</span>
          <span class="ge-btn-label">Plutôt agréable</span>
          <span class="ge-btn-sub">enthousiasme, excitation</span>
        </button>
        <button class="ge-btn" data-next="step3-haute-desagreable">
          <span class="ge-btn-icon">◈</span>
          <span class="ge-btn-label">Plutôt désagréable</span>
          <span class="ge-btn-sub">tension, malaise</span>
        </button>
      </div>
    </div>

    <!-- Étape 2b : Valence — Énergie basse -->
    <div class="ge-step ge-step--hidden" id="step2-basse">
      <p class="ge-question">Ce calme pesant est…</p>
      <div class="ge-choices">
        <button class="ge-btn" data-next="step3-basse-agreable">
          <span class="ge-btn-icon">✦</span>
          <span class="ge-btn-label">Plutôt agréable</span>
          <span class="ge-btn-sub">sérénité, repos</span>
        </button>
        <button class="ge-btn" data-next="step3-basse-desagreable">
          <span class="ge-btn-icon">◈</span>
          <span class="ge-btn-label">Plutôt désagréable</span>
          <span class="ge-btn-sub">épuisement, tristesse</span>
        </button>
      </div>
    </div>

    <!-- Étape 3 : Catégories primaires -->
    <!-- Haute + Désagréable -->
    <div class="ge-step ge-step--hidden" id="step3-haute-desagreable">
      <p class="ge-question">Ce que je ressens ressemble le plus à…</p>
      <div class="ge-choices ge-choices--3">
        <button class="ge-btn" data-next="step4-colere">
          <span class="ge-btn-icon">🔥</span>
          <span class="ge-btn-label">De la colère</span>
          <span class="ge-btn-sub">injustice, résistance</span>
        </button>
        <button class="ge-btn" data-next="step4-peur">
          <span class="ge-btn-icon">⚠</span>
          <span class="ge-btn-label">De la peur</span>
          <span class="ge-btn-sub">menace, incertitude</span>
        </button>
        <button class="ge-btn" data-next="step4-frustration">
          <span class="ge-btn-icon">◌</span>
          <span class="ge-btn-label">De la frustration</span>
          <span class="ge-btn-sub">obstacle, impuissance</span>
        </button>
      </div>
    </div>

    <!-- Haute + Agréable -->
    <div class="ge-step ge-step--hidden" id="step3-haute-agreable">
      <p class="ge-question">Ce que je ressens ressemble le plus à…</p>
      <div class="ge-choices ge-choices--3">
        <button class="ge-btn" data-next="step4-joie">
          <span class="ge-btn-icon">☀</span>
          <span class="ge-btn-label">De la joie</span>
          <span class="ge-btn-sub">légèreté, plaisir</span>
        </button>
        <button class="ge-btn" data-next="step4-excitation">
          <span class="ge-btn-icon">⚡</span>
          <span class="ge-btn-label">De l'excitation</span>
          <span class="ge-btn-sub">anticipation, élan</span>
        </button>
        <button class="ge-btn" data-next="step4-fierte">
          <span class="ge-btn-icon">✦</span>
          <span class="ge-btn-label">De la fierté</span>
          <span class="ge-btn-sub">accomplissement, valeur</span>
        </button>
      </div>
    </div>

    <!-- Basse + Désagréable -->
    <div class="ge-step ge-step--hidden" id="step3-basse-desagreable">
      <p class="ge-question">Ce que je ressens ressemble le plus à…</p>
      <div class="ge-choices ge-choices--3">
        <button class="ge-btn" data-next="step4-tristesse">
          <span class="ge-btn-icon">🌧</span>
          <span class="ge-btn-label">De la tristesse</span>
          <span class="ge-btn-sub">perte, manque</span>
        </button>
        <button class="ge-btn" data-next="step4-honte">
          <span class="ge-btn-icon">◉</span>
          <span class="ge-btn-label">De la honte / culpabilité</span>
          <span class="ge-btn-sub">jugement, faute</span>
        </button>
        <button class="ge-btn" data-next="step4-epuisement">
          <span class="ge-btn-icon">○</span>
          <span class="ge-btn-label">De l'épuisement</span>
          <span class="ge-btn-sub">vide, détachement</span>
        </button>
      </div>
    </div>

    <!-- Basse + Agréable -->
    <div class="ge-step ge-step--hidden" id="step3-basse-agreable">
      <p class="ge-question">Ce que je ressens ressemble le plus à…</p>
      <div class="ge-choices ge-choices--3">
        <button class="ge-btn" data-next="step4-paix">
          <span class="ge-btn-icon">◌</span>
          <span class="ge-btn-label">De la paix</span>
          <span class="ge-btn-sub">calme, acceptation</span>
        </button>
        <button class="ge-btn" data-next="step4-gratitude">
          <span class="ge-btn-icon">✦</span>
          <span class="ge-btn-label">De la gratitude</span>
          <span class="ge-btn-sub">connexion, chaleur</span>
        </button>
        <button class="ge-btn" data-next="step4-contemplation">
          <span class="ge-btn-icon">○</span>
          <span class="ge-btn-label">De la contemplation</span>
          <span class="ge-btn-sub">distance sereine, réflexion</span>
        </button>
      </div>
    </div>

    <!-- ── Étape 4 : Granularité fine ── -->
    <!-- Colère -->
    <div class="ge-step ge-step--hidden" id="step4-colere">
      <p class="ge-question">Précisément, ce que je vis est…</p>
      <div class="ge-choices ge-choices--fine">
        <button class="ge-btn ge-btn--fine" data-word="Indignation" data-resolve="Vous traversez un état d'indignation. Quelque chose a heurté profondément votre sens de la justice. Nommer cela, c'est cesser de subir.">Indignation</button>
        <button class="ge-btn ge-btn--fine" data-word="Trahison" data-resolve="Vous traversez un sentiment de trahison. Une confiance a été rompue. Ce n'est pas de la faiblesse — c'est de l'attachement.">Trahison</button>
        <button class="ge-btn ge-btn--fine" data-word="Rancœur" data-resolve="Vous portez de la rancœur. Une blessure ancienne non résolue refait surface. La nommer est déjà la dépotentialiser.">Rancœur</button>
        <button class="ge-btn ge-btn--fine" data-word="Mépris" data-resolve="Vous ressentez du mépris. C'est une distanciation protectrice face à une valeur bafouée. Observer cela sans le nier vous redonne de l'agentivité.">Mépris</button>
        <button class="ge-btn ge-btn--fine" data-word="Exaspération" data-resolve="Vous êtes dans l'exaspération. La répétition d'un schéma non résolu a saturé votre tolérance. Ce signal mérite d'être écouté.">Exaspération</button>
      </div>
    </div>

    <!-- Peur -->
    <div class="ge-step ge-step--hidden" id="step4-peur">
      <p class="ge-question">Précisément, ce que je vis est…</p>
      <div class="ge-choices ge-choices--fine">
        <button class="ge-btn ge-btn--fine" data-word="Anxiété" data-resolve="Vous traversez de l'anxiété. Une menace diffuse, sans objet précis, mobilise votre système d'alerte. Nommer cela démantèle son pouvoir.">Anxiété</button>
        <button class="ge-btn ge-btn--fine" data-word="Appréhension" data-resolve="Vous ressentez de l'appréhension. Une situation future concentre votre vigilance. Ce n'est pas une prédiction — c'est une émotion.">Appréhension</button>
        <button class="ge-btn ge-btn--fine" data-word="Panique" data-resolve="Vous êtes dans un état de panique. Votre cortex préfrontal peut reprendre la main. Respiration lente, 4 temps. Vous êtes en sécurité maintenant.">Panique</button>
        <button class="ge-btn ge-btn--fine" data-word="Vulnérabilité" data-resolve="Vous ressentez de la vulnérabilité. Être exposé est inconfortable. C'est aussi la condition de tout lien authentique.">Vulnérabilité</button>
        <button class="ge-btn ge-btn--fine" data-word="Insécurité" data-resolve="Vous traversez un sentiment d'insécurité. Une base stable (intérieure ou extérieure) manque. Identifier le manque est la première étape pour y répondre.">Insécurité</button>
      </div>
    </div>

    <!-- Frustration -->
    <div class="ge-step ge-step--hidden" id="step4-frustration">
      <p class="ge-question">Précisément, ce que je vis est…</p>
      <div class="ge-choices ge-choices--fine">
        <button class="ge-btn ge-btn--fine" data-word="Impuissance" data-resolve="Vous ressentez de l'impuissance. Un obstacle bloque une action que vous voulez mener. Identifier ce qui est hors de votre contrôle libère de l'énergie pour ce qui y est.">Impuissance</button>
        <button class="ge-btn ge-btn--fine" data-word="Déception" data-resolve="Vous traversez une déception. L'écart entre ce qui était attendu et ce qui est arrivé est douloureux. C'est le signe que vous attendiez quelque chose de bien.">Déception</button>
        <button class="ge-btn ge-btn--fine" data-word="Impatience" data-resolve="Vous ressentez de l'impatience. Le rythme extérieur ne correspond pas à votre rythme interne. Ce signal mérite d'être interrogé.">Impatience</button>
        <button class="ge-btn ge-btn--fine" data-word="Ambivalence" data-resolve="Vous êtes dans l'ambivalence. Deux besoins contradictoires coexistent. Les nommer séparément, c'est pouvoir les négocier.">Ambivalence</button>
        <button class="ge-btn ge-btn--fine" data-word="Résignation" data-resolve="Vous ressentez de la résignation. Un abandon progressif face à un obstacle persistant. Observer cela sans jugement est le début d'un nouveau choix.">Résignation</button>
      </div>
    </div>

    <!-- Tristesse -->
    <div class="ge-step ge-step--hidden" id="step4-tristesse">
      <p class="ge-question">Précisément, ce que je vis est…</p>
      <div class="ge-choices ge-choices--fine">
        <button class="ge-btn ge-btn--fine" data-word="Deuil" data-resolve="Vous traversez un état de deuil. Une perte — réelle ou symbolique — demande à être reconnue. Le deuil n'est pas une faiblesse, c'est le prix de l'attachement.">Deuil</button>
        <button class="ge-btn ge-btn--fine" data-word="Mélancolie" data-resolve="Vous ressentez de la mélancolie. Une nostalgie douce-amère pour quelque chose qui n'est plus. Laisser cette émotion être, sans l'accélérer.">Mélancolie</button>
        <button class="ge-btn ge-btn--fine" data-word="Solitude" data-resolve="Vous traversez un sentiment de solitude. Un manque de connexion — pas nécessairement d'absence. Nommer ce besoin est déjà une forme de connexion avec soi.">Solitude</button>
        <button class="ge-btn ge-btn--fine" data-word="Désespoir" data-resolve="Vous ressentez du désespoir. La perception que rien ne changera. C'est une distorsion cognitive sous pression. Ce moment n'est pas permanent.">Désespoir</button>
        <button class="ge-btn ge-btn--fine" data-word="Nostalgie" data-resolve="Vous ressentez de la nostalgie. Un passé lumineux contraste avec le présent. C'est une ressource, pas un piège — si vous choisissez de l'utiliser.">Nostalgie</button>
      </div>
    </div>

    <!-- Honte -->
    <div class="ge-step ge-step--hidden" id="step4-honte">
      <p class="ge-question">Précisément, ce que je vis est…</p>
      <div class="ge-choices ge-choices--fine">
        <button class="ge-btn ge-btn--fine" data-word="Honte" data-resolve="Vous ressentez de la honte. Ce n'est pas ce que vous avez fait qui vous définit — c'est la conviction que vous êtes fondamentalement défaillant. Cette conviction peut être remise en question.">Honte</button>
        <button class="ge-btn ge-btn--fine" data-word="Culpabilité" data-resolve="Vous ressentez de la culpabilité. Un acte ou une omission heurte vos valeurs. Contrairement à la honte, la culpabilité est réparable — elle pointe vers une action possible.">Culpabilité</button>
        <button class="ge-btn ge-btn--fine" data-word="Embarras" data-resolve="Vous ressentez de l'embarras. Une exposition sociale inattendue active votre système d'autoévaluation. C'est une émotion très humaine, et très temporaire.">Embarras</button>
        <button class="ge-btn ge-btn--fine" data-word="Remords" data-resolve="Vous portez des remords. Un passé non modifiable pèse sur le présent. Reconnaître cela ouvre la voie à la réparation — ou à l'acceptation de ce qui ne peut être réparé.">Remords</button>
        <button class="ge-btn ge-btn--fine" data-word="Auto-critique" data-resolve="Vous êtes dans un mode d'auto-critique intense. Ce juge intérieur a une intention protectrice mal calibrée. Observer la voix plutôt que de vous y identifier est un acte de distance saine.">Auto-critique</button>
      </div>
    </div>

    <!-- Épuisement -->
    <div class="ge-step ge-step--hidden" id="step4-epuisement">
      <p class="ge-question">Précisément, ce que je vis est…</p>
      <div class="ge-choices ge-choices--fine">
        <button class="ge-btn ge-btn--fine" data-word="Burnout" data-resolve="Vous êtes en état d'épuisement profond. Les ressources sont à sec. Ce n'est pas un manque de volonté — c'est un signal biologique sérieux qui mérite une réponse sérieuse.">Burnout</button>
        <button class="ge-btn ge-btn--fine" data-word="Détachement" data-resolve="Vous ressentez du détachement. Une anesthésie émotionnelle protectrice s'est installée. C'est souvent le signe d'une surcharge prolongée. Nommer cela, c'est déjà sortir de l'anesthésie.">Détachement</button>
        <button class="ge-btn ge-btn--fine" data-word="Apathie" data-resolve="Vous traversez de l'apathie. La motivation, l'élan, l'intérêt semblent absents. Ce n'est pas qui vous êtes — c'est un état, et les états changent.">Apathie</button>
        <button class="ge-btn ge-btn--fine" data-word="Accablement" data-resolve="Vous êtes accablé. Le poids de trop de choses à la fois écrase. Réduire le champ de vision à la prochaine heure est une tactique neurologique légitime.">Accablement</button>
        <button class="ge-btn ge-btn--fine" data-word="Vide" data-resolve="Vous ressentez le vide. L'absence de sens, de ressenti, de direction. Ce n'est pas une vérité sur vous — c'est un signal que quelque chose de fondamental demande à être réexaminé.">Vide</button>
      </div>
    </div>

    <!-- Joie -->
    <div class="ge-step ge-step--hidden" id="step4-joie">
      <p class="ge-question">Précisément, ce que je vis est…</p>
      <div class="ge-choices ge-choices--fine">
        <button class="ge-btn ge-btn--fine" data-word="Allégresse" data-resolve="Vous ressentez de l'allégresse. Une légèreté vive et spontanée. Laissez-la exister pleinement — les émotions positives méritent autant d'attention que les difficiles.">Allégresse</button>
        <button class="ge-btn ge-btn--fine" data-word="Soulagement" data-resolve="Vous ressentez du soulagement. Une tension longtemps portée vient de se dissoudre. Savourez ce relâchement — votre système nerveux en a besoin.">Soulagement</button>
        <button class="ge-btn ge-btn--fine" data-word="Jubilation" data-resolve="Vous ressentez de la jubilation. Une joie intense et expansive. Laissez-la occuper tout l'espace — elle est réelle.">Jubilation</button>
        <button class="ge-btn ge-btn--fine" data-word="Contentement" data-resolve="Vous ressentez du contentement. Une satisfaction calme et profonde. C'est l'une des formes de bonheur les plus stables — et les plus sous-estimées.">Contentement</button>
        <button class="ge-btn ge-btn--fine" data-word="Émerveillement" data-resolve="Vous ressentez de l'émerveillement. Quelque chose a dépassé vos attentes ou révélé sa beauté. Cette émotion est liée à l'expansion du sens.">Émerveillement</button>
      </div>
    </div>

    <!-- Excitation -->
    <div class="ge-step ge-step--hidden" id="step4-excitation">
      <p class="ge-question">Précisément, ce que je vis est…</p>
      <div class="ge-choices ge-choices--fine">
        <button class="ge-btn ge-btn--fine" data-word="Anticipation" data-resolve="Vous ressentez de l'anticipation. Votre cerveau projette un futur désirable et s'y prépare. Cet élan est une énergie — utilisez-la.">Anticipation</button>
        <button class="ge-btn ge-btn--fine" data-word="Enthousiasme" data-resolve="Vous ressentez de l'enthousiasme. Un alignement entre votre énergie et une direction. Notez ce qui l'a provoqué — c'est une information précieuse sur vos valeurs profondes.">Enthousiasme</button>
        <button class="ge-btn ge-btn--fine" data-word="Inspiration" data-resolve="Vous ressentez de l'inspiration. Une connexion soudaine entre une idée et votre élan propre. Capturez-la maintenant, avant que le quotidien ne la dilue.">Inspiration</button>
        <button class="ge-btn ge-btn--fine" data-word="Désir" data-resolve="Vous ressentez du désir. Un mouvement vers quelque chose ou quelqu'un. Nommer l'objet de ce désir avec précision est la première condition pour pouvoir le poursuivre ou le questionner.">Désir</button>
        <button class="ge-btn ge-btn--fine" data-word="Euphorie" data-resolve="Vous ressentez de l'euphorie. Une intensité émotionnelle haute. Profitez de cet état — et observez-le sans trop vous y identifier, car les états passent.">Euphorie</button>
      </div>
    </div>

    <!-- Fierté -->
    <div class="ge-step ge-step--hidden" id="step4-fierte">
      <p class="ge-question">Précisément, ce que je vis est…</p>
      <div class="ge-choices ge-choices--fine">
        <button class="ge-btn ge-btn--fine" data-word="Fierté" data-resolve="Vous ressentez de la fierté. Un accomplissement aligné avec vos valeurs a été reconnu — par vous. C'est rare et précieux. Laissez-le s'installer.">Fierté</button>
        <button class="ge-btn ge-btn--fine" data-word="Confiance" data-resolve="Vous ressentez de la confiance. Une foi dans votre capacité à faire face. Ce n'est pas de l'arrogance — c'est de la compétence reconnue.">Confiance</button>
        <button class="ge-btn ge-btn--fine" data-word="Satisfaction" data-resolve="Vous ressentez de la satisfaction. Un travail mené à son terme, un effort honoré. Prenez le temps de l'enregistrer — votre cerveau en a besoin pour apprendre.">Satisfaction</button>
        <button class="ge-btn ge-btn--fine" data-word="Dignité" data-resolve="Vous ressentez de la dignité. Un sentiment d'intégrité préservée face à une épreuve. C'est l'une des formes de force les plus solides qui soit.">Dignité</button>
        <button class="ge-btn ge-btn--fine" data-word="Gratitude envers soi" data-resolve="Vous ressentez de la gratitude envers vous-même. Vous avez traversé quelque chose et vous avez tenu. Reconnaître cela n'est pas de la vanité — c'est de la justice.">Gratitude envers soi</button>
      </div>
    </div>

    <!-- Paix -->
    <div class="ge-step ge-step--hidden" id="step4-paix">
      <p class="ge-question">Précisément, ce que je vis est…</p>
      <div class="ge-choices ge-choices--fine">
        <button class="ge-btn ge-btn--fine" data-word="Sérénité" data-resolve="Vous ressentez de la sérénité. Un calme stable, non fragile. Votre système nerveux est en régulation. C'est un état à cultiver délibérément.">Sérénité</button>
        <button class="ge-btn ge-btn--fine" data-word="Acceptation" data-resolve="Vous ressentez de l'acceptation. Non la résignation, mais le choix lucide de ne pas lutter contre ce qui est. C'est une forme de sagesse active.">Acceptation</button>
        <button class="ge-btn ge-btn--fine" data-word="Plénitude" data-resolve="Vous ressentez de la plénitude. Un sentiment de complétude rare. Notez ce contexte — il vous dit ce dont vous avez vraiment besoin pour vivre.">Plénitude</button>
        <button class="ge-btn ge-btn--fine" data-word="Quiétude" data-resolve="Vous ressentez de la quiétude. Une paix tranquille, sans effort. Laissez-la être sans chercher à l'analyser ou la justifier.">Quiétude</button>
        <button class="ge-btn ge-btn--fine" data-word="Équilibre" data-resolve="Vous ressentez de l'équilibre. Les différentes polarités de votre vie semblent momentanément alignées. Observez ce qui a rendu cet état possible.">Équilibre</button>
      </div>
    </div>

    <!-- Gratitude -->
    <div class="ge-step ge-step--hidden" id="step4-gratitude">
      <p class="ge-question">Précisément, ce que je vis est…</p>
      <div class="ge-choices ge-choices--fine">
        <button class="ge-btn ge-btn--fine" data-word="Gratitude" data-resolve="Vous ressentez de la gratitude. Une reconnaissance pour ce qui est là, maintenant. La gratitude est l'une des émotions les plus documentées pour le bien-être durable.">Gratitude</button>
        <button class="ge-btn ge-btn--fine" data-word="Tendresse" data-resolve="Vous ressentez de la tendresse. Un attachement doux pour quelqu'un ou quelque chose. C'est une forme de soin qui dit quelque chose d'important sur ce qui compte pour vous.">Tendresse</button>
        <button class="ge-btn ge-btn--fine" data-word="Connexion" data-resolve="Vous ressentez de la connexion. Un sentiment d'appartenance ou de résonance avec quelqu'un. C'est un besoin humain fondamental — et vous le ressentez maintenant.">Connexion</button>
        <button class="ge-btn ge-btn--fine" data-word="Affection" data-resolve="Vous ressentez de l'affection. Un lien chaleureux, ancré, sans effort. Prenez le temps de l'exprimer — les liens se nourrissent d'être nommés.">Affection</button>
        <button class="ge-btn ge-btn--fine" data-word="Émerveillement partagé" data-resolve="Vous ressentez de l'émerveillement partagé. La beauté d'une expérience vécue avec d'autres. C'est l'une des formes les plus riches de lien humain.">Émerveillement partagé</button>
      </div>
    </div>

    <!-- Contemplation -->
    <div class="ge-step ge-step--hidden" id="step4-contemplation">
      <p class="ge-question">Précisément, ce que je vis est…</p>
      <div class="ge-choices ge-choices--fine">
