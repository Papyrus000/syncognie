<AtelierLayout
  title="Synthèse · Boîte à outils"
  filename="synthese"
  parent={{ label: 'atelier', href: '/atelier' }}
>

<div class="syn-page">

  <!-- ══════════════════════════════
       HERO — style Matrix / terminal
       ══════════════════════════════ -->

<div class="atelier-terminal">
    <span class="atelier-terminal-prompt">&gt;</span>
    <span class="atelier-terminal-text" id="terminalText"></span><span class="atelier-terminal-cursor" id="terminalCursor">_</span>
  </div>

  <nav class="syn-nav" id="synNav" style="opacity:0">
    <a href="#cerveau"      class="syn-nav-pill" style="--c:#f5a623">Cerveau</a>
    <a href="#construction" class="syn-nav-pill" style="--c:#e85d20">Construction</a>
    <a href="#relations"    class="syn-nav-pill" style="--c:#d45a8a">Relations</a>
    <a href="#sens"         class="syn-nav-pill" style="--c:#c8b020">Sens</a>
    <a href="#corps"        class="syn-nav-pill" style="--c:#5dbe8a">Corps</a>
    <a href="#systemes"     class="syn-nav-pill" style="--c:#5090a8">Systèmes</a>
    <a href="#pouvoir"      class="syn-nav-pill" style="--c:#a06878">Pouvoir</a>
    <a href="#philosophie"  class="syn-nav-pill" style="--c:#8a9e5a">Philosophie</a>
