    border: 1px solid rgba(155,111,212,0.2);
    padding: 4px 12px;
    border-radius: 4px;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
  }
  .syn-q-reset:hover { color: rgba(155,111,212,0.9); border-color: rgba(155,111,212,0.5); }

  /* ════════════════════
     TOOLTIP PRONONCIATION
     ════════════════════ */
  .syn-prononc-tooltip {
    position: fixed;
    z-index: 1000;
    background: rgba(20, 12, 4, 0.97);
    border: 1px solid rgba(232,184,50,0.35);
    border-radius: 7px;
    padding: 0.5rem 0.85rem;
    pointer-events: none;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.18s, transform 0.18s;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    max-width: 220px;
    box-shadow: 0 6px 24px rgba(0,0,0,0.5);
  }
  .syn-prononc-tooltip.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .syn-prononc-phonetique {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: #e8b832;
    letter-spacing: 0.04em;
  }
  .syn-prononc-phonetique::before {
    content: '🔊 ';
    font-size: 0.7rem;
    opacity: 0.7;
  }
  .syn-prononc-origine {
    font-family: 'Mulish', sans-serif;
    font-size: 0.66rem;
    color: rgba(255,200,130,0.45);
    font-style: italic;
  }

  /* ── Pied de page ── */
  .syn-footer {
    margin-top: 3rem;
    padding-top: 1.2rem;
    border-top: 1px solid rgba(255,150,60,0.08);
  }
  .syn-footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .syn-footer-text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.55rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,150,60,0.25);
  }
  .syn-footer-back {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem;
    color: rgba(200,120,48,0.5);
    text-decoration: none;
    transition: color 0.2s;
  }
  .syn-footer-back:hover { color: #c87830; }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .syn-cards       { grid-template-columns: 1fr; }
    .syn-links-grid  { grid-template-columns: 1fr; }
    .syn-q-grid      { grid-template-columns: 1fr; }
    .syn-hero-content { padding: 1.4rem 1rem 1.2rem; }
    .syn-footer-inner { flex-direction: column; gap: 0.5rem; align-items: flex-start; }
  }
</style>

<script>
// ═══════════════════════════════════════════════════════
// HERO : Canvas Matrix + typage séquentiel
// ═══════════════════════════════════════════════════════
// ── Terminal Typewriter ──────────────────────────────────────────────────
  const termText   = document.getElementById('terminalText');
  const termCursor = document.getElementById('terminalCursor');
  const synNav     = document.getElementById('synNav');
  const phrase     = "synthèse : 35 penseurs, 10 domaines, connexions pratiques...";

  if (termText && termCursor) {
    let i = 0;
    termCursor.style.opacity = '0';

    const type = () => {
      if (i < phrase.length) {
        termText.textContent += phrase[i];
        i++;
        setTimeout(type, 30 + Math.random() * 30);
      } else {
        termCursor.style.opacity = '1';
        if (synNav) synNav.style.opacity = '1';
      }
    };

    setTimeout(type, 600);
  }

// ═══════════════════════════════════════════════════════
// TOOLTIP PRONONCIATION
// ═══════════════════════════════════════════════════════
(function() {
  const tooltip = document.getElementById('prononcTooltip')!;
  const phonEl  = document.getElementById('prononcPhon')!;
  const origEl  = document.getElementById('prononcOrig')!;
  let hideTimer: ReturnType<typeof setTimeout> | null = null;

  document.querySelectorAll<HTMLElement>('.syn-card-nom[data-prononc]').forEach(el => {
    el.addEventListener('mouseenter', (e) => {
      if (hideTimer) clearTimeout(hideTimer);
      phonEl.textContent = el.dataset.prononc || '';
      origEl.textContent = el.dataset.origine || '';

      const me = e as MouseEvent;
      const tx = Math.min(me.clientX + 16, window.innerWidth - 240);
      const ty = me.clientY - 60;
      tooltip.style.left = tx + 'px';
      tooltip.style.top  = ty + 'px';
      tooltip.classList.add('visible');
    });
    el.addEventListener('mousemove', (e) => {
      const me = e as MouseEvent;
      const tx = Math.min(me.clientX + 16, window.innerWidth - 240);
      const ty = me.clientY - 60;
      tooltip.style.left = tx + 'px';
      tooltip.style.top  = ty + 'px';
    });
    el.addEventListener('mouseleave', () => {
      hideTimer = setTimeout(() => tooltip.classList.remove('visible'), 120);
    });
  });
})();

// ═══════════════════════════════════════════════════════
// QUESTIONS INTERACTIVES → highlight des cartes
// ═══════════════════════════════════════════════════════
(function() {
  const allCards = Array.from(document.querySelectorAll<HTMLElement>('.syn-card'));
  const buttons  = Array.from(document.querySelectorAll<HTMLButtonElement>('.syn-q-item'));
  const resetBtn = document.getElementById('qReset')!;
  const resetWrap = document.getElementById('qResetWrap')!;
  let activeBtn: HTMLButtonElement | null = null;

  function clearAll() {
    allCards.forEach(c => {
      c.classList.remove('syn-card--highlight', 'syn-card--dimmed');
    });
    buttons.forEach(b => b.classList.remove('syn-q-item--active'));
    resetWrap.style.display = 'none';
    activeBtn = null;
  }

  function activate(btn: HTMLButtonElement) {
    if (activeBtn === btn) { clearAll(); return; }
    clearAll();

    const targets = (btn.dataset.targets || '').split(',').map(s => s.trim());
    const targetSet = new Set(targets);

    allCards.forEach(card => {
      if (targetSet.has(card.id)) {
        card.classList.add('syn-card--highlight');
      } else {
        card.classList.add('syn-card--dimmed');
      }
    });

    btn.classList.add('syn-q-item--active');
    resetWrap.style.display = 'flex';
    activeBtn = btn;

    // Scroll vers la première carte mise en évidence
    const firstTarget = document.getElementById(targets[0]);
    if (firstTarget) {
      setTimeout(() => {
        firstTarget.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }, 80);
    }
  }

  buttons.forEach(btn => {
    btn.addEventListener('click', () => activate(btn));
  });
  resetBtn.addEventListener('click', clearAll);
})();
</script>

</AtelierLayout>
