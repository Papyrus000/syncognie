---
import { getCollection } from 'astro:content';
import AtelierLayout from '../../layouts/AtelierLayout.astro';
import { PENSEURS } from '../../data/penseurs';

const tout = await getCollection('atelier');

const master = tout.find(e => e.id === 'index.md' || e.slug === 'index');
const entrees = tout
  .filter(e => e.id !== 'index.md' && e.slug !== 'index' && e.data.draft !== true)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

if (!master) throw new Error('Fichier src/content/atelier/index.md introuvable');
const { Content } = await master.render();

// Progression globale
const exploresIds = new Set(tout.filter(e => e.data.penseur).map(e => e.data.penseur));
const total    = PENSEURS.length;
const explores = PENSEURS.filter(p => exploresIds.has(p.id)).length;
const pct      = Math.round((explores / total) * 100);

// Progression par niveau
const niveaux = [
  { num: 1, label: 'Soi',           couleur: '#7bd4a0', couleurBg: 'rgba(123,212,160,0.12)', couleurBorder: 'rgba(123,212,160,0.25)' },
  { num: 2, label: 'Le monde',      couleur: '#7ab8f5', couleurBg: 'rgba(122,184,245,0.12)', couleurBorder: 'rgba(122,184,245,0.25)' },
  { num: 3, label: 'Comment vivre', couleur: '#c9a0f0', couleurBg: 'rgba(201,160,240,0.12)', couleurBorder: 'rgba(201,160,240,0.25)' },
];

const niveauxData = niveaux.map(niv => {
  const penseursDuNiveau = PENSEURS.filter(p => p.niveau === niv.num);
  const exploredDuNiveau = penseursDuNiveau.filter(p => exploresIds.has(p.id)).length;
  const totalDuNiveau    = penseursDuNiveau.length;
  return { ...niv, explored: exploredDuNiveau, total: totalDuNiveau };
});

function formatDate(date: Date) {
  return date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'short', year: 'numeric' });
}
---

<AtelierLayout title={master.data.title} filename={master.data.title}>

  <Content />

  <!-- ── Bloc Fondations ── -->
  <a href="/atelier/fondations" class="fondations-bloc">

    <!-- Ligne principale : logo + titre + label + flèche -->
    <div class="fondations-main">
      <span class="fondations-star" aria-hidden="true">🌟</span>
      <span class="fondations-titre">Fondations</span>
      <span class="fondations-label">référence permanente</span>
      <span class="fondations-arrow">→</span>
    </div>

    <!-- Barre de progression globale -->
    <div class="fondations-meta">
      <div class="fondations-bar">
        <div class="fondations-fill" style={`width: ${pct}%`}></div>
      </div>
      <span class="fondations-compte">{explores} / {total}</span>
    </div>

    <!-- Barres des 3 niveaux avec cases -->
    <div class="fondations-niveaux">
      {niveauxData.map(niv => (
        <div class="fniv" style={`--c: ${niv.couleur}; --bg: ${niv.couleurBg}; --border: ${niv.couleurBorder}`}>
          <span class="fniv-label">{niv.label}</span>
          <div class="fniv-cases">
            {Array.from({ length: niv.total }, (_, i) => (
              <span class={`fniv-case ${i < niv.explored ? 'fniv-case--on' : ''}`}></span>
            ))}
          </div>
          <span class="fniv-compte">{niv.explored}/{niv.total}</span>
        </div>
      ))}
    </div>

  </a>

  <!-- ── Articles ── -->
  {entrees.length > 0 && (
    <div class="atelier-entrees">
      <div class="entrees-sep"></div>
      <h2>Exploration</h2>
      <ul class="entrees-list">
        {entrees.map((entree) => (
          <li>
            <a href={`/atelier/${entree.slug}`} class="entree-link">
              <span class="entree-arrow">→</span>
              <span class="entree-title">{entree.data.title}</span>
              {entree.data.extrait && (
                <span class="entree-extrait">{entree.data.extrait}</span>
              )}
              <span class="entree-date">{formatDate(entree.data.date)}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}

</AtelierLayout>

<style>
  /* ── Bloc Fondations ── */
  .fondations-bloc {
    display: block;
    text-decoration: none;
    border: 1px solid rgba(100, 200, 130, 0.2);
    background: rgba(60, 40, 20, 0.6);
    border-radius: 10px;
    padding: 0.85rem 1.2rem 1rem;
    margin: 1.8rem 0 0;
    position: relative;
    overflow: hidden;
    transition: border-color 0.25s, background 0.25s, transform 0.2s;
  }
  .fondations-bloc::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, #4aa870, #7bd4a0, #4aa870);
    opacity: 0.5;
    transition: opacity 0.25s;
  }
  .fondations-bloc:hover {
    border-color: rgba(100, 200, 130, 0.35);
    background: rgba(60, 40, 20, 0.75);
    transform: translateY(-2px);
  }
  .fondations-bloc:hover::before { opacity: 1; }

  /* Ligne principale */
  .fondations-main {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    margin-bottom: 0.65rem;
  }
  .fondations-star {
    font-size: 1.15rem;
    flex-shrink: 0;
    filter: drop-shadow(0 0 6px rgba(123,212,160,0.5));
  }
  .fondations-titre {
    font-family: 'Libre Baskerville', serif;
    font-size: 1rem;
    font-weight: 700;
    color: #7bd4a0;
    letter-spacing: 0.01em;
    flex-shrink: 0;
  }
  .fondations-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.58rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.18);
    flex: 1;
  }
  .fondations-arrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9rem;
    color: #7bd4a0;
    opacity: 0.5;
    flex-shrink: 0;
    transition: opacity 0.2s, transform 0.2s;
  }
  .fondations-bloc:hover .fondations-arrow { opacity: 1; transform: translateX(3px); }

  /* Barre globale */
  .fondations-meta {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    margin-bottom: 0.85rem;
  }
  .fondations-bar {
    flex: 1;
    height: 2px;
    background: rgba(255,255,255,0.05);
    border-radius: 2px;
    overflow: hidden;
  }
  .fondations-fill {
    height: 100%;
    background: linear-gradient(90deg, #4aa870, #7bd4a0);
    border-radius: 2px;
  }
  .fondations-compte {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    color: rgba(123,212,160,0.5);
    white-space: nowrap;
  }

  /* ── Niveaux ── */
  .fondations-niveaux {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .fniv {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }
  .fniv-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.62rem;
    color: var(--c);
    opacity: 0.8;
    white-space: nowrap;
    width: 7.5rem;
    flex-shrink: 0;
  }
  .fniv-cases {
    display: flex;
    flex-wrap: wrap;
    gap: 3px;
    flex: 1;
  }
  .fniv-case {
    width: 10px;
    height: 10px;
    border-radius: 2px;
    border: 1px solid var(--border);
    background: transparent;
    transition: background 0.3s, box-shadow 0.3s;
    flex-shrink: 0;
  }
  .fniv-case--on {
    background: var(--c);
    border-color: var(--c);
    box-shadow: 0 0 4px var(--c);
  }
  .fniv-compte {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem;
    color: var(--c);
    opacity: 0.55;
    white-space: nowrap;
    width: 2.5rem;
    text-align: right;
    flex-shrink: 0;
  }

  /* ── Articles ── */
  .atelier-entrees { margin-top: 2.5rem; }
  .entrees-sep {
    border-top: 1px solid rgba(255,150,80,0.12);
    margin-bottom: 1.8rem;
  }
  .atelier-entrees h2 {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.95rem;
    font-weight: 500;
    color: #c87830;
    margin-bottom: 1.2rem;
  }
  .entrees-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .entree-link {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    text-decoration: none;
    padding: 0.5rem 0.6rem;
    border-radius: 6px;
    transition: background 0.2s;
  }
  .entree-arrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    color: #7a5a3a;
    flex-shrink: 0;
    transition: color 0.2s, transform 0.2s;
  }
  .entree-link:hover .entree-arrow { color: #7abd6e; transform: translateX(3px); }
  .entree-title {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9rem;
    color: #d4a878;
    flex-shrink: 0;
    transition: color 0.2s;
  }
  .entree-link:hover .entree-title { color: #7abd6e; }
  .entree-extrait {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    color: #7a5a3a;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    flex: 1;
  }
  .entree-date {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    color: #5a3a1a;
    flex-shrink: 0;
    margin-left: auto;
  }

  @media (max-width: 640px) {
    .fniv-label { width: 5rem; }
    .fniv-case { width: 8px; height: 8px; }
  }
</style>
