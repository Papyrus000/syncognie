---
import { getCollection } from 'astro:content';
import AtelierLayout from '../../layouts/AtelierLayout.astro';
import { PENSEURS, DOMAINES } from '../../data/penseurs';
import type { Domaine } from '../../data/penseurs';

const tout = await getCollection('atelier');

const master = tout.find(e => e.id === 'index.md' || e.slug === 'index');
const entrees = tout
  .filter(e => e.id !== 'index.md' && e.slug !== 'index' && e.data.draft !== true)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

if (!master) throw new Error('Fichier src/content/atelier/index.md introuvable');
const { Content } = await master.render();

// Progression globale — basée sur mode 2 (detail), pas sur article rédigé
const exploresIds = new Set(tout.filter(e => e.data.penseur).map(e => e.data.penseur));
const total    = PENSEURS.length;
const explores = PENSEURS.filter(p => !!p.detail).length;
const pct      = Math.round((explores / total) * 100);

// ── Niveau 1 · Soi — détail par domaine ─────────────────────────────────────
const domainesSoi: Domaine[] = ['cerveau', 'construction', 'relations', 'sens'];

const niv1Domaines = domainesSoi.map(id => {
  const { label, couleur } = DOMAINES[id];
  const liste    = PENSEURS.filter(p => p.domaine === id);
  const explored = liste.filter(p => !!p.detail).length;
  const penseurs = liste.map(p => ({
    id: p.id,
    titre: `${p.nom} — ${p.concept}`,
    explored: !!p.detail,
    slug: p.id,
  }));
  return { id, label, couleur, explored, total: liste.length, penseurs };
});

const niv1Total    = niv1Domaines.reduce((s, d) => s + d.total, 0);
const niv1Explored = niv1Domaines.reduce((s, d) => s + d.explored, 0);

// ── Niveau 1b · Corps — détail par domaine ───────────────────────────────────
const domainesCorps: Domaine[] = ['corps-sommeil', 'corps-mouvement', 'corps-metabolisme'];

const niv1bDomaines = domainesCorps.map(id => {
  const { label, couleur } = DOMAINES[id];
  const liste    = PENSEURS.filter(p => p.domaine === id);
  const explored = liste.filter(p => !!p.detail).length;
  const penseurs = liste.map(p => ({
    id: p.id,
    titre: `${p.nom} — ${p.concept}`,
    explored: !!p.detail,
    slug: p.id,
  }));
  return { id, label, couleur, explored, total: liste.length, penseurs };
});

const niv1bTotal    = niv1bDomaines.reduce((s, d) => s + d.total, 0);
const niv1bExplored = niv1bDomaines.reduce((s, d) => s + d.explored, 0);

// ── Niveaux 2 & 3 — barre simple ─────────────────────────────────────────────
const niveauxSimples = [
  { num: 2, label: 'Le monde',      couleur: '#5090a8', couleurBorder: 'rgba(80,144,168,0.35)' },
  { num: 3, label: 'Comment vivre', couleur: '#8a9e5a', couleurBorder: 'rgba(138,158,90,0.35)' },
];

const niveauxSimplesData = niveauxSimples.map(niv => {
  const liste    = PENSEURS.filter(p => p.niveau === niv.num);
  const explored = liste.filter(p => !!p.detail).length;
  const penseurs = liste.map(p => ({
    id: p.id,
    titre: `${p.nom} — ${p.concept}`,
    explored: !!p.detail,
    slug: p.id,
  }));
  return { ...niv, explored, total: liste.length, penseurs };
});

function formatDate(date: Date) {
  return date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'short', year: 'numeric' });
}

// ── Sections non finalisées — mettre à true pour réactiver ──────────────────
const SHOW_NIVEAU_0  = false;  // /atelier/le-reel
const SHOW_NIVEAU_4  = false;  // /atelier/agir
const SHOW_SYNTHESE  = false;  // /atelier/synthese
---

<AtelierLayout
  title={`${master.data.title} — L'Atelier des Idées`}
  description="L'Atelier des Idées : explorations de philosophie, psychologie, neurosciences et systèmes complexes. Des articles de fond sur les penseurs qui comptent vraiment."
  ogTitle="L'Atelier des Idées — Syncognie"
  ogDescription="Philosophie, psychologie, neurosciences, systèmes : des explorations de fond sur les penseurs et idées qui éclairent comment fonctionne le monde — et comment y vivre."
  filename={master.data.title}
>

  <!-- ── Hero unifié : image + texte overlay ── -->
  <div class="atelier-hero-stage">
  <div class="atelier-hero-wrap">
    <picture>
      <source
        srcset="/images/atelier-hero-v3.webp"
        type="image/webp"
      />
      <source
        srcset="/images/atelier-hero-v3.jpg"
        type="image/jpeg"
      />
      <img
        src="/images/atelier-hero-v3.jpg"
        alt="Syncognie — l'Atelier des Idées, illustration pixel art"
        width="1400"
        height="764"
        loading="eager"
        decoding="async"
        class="atelier-hero-img"
      />
    </picture>
    <!-- Texte superposé -->

  </div>
  <!-- Ombre sol -->
  <div class="atelier-hero-ground"></div>
  </div>

  <!-- ── Terminal line ── -->
  <div class="atelier-terminal">
    <span class="atelier-terminal-prompt">&gt;</span>
    <span class="atelier-terminal-text" id="terminalText"></span><span class="atelier-terminal-cursor" id="terminalCursor">_</span>
  </div>

  <!-- Niveau 0 : SHOW_NIVEAU_0 = false pour désactiver, true pour réactiver -->
  {SHOW_NIVEAU_0 && (
  <a href="/atelier/le-reel" class="extra-bloc extra-bloc--reel" id="reelBloc" aria-label="Voir la page Le Réel">
    <div class="extra-bloc-inner">
      <div class="extra-titre-ligne">
        <span class="extra-badge" style="color:#9b6fd4;border-color:rgba(155,111,212,0.35)">niveau 0</span>
        <span class="extra-titre" style="color:#c8b4f0">Le Réel</span>
        <span class="extra-desc">substrat physique · thermodynamique · évolution · information</span>
        <span class="extra-arrow" style="color:#9b6fd4">&#x2192;</span>
      </div>
      <div class="extra-domaines">
        <span class="extra-dom" style="--c:#9b6fd4">entropie</span>
        <span class="extra-dom-sep">·</span>
        <span class="extra-dom" style="--c:#5daa88">évolution darwinienne</span>
        <span class="extra-dom-sep">·</span>
        <span class="extra-dom" style="--c:#5d9ed4">Shannon &amp; Kolmogorov</span>
        <span class="extra-dom-sep">·</span>
        <span class="extra-dom" style="--c:#c47b40">émergence</span>
      </div>
    </div>
    <div class="extra-glow extra-glow--reel"></div>
  </a>
  )}

  <!-- ── Bloc Fondations ── -->
  <div class="fondations-bloc" id="fondationsBloc">

    <!-- Ligne principale : titre + label + flèche vers page complète -->
    <a href="/atelier/fondations" class="fondations-main" aria-label="Voir la page Fondations complete">
      <span class="fondations-titre">Fondations</span>
      <span class="fondations-label">reference permanente</span>
      <span class="fondations-cta">
        <span class="fondations-cta-text">voir la page</span>
        <span class="fondations-arrow">&#x2192;</span>
      </span>
    </a>

    <!-- Barre de progression globale -->
    <a href="/atelier/fondations" class="fondations-meta" aria-label="Voir toutes les fondations">
      <div class="fondations-bar">
        <div class="fondations-fill" style={`width: ${pct}%`}></div>
      </div>
      <span class="fondations-compte">{explores} / {total}</span>
    </a>

    <!-- ── Niveau 1 · Soi — avec sous-domaines ── -->
    <div class="fniv-bloc">
      <div class="fniv-bloc-head">
        <span class="fniv-bloc-badge">niveau 1</span>
        <span class="fniv-bloc-titre">Soi</span>
        <span class="fniv-bloc-compte">{niv1Explored}/{niv1Total}</span>
      </div>
      <div class="fniv-sous-liste">
        {niv1Domaines.map(d => (
          <div class="fniv-sous" style={`--c: ${d.couleur}`}>
            <span class="fniv-sous-label">{d.label}</span>
            <div class="fniv-cases">
              {d.penseurs.map((p) => (
                <a
                  href={`/atelier/fondations#open=${p.id}`}
                  class={`fniv-case fniv-case--link${p.explored ? ' fniv-case--on' : ''}`}
                  data-title={p.explored ? p.titre : 'Article à venir'}
                  aria-label={p.explored ? p.titre : 'À venir'}
                  onClick="event.stopPropagation()"
                ></a>
              ))}
            </div>
            <span class="fniv-sous-compte">{d.explored}/{d.total}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- ── Niveau 1b · Corps — avec sous-domaines ── -->
    <div class="fniv-bloc fniv-bloc--corps">
      <div class="fniv-bloc-head">
        <span class="fniv-bloc-badge fniv-bloc-badge--corps">niveau 1 corps</span>
        <span class="fniv-bloc-titre">Le corps</span>
        <span class="fniv-bloc-compte fniv-bloc-compte--corps">{niv1bExplored}/{niv1bTotal}</span>
      </div>
      <div class="fniv-sous-liste">
        {niv1bDomaines.map(d => (
          <div class="fniv-sous" style={`--c: ${d.couleur}`}>
            <span class="fniv-sous-label">{d.label}</span>
            <div class="fniv-cases">
              {d.penseurs.map((p) => (
                <a
                  href={`/atelier/fondations#open=${p.id}`}
                  class={`fniv-case fniv-case--link${p.explored ? ' fniv-case--on' : ''}`}
                  data-title={p.explored ? p.titre : 'Article à venir'}
                  aria-label={p.explored ? p.titre : 'À venir'}
                  onClick="event.stopPropagation()"
                ></a>
              ))}
            </div>
            <span class="fniv-sous-compte">{d.explored}/{d.total}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- ── Niveaux 2 & 3 — barres simples ── -->
    <div class="fondations-niveaux">
      {niveauxSimplesData.map(niv => (
        <div class="fniv" style={`--c: ${niv.couleur}; --border: ${niv.couleurBorder}`}>
          <span class="fniv-badge-num">niveau {niv.num}</span>
          <span class="fniv-label">{niv.label}</span>
          <div class="fniv-cases">
            {niv.penseurs.map((p) => (
              <a
                href={`/atelier/fondations#open=${p.id}`}
                class={`fniv-case fniv-case--link${p.explored ? ' fniv-case--on' : ''}`}
                data-title={p.explored ? p.titre : 'Article à venir'}
                aria-label={p.explored ? p.titre : 'À venir'}
                onClick="event.stopPropagation()"
              ></a>
            ))}
          </div>
          <span class="fniv-compte">{niv.explored}/{niv.total}</span>
        </div>
      ))}
    </div>

  </div>


  <!-- Niveau 4 : SHOW_NIVEAU_4 = false pour désactiver, true pour réactiver -->
  {SHOW_NIVEAU_4 && (
  <a href="/atelier/agir" class="extra-bloc extra-bloc--agir" id="agirBloc" aria-label="Voir la page Agir">
    <div class="extra-bloc-inner">
      <div class="extra-titre-ligne">
        <span class="extra-badge" style="color:#c87d3c;border-color:rgba(200,125,60,0.35)">niveau 4</span>
        <span class="extra-titre" style="color:#f0b870">Agir</span>
        <span class="extra-desc">décision · jeu · stratégie · coopération</span>
        <span class="extra-arrow" style="color:#c87d3c">&#x2192;</span>
      </div>
      <div class="extra-domaines">
        <span class="extra-dom" style="--c:#c87d3c">Bayes · Kahneman · Taleb</span>
        <span class="extra-dom-sep">·</span>
        <span class="extra-dom" style="--c:#b85a4a">Nash · Schelling</span>
        <span class="extra-dom-sep">·</span>
        <span class="extra-dom" style="--c:#8a6840">Clausewitz</span>
        <span class="extra-dom-sep">·</span>
        <span class="extra-dom" style="--c:#6a9860">Axelrod · Ostrom</span>
      </div>
    </div>
    <div class="extra-glow extra-glow--agir"></div>
  </a>
  )}

  <!-- Synthèse : SHOW_SYNTHESE = false pour désactiver, true pour réactiver -->
  {SHOW_SYNTHESE && (
  <a href="/atelier/synthese" class="extra-bloc extra-bloc--synthese" aria-label="Voir la synthèse — boîte à outils">
    <div class="extra-bloc-inner">
      <div class="extra-titre-ligne">
        <span class="extra-badge" style="color:#7abd6e;border-color:rgba(122,189,110,0.35)">synthèse</span>
        <span class="extra-titre" style="color:#b0e090">Boîte à outils</span>
        <span class="extra-desc">35 penseurs condensés · connexions · index pratique</span>
        <span class="extra-arrow" style="color:#7abd6e">&#x2192;</span>
      </div>
      <div class="extra-domaines">
        <span class="extra-dom" style="--c:#f5a623">Cerveau</span>
        <span class="extra-dom-sep">·</span>
        <span class="extra-dom" style="--c:#e85d20">Construction</span>
        <span class="extra-dom-sep">·</span>
        <span class="extra-dom" style="--c:#d45a8a">Relations</span>
        <span class="extra-dom-sep">·</span>
        <span class="extra-dom" style="--c:#5090a8">Systèmes</span>
        <span class="extra-dom-sep">·</span>
        <span class="extra-dom" style="--c:#8a9e5a">Philosophie</span>
      </div>
    </div>
    <div class="extra-glow extra-glow--synthese"></div>
  </a>
  )}

  <!-- Tooltip global -->
  <div class="fniv-tooltip" id="fnivTooltip" aria-hidden="true"></div>

  <!-- ── Lien discret : Le Salon des Idées ── -->
  <div class="salon-lien-wrap">
    <a href="/atelier/dialogue" class="salon-lien">
      <span class="salon-lien-dot"></span>
      <span class="salon-lien-label">Le Salon des Idées</span>
      <span class="salon-lien-sub">dialogues entre penseurs · prochainement</span>
      <span class="salon-lien-arrow">&#x2192;</span>
    </a>
  </div>

  <!-- ── Articles ── -->
  {entrees.length > 0 && (
    <div class="atelier-entrees">
      <div class="entrees-sep"></div>
      <h2>Exploration</h2>
      <ul class="entrees-list">
        {entrees.map((entree) => (
          <li>
            <a href={`/atelier/${entree.slug}`} class="entree-link">
              <span class="entree-arrow">&#x2192;</span>
              <span class="entree-title">{entree.data.title}</span>
              {entree.data.extrait && (
                <span class="entree-extrait">{entree.data.extrait}</span>
              )}
              <span class="entree-date">{formatDate(entree.data.date)}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}

</AtelierLayout>

<script>
  // ── Terminal typewriter ──────────────────────────────────────────────────
  const termText   = document.getElementById('terminalText');
  const termCursor = document.getElementById('terminalCursor');
  const phrase     = "espace de concepts, d'idées, de penseurs";

  if (termText && termCursor) {
    let i = 0;
    termCursor.style.opacity = '0';

    const type = () => {
      if (i < phrase.length) {
        termText.textContent += phrase[i];
        i++;
        setTimeout(type, 28 + Math.random() * 22);
      } else {
        // frappe terminée — curseur se met à clignoter
        termCursor.style.opacity = '1';
      }
    };

    // légère pause avant de commencer
    setTimeout(type, 520);
  }

  const tooltip = document.getElementById('fnivTooltip');
  const cases   = document.querySelectorAll<HTMLElement>('.fniv-case[data-title]');

  if (tooltip) {
    let hideTimer: ReturnType<typeof setTimeout> | null = null;

    cases.forEach(el => {
      el.addEventListener('mouseenter', () => {
        const title = el.dataset.title;
        if (!title) return;
        if (hideTimer) { clearTimeout(hideTimer); hideTimer = null; }
        tooltip.textContent = title;
        tooltip.classList.add('fniv-tooltip--visible');
        tooltip.classList.toggle('fniv-tooltip--venir', title === 'Article a venir');
        const rect = el.getBoundingClientRect();
        tooltip.style.left = `${rect.left + rect.width / 2}px`;
        tooltip.style.top  = `${rect.top - 8}px`;
      });
      el.addEventListener('mouseleave', () => {
        hideTimer = setTimeout(() => {
          tooltip.classList.remove('fniv-tooltip--visible');
        }, 120);
      });
    });
  }
</script>

<style>
  /* ── Bloc Fondations ── */
  .fondations-bloc {
    display: block;
    text-decoration: none;
    border: 1px solid rgba(232, 160, 80, 0.18);
    background: rgba(62, 38, 16, 0.45);
    border-radius: 12px;
    padding: 1.2rem 1.5rem 1.4rem;
    margin: 1.8rem 0 1.8rem;
    position: relative;
    overflow: hidden;
    transition: border-color 0.25s, background 0.25s, transform 0.2s, box-shadow 0.25s;
  }
  .fondations-bloc::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, #e85d20, #f5a623, #ffe066, #f5a623, #e85d20);
    opacity: 0.55;
    transition: opacity 0.25s;
  }
  .fondations-bloc:hover {
    border-color: rgba(232, 160, 80, 0.32);
    background: rgba(72, 46, 20, 0.58);
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(20, 8, 0, 0.4);
  }
  .fondations-bloc:hover::before { opacity: 1; }

  /* Ligne titre — lien cliquable */
  .fondations-main {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 1rem;
    text-decoration: none;
    width: 100%;
    max-width: 100%;
  }
  .fondations-titre {
    font-family: 'Libre Baskerville', serif;
    font-size: 1.1rem;
    font-weight: 700;
    font-style: italic;
    color: #e8a050;
    letter-spacing: 0.01em;
    flex-shrink: 0;
  }
  .fondations-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.58rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.16);
    flex: 1;
  }
  .fondations-cta {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    flex-shrink: 0;
  }
  .fondations-cta-text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.70rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: rgba(232, 160, 80, 0.55);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.2s, transform 0.2s;
  }
  .fondations-arrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.4rem;
    color: #e8a050;
    opacity: 0.45;
    flex-shrink: 0;
    transition: opacity 0.2s, transform 0.2s;
  }
  .fondations-main:hover .fondations-cta-text { opacity: 1; transform: translateX(0); }
  .fondations-main:hover .fondations-arrow    { opacity: 1; transform: translateX(3px); }

  /* Barre globale */
  .fondations-meta {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    margin-bottom: 1.4rem;
    text-decoration: none;
    cursor: pointer;
  }
  .fondations-meta:hover .fondations-fill {
    box-shadow: 0 0 10px rgba(245,166,35,0.7);
  }
  .fondations-meta:hover .fondations-compte {
    color: #f5a623;
    opacity: 1;
  }
  .fondations-bar {
    flex: 1;
    height: 4px;
    background: rgba(255,255,255,0.06);
    border-radius: 4px;
    overflow: hidden;
  }
  .fondations-fill {
    height: 100%;
    background: linear-gradient(90deg, #e85d20, #f5a623, #ffe066);
    border-radius: 4px;
    box-shadow: 0 0 6px rgba(245,166,35,0.45);
  }
  .fondations-compte {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    color: #f5a623;
    white-space: nowrap;
  }

  /* Blocs niveaux */
  .fniv-bloc {
    margin-bottom: 1.1rem;
    padding: 0.85rem 1rem;
    border-radius: 8px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
  }
  .fniv-bloc--corps {
    background: rgba(123,159,212,0.04);
    border-color: rgba(123,159,212,0.12);
  }
  .fniv-bloc-head {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.75rem;
  }
  .fniv-bloc-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.55rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(245,166,35,0.55);
    flex-shrink: 0;
  }
  .fniv-bloc-badge--corps { color: rgba(123,159,212,0.6); }
  .fniv-bloc-titre {
    font-family: 'Libre Baskerville', serif;
    font-size: 0.82rem;
    font-style: italic;
    font-weight: 700;
    color: rgba(240,210,160,0.75);
    flex: 1;
  }
  .fniv-bloc-compte {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem;
    color: rgba(245,166,35,0.5);
    white-space: nowrap;
  }
  .fniv-bloc-compte--corps { color: rgba(123,159,212,0.55); }

  /* Sous-domaines */
  .fniv-sous-liste { display: flex; flex-direction: column; gap: 0.45rem; }
  .fniv-sous { display: flex; align-items: center; gap: 0.65rem; }
  .fniv-sous-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6rem;
    color: var(--c);
    opacity: 0.9;
    white-space: nowrap;
    width: 8.5rem;
    flex-shrink: 0;
    letter-spacing: 0.02em;
  }
  .fniv-sous-compte {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.58rem;
    color: var(--c);
    opacity: 0.5;
    white-space: nowrap;
    width: 2.2rem;
    text-align: right;
    flex-shrink: 0;
  }

  /* Cases */
