                      {/* Mode 1 — fermé */}
                      <div class="f-c-mode1">
                        <div class="f-c-top">
                          <span class="f-c-concept">{p.concept}</span>
                          {(on || hasDetail) && (
                            <span class="f-c-toggle" aria-label="Développer">▾</span>
                          )}
                        </div>
                        <p class="f-c-nom">{p.nom}</p>
                        {p.dates && <span class="f-c-dates">{p.dates}</span>}
                        <p class="f-c-desc">{p.description}</p>
                        <div class="f-c-foot">
                          <span class="f-c-val">{p.validite}</span>
                          {!on && !hasDetail && <span class="f-c-avenir">à venir</span>}
                        </div>
                      </div>

                      {/* Mode 2 — développé */}
                      {hasDetail && (
                        <div class="f-c-mode2" hidden>
                          <div class="f-c-detail-body">
                            {((p as any).detail as string).split('\n\n').map((para: string) => (
                              <p class="f-c-detail-para">{para}</p>
                            ))}
                          </div>
                          {/* Mode 3 — lien article si rédigé, notice si à venir */}
                          {on ? (
                            <a href={`/atelier/${p.id}`} class="f-c-article-link">
                              <span class="f-c-article-arrow">→</span>
                              <span>lire l'article complet</span>
                            </a>
