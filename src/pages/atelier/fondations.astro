      <div class="f-niv-head">
        <span class="f-niv-badge f-niv-badge--vivre">niveau 3</span>
        <h2 class="f-niv-titre f-niv-titre--vivre">Comment vivre</h2>
        <p class="f-niv-desc">Les fondations philosophiques qui tiennent depuis des siècles. Vieilles de siècles, empiriquement robustes.</p>
      </div>

      {parDomaine
        .filter(d => domainesViv.includes(d.id as Domaine))
        .map(dom => {
          const list = dom.penseurs;
          if (list.length === 0) return null;
          return (
            <div class="f-dom">
              <h3 class="f-dom-titre" style={`--c:${dom.couleur}`}>
                <span class="f-dom-dot"></span>
                {dom.label}
              </h3>
              <div class="f-grille">
                {list.map(p => {
                  const on = exploresIds.has(p.id);
                  const Tag = on ? 'a' : 'div';
                  const linkProps = on ? { href: `/atelier/${p.id}` } : {};
                  return (
                    <Tag
                      class={`f-carte ${on ? 'f-carte--on' : 'f-carte--off'}`}
