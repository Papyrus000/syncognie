---
import { getCollection } from 'astro:content';
import AtelierLayout from '../../layouts/AtelierLayout.astro';
import { PENSEURS, DOMAINES } from '../../data/penseurs';
import type { Domaine } from '../../data/penseurs';

const entrees = await getCollection('atelier');
const exploresIds = new Set(
  entrees.filter(e => e.data.penseur).map(e => e.data.penseur as string)
);

const parDomaine = (Object.entries(DOMAINES) as [Domaine, { label: string; couleur: string }][])
  .map(([id, domaine]) => ({
    id,
    ...domaine,
    penseurs: PENSEURS.filter(p => p.domaine === id),
  }));

const niveaux = [
  {
    num: 1,
    label: 'Soi',
    desc: 'Ce qu\'il faut comprendre avant tout le reste — comment je fonctionne, comment je me construis, comment je me relie aux autres, pourquoi je fais ce que je fais.',
  },
  {
    num: 2,
    label: 'Le monde',
    desc: 'Comment fonctionnent les systèmes, le pouvoir, la complexité — voir au-delà de l\'individu.',
  },
  {
    num: 3,
    label: 'Comment vivre',
    desc: 'Les fondations philosophiques qui tiennent depuis des siècles. Vieilles de siècles, empiriquement robustes.',
  },
] as const;

const total    = PENSEURS.length;
const explores = PENSEURS.filter(p => exploresIds.has(p.id)).length;
const pct      = Math.round((explores / total) * 100);
---

<AtelierLayout title="Fondations" filename="fondations">

  <div class="f-header">
    <h1>Fondations</h1>
    <p class="f-sub">Les briques : idées, concepts, penseurs essentiels pour se comprendre, comprendre les autres et naviguer dans la vie.</p>
    <p class="f-sub">Sélectionnés sur trois critères : solidité empirique, pouvoir structurant, applicabilité concrète.</p>
    <div class="f-prog">
      <div class="f-prog-bar">
        <div class="f-prog-fill" style={`width:${pct}%`}></div>
      </div>
      <span class="f-prog-label">{explores} / {total} explorés</span>
    </div>
  </div>

  <hr class="f-hr" />

  {niveaux.map(niv => {
    const domaines = parDomaine.filter(d =>
      d.penseurs.some(p => p.niveau === niv.num)
    );
    return (
      <section class="f-niveau">
        <div class="f-niv-head">
          <span class="f-niv-badge">niveau {niv.num}</span>
          <h2 class="f-niv-titre">{niv.label}</h2>
          <p class="f-niv-desc">{niv.desc}</p>
        </div>

        {domaines.map(dom => {
          const list = dom.penseurs.filter(p => p.niveau === niv.num);
          return (
            <div class="f-dom">
              <h3 class="f-dom-titre" style={`--c:${dom.couleur}`}>
                <span class="f-dom-dot"></span>
                {dom.label}
              </h3>
              <div class="f-grille">
                {list.map(p => {
                  const on = exploresIds.has(p.id);
                  return (
                    <div class={`f-carte ${on ? 'f-carte--on' : 'f-carte--off'}`} style={`--c:${dom.couleur}`}>
                      <div class="f-c-top">
                        <span class="f-c-concept">{p.concept}</span>
                        {on && <a href={`/atelier/${p.id}`} class="f-c-lien">→</a>}
                      </div>
                      <p class="f-c-nom">{p.nom}</p>
                      {p.dates && <span class="f-c-dates">{p.dates}</span>}
                      <p class="f-c-desc">{p.description}</p>
                      <div class="f-c-foot">
                        <span class="f-c-val">{p.validite}</span>
                        {!on && <span class="f-c-avenir">à venir</span>}
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>
          );
        })}
      </section>
    );
  })}

  <div class="f-retour">
    <div class="f-retour-sep"></div>
    <a href="/atelier" class="f-retour-link">← retour à l'atelier</a>
  </div>

</AtelierLayout>

<style>
  /* Padding légèrement augmenté */
  :global(.atelier-content) {
    padding-left: 3.5rem !important;
    padding-right: 3.5rem !important;
  }

  .f-header { margin-bottom: 2rem; }

  .f-header h1 {
    font-family: 'Libre Baskerville', serif;
    font-size: 1.35rem;
    font-weight: 400;
    font-style: italic;
    color: #e8a050;
    margin-bottom: 1rem;
  }

  .f-sub {
    font-family: 'Mulish', sans-serif;
    font-weight: 300;
    font-size: 1rem;
    color: #d4a878;
    line-height: 1.75;
    margin-bottom: 0.3rem;
  }

  .f-prog {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 1.4rem;
  }
  .f-prog-bar {
    flex: 1;
    height: 2px;
    background: rgba(255,255,255,0.07);
    border-radius: 2px;
    overflow: hidden;
  }
  .f-prog-fill {
    height: 100%;
    background: linear-gradient(90deg, #c07040, #e8a050);
    border-radius: 2px;
  }
  .f-prog-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    color: #8a6a4a;
    white-space: nowrap;
  }

  .f-hr {
    border: none;
    border-top: 1px solid rgba(255,150,80,0.12);
    margin: 0 0 2.5rem;
  }

  /* Niveau — structurant et lisible */
  .f-niveau {
    margin-bottom: 3.5rem;
  }

  .f-niv-head { margin-bottom: 1.8rem; }

  .f-niv-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #e8a050;
    opacity: 0.8;
    display: block;
    margin-bottom: 0.3rem;
  }

  .f-niv-titre {
    font-family: 'Libre Baskerville', serif;
    font-size: 1.9rem;
    font-weight: 700;
    color: #f0d0a0;
    margin-bottom: 0.5rem;
  }

  .f-niv-desc {
    font-family: 'Mulish', sans-serif;
    font-weight: 300;
    font-size: 1rem;
    color: #d4a878;
    line-height: 1.7;
    max-width: 580px;
  }

  /* Domaine */
  .f-dom { margin-bottom: 2.2rem; }

  .f-dom-titre {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--c);
    letter-spacing: 0.04em;
    margin-bottom: 1rem;
  }
  .f-dom-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--c);
    flex-shrink: 0;
  }

  .f-grille {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 0.85rem;
  }

  /* Carte */
  .f-carte {
    border-radius: 8px;
    padding: 1.1rem 1.2rem 1rem;
    border: 1px solid rgba(255,255,255,0.06);
    position: relative;
    overflow: hidden;
    transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
  }
  .f-carte::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--c);
    opacity: 0;
    transition: opacity 0.2s;
  }
  .f-carte--on {
    background: rgba(255,255,255,0.04);
    border-color: rgba(255,255,255,0.09);
  }
  .f-carte--on::before { opacity: 0.6; }
  .f-carte--on:hover {
    transform: translateY(-2px);
    border-color: rgba(255,255,255,0.15);
    box-shadow: 0 8px 24px rgba(0,0,0,0.3);
  }
  .f-carte--on:hover::before { opacity: 1; }
  .f-carte--off {
    background: rgba(255,255,255,0.02);
    border-color: rgba(255,255,255,0.04);
  }

  .f-c-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.45rem;
  }

  /* Concept — couleur fixe claire, toujours lisible */
  .f-c-concept {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: #f0c878;
    line-height: 1.4;
    flex: 1;
  }
  .f-carte--off .f-c-concept { color: #a08858; }

  .f-c-lien {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    color: var(--c);
    text-decoration: none;
    opacity: 0.6;
    margin-left: 0.4rem;
    flex-shrink: 0;
    transition: opacity 0.2s, transform 0.2s;
  }
  .f-c-lien:hover { opacity: 1; transform: translateX(2px); }

  .f-c-nom {
    font-family: 'Libre Baskerville', serif;
    font-size: 1rem;
    font-weight: 700;
    color: #e8c090;
    margin-bottom: 0.1rem;
  }
  .f-carte--off .f-c-nom { color: #b08860; }

  .f-c-dates {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    color: rgba(255,255,255,0.32);
    display: block;
    margin-bottom: 0.6rem;
  }

  .f-c-desc {
    font-family: 'Mulish', sans-serif;
    font-weight: 300;
    font-size: 0.9rem;
    color: #d4a878;
    line-height: 1.7;
    margin-top: 0.5rem;
    margin-bottom: 0.85rem;
  }
  .f-carte--off .f-c-desc { color: #9a7858; }

  .f-c-foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
    padding-top: 0.4rem;
    border-top: 1px solid rgba(255,255,255,0.05);
  }
  .f-c-val {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    color: rgba(255,255,255,0.45);
    letter-spacing: 0.02em;
  }
  .f-c-val::before {
    content: 'validité · ';
    color: rgba(255,255,255,0.25);
  }
  .f-c-avenir {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    color: rgba(255,255,255,0.3);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .f-retour { margin-top: 3rem; }
  .f-retour-sep {
    border-top: 1px solid rgba(255,150,80,0.1);
    margin-bottom: 1.2rem;
  }
  .f-retour-link {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: #7a5a3a;
    text-decoration: none;
    transition: color 0.2s;
  }
  .f-retour-link:hover { color: #f0a050; }

  @media (max-width: 640px) {
    :global(.atelier-content) {
      padding-left: 1.8rem !important;
      padding-right: 1.8rem !important;
    }
    .f-grille { grid-template-columns: 1fr; }
  }
</style>
