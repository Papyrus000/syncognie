---
import { getCollection } from 'astro:content';
import AtelierLayout from '../../layouts/AtelierLayout.astro';
import { PENSEURS, DOMAINES } from '../../data/penseurs';
import type { Domaine } from '../../data/penseurs';

const entrees = await getCollection('atelier');
const exploresIds = new Set(
  entrees.filter(e => e.data.penseur).map(e => e.data.penseur as string)
);

const parDomaine = (Object.entries(DOMAINES) as [Domaine, { label: string; couleur: string }][])
  .map(([id, domaine]) => ({
    id,
    ...domaine,
    penseurs: PENSEURS.filter(p => p.domaine === id),
  }));

const niveaux = [
  {
    num: 1,
    label: 'Soi',
    desc: "Ce qu'il faut comprendre avant tout le reste — comment je fonctionne, comment je me construis, comment je me relie aux autres, pourquoi je fais ce que je fais.",
  },
  {
    num: 2,
    label: 'Le monde',
    desc: "Comment fonctionnent les systèmes, le pouvoir, la complexité — voir au-delà de l'individu.",
  },
  {
    num: 3,
    label: 'Comment vivre',
    desc: 'Les fondations philosophiques qui tiennent depuis des siècles. Vieilles de siècles, empiriquement robustes.',
  },
] as const;

const total    = PENSEURS.length;
const explores = PENSEURS.filter(p => exploresIds.has(p.id)).length;
const pct      = Math.round((explores / total) * 100);
---

<AtelierLayout title="Fondations" filename="fondations">

  <div class="f-header">
    <h1>Fondations</h1>
    <p class="f-sub">Les briques : idées, concepts, penseurs essentiels pour se comprendre, comprendre les autres et naviguer dans la vie.</p>
    <p class="f-sub">Sélectionnés sur trois critères : solidité empirique, pouvoir structurant, applicabilité concrète.</p>
    <div class="f-prog">
      <div class="f-prog-bar">
        <div class="f-prog-fill" style={`width:${pct}%`}></div>
      </div>
      <span class="f-prog-label">{explores} / {total} explorés</span>
    </div>
  </div>

  <hr class="f-hr" />

  <!-- Barre de filtres chips -->
  <div class="f-filtres">
    <div class="f-chips-groupe">
      <button class="f-chip f-chip--active" data-niveau="tout">Tout</button>
      <button class="f-chip" data-niveau="1">Niveau 1 · Soi</button>
      <button class="f-chip" data-niveau="2">Niveau 2 · Le monde</button>
      <button class="f-chip" data-niveau="3">Niveau 3 · Vivre</button>
    </div>
    <span class="f-chips-sep">·</span>
    <button class="f-chip f-chip--rediges" id="chip-rediges">✦ Rédigées</button>
  </div>

  <!-- Contenu filtrable -->
  <div id="f-contenu">
    {niveaux.map(niv => {
      const domaines = parDomaine.filter(d =>
        d.penseurs.some(p => p.niveau === niv.num)
      );
      return (
        <section class="f-niveau" data-niveau={String(niv.num)}>
          <div class="f-niv-head">
            <span class="f-niv-badge">niveau {niv.num}</span>
            <h2 class="f-niv-titre">{niv.label}</h2>
            <p class="f-niv-desc">{niv.desc}</p>
          </div>

          {domaines.map(dom => {
            const list = dom.penseurs.filter(p => p.niveau === niv.num);
            return (
              <div class="f-dom">
                <h3 class="f-dom-titre" style={`--c:${dom.couleur}`}>
                  <span class="f-dom-dot"></span>
                  {dom.label}
                </h3>
                <div class="f-grille">
                  {list.map(p => {
                    const on = exploresIds.has(p.id);
                    const Tag = on ? 'a' : 'div';
                    const linkProps = on ? { href: `/atelier/${p.id}` } : {};
                    return (
                      <Tag
                        class={`f-carte ${on ? 'f-carte--on' : 'f-carte--off'}`}
                        style={`--c:${dom.couleur}`}
                        data-redige={on ? 'true' : 'false'}
                        {...linkProps}
                      >
                        <div class="f-c-top">
                          <span class="f-c-concept">{p.concept}</span>
                          {on && <span class="f-c-lien">→</span>}
                        </div>
                        <p class="f-c-nom">{p.nom}</p>
                        {p.dates && <span class="f-c-dates">{p.dates}</span>}
                        <p class="f-c-desc">{p.description}</p>
                        <div class="f-c-foot">
                          <span class="f-c-val">{p.validite}</span>
                          {!on && <span class="f-c-avenir">à venir</span>}
                        </div>
                      </Tag>
                    );
                  })}
                </div>
              </div>
            );
          })}
        </section>
      );
    })}
  </div>

  <div class="f-retour">
    <div class="f-retour-sep"></div>
    <a href="/atelier" class="f-retour-link">← retour à l'atelier</a>
  </div>

</AtelierLayout>

<script>
  const niveauChips = document.querySelectorAll<HTMLButtonElement>('.f-chip[data-niveau]');
  const chipRediges = document.getElementById('chip-rediges') as HTMLButtonElement | null;
  const sections    = document.querySelectorAll<HTMLElement>('.f-niveau');
  const cartes      = document.querySelectorAll<HTMLElement>('.f-carte');

  let niveauActif = 'tout';
  let redigesOnly = false;

  function appliquerFiltres() {
    // 1. Niveaux
    sections.forEach(sec => {
      const match = niveauActif === 'tout' || sec.dataset.niveau === niveauActif;
      sec.style.display = match ? '' : 'none';
    });

    // 2. Cartes rédigées
    cartes.forEach(carte => {
      if (!redigesOnly) {
        carte.style.display = '';
        return;
      }
      carte.style.display = carte.dataset.redige === 'true' ? '' : 'none';
    });

    // 3. Masquer les domaines entièrement vides
    document.querySelectorAll<HTMLElement>('.f-dom').forEach(dom => {
      const grille = dom.querySelector<HTMLElement>('.f-grille');
      if (!grille) return;
      const visibles = Array.from(grille.children).filter(
        c => (c as HTMLElement).style.display !== 'none'
      );
      dom.style.display = visibles.length === 0 ? 'none' : '';
    });
  }

  // Chips niveau
  niveauChips.forEach(chip => {
    chip.addEventListener('click', () => {
      niveauChips.forEach(c => c.classList.remove('f-chip--active'));
      chip.classList.add('f-chip--active');
      niveauActif = chip.dataset.niveau ?? 'tout';
      appliquerFiltres();
    });
  });

  // Chip rédigées — toggle
  chipRediges?.addEventListener('click', () => {
    redigesOnly = !redigesOnly;
    chipRediges.classList.toggle('f-chip--rediges-on', redigesOnly);
    appliquerFiltres();
  });
</script>

<style>
  .f-header { margin-bottom: 2rem; }

  .f-header h1 {
    font-family: 'Libre Baskerville', serif;
    font-size: 1.35rem;
    font-weight: 400;
    font-style: italic;
    color: #e8a050;
    margin-bottom: 1rem;
  }

  .f-sub {
    font-family: 'Mulish', sans-serif;
    font-weight: 300;
    font-size: 1rem;
    color: #d4a878;
    line-height: 1.75;
    margin-bottom: 0.3rem;
  }

  .f-prog {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 1.4rem;
  }
  .f-prog-bar {
    flex: 1;
    height: 2px;
    background: rgba(255,255,255,0.07);
    border-radius: 2px;
    overflow: hidden;
  }
  .f-prog-fill {
    height: 100%;
    background: linear-gradient(90deg, #e85d20, #f5a623, #ffe066);
    border-radius: 2px;
    box-shadow: 0 0 8px rgba(245, 166, 35, 0.5);
  }
  .f-prog-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    color: #f5a623;
    white-space: nowrap;
  }

  .f-hr {
    border: none;
    border-top: 1px solid rgba(255,150,80,0.12);
    margin: 0 0 1.8rem;
  }

  /* ── Filtres ── */
  .f-filtres {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }
  .f-chips-groupe {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .f-chips-sep {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    color: rgba(255,255,255,0.2);
    padding: 0 0.15rem;
    user-select: none;
  }

  .f-chip {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    padding: 4px 13px;
    border-radius: 20px;
    border: 1px solid rgba(255,255,255,0.1);
    background: rgba(255,255,255,0.04);
    color: rgba(255,255,255,0.4);
    cursor: pointer;
    transition: background 0.18s, color 0.18s, border-color 0.18s;
  }
  .f-chip:hover {
    background: rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.7);
    border-color: rgba(255,255,255,0.2);
  }

  /* Chip niveau actif */
  .f-chip--active {
    background: rgba(232, 160, 80, 0.15);
    border-color: rgba(232, 160, 80, 0.45);
    color: #e8a050;
  }
  .f-chip--active:hover {
    background: rgba(232, 160, 80, 0.22);
    color: #f0b060;
  }

  /* Chip rédigées — état off */
  .f-chip--rediges {
    border-color: rgba(255,230,100,0.2);
    color: rgba(255,230,100,0.45);
  }
  .f-chip--rediges:hover {
    border-color: rgba(255,230,100,0.4);
    color: rgba(255,230,100,0.8);
    background: rgba(255,230,100,0.06);
  }

  /* Chip rédigées — état on */
  .f-chip--rediges-on {
    background: rgba(255,230,100,0.13);
    border-color: rgba(255,230,100,0.55);
    color: #ffe066;
  }
  .f-chip--rediges-on:hover {
    background: rgba(255,230,100,0.2);
  }

  /* ── Niveaux ── */
  .f-niveau { margin-bottom: 3.5rem; }
  .f-niv-head { margin-bottom: 1.8rem; }

  .f-niv-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #e8a050;
    opacity: 0.8;
    display: block;
    margin-bottom: 0.3rem;
  }
  .f-niv-titre {
    font-family: 'Libre Baskerville', serif;
    font-size: 1.9rem;
    font-weight: 700;
    color: #f0d0a0;
    margin-bottom: 0.5rem;
  }
  .f-niv-desc {
    font-family: 'Mulish', sans-serif;
    font-weight: 300;
    font-size: 1rem;
    color: #d4a878;
    line-height: 1.7;
    max-width: 580px;
  }

  /* ── Domaines ── */
  .f-dom { margin-bottom: 2.2rem; }
  .f-dom-titre {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--c);
    letter-spacing: 0.04em;
    margin-bottom: 1rem;
  }
  .f-dom-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--c);
    flex-shrink: 0;
  }

  .f-grille {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 0.85rem;
  }

  /* ── Cartes ── */
  .f-carte {
    border-radius: 8px;
    padding: 1.1rem 1.2rem 1rem;
    border: 1px solid rgba(255,255,255,0.06);
    position: relative;
    overflow: hidden;
    transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
    text-decoration: none;
    display: block;
  }
  .f-carte::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--c);
    opacity: 0;
    transition: opacity 0.2s;
  }
  .f-carte--on {
    background: rgba(255,255,255,0.07);
    border-color: rgba(255,255,255,0.18);
    box-shadow: 0 2px 12px rgba(0,0,0,0.25);
    cursor: pointer;
  }
  .f-carte--on::before { opacity: 1; }
  .f-carte--on:hover {
    transform: translateY(-3px);
    border-color: rgba(255,255,255,0.28);
    box-shadow: 0 10px 28px rgba(0,0,0,0.4);
  }
  .f-carte--on:hover::before { filter: brightness(1.2); }
  .f-carte--off {
    background: rgba(0,0,0,0.15);
    border-color: rgba(255,255,255,0.04);
    opacity: 0.55;
  }

  .f-c-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.45rem;
  }
  .f-c-concept {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: #f0c878;
    line-height: 1.4;
    flex: 1;
  }
  .f-carte--off .f-c-concept { color: #a08858; }

  .f-c-lien {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    color: var(--c);
    opacity: 0.7;
    margin-left: 0.4rem;
    flex-shrink: 0;
    transition: opacity 0.2s, transform 0.2s;
  }
  .f-carte--on:hover .f-c-lien { opacity: 1; transform: translateX(3px); }

  .f-c-nom {
    font-family: 'Libre Baskerville', serif;
    font-size: 1rem;
    font-weight: 700;
    color: #e8c090;
    margin-bottom: 0.1rem;
  }
  .f-carte--off .f-c-nom { color: #b08860; }

  .f-c-dates {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    color: rgba(255,255,255,0.32);
    display: block;
    margin-bottom: 0.6rem;
  }
  .f-c-desc {
    font-family: 'Mulish', sans-serif;
    font-weight: 300;
    font-size: 0.9rem;
    color: #d4a878;
    line-height: 1.7;
    margin-top: 0.5rem;
    margin-bottom: 0.85rem;
  }
  .f-carte--off .f-c-desc { color: #9a7858; }

  .f-c-foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
    padding-top: 0.4rem;
    border-top: 1px solid rgba(255,255,255,0.05);
  }
  .f-c-val {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    color: rgba(255,255,255,0.45);
    letter-spacing: 0.02em;
  }
  .f-c-val::before {
    content: 'validité · ';
    color: rgba(255,255,255,0.25);
  }
  .f-c-avenir {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem;
    color: rgba(255,255,255,0.3);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* ── Retour ── */
  .f-retour { margin-top: 3rem; }
  .f-retour-sep {
    border-top: 1px solid rgba(255,150,80,0.1);
    margin-bottom: 1.2rem;
  }
  .f-retour-link {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    color: #7a5a3a;
    text-decoration: none;
    transition: color 0.2s;
  }
  .f-retour-link:hover { color: #f0a050; }

  @media (max-width: 640px) {
    .f-grille { grid-template-columns: 1fr; }
    .f-chips-sep { display: none; }
  }
</style>
