        .filter(d => domainesCorps.includes(d.id as Domaine))
        .map(dom => {
          const list = dom.penseurs;
          if (list.length === 0) return null;
          return (
            <div class="f-dom">
              <h3 class="f-dom-titre" style={`--c:${dom.couleur}`}>
                <span class="f-dom-dot"></span>
                {dom.label}
              </h3>
              <div class="f-grille">
                {list.map(p => {
                  const on = exploresIds.has(p.id);
                  const Tag = on ? 'a' : 'div';
                  const linkProps = on ? { href: `/atelier/${p.id}` } : {};
                  return (
                    <Tag
                      class={`f-carte ${on ? 'f-carte--on' : 'f-carte--off'}`}
                      style={`--c:${dom.couleur}`}
                      data-redige={on ? 'true' : 'false'}
                      {...linkProps}
                    >
                      <div class="f-c-top">
                        <span class="f-c-concept">{p.concept}</span>
                        {on && <span class="f-c-lien">→</span>}
                      </div>
                      <p class="f-c-nom">{p.nom}</p>
                      {p.dates && <span class="f-c-dates">{p.dates}</span>}
                      <p class="f-c-desc">{p.description}</p>
                      <div class="f-c-foot">
                        <span class="f-c-val">{p.validite}</span>
                        {!on && <span class="f-c-avenir">à venir</span>}
                      </div>
                    </Tag>
                  );
                })}
              </div>
            </div>
          );
        })
      }
    </section>

    <!-- ── NIVEAU 2 · Le monde ── -->
    <section class="f-niveau" data-filtre="monde">
      <div class="f-niv-head">
        <span class="f-niv-badge f-niv-badge--monde">niveau 2</span>
        <h2 class="f-niv-titre f-niv-titre--monde">Le monde</h2>
        <p class="f-niv-desc">Comment fonctionnent les systèmes, le pouvoir, la complexité — voir au-delà de l'individu. Et comment naviguer dans l'information sans se perdre.</p>
      </div>

      {parDomaine
        .filter(d => domainesMonde.includes(d.id as Domaine))
        .map(dom => {
          const list = dom.penseurs;
          if (list.length === 0) return null;
          return (
            <div class="f-dom">
              <h3 class="f-dom-titre" style={`--c:${dom.couleur}`}>
                <span class="f-dom-dot"></span>
