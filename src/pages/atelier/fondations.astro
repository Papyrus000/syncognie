  </div>

  <div class="f-retour">
    <div class="f-retour-sep"></div>
    <a href="/atelier" class="f-retour-link">← retour à l'atelier</a>
  </div>

</AtelierLayout>

<script>
  // ── Boot sequence fondations ─────────────────────────────────────────────
  const line1El   = document.getElementById('fLine1');
  const cursor1El = document.getElementById('fCursor1');
  const line2Wrap = document.getElementById('fLine2Wrap');
  const line2El   = document.getElementById('fLine2');
  const cursor2El = document.getElementById('fCursor2');
  const progEl    = document.getElementById('fProg');
  const progSecEl = document.getElementById('fProgSections');

  const phrase1 = "chargement des briques fondamentales...";
  const phrase2 = "critères · solidité empirique · pouvoir structurant · applicabilité";

  function typePhrase(
    textEl: HTMLElement | null,
    cursorEl: HTMLElement | null,
    phrase: string,
    delay: number,
    onDone?: () => void
  ) {
    if (!textEl || !cursorEl) return;
    let i = 0;
    cursorEl.style.opacity = '0';
    setTimeout(() => {
      const tick = () => {
        if (i < phrase.length) {
          textEl.textContent += phrase[i];
          i++;
          setTimeout(tick, 24 + Math.random() * 22);
        } else {
          cursorEl.style.opacity = '1';
          if (onDone) setTimeout(onDone, 320);
        }
      };
      tick();
    }, delay);
  }

  // Séquence : ligne 1 → ligne 2 → barres
  typePhrase(line1El, cursor1El, phrase1, 400, () => {
    // Curseur 1 s'arrête, ligne 2 apparaît
    if (cursor1El) cursor1El.style.animation = 'none', cursor1El.style.opacity = '0.3';
    if (line2Wrap) line2Wrap.style.opacity = '1';

    typePhrase(line2El, cursor2El, phrase2, 0, () => {
      // Barres apparaissent en fondu
      [progEl, progSecEl].forEach(el => {
        if (el) {
          el.classList.remove('f-prog--hidden');
          el.classList.add('f-prog--visible');
        }
      });
    });
  });
</script>

<script>
  const chips    = document.querySelectorAll<HTMLButtonElement>('.f-chip[data-filtre]');
  const chipRed  = document.getElementById('chip-rediges') as HTMLButtonElement | null;
  const sections = document.querySelectorAll<HTMLElement>('.f-niveau');
  const cartes   = document.querySelectorAll<HTMLElement>('.f-carte');

  let filtreActif = 'tout';
  let redigesOnly = false;

  function appliquerFiltres() {
    // 1. Sections
    sections.forEach(sec => {
      const f = sec.dataset.filtre ?? '';
      sec.style.display = (filtreActif === 'tout' || filtreActif === f) ? '' : 'none';
    });

    // 2. Cartes rédigées
    cartes.forEach(carte => {
      if (!redigesOnly) { carte.style.display = ''; return; }
      carte.style.display = carte.dataset.redige === 'true' ? '' : 'none';
    });

    // 3. Masquer les domaines vides
    document.querySelectorAll<HTMLElement>('.f-dom').forEach(dom => {
      const grille = dom.querySelector<HTMLElement>('.f-grille');
      if (!grille) return;
      const visibles = Array.from(grille.children).filter(
        c => (c as HTMLElement).style.display !== 'none'
      );
      dom.style.display = visibles.length === 0 ? 'none' : '';
    });
  }

  chips.forEach(chip => {
    chip.addEventListener('click', () => {
      chips.forEach(c => c.classList.remove('f-chip--active'));
      chip.classList.add('f-chip--active');
      filtreActif = chip.dataset.filtre ?? 'tout';
      appliquerFiltres();
    });
  });

  chipRed?.addEventListener('click', () => {
    redigesOnly = !redigesOnly;
    chipRed.classList.toggle('f-chip--rediges-on', redigesOnly);
    appliquerFiltres();
  });
</script>

<style>
