---
import { getCollection } from 'astro:content';
import AtelierLayout from '../../layouts/AtelierLayout.astro';
import { PENSEURS, DOMAINES } from '../../data/penseurs';
// Note: penseurs.ts now includes a `detail` field for mode 2
import type { Domaine } from '../../data/penseurs';

const entrees = await getCollection('atelier');
const exploresIds = new Set(
  entrees.filter(e => e.data.penseur).map(e => e.data.penseur as string)
);

const parDomaine = (Object.entries(DOMAINES) as [Domaine, { label: string; couleur: string }][])
  .map(([id, domaine]) => ({
    id,
    ...domaine,
    penseurs: PENSEURS.filter(p => p.domaine === id),
  }));

// Groupes de domaines par section
const domainesSoi:   Domaine[] = ['cerveau', 'construction', 'relations', 'sens'];
const domainesCorps: Domaine[] = ['corps-sommeil', 'corps-mouvement', 'corps-metabolisme'];
const domainesMonde: Domaine[] = ['systemes', 'pouvoir'];
const domainesViv:   Domaine[] = ['philosophie'];

// Progression globale
const total    = PENSEURS.length;
const explores = PENSEURS.filter(p => exploresIds.has(p.id)).length;
const pct      = Math.round((explores / total) * 100);

// Progression par section (pour la barre en haut)
function progSection(domaines: Domaine[]) {
  const t = PENSEURS.filter(p => domaines.includes(p.domaine)).length;
  const e = PENSEURS.filter(p => domaines.includes(p.domaine) && exploresIds.has(p.id)).length;
  return { total: t, explores: e, pct: t > 0 ? Math.round((e / t) * 100) : 0 };
}

const progSoi   = progSection(domainesSoi);
const progCorps = progSection(domainesCorps);
const progMonde = progSection(domainesMonde);
const progViv   = progSection(domainesViv);
---

<AtelierLayout title="Fondations" filename="fondations">

  <div class="f-header">

    <!-- Titre terminal -->
    <div class="f-titre-terminal">
      <span class="f-titre-prefix">//</span>
      <h1 class="f-titre-main">fondations</h1>
    </div>

    <!-- Lignes terminal -->
    <div class="f-terminal-bloc" id="fTerminal" aria-live="polite">
      <div class="f-term-line">
        <span class="f-term-prompt">&gt;</span>
        <span class="f-term-text" id="fLine1"></span><span class="f-term-cursor" id="fCursor1">_</span>
      </div>
      <div class="f-term-line f-term-line--hidden" id="fLine2Wrap">
        <span class="f-term-prompt">&gt;</span>
        <span class="f-term-text" id="fLine2"></span><span class="f-term-cursor" id="fCursor2">_</span>
      </div>
    </div>

    <!-- Barre globale -->
    <div class="f-prog f-prog--hidden" id="fProg">
      <div class="f-prog-bar">
        <div class="f-prog-fill" style={`width:${pct}%`}></div>
      </div>
      <span class="f-prog-label">{explores} / {total} explorés</span>
    </div>

    <!-- Mini-barres par section -->
    <div class="f-prog-sections f-prog--hidden" id="fProgSections">
      {[
        { label: 'Soi',    prog: progSoi,   couleur: '#f5a623' },
        { label: 'Corps',  prog: progCorps, couleur: '#5dbe8a' },
        { label: 'Monde',  prog: progMonde, couleur: '#5090a8' },
        { label: 'Vivre',  prog: progViv,   couleur: '#8a9e5a' },
      ].map(s => (
        <div class="f-prog-sec">
          <span class="f-prog-sec-label" style={`color:${s.couleur}`}>{s.label}</span>
          <div class="f-prog-sec-bar">
            <div class="f-prog-sec-fill" style={`width:${s.prog.pct}%; background:${s.couleur}`}></div>
          </div>
          <span class="f-prog-sec-compte" style={`color:${s.couleur}`}>{s.prog.explores}/{s.prog.total}</span>
        </div>
      ))}
    </div>
  </div>

  <hr class="f-hr" />

  <!-- Barre de filtres chips -->
  <div class="f-filtres">
    <div class="f-chips-groupe">
      <button class="f-chip f-chip--active" data-filtre="tout">Tout</button>
      <button class="f-chip" data-filtre="soi">Niveau 1 · Soi</button>
      <button class="f-chip f-chip--corps" data-filtre="corps">Niveau 1 · Corps</button>
      <button class="f-chip" data-filtre="monde">Niveau 2 · Le monde</button>
      <button class="f-chip" data-filtre="vivre">Niveau 3 · Vivre</button>
    </div>
    <span class="f-chips-sep">·</span>
    <button class="f-chip f-chip--rediges" id="chip-rediges">✦ Rédigées</button>
  </div>

  <!-- Contenu filtrable -->
  <div id="f-contenu">

    <!-- ── NIVEAU 1 · Soi ── -->
    <section class="f-niveau" data-filtre="soi">
      <div class="f-niv-head">
        <span class="f-niv-badge f-niv-badge--soi">niveau 1</span>
        <h2 class="f-niv-titre f-niv-titre--soi">Soi</h2>
        <p class="f-niv-desc">Ce qu'il faut comprendre avant tout le reste — comment je fonctionne, comment je me construis, comment je me relie aux autres, pourquoi je fais ce que je fais.</p>
      </div>

      {parDomaine
        .filter(d => domainesSoi.includes(d.id as Domaine))
        .map(dom => {
          const list = dom.penseurs;
          if (list.length === 0) return null;
          return (
            <div class="f-dom">
              <h3 class="f-dom-titre" style={`--c:${dom.couleur}`}>
                <span class="f-dom-dot"></span>
                {dom.label}
              </h3>
              <div class="f-grille">
                {list.map(p => {
                  const on = exploresIds.has(p.id);
                  const hasDetail = !!(p as any).detail;
                  return (
                    <div
                      class={`f-carte ${on ? 'f-carte--on' : 'f-carte--off'}`}
                      style={`--c:${dom.couleur}`}
                      data-redige={on ? 'true' : 'false'}
                      data-id={p.id}
                      data-has-detail={hasDetail ? 'true' : 'false'}
