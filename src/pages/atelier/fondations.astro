                          )}
                          <button class="f-c-fermer" aria-label="Fermer">✕ fermer</button>
                        </div>
                      )}
                    </div>
                  );
                })}
              </div>
            </div>
          );
        })
      }
    </section>

    <!-- ── NIVEAU 1b · Corps ── -->
