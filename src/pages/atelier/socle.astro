---
import AtelierLayout from '../../layouts/AtelierLayout.astro';
import { parse } from 'yaml';
import { readFileSync } from 'fs';
import path from 'path';

const yamlPath = path.resolve(process.cwd(), 'src/data/concepts.yaml');
const raw = readFileSync(yamlPath, 'utf-8');
const data      = parse(raw) as {
  meta: {
    questions: { id: string; label: string }[]
  };
  concepts: {
    titre: string;
    vocabulaire: string[];
    question: string;
    domaine: string;
    penseur: string;
    statut: 'solide' | 'nuance' | 'emergent';
    definition_courte: string;
    definition: string;
    utilite: string;
    pattern: string;
    concepts_lies: string[];
  }[]
};

const { questions } = data.meta;
const concepts = data.concepts;

const parQuestion = questions.map(q => ({
  ...q,
  concepts: concepts.filter(c => c.question === q.id),
}));

const total = concepts.length;

const couleurs: Record<string, string> = {
  comportement: '#e8943a',
  emotions:     '#e8b832',
  changement:   '#7abd6e',
  relations:    '#e87070',
  influence:    '#9b6fd4',
  conflits:     '#e07890',
  corps:        '#5daa88',
  sante:        '#5090a8',
  decisions:    '#c88840',
  clarte:       '#8a9e5a',
};

const statutLabel: Record<string, string> = {
  solide:   'solide',
  nuance:   'nuancé',
  emergent: 'émergent',
};
---

<AtelierLayout
  title="Fondations étendues — Extension"
  description="50 concepts, 10 questions, les penseurs et patterns qui éclairent la vie. Un socle de connaissance utile filtré et organisé."
  filename="fondations étendues"
>

  <!-- ── En-tête style terminal ── -->
  <div class="s-header">
    <div class="s-titre-terminal">
      <span class="s-titre-prefix">//</span>
      <h1 class="s-titre-main">fondations étendues</h1>
    </div>
    <div class="s-terminal-bloc">
      <div class="s-term-line">
        <span class="s-term-prompt">&gt;</span>
        <span class="s-term-text" id="sLine1"></span><span class="s-term-cursor" id="sCursor1">_</span>
      </div>
      <div class="s-term-line s-term-line--hidden" id="sLine2Wrap">
        <span class="s-term-prompt">&gt;</span>
        <span class="s-term-text" id="sLine2"></span><span class="s-term-cursor" id="sCursor2">_</span>
      </div>
    </div>
    <div class="s-meta-ligne s-meta--hidden" id="sMeta">
      <span class="s-meta-item">{total} concepts</span>
      <span class="s-meta-sep">·</span>
      <span class="s-meta-item">10 questions</span>
      <span class="s-meta-sep">·</span>
      <span class="s-meta-item">filtre épistémique appliqué</span>
    </div>
  </div>

  <hr class="s-hr" />

  <!-- ── Barre de recherche ── -->
  <div class="s-search-wrap">
    <div class="s-search-inner">
      <span class="s-search-icon" aria-hidden="true">//</span>
      <input
        type="text"
        id="sSearchInput"
        class="s-search-input"
        placeholder="rechercher — concept, penseur, domaine, pattern…"
        autocomplete="off"
        spellcheck="false"
      />
      <button class="s-search-clear" id="sSearchClear" aria-label="Effacer la recherche" hidden>✕</button>
    </div>
    <div class="s-search-status" id="sSearchStatus" hidden>
      <span id="sSearchCount" class="s-search-count"></span>
      <span class="s-search-status-sep">·</span>
      <button class="s-search-reset" id="sSearchReset" type="button">tout afficher</button>
    </div>
  </div>

  <!-- ── Bandeau de navigation par questions ── -->
  <div class="s-nav" id="sNav">
    {questions.map(q => (
      <button
        class="s-nav-chip"
        data-q={q.id}
        style={`--c: ${couleurs[q.id] ?? '#e8a050'}`}
        onclick={`scrollToSection('${q.id}')`}
      >
        <span class="s-nav-num">{String(questions.indexOf(q) + 1).padStart(2, '0')}</span>
        <span class="s-nav-label">{q.label.replace('Pourquoi ', '').replace('Comment ', '').replace('?', '')}</span>
      </button>
    ))}
  </div>

  <!-- ── Contenu par question ── -->
  <div id="s-contenu">
    {parQuestion.map((q, qi) => (
      <section class="s-section" id={`section-${q.id}`} data-q={q.id}>

        <div class="s-sec-head" style={`--c: ${couleurs[q.id] ?? '#e8a050'}`}>
          <span class="s-sec-num">{String(qi + 1).padStart(2, '0')}</span>
          <h2 class="s-sec-titre">{q.label}</h2>
          <span class="s-sec-compte">{q.concepts.length} concepts</span>
        </div>

        <div class="s-grille">
          {q.concepts.map(c => (
            <div
              class="s-carte"
              style={`--c: ${couleurs[c.question] ?? '#e8a050'}`}
              data-slug={c.titre.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[''`]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '')}
              data-search={[
                c.titre,
                c.definition_courte,
                c.penseur,
                c.domaine,
                c.pattern,
                ...(c.vocabulaire ?? []),
              ].join(' ').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '')}
              role="button"
              tabindex="0"
            >
              <div class="s-c-mode1">
                <div class="s-c-top">
                  <h3 class="s-c-titre">{c.titre}</h3>
                  <span class="s-c-toggle" aria-label="Développer">▾</span>
                </div>
                <div class="s-c-meta">
                  <span class={`s-c-statut s-c-statut--${c.statut}`}>{statutLabel[c.statut]}</span>
                  <span class="s-c-domaine">{c.domaine}</span>
                </div>
                <p class="s-c-penseur">{c.penseur}</p>
                <p class="s-c-def-courte">{c.definition_courte}</p>
                <div class="s-c-pattern">
                  <span class="s-c-pattern-label">pattern</span>
                  <span class="s-c-pattern-text">{c.pattern}</span>
                </div>
              </div>

              <div class="s-c-open-head" hidden>
                <div class="s-c-top">
                  <p class="s-c-titre" aria-hidden="true">{c.titre}</p>
                  <span class="s-c-toggle s-c-toggle--open">▾</span>
                </div>
                <div class="s-c-meta">
                  <span class={`s-c-statut s-c-statut--${c.statut}`}>{statutLabel[c.statut]}</span>
                  <span class="s-c-domaine">{c.domaine}</span>
                </div>
                <p class="s-c-penseur">{c.penseur}</p>
              </div>

              <div class="s-c-mode2" hidden>
                <div class="s-c-sep"></div>

                <div class="s-c-bloc">
                  <span class="s-c-bloc-label">définition</span>
                  <div class="s-c-bloc-paras">
                    {c.definition.split('\n\n').filter((p: string) => p.trim()).map((para: string) => (
                      <p class="s-c-bloc-text">{para.trim()}</p>
                    ))}
                  </div>
                </div>

                <div class="s-c-bloc">
                  <span class="s-c-bloc-label">utilité concrète</span>
                  <div class="s-c-bloc-paras">
                    {c.utilite.split('\n\n').filter((p: string) => p.trim()).map((para: string) => (
                      <p class="s-c-bloc-text">{para.trim()}</p>
                    ))}
                  </div>
                </div>

                <div class="s-c-bloc">
                  <span class="s-c-bloc-label">pattern</span>
                  <div class="s-c-pattern s-c-pattern--open">
                    <span class="s-c-pattern-text">{c.pattern}</span>
                  </div>
                </div>

                <div class="s-c-bloc s-c-bloc--vocab">
                  <span class="s-c-bloc-label">vocabulaire clé</span>
                  <div class="s-c-tags">
                    {c.vocabulaire.map(v => (
                      <span class="s-c-tag">{v}</span>
                    ))}
                  </div>
                </div>

                {c.concepts_lies.length > 0 && (
                  <div class="s-c-bloc s-c-bloc--lies">
                    <span class="s-c-bloc-label">concepts liés</span>
                    <div class="s-c-tags">
                      {c.concepts_lies.map((slug: string) => (
                        <button class="s-c-tag s-c-tag--lie" data-target={slug} type="button">
                          {slug.replace(/-/g, ' ')}
                        </button>
                      ))}
                    </div>
                  </div>
                )}

                <button class="s-c-fermer" aria-label="Fermer">✕ fermer</button>
              </div>

            </div>
          ))}
        </div>

      </section>
    ))}
  </div>

  <!-- ── Message aucun résultat ── -->
  <div class="s-no-result" id="sNoResult" hidden>
    <span class="s-no-result-icon">//</span>
    <span class="s-no-result-text">aucun concept pour « <span id="sNoResultQuery"></span> »</span>
  </div>

  <!-- ── Retour ── -->
  <div class="s-retour">
    <hr class="s-retour-sep" />
    <a href="/atelier" class="s-retour-link">← atelier</a>
  </div>

</AtelierLayout>

<script>
  function toSlug(s: string): string {
    return s.toLowerCase()
      .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
      .replace(/[''`]/g, '')
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-|-$/g, '');
  }

  function offsetRelativeTo(el: HTMLElement, container: HTMLElement): number {
    let top = 0;
    let cur: HTMLElement | null = el;
    while (cur && cur !== container) {
      top += cur.offsetTop;
      cur = cur.offsetParent as HTMLElement | null;
    }
    return top;
  }

  (window as any).scrollToSection = function(id: string) {
    const el      = document.getElementById(`section-${id}`);
    const content = document.getElementById('atelierContent');
    if (el && content) {
      const top = offsetRelativeTo(el, content) - 80;
      content.scrollTo({ top, behavior: 'smooth' });
    }
  };

  // ── Accordéon ────────────────────────────────────────────────────────────────
  const atelierContent = document.getElementById('atelierContent');

  document.querySelectorAll<HTMLElement>('.s-carte').forEach(carte => {

    function openCarte() {
      document.querySelectorAll<HTMLElement>('.s-carte--open').forEach(other => {
        if (other === carte) return;
        other.classList.remove('s-carte--open');
        const m1 = other.querySelector<HTMLElement>('.s-c-mode1');
        const m2 = other.querySelector<HTMLElement>('.s-c-mode2');
        const oh = other.querySelector<HTMLElement>('.s-c-open-head');
        if (m1) m1.hidden = false;
        if (m2) m2.hidden = true;
        if (oh) oh.hidden = true;
      });
      carte.classList.add('s-carte--open');
      const mode1    = carte.querySelector<HTMLElement>('.s-c-mode1');
      const mode2    = carte.querySelector<HTMLElement>('.s-c-mode2');
      const openHead = carte.querySelector<HTMLElement>('.s-c-open-head');
      if (mode1)    mode1.hidden    = true;
      if (mode2)    mode2.hidden    = false;
      if (openHead) openHead.hidden = false;
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          if (atelierContent) {
            const carteTop  = offsetRelativeTo(carte, atelierContent);
            const fixedBar  = atelierContent.querySelector<HTMLElement>('header, nav, [class*="topbar"], [class*="header"]');
            const barHeight = fixedBar ? fixedBar.offsetHeight : 52;
            atelierContent.scrollTo({ top: carteTop - barHeight - 8, behavior: 'smooth' });
          }
        });
      });
    }

    function closeCarte() {
      const snapTop = atelierContent
        ? offsetRelativeTo(carte, atelierContent) - atelierContent.scrollTop
        : 0;
      carte.classList.remove('s-carte--open');
      const mode1    = carte.querySelector<HTMLElement>('.s-c-mode1');
      const mode2    = carte.querySelector<HTMLElement>('.s-c-mode2');
      const openHead = carte.querySelector<HTMLElement>('.s-c-open-head');
      if (mode1)    mode1.hidden    = false;
      if (mode2)    mode2.hidden    = true;
      if (openHead) openHead.hidden = true;
      requestAnimationFrame(() => {
        if (atelierContent) {
          const newTop = offsetRelativeTo(carte, atelierContent);
          atelierContent.scrollTop = newTop - snapTop;
        }
      });
    }

    function toggle(e: Event) {
      if ((e.target as HTMLElement).closest('.s-c-fermer')) return;
      carte.classList.contains('s-carte--open') ? closeCarte() : openCarte();
    }

    carte.addEventListener('click', toggle);
    carte.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggle(e); }
    });

    const fermer = carte.querySelector<HTMLElement>('.s-c-fermer');
    if (fermer) {
      fermer.addEventListener('click', (e: Event) => { e.stopPropagation(); closeCarte(); });
    }
  });

  // ── Concepts liés ─────────────────────────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('.s-c-tag--lie').forEach(btn => {
    btn.addEventListener('click', (e: Event) => {
      e.stopPropagation();
      const slug = toSlug((btn as HTMLElement).dataset.target ?? '');
      if (!slug) return;
      const allCartes = document.querySelectorAll<HTMLElement>('.s-carte');
      let target: HTMLElement | null = null;
      allCartes.forEach(c => { if (toSlug(c.dataset.slug ?? '') === slug) target = c; });
      if (!target || !atelierContent) return;
      const parentCarte = btn.closest<HTMLElement>('.s-carte');
      if (parentCarte) {
        parentCarte.classList.remove('s-carte--open');
        const m1 = parentCarte.querySelector<HTMLElement>('.s-c-mode1');
        const m2 = parentCarte.querySelector<HTMLElement>('.s-c-mode2');
        const oh = parentCarte.querySelector<HTMLElement>('.s-c-open-head');
        if (m1) m1.hidden = false;
        if (m2) m2.hidden = true;
        if (oh) oh.hidden = true;
      }
      const tm1 = target.querySelector<HTMLElement>('.s-c-mode1');
      const tm2 = target.querySelector<HTMLElement>('.s-c-mode2');
      const toh = target.querySelector<HTMLElement>('.s-c-open-head');
      target.classList.add('s-carte--open');
      if (tm1) tm1.hidden = true;
      if (tm2) tm2.hidden = false;
      if (toh) toh.hidden = false;
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          if (atelierContent && target) {
            const top       = offsetRelativeTo(target, atelierContent);
            const fixedBar  = atelierContent.querySelector<HTMLElement>('header, nav, [class*="topbar"], [class*="header"]');
            const barHeight = fixedBar ? fixedBar.offsetHeight : 52;
            atelierContent.scrollTo({ top: top - barHeight - 8, behavior: 'smooth' });
          }
        });
      });
    });
  });

  // ── Nav chips ─────────────────────────────────────────────────────────────────
  const content  = document.getElementById('atelierContent');
  const sections = document.querySelectorAll<HTMLElement>('.s-section');
  const chips    = document.querySelectorAll<HTMLElement>('.s-nav-chip');
  if (content) {
    content.addEventListener('scroll', () => {
      let current = '';
      sections.forEach(sec => {
        if (offsetRelativeTo(sec, content) - 160 <= content.scrollTop) current = sec.dataset.q ?? '';
      });
      chips.forEach(chip => {
        chip.classList.toggle('s-nav-chip--active', chip.dataset.q === current);
      });
    }, { passive: true });
  }

  // ── Animation terminal ────────────────────────────────────────────────────────
  const line1El   = document.getElementById('sLine1')     as HTMLElement | null;
  const cursor1   = document.getElementById('sCursor1')   as HTMLElement | null;
  const line2Wrap = document.getElementById('sLine2Wrap') as HTMLElement | null;
  const line2El   = document.getElementById('sLine2')     as HTMLElement | null;
  const cursor2   = document.getElementById('sCursor2')   as HTMLElement | null;
  const metaEl    = document.getElementById('sMeta')      as HTMLElement | null;

  function typeText(el: HTMLElement, cursor: HTMLElement, text: string, delay: number, onDone?: () => void) {
    let i = 0;
    setTimeout(() => {
      const iv = setInterval(() => {
        el.textContent += text[i]; i++;
        if (i >= text.length) { clearInterval(iv); cursor.style.display = 'none'; onDone?.(); }
      }, 32);
    }, delay);
  }

  if (line1El && cursor1) {
    typeText(line1El, cursor1, 'la connaissance utile dans une vie', 300, () => {
      if (line2Wrap && line2El && cursor2) {
        line2Wrap.classList.remove('s-term-line--hidden');
        typeText(line2El, cursor2, 'filtre épistémique · penseurs · patterns', 200, () => {
          if (metaEl) { metaEl.classList.remove('s-meta--hidden'); metaEl.classList.add('s-meta--visible'); }
        });
      }
    });
  }

  // ── RECHERCHE LIVE ────────────────────────────────────────────────────────────
  const searchInput   = document.getElementById('sSearchInput')   as HTMLInputElement  | null;
  const searchClear   = document.getElementById('sSearchClear')   as HTMLButtonElement | null;
  const searchStatus  = document.getElementById('sSearchStatus')  as HTMLElement       | null;
  const searchCount   = document.getElementById('sSearchCount')   as HTMLElement       | null;
  const searchReset   = document.getElementById('sSearchReset')   as HTMLButtonElement | null;
  const noResult      = document.getElementById('sNoResult')      as HTMLElement       | null;
  const noResultQuery = document.getElementById('sNoResultQuery') as HTMLElement       | null;
  const navEl         = document.getElementById('sNav')           as HTMLElement       | null;

  const allCartes   = document.querySelectorAll<HTMLElement>('.s-carte');
  const allSections = document.querySelectorAll<HTMLElement>('.s-section');

  function normalise(s: string): string {
    return s.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
  }

  function applySearch(raw: string) {
    const query  = normalise(raw.trim());
    if (!query) { resetSearch(); return; }

    // AND implicite : tous les tokens doivent matcher
    const tokens = query.split(/\s+/).filter(Boolean);
    let visible  = 0;

    allCartes.forEach(carte => {
      const match = tokens.every(t => (carte.dataset.search ?? '').includes(t));
      carte.style.display = match ? '' : 'none';
      if (match) visible++;
    });

    // Masquer les sections vides
    allSections.forEach(sec => {
      const hasVisible = [...sec.querySelectorAll<HTMLElement>('.s-carte')].some(c => c.style.display !== 'none');
      sec.style.display = hasVisible ? '' : 'none';
    });

    // Masquer la nav (ne sert à rien en mode filtre)
    if (navEl) navEl.style.display = 'none';

    // Statut
    if (searchStatus && searchCount) {
      searchStatus.hidden = false;
      searchCount.textContent = `${visible} résultat${visible !== 1 ? 's' : ''}`;
    }

    // Aucun résultat
    if (noResult && noResultQuery) {
      noResult.hidden           = visible > 0;
      noResultQuery.textContent = raw.trim();
    }

    if (searchClear) searchClear.hidden = false;
  }

  function resetSearch() {
    allCartes.forEach(c   => (c.style.display   = ''));
    allSections.forEach(s => (s.style.display   = ''));
    if (navEl)        navEl.style.display        = '';
    if (searchStatus) searchStatus.hidden        = true;
    if (noResult)     noResult.hidden            = true;
    if (searchClear)  searchClear.hidden         = true;
    if (searchInput)  searchInput.value          = '';
  }

  let debounceTimer: ReturnType<typeof setTimeout>;

  if (searchInput) {
    searchInput.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => applySearch(searchInput.value), 120);
    });
    searchInput.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape') resetSearch();
    });
  }

  if (searchClear) searchClear.addEventListener('click', () => resetSearch());
  if (searchReset) searchReset.addEventListener('click', () => resetSearch());
</script>

<style>

  /* ── Header ── */
  .s-header { margin-bottom: 1.6rem; }
  .s-titre-terminal { display: flex; align-items: baseline; gap: 0.6rem; margin-bottom: 1.2rem; }
  .s-titre-prefix {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1.3rem; color: #7abd6e; opacity: 0.7; user-select: none;
  }
  .s-titre-main {
    font-family: 'JetBrains Mono', monospace;
    font-weight: 500; font-size: 1.6rem; color: #f0c878; letter-spacing: 0.04em;
  }
  .s-terminal-bloc { display: flex; flex-direction: column; gap: 0.35rem; margin-bottom: 1.4rem; }
  .s-term-line { display: flex; align-items: baseline; gap: 0.55rem; }
  .s-term-line--hidden { opacity: 0; }
  .s-term-prompt {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem; color: #7abd6e; flex-shrink: 0; user-select: none; opacity: 0.75;
  }
  .s-term-text {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82rem; color: rgba(212,168,100,0.78); letter-spacing: 0.02em; font-style: italic;
  }
  .s-term-cursor {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82rem; color: #7abd6e; animation: sBlink 1.1s step-end infinite;
  }
  @keyframes sBlink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

  .s-meta-ligne { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; transition: opacity 0.5s ease, transform 0.5s ease; }
  .s-meta--hidden  { opacity: 0; transform: translateY(6px); }
  .s-meta--visible { opacity: 1; transform: translateY(0); }
  .s-meta-item {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.65rem; color: #6a4828; letter-spacing: 0.06em; text-transform: uppercase;
  }
  .s-meta-sep { color: rgba(255,150,80,0.25); font-size: 0.7rem; }

  .s-c-mode1[hidden],
  .s-c-mode2[hidden] { display: none; }

  .s-hr { border: none; border-top: 1px solid rgba(255,150,80,0.12); margin: 1.2rem 0; }

  /* ── BARRE DE RECHERCHE ─────────────────────────────────────────────────────── */
  .s-search-wrap { margin-bottom: 1.2rem; }

  .s-search-inner {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,150,80,0.18);
    border-radius: 8px;
    padding: 0.55rem 0.85rem;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .s-search-inner:focus-within {
    border-color: rgba(232,148,58,0.5);
    box-shadow: 0 0 0 3px rgba(232,148,58,0.09), 0 2px 14px rgba(0,0,0,0.18);
  }

  .s-search-icon {
