---
import BaseLayout from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const allCarnet   = await getCollection('carnet');
const allFenetres = await getCollection('fenetres');
const allJournal  = await getCollection('journal', ({ data }) => !data.draft);
const journalEntries = allJournal.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const allNouvelles = await getCollection('nouvelles', ({ data }) => !data.draft);
const nouvellesEntries = allNouvelles.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Jardin — notes libres, triées par date décroissante
let allJardin = [];
try { allJardin = await getCollection('jardin'); } catch (e) {}
const jardinNotes = allJardin.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Sous la surface — articles interactifs
let allSousLaSurface = [];
try { allSousLaSurface = await getCollection('sous-la-surface', ({ data }) => !data.draft); } catch (e) {}
const slsEntries = allSousLaSurface.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const serieNotes = allArticles
  .filter(a => a.data.serie === "Notes d'un modèle en construction")
  .sort((a, b) => (a.data.episode ?? 0) - (b.data.episode ?? 0)); // ordre des épisodes croissant

const serieDialogues = allArticles
  .filter(a => a.data.serie === "Les rencontres de Nathalie et Élodie")
  .sort((a, b) => (a.data.episode ?? 0) - (b.data.episode ?? 0));

const serieMecanique = allArticles
  .filter(a => a.data.serie === "Mécanique")
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()); // plus récent en premier

const fenetresAnalyses = allArticles
  .filter(a => !!a.data.lien_fenetre);

const nbCartes = serieNotes.length + serieMecanique.length + fenetresAnalyses.length;

const recents = [...allArticles, ...allCarnet, ...allFenetres]
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

// Premier épisode de Vies (épisode 1)
const premierEpisodeVies = [...serieDialogues].sort((a, b) => (a.data.episode ?? 0) - (b.data.episode ?? 0))[0];

// Tous les outils — dérivés automatiquement depuis src/data/outils.ts
import { outils as tousOutils } from '../data/outils';
const STATUT_SOMMAIRE: Record<string, string> = { 'actif': 'disponible', 'en-cours': 'disponible', 'bientot': 'bientot', 'idee': 'idee' };
const outilsSommaire = [...tousOutils].reverse().map(o => ({
  titre:   o.titre,
  desc:    o.desc,
  icone:   o.icone,
  couleur: o.color,
  lien:    o.lien,
  statut:  STATUT_SOMMAIRE[o.statut] ?? o.statut,
}));

function stadeLabel(stade?: string) {
  if (stade === 'pousse') return '🌿 Pousse';
  if (stade === 'arbre')  return '🌳 Arbre';
  return '🌱 Graine';
}

function formatDate(date: Date) {
  return date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
}

function formatDateShort(date: Date) {
  return date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'short', year: 'numeric' });
}
---

<BaseLayout title="Syncognie — Synergie · Cognition · Dialogue" description="Des concepts qui se rencontrent, se frottent, s'éclairent — et font naître ce qu'aucun ne contenait seul. Jardin numérique en croissance.">

<!-- ══ HERO ══ -->
<section class="hero">
  <div class="hero-left">
    <p class="hero-eyebrow">Synergie · Cognition · Dialogue</p>
    <h1 class="hero-titre">Rassembler les idées.<br><em>Accompagner la synergie.</em></h1>
    <p class="hero-sous">Des concepts qui se rencontrent, se frottent, s'éclairent... et font naître ce qu'aucun ne contenait seul.<br> Un atelier de pensée...</p>
    <div class="hero-note">
      <span class="hero-note-g">✦</span>
      <p class="hero-note-t">Jardin numérique en croissance. Un espace vivant où chaque note évolue à son rythme.</p>
    </div>
  </div>
  <div class="hero-graphe">
    <canvas id="emergence-canvas" width="280" height="320"
      aria-label="Graphe d'émergence — des concepts qui se rencontrent, se frottent et font naître une propriété nouvelle"></canvas>
  </div>
</section>

<!-- ══ PORTES ══ -->
<div class="portes-wrap">

  <!-- VIES -->
  <a class="porte porte--vies" href="/vies">
    <div class="porte-barre"></div>
    <div class="porte-halo"></div>
    <div class="porte-inner">

      <div class="porte-eyebrow">Vies</div>

      <h2 class="porte-titre">Des personnages qui vivent<br><em>ce qu'ils ne comprennent pas encore.</em></h2>

      <p class="porte-sous">Des dialogues entre personnages où les concepts arrivent par la vie avant d'être nommés.</p>

      <div class="dial-zone">
        <div class="dial-echanges">
          <div class="dial-rp">
            <span class="dial-nom dial-nom--n">Nathalie</span>
            <div class="dial-txt">Le mouvement qui continue parce que personne lui a dit d'arrêter.</div>
          </div>
          <div class="dial-rp">
            <span class="dial-nom dial-nom--e">Élodie</span>
            <div class="dial-txt">Exactement. Et ça peut se refermer sur n'importe quoi. Pas besoin d'une substance.</div>
          </div>
        </div>
        <p class="dial-ellipse">…</p>
        <div class="dial-echanges">
          <div class="dial-rp">
            <span class="dial-nom dial-nom--e">Élodie</span>
            <div class="dial-txt">Peut-être. Ou peut-être que c'est ce qu'on se dit pour se sentir moins démunis.</div>
          </div>
        </div>
      </div>

      <div class="porte-pied">
        <div class="porte-tags">
          <span class="ptag ptag--vies">Dialogues</span>
          <span class="ptag ptag--vies">Fenêtres</span>
          <span class="ptag ptag--vies">Fragments</span>
        </div>
        <span class="porte-cta">Entrer <span class="cta-arr">→</span></span>
      </div>

    </div>
  </a>

  <!-- CARTES -->
  <a class="porte porte--cartes" href="/cartes">
    <div class="porte-barre"></div>
    <div class="cartes-reglure"></div>
    <div class="porte-inner">

      <div class="porte-eyebrow">Cartes</div>

      <h2 class="porte-titre">Des mécanismes retournés<br><em>jusqu'à ce qu'ils parlent.</em></h2>

      <p class="porte-sous">Des analyses qui convoquent plusieurs penseurs sur un même phénomène. Gottman, McGilchrist, Kahneman et d'autres...</p>

      <div class="penseurs-zone">
        <div class="penseur">
          <span class="p-nom">Gödel</span>
          <span class="p-phrase">tout système assez riche contient des vérités qu'il ne peut pas prouver</span>
          <span class="p-badge p-badge--or">Prisme</span>
        </div>
        <div class="penseur">
          <span class="p-nom">McGilchrist</span>
          <span class="p-phrase">l'hémisphère gauche ne sait pas ce qu'il ne sait pas</span>
          <span class="p-badge p-badge--bl">Note</span>
        </div>
        <div class="penseur">
          <span class="p-nom">Gottman</span>
          <span class="p-phrase">ce n'est pas la crise qui détruit — c'est l'accumulation des micro-retraits</span>
          <span class="p-badge p-badge--or">Prisme</span>
        </div>
      </div>

      <div class="kz-encart">
        <span class="kz-q">"</span>
        <p class="kz-txt">La carte n'est pas le territoire.</p>
        <span class="kz-src">Alfred Korzybski · 1931</span>
      </div>

      <div class="porte-pied">
        <div class="porte-tags">
          <span class="ptag ptag--or">Prismes</span>
          <span class="ptag ptag--vi">Fenêtres→</span>
          <span class="ptag ptag--bl">Notes</span>
        </div>
        <span class="porte-cta">Cartographier <span class="cta-arr">→</span></span>
      </div>

    </div>
  </a>

</div>

<!-- ══ EXPLORER ══ -->
<section class="explorer">

  <div class="explorer-sep">
    <div class="sep-line"></div>
    <span class="sep-lbl">Explorer par entrée</span>
    <div class="sep-line"></div>
  </div>

  <div class="explorer-row">

    <!-- VERT — Sommaire -->
    <div class="cadre cadre--vert">
      <div class="cadre-hd">
        <div class="cadre-ey">
          <div class="cadre-dot"></div>
          <span class="cadre-lbl">Sommaire</span>
        </div>
        <a class="cadre-lnk" href="/articles">Tout voir →</a>
      </div>
      <div class="cadre-bd">
        <ul class="toc">

          <!-- ── I. CARTES ── -->
          <li class="toc-section">
            <a class="toc-row toc-row--section" href="/cartes">
              <span class="toc-n">I</span>
              <span class="toc-name">Cartes</span>
              <span class="toc-dots"></span>
              <span class="toc-desc">Mécanismes retournés jusqu'à ce qu'ils parlent</span>
              <span class="toc-ct">{nbCartes} cartes</span>
            </a>

            <!-- Sous-rubriques -->
            <ul class="toc-sub">

              <!-- Prismes -->
              <li>
                <div class="toc-sub-row toc-sub-row--mecanique-hd">
                  <span class="toc-sub-bullet">↳</span>
                  <a class="toc-sub-name toc-sub-name--lien" href="/cartes#prismes">Prismes</a>
                  <span class="toc-sub-ct">{serieNotes.length} notes</span>
                </div>
                <ul class="toc-mecanique">
                  {serieNotes.map((note) => (
                    <li>
                      <a class="toc-mec-item" href={`/articles/${note.id}`}>
                        <span class="toc-mec-ep">Ép. {String(note.data.episode ?? '').padStart(2,'0')}</span>
                        <span class="toc-mec-titre">{note.data.title}</span>
                        <span class="toc-mec-arr">→</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </li>

              <!-- Mécanique -->
              <li>
                <div class="toc-sub-row toc-sub-row--mecanique-hd">
                  <span class="toc-sub-bullet">↳</span>
                  <a class="toc-sub-name toc-sub-name--lien" href="/series/mecanique">Mécanique</a>
                  <span class="toc-sub-ct">{serieMecanique.length} notes</span>
                </div>
                <!-- Liste des notes Mécanique par date -->
                <ul class="toc-mecanique">
                  {serieMecanique.map((note) => (
                    <li>
                      <a class="toc-mec-item" href={`/articles/${note.id}`}>
                        <span class="toc-mec-date">{formatDateShort(note.data.date)}</span>
                        <span class="toc-mec-titre">{note.data.title}</span>
                        <span class="toc-mec-arr">→</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </li>

            </ul>
          </li>

          <!-- ── II. VIES ── -->
          <li class="toc-section">
            <a class="toc-row toc-row--section" href="/vies">
              <span class="toc-n">II</span>
              <span class="toc-name">Vies</span>
              <span class="toc-dots"></span>
              <span class="toc-desc">Dialogues — personnages qui vivent ce qu'ils ne comprennent pas encore</span>
              <span class="toc-ct">{serieDialogues.length} épisodes</span>
            </a>

            <!-- Tous les épisodes -->
            <ul class="toc-mecanique">
              {serieDialogues.map((ep) => (
                <li>
                  <a class="toc-mec-item" href={`/articles/${ep.id}`}>
                    <span class="toc-mec-ep">Ép. {String(ep.data.episode ?? '').padStart(2,'0')}</span>
                    <span class="toc-mec-titre">{ep.data.title}</span>
                    <span class="toc-mec-arr">→</span>
                  </a>
                </li>
              ))}
            </ul>
          </li>

          <!-- ── III. ATELIER ── -->
          <li class="toc-section">
            <a class="toc-row toc-row--section" href="/atelier">
              <span class="toc-n">III</span>
              <span class="toc-name">Atelier</span>
              <span class="toc-dots"></span>
              <span class="toc-desc">Explorations de fond — penseurs, outils, dialogues</span>
            </a>

            <!-- Rubriques et articles de l'atelier -->
            <ul class="toc-sub">

              <!-- Fondations -->
              <li>
                <div class="toc-sub-row toc-sub-row--mecanique-hd">
                  <span class="toc-sub-bullet">↳</span>
                  <a class="toc-sub-name toc-sub-name--lien" href="/atelier/fondations">Fondations</a>
                  <span class="toc-sub-ct">penseurs &amp; concepts</span>
                </div>
              </li>

              <!-- Fondations étendues -->
              <li>
                <div class="toc-sub-row toc-sub-row--mecanique-hd">
                  <span class="toc-sub-bullet">↳</span>
                  <a class="toc-sub-name toc-sub-name--lien" href="/atelier/socle">Fondations étendues</a>
                  <span class="toc-sub-ct">extension</span>
                </div>
              </li>

              <!-- Granularité Émotionnelle -->
              <li>
                <div class="toc-sub-row toc-sub-row--mecanique-hd">
                  <span class="toc-sub-bullet">↳</span>
                  <a class="toc-sub-name toc-sub-name--lien" href="/atelier/granularite-emotionnelle">Granularité Émotionnelle</a>
                  <span class="toc-sub-ct">outil · évaluer</span>
                </div>
              </li>

              <!-- Le Nuancier Émotionnel -->
              <li>
                <div class="toc-sub-row toc-sub-row--mecanique-hd">
                  <span class="toc-sub-bullet">↳</span>
                  <a class="toc-sub-name toc-sub-name--lien" href="/atelier/nuancier">Le Nuancier Émotionnel</a>
                  <span class="toc-sub-ct">outil · entraîner</span>
                </div>
              </li>

              <!-- Le Salon des Idées -->
              <li>
                <div class="toc-sub-row toc-sub-row--mecanique-hd">
                  <span class="toc-sub-bullet">↳</span>
                  <a class="toc-sub-name toc-sub-name--lien" href="/atelier/dialogue">Le Salon des Idées</a>
                  <span class="toc-sub-ct">dialogues · prochainement</span>
                </div>
              </li>

            </ul>
          </li>

          <!-- ── IV. OUTILS ── -->
          <li class="toc-section">
            <a class="toc-row toc-row--section" href="/outils">
              <span class="toc-n">IV</span>
              <span class="toc-name">Outils</span>
              <span class="toc-dots"></span>
              <span class="toc-desc">Instruments pour explorer les concepts</span>
              <span class="toc-ct">{outilsSommaire.filter(o => o.statut === 'disponible').length} outils</span>
            </a>

            <!-- Outils disponibles uniquement -->
            <ul class="toc-sub toc-sub--outils">
              {outilsSommaire.filter(o => o.statut === 'disponible').map((o) => (
                <li>
                  <a class="toc-outil-item" href={o.lien} style={`--outil-c: ${o.couleur}`}>
                    <span class="toc-outil-icone" style={`color: ${o.couleur}`}>{o.icone}</span>
                    <span class="toc-outil-nom">{o.titre}</span>
                    <span class="toc-outil-desc">{o.desc}</span>
                    <span class="toc-outil-arr">→</span>
                  </a>
                </li>
              ))}
            </ul>
          </li>

          <!-- ── V. JOURNAL ── -->
          <li class="toc-section">
            <a class="toc-row toc-row--section" href="/journal">
              <span class="toc-n">V</span>
              <span class="toc-name">Journal</span>
              <span class="toc-dots"></span>
              <span class="toc-desc">Notes de bord, réflexions en cours, fragments du processus</span>
              <span class="toc-ct">{journalEntries.length} entrée{journalEntries.length > 1 ? 's' : ''}</span>
            </a>

            <ul class="toc-mecanique">
              {journalEntries.slice(0, 8).map((entry) => (
                <li>
                  <a class="toc-mec-item" href={`/journal/${entry.id}`}>
                    <span class="toc-mec-date">
                      {entry.data.date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'short', year: 'numeric' })}
                    </span>
                    <span class="toc-mec-titre">{entry.data.title}</span>
                    <span class="toc-mec-arr">→</span>
                  </a>
                </li>
              ))}
              {journalEntries.length > 8 && (
                <li>
                  <a class="toc-mec-item" href="/journal">
                    <span class="toc-mec-date"></span>
                    <span class="toc-mec-titre" style="font-style:italic;opacity:.6">
                      Voir toutes les entrées ({journalEntries.length}) →
                    </span>
                  </a>
                </li>
              )}
            </ul>
          </li>

          <!-- ── VI. CARNET ── -->
          <li class="toc-section">
            <a class="toc-row toc-row--section" href="/carnet">
              <span class="toc-n">VI</span>
              <span class="toc-name">Carnet</span>
              <span class="toc-dots"></span>
              <span class="toc-desc">Notes, fragments, pensées en cours</span>
              <span class="toc-ct">{allCarnet.length} notes</span>
            </a>

            <ul class="toc-mecanique">
              {allCarnet.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 6).map((note) => (
                <li>
                  <a class="toc-mec-item" href={`/carnet/${note.id}`}>
                    <span class="toc-mec-date">
                      {note.data.date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'short', year: 'numeric' })}
                    </span>
                    <span class="toc-mec-titre">{note.data.title}</span>
                    <span class="toc-mec-arr">→</span>
                  </a>
                </li>
              ))}
            </ul>
          </li>

          <!-- ── VII. NOUVELLES ── -->
          <li class="toc-section">
            <a class="toc-row toc-row--section" href="/nouvelles">
              <span class="toc-n">VII</span>
              <span class="toc-name">Nouvelles</span>
              <span class="toc-dots"></span>
              <span class="toc-desc">Courtes fictions, fragments narratifs</span>
              <span class="toc-ct">{nouvellesEntries.length} nouvelle{nouvellesEntries.length > 1 ? 's' : ''}</span>
            </a>

            <ul class="toc-mecanique">
              {nouvellesEntries.slice(0, 6).map((entry) => (
                <li>
                  <a class="toc-mec-item" href={`/nouvelles/${entry.id}`}>
                    <span class="toc-mec-date">
                      {entry.data.date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'short', year: 'numeric' })}
                    </span>
                    <span class="toc-mec-titre">{entry.data.title}</span>
                    <span class="toc-mec-arr">→</span>
                  </a>
                </li>
              ))}
              {nouvellesEntries.length > 6 && (
                <li>
                  <a class="toc-mec-item" href="/nouvelles">
                    <span class="toc-mec-date"></span>
                    <span class="toc-mec-titre" style="font-style:italic;opacity:.6">
                      Voir toutes les nouvelles ({nouvellesEntries.length}) →
                    </span>
                  </a>
                </li>
              )}
            </ul>
          </li>

          <!-- ── VIII. JARDIN ── -->
          <li class="toc-section">
            <a class="toc-row toc-row--section" href="/jardin">
              <span class="toc-n">VIII</span>
              <span class="toc-name">Jardin</span>
              <span class="toc-dots"></span>
              <span class="toc-desc">Notes en croissance — concepts, fragments, connexions qui émergent</span>
              <span class="toc-ct">{jardinNotes.length} note{jardinNotes.length !== 1 ? 's' : ''}</span>
            </a>

            <ul class="toc-mecanique">
              {jardinNotes.slice(0, 3).map((note) => (
                <li>
                  <a class="toc-mec-item" href={`/jardin/${note.id}`}>
                    <span class="toc-mec-date">
                      {note.data.date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'short', year: 'numeric' })}
                    </span>
                    <span class="toc-mec-titre">{note.data.titre}</span>
                    <span class="toc-mec-arr">→</span>
                  </a>
                </li>
              ))}
              {jardinNotes.length === 0 && (
                <li>
                  <span class="toc-mec-item" style="opacity:.4;cursor:default;pointer-events:none">
                    <span class="toc-mec-date"></span>
                    <span class="toc-mec-titre" style="font-style:italic">Le jardin pousse…</span>
                  </span>
                </li>
              )}
            </ul>
          </li>

          <!-- ── IX. BIBLIOTHÈQUE ── -->
          <li class="toc-section">
            <a class="toc-row toc-row--section" href="/bibliotheque">
              <span class="toc-n">IX</span>
              <span class="toc-name">Bibliothèque</span>
              <span class="toc-dots"></span>
              <span class="toc-desc">Tous les concepts, penseurs et mécanismes — index dense</span>
              <span class="toc-ct">index</span>
            </a>
          </li>

          <!-- ── X. SOUS LA SURFACE ── -->
          <li class="toc-section toc-section--last">
            <a class="toc-row toc-row--section" href="/sous-la-surface">
              <span class="toc-n" style="color:#5b8fa8">X</span>
              <span class="toc-name">Sous la surface</span>
              <span class="toc-dots"></span>
              <span class="toc-desc">Scènes annotées — concepts qui s'illuminent sur la vie réelle</span>
              <span class="toc-ct">{slsEntries.length > 0 ? `${slsEntries.length} article${slsEntries.length > 1 ? 's' : ''}` : 'nouveau'}</span>
            </a>
            <ul class="toc-mecanique">
              {slsEntries.slice(0, 5).map((entry) => (
                <li>
                  <a class="toc-mec-item" href={`/sous-la-surface/${entry.id}`}>
                    <span class="toc-mec-date">
                      {entry.data.date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'short', year: 'numeric' })}
                    </span>
                    <span class="toc-mec-titre">{entry.data.title}</span>
                    <span class="toc-mec-arr">→</span>
                  </a>
                </li>
              ))}
              {slsEntries.length === 0 && (
                <li>
                  <span class="toc-mec-item" style="opacity:.4;cursor:default;pointer-events:none">
                    <span class="toc-mec-date"></span>
                    <span class="toc-mec-titre" style="font-style:italic">Premier article bientôt…</span>
                  </span>
                </li>
              )}
            </ul>
          </li>

        </ul>
      </div>
    </div>

    <!-- ORANGE — Carnet -->
    <div class="cadre cadre--orange">
      <div class="cadre-hd">
        <div class="cadre-ey">
          <div class="cadre-dot"></div>
          <span class="cadre-lbl">Carnet</span>
        </div>
        <a class="cadre-lnk" href="/carnet">Tout →</a>
      </div>
      <div class="cadre-bd">
        <ul class="carnet-list">
