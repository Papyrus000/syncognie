---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');
articles.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function toSlug(str: string) {
  return str.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
}
const seriesUniques = [...new Set(articles.filter(a => a.data.serie).map(a => a.data.serie as string))];
const nbSeries = seriesUniques.length;
---

<Base title="Syncognie">
  <Header id="site-header" />

  <section class="hero">

    <!-- ✦ SPIRALE FILIGRANE INTERACTIVE -->
    <svg id="spirale" class="hero-filigrane" viewBox="0 0 420 420" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <!-- Cercle rotatif de fond -->
      <circle cx="210" cy="210" r="185"
        stroke="#8b5e3c" stroke-width=".6"
        stroke-dasharray="2 10"
        opacity=".18"
        class="fil-rotate"/>

      <!-- Chemins spirale -->
      <path d="M210 210
               C210 188, 224 174, 240 174
               C270 174, 295 199, 295 230
               C295 272, 260 305, 210 305
               C148 305, 96 253, 96 190
               C96 116, 151 62, 225 62"
            stroke="#c4993a" stroke-width="1.2"
            stroke-linecap="round" opacity=".28"/>
      <path d="M225 62
               C272 62, 332 98, 358 155
               C384 210, 370 285, 322 324"
            stroke="#c4993a" stroke-width=".8"
            stroke-linecap="round" opacity=".16"/>

      <!-- Lignes rayonnantes -->
      <line x1="210" y1="210" x2="240" y2="174" stroke="#8b5e3c" stroke-width=".7" opacity=".2"/>
      <line x1="210" y1="210" x2="295" y2="230" stroke="#8b5e3c" stroke-width=".7" opacity=".18"/>
      <line x1="210" y1="210" x2="210" y2="305" stroke="#8b5e3c" stroke-width=".7" opacity=".18"/>
      <line x1="210" y1="210" x2="96"  y2="190" stroke="#8b5e3c" stroke-width=".7" opacity=".16"/>
      <line x1="210" y1="210" x2="225" y2="62"  stroke="#8b5e3c" stroke-width=".7" opacity=".16"/>

      <!-- ✦ 5 POINTS INTERACTIFS — data-node="0..4" -->
      <!-- node-0 : centre haut (225,62) — extrémité spirale -->
      <circle data-node="0" cx="225" cy="62"  r="4"   fill="#c4993a" class="fil-pulse-2 node"/>
      <!-- node-1 : droite (295,230) -->
      <circle data-node="1" cx="295" cy="230" r="3.5" fill="#8b5e3c" class="fil-pulse-2 node"/>
      <!-- node-2 : bas (210,305) -->
      <circle data-node="2" cx="210" cy="305" r="4"   fill="#c4993a" class="fil-pulse-3 node"/>
      <!-- node-3 : gauche (96,190) -->
      <circle data-node="3" cx="96"  cy="190" r="3.5" fill="#8b5e3c" class="fil-pulse node"/>
      <!-- node-4 : haut-droite proche (240,174) -->
      <circle data-node="4" cx="240" cy="174" r="4.5" fill="#c4993a" class="fil-pulse node"/>

      <!-- Halos d'illumination (invisibles par défaut) -->
      <circle data-halo="0" cx="225" cy="62"  r="11" fill="none" stroke="#c4993a" stroke-width="1.5" opacity="0" class="halo"/>
      <circle data-halo="1" cx="295" cy="230" r="10" fill="none" stroke="#8b5e3c" stroke-width="1.5" opacity="0" class="halo"/>
      <circle data-halo="2" cx="210" cy="305" r="11" fill="none" stroke="#c4993a" stroke-width="1.5" opacity="0" class="halo"/>
      <circle data-halo="3" cx="96"  cy="190" r="10" fill="none" stroke="#8b5e3c" stroke-width="1.5" opacity="0" class="halo"/>
      <circle data-halo="4" cx="240" cy="174" r="12" fill="none" stroke="#c4993a" stroke-width="1.5" opacity="0" class="halo"/>

      <!-- Cercles internes décoratifs -->
      <circle cx="210" cy="210" r="28"
        stroke="#8b5e3c" stroke-width="1"
        opacity=".18" class="fil-pulse"/>
      <circle cx="210" cy="210" r="52"
        stroke="#8b5e3c" stroke-width=".5"
        opacity=".1" class="fil-pulse-2"/>
      <circle cx="210" cy="210" r="5"
        fill="#8b5e3c" opacity=".25"
        class="fil-float"/>
      <circle cx="210" cy="210" r="2.5"
        fill="#f5f0e8" opacity=".6"
        class="fil-float"/>
    </svg>

    <div class="hero-left" data-zone="hero">
      <p class="hero-eyebrow">Synergie · Cognition · Dialogue</p>
      <h1 class="hero-titre">
        Rassembler les idées.<br>
        <em>Accompagner la synergie.</em>
      </h1>
      <p class="hero-sous">
        Un espace de réflexion où les concepts s'entrechoquent 
        pour révéler de nouveaux sens.<br> 
        Entre carnet de bord et laboratoire cognitif, ici on 
        explore par le prisme du lien...
      </p>
      <div class="hero-note">
        <span class="hero-note-glyph">✦</span>
        <p class="hero-note-text">
          Jardin numérique en croissance : Un espace vivant et imparfait. 
          Architecture artisanale propulsée par Astro et Cloudflare 
          où chaque note évolue au fil du temps, à son rythme.
        </p>
      </div>
    </div>

    <div class="hero-portals">
      <a class="portal portal-articles" href="/articles" data-zone="articles"><div class="portal-lueur" aria-hidden="true"></div>
        <div class="portal-header">
          <div class="portal-dot"></div>
          <span class="portal-label">Articles</span>
        </div>
        <div class="portal-articles-body">
          <p class="portal-articles-count">
            <span class="portal-count-n">{articles.length}</span>
            <span class="portal-count-label">{articles.length > 1 ? 'publications' : 'publication'}</span>
          </p>
          <p class="portal-articles-hint">Notes, récits & analyses</p>
        </div>
        <span class="portal-cta">Explorer →</span>
      </a>

      <a class="portal portal-outils" href="/outils" data-zone="outils"><div class="portal-lueur" aria-hidden="true"></div>
        <div class="portal-header">
          <div class="portal-dot"></div>
          <span class="portal-label">Outils</span>
        </div>
        <p class="portal-desc">Des boussoles, pas des diagnostics</p>
        <ul class="portal-items">
          <li>Baromètre de charge</li>
          <li>Tracker d'habitudes</li>
          <li>Boussole dopamine</li>
          <li>Récits conceptuels…</li>
        </ul>
        <span class="portal-cta">Explorer →</span>
      </a>
    </div>

  </section>

  <!-- ✦ BANDE FENÊTRES -->
  <a href="/fenetres" class="fenetre-bande" data-zone="fenetres">
    <div class="fenetre-bande-inner">
      <div class="fenetre-bande-left">
        <p class="fenetre-bande-label">Fenêtres</p>
        <p class="fenetre-bande-amorce">
          <em>Pas de notification depuis ce matin. Il vérifie quand même.</em>
        </p>
      </div>
      <span class="fenetre-bande-cta">Des instants ordinaires →</span>
    </div>
  </a>

  <div class="ornament-sep">
    <div class="orn-line"></div>
    <div class="orn-centre">
      <div class="orn-diamond"></div>
      <span class="orn-label">Publications récentes</span>
      <div class="orn-diamond"></div>
    </div>
    <div class="orn-line"></div>
  </div>

  <div class="bas-wrap">

    <!-- Colonne gauche : articles -->
    <div class="articles-col">
      {articles.slice(0, 5).map((article, i) => {
        const estRecit = article.data.format === 'dialogue' || article.data.format === 'recit';
        return (
          <a
            class={`article-item${estRecit ? ' est-recit' : ''}`}
            href={`/articles/${article.slug}`}
            style={`animation-delay: ${0.42 + i * 0.1}s`}
          >
            <div class="article-meta">
              <span class="article-date">
                {article.data.date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}
              </span>
              {estRecit && <span class="badge badge-recit">◈ Récit</span>}
              {article.data.format === 'analyse' && <span class="badge badge-analyse">◈ Analyse</span>}
              {article.data.statut === 'en-cours' && <span class="badge badge-wip">En cours</span>}
              {article.data.stade === 'graine' && <span class="badge badge-graine badge-stade"><span class="badge-stade-icon">🌱</span> Graine</span>}
              {article.data.stade === 'pousse' && <span class="badge badge-pousse badge-stade"><span class="badge-stade-icon">🌿</span> Pousse</span>}
              {article.data.stade === 'arbre'  && <span class="badge badge-arbre  badge-stade"><span class="badge-stade-icon">🌳</span> Arbre</span>}
              {article.data.serie && article.data.episode && (
                <span class="badge badge-serie" data-tooltip={article.data.serie}>
                  <span class="badge-serie-bulles" aria-hidden="true">
                    <span class="bulle bulle-1"></span>
                    <span class="bulle bulle-2"></span>
                  </span>
                  <span class="badge-serie-ep">ép. {article.data.episode}</span>
                </span>
              )}
            </div>
            <p class="article-titre">{article.data.title}</p>
            {article.data.description && (
              <p class="article-desc">{article.data.description}</p>
            )}
            <span class="article-lire">
              {estRecit ? 'Lire le récit →' : 'Lire →'}
            </span>
          </a>
        );
      })}
    </div>

    <!-- Colonne droite : série + stades -->
    <aside class="legende-col">

      {nbSeries > 0 && seriesUniques.map((serieName) => {
        const slug = toSlug(serieName);
        const nbEp = articles.filter(a => a.data.serie === serieName).length;
        return (
          <a href={`/series/${slug}`} class="legende-card legende-card--serie" data-zone="serie">
            <div class="legende-serie-top">
              <svg class="legende-serie-svg" viewBox="0 0 38 38" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <rect x="1" y="1" width="24" height="16" rx="4" stroke="#c4993a" stroke-width="1" fill="rgba(196,153,58,.04)" opacity=".7"/>
                <circle cx="7"  cy="9" r="1.5" fill="#c4993a" opacity=".5" class="sdot-a sdot-bounce"/>
                <circle cx="13" cy="9" r="1.5" fill="#c4993a" opacity=".5" class="sdot-b sdot-bounce"/>
                <circle cx="19" cy="9" r="1.5" fill="#c4993a" opacity=".5" class="sdot-c sdot-bounce"/>
                <path d="M7 17 L4 22 L11 17" fill="rgba(196,153,58,.04)" stroke="#c4993a" stroke-width=".8" opacity=".5" stroke-linejoin="round"/>
                <rect x="13" y="21" width="24" height="16" rx="4" stroke="#8b5e3c" stroke-width="1" fill="rgba(139,94,60,.03)" opacity=".55"/>
                <circle cx="20" cy="29" r="1.5" fill="#8b5e3c" opacity=".4" class="sdot-d sdot-bounce"/>
                <circle cx="26" cy="29" r="1.5" fill="#8b5e3c" opacity=".4" class="sdot-e sdot-bounce"/>
                <circle cx="32" cy="29" r="1.5" fill="#8b5e3c" opacity=".4" class="sdot-f sdot-bounce"/>
                <path d="M31 21 L34 16 L27 21" fill="rgba(139,94,60,.03)" stroke="#8b5e3c" stroke-width=".8" opacity=".4" stroke-linejoin="round"/>
              </svg>
              <div>
                <p class="legende-serie-eyebrow">Série · {nbEp} ép.</p>
                <p class="legende-titre">{serieName}</p>
              </div>
            </div>
            <div class="legende-serie-voix">
              <div class="voix-i voix-e">É</div>
              <div class="voix-i voix-n">N</div>
              <span class="voix-label">Élodie & Nathalie</span>
            </div>
            <span class="legende-cta">Lire la série →</span>
          </a>
        );
      })}

      <a href="/stades" class="legende-card legende-card--link legende-card--jardin" data-zone="stades">
        <p class="legende-titre">Stades de maturité</p>
        <ul class="legende-list">
          <li class="stade-item stade-item--1">
            <span class="badge badge-graine badge-stade"><span class="badge-stade-icon">🌱</span> Graine</span>
            <span class="legende-desc">Idée posée, peu développée</span>
          </li>
          <li class="stade-item stade-item--2">
            <span class="badge badge-pousse badge-stade"><span class="badge-stade-icon">🌿</span> Pousse</span>
            <span class="legende-desc">En cours d'exploration</span>
          </li>
          <li class="stade-item stade-item--3">
            <span class="badge badge-arbre badge-stade"><span class="badge-stade-icon">🌳</span> Arbre</span>
            <span class="legende-desc">Consolidé, dense</span>
          </li>
        </ul>
        <p class="legende-note">
          Syncognie est un jardin numérique — les notes évoluent, se ramifient, mûrissent avec le temps.
        </p>
        <span class="legende-cta">En savoir plus →</span>
      </a>

    </aside>

  </div>

  <Footer />
</Base>

<!-- ✦ SCRIPT SPIRALE INTERACTIVE -->
<script>
(function () {

  // ── Configuration des zones ──────────────────────────────────────
  // nodes    : indices des points à illuminer (0-4)
  // color    : couleur d'illumination
  // glow     : rayon du halo (px dans le viewBox SVG)
  const ZONES = {
    articles: {
      nodes: [0, 1, 2, 3, 4],          // tous — importance max
      color: '#6b7fb8',                  // bleu ardoise
      glow: '#6b7fb8'
    },
    outils: {
      nodes: [0, 1, 2, 3],              // 4 points
      color: '#e8724a',                  // orange
      glow: '#e8724a'
    },
    hero: {
      nodes: [1, 2, 4],                 // 3 points
      color: '#8b5e3c',                  // terracotta
      glow: '#8b5e3c'
    },
    header: {
      nodes: [0, 3],                     // 2 points
      color: '#c4993a',                  // or
      glow: '#c4993a'
    },
    stades: {
      nodes: [2],                        // 1 point — importance min
      color: '#2e7d4e',                  // vert
      glow: '#2e7d4e'
    },
    fenetres: {
      nodes: [0, 2, 4],                  // 3 points — fenêtres/instants
      color: '#8b7355',                  // brun chaud
      glow: '#8b7355'
    }
  };

  // ── Récupération des éléments SVG ───────────────────────────────
  const nodes = document.querySelectorAll('.node');
  const halos = document.querySelectorAll('.halo');

  // Couleurs de base (terracotta / or alternés)
  const BASE_COLORS = ['#c4993a', '#8b5e3c', '#c4993a', '#8b5e3c', '#c4993a'];
  const BASE_RADII  = [4, 3.5, 4, 3.5, 4.5];

  // État courant
  let activeZone = null;
  let fadeTimers = [];

  // ── Fonctions d'animation ────────────────────────────────────────

  function illuminate(zoneKey) {
    if (activeZone === zoneKey) return;
    cancelFade();
    activeZone = zoneKey;

    const zone = ZONES[zoneKey];
    if (!zone) return;

    // Reset tous les points d'abord
    nodes.forEach((node, i) => {
      node.setAttribute('fill', BASE_COLORS[i]);
      node.setAttribute('r', BASE_RADII[i]);
      node.style.filter = '';
    });
    halos.forEach(h => {
      h.setAttribute('opacity', '0');
      h.style.transition = '';
    });

    // Illuminer les points de cette zone avec délai en cascade
    zone.nodes.forEach((nodeIdx, order) => {
      const node = document.querySelector(`[data-node="${nodeIdx}"]`);
      const halo = document.querySelector(`[data-halo="${nodeIdx}"]`);
      if (!node || !halo) return;

      setTimeout(() => {
        // Point
        node.setAttribute('fill', zone.color);
        node.setAttribute('r', BASE_RADII[nodeIdx] * 1.6);
        node.style.filter = `drop-shadow(0 0 4px ${zone.color})`;

        // Halo
        halo.setAttribute('stroke', zone.glow);
        halo.style.transition = 'opacity 0.35s ease';
        halo.setAttribute('opacity', '0.6');
      }, order * 60); // cascade 60ms entre chaque point
    });
  }

  function cancelFade() {
    fadeTimers.forEach(clearTimeout);
    fadeTimers = [];
  }

  function fadeOut() {
    cancelFade();
    activeZone = null;

    nodes.forEach((node, i) => {
      const t = setTimeout(() => {
        node.setAttribute('fill', BASE_COLORS[i]);
        node.setAttribute('r', BASE_RADII[i]);
        node.style.filter = '';
      }, i * 80);
      fadeTimers.push(t);
    });

    halos.forEach((halo, i) => {
      const t = setTimeout(() => {
        halo.style.transition = 'opacity 0.5s ease';
        halo.setAttribute('opacity', '0');
      }, i * 60);
      fadeTimers.push(t);
    });
  }

  // ── Attacher les écouteurs ───────────────────────────────────────

  // Zones dans la page
  document.querySelectorAll('[data-zone]').forEach(el => {
    const zone = el.dataset.zone;
    el.addEventListener('mouseenter', () => illuminate(zone));
    el.addEventListener('mouseleave', fadeOut);
    // Touch support
    el.addEventListener('touchstart', () => illuminate(zone), { passive: true });
    el.addEventListener('touchend', () => {
      setTimeout(fadeOut, 800);
    }, { passive: true });
  });

  // Header (topbar) — on écoute directement le <header> du site
  const siteHeader = document.querySelector('header');
  if (siteHeader) {
    siteHeader.addEventListener('mouseenter', () => illuminate('header'));
    siteHeader.addEventListener('mouseleave', fadeOut);
  }

})();
</script>

<style>
  /* ── HERO ── */
  .hero {
    max-width: var(--max);
    margin: 0 auto;
    padding: 4.5rem 1.75rem 0;
    display: grid;
    grid-template-columns: 1fr 168px;
    gap: 2.5rem;
    align-items: start;
    opacity: 0;
    animation: rise .9s .1s ease forwards;
    position: relative;
  }

  @media (max-width: 600px) {
    .hero { grid-template-columns: 1fr; gap: 2rem; }
    .hero-filigrane { display: none; }
  }

  /* ── SPIRALE FILIGRANE ── */
  .hero-filigrane {
    position: absolute;
    top: 50%;
    left: 64%;
    transform: translate(-50%, -50%);
    width: 420px;
    height: 420px;
    pointer-events: none;
    z-index: 0;
  }

  /* Transitions sur les noeuds SVG */
  .node {
    transition: r 0.3s ease, fill 0.3s ease;
  }

  .halo {
    transition: opacity 0.35s ease;
  }

  .fil-rotate {
    transform-origin: 210px 210px;
    animation: fil-spin 32s linear infinite;
  }
  @keyframes fil-spin { to { transform: rotate(360deg); } }

  .fil-pulse   { animation: fil-p 6s ease-in-out infinite; }
  .fil-pulse-2 { animation: fil-p 6s ease-in-out infinite; animation-delay: 1.5s; }
  .fil-pulse-3 { animation: fil-p 6s ease-in-out infinite; animation-delay: 3s; }
  @keyframes fil-p {
    0%,100% { opacity: .18; }
    50%      { opacity: .55; }
  }

  .fil-float {
    animation: fil-f 8s ease-in-out infinite;
    transform-origin: 210px 210px;
  }
  @keyframes fil-f {
    0%,100% { transform: translateY(0); }
    50%      { transform: translateY(-6px); }
  }

  /* ── CONTENU HERO ── */
  .hero-left {
    position: relative;
    z-index: 1;
  }

  .hero-portals {
    display: flex;
    flex-direction: column;
    gap: .8rem;
    padding-top: .6rem;
    position: relative;
    z-index: 1;
  }

  .hero-eyebrow {
    font-family: 'Mulish', sans-serif;
    font-size: .6rem;
    font-weight: 300;
    letter-spacing: .3em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.2rem;
    opacity: .75;
  }

  .hero-titre {
    font-size: clamp(1.4rem, 2.9vw, 1.9rem);
    font-weight: 700;
    color: var(--ink);
    line-height: 1.22;
    margin-bottom: 1.3rem;
    letter-spacing: -.015em;
  }

  .hero-titre em {
    font-style: italic;
    font-weight: 400;
    color: var(--gold, #c4993a);
  }

  .hero-sous {
    font-family: 'Mulish', sans-serif;
    font-size: .95rem;
    font-weight: 400;
    color: var(--ink-soft);
    line-height: 1.8;
    max-width: 42ch;
    margin-bottom: 1.75rem;
  }

  .hero-note {
    display: flex;
    align-items: flex-start;
    gap: .7rem;
    padding: .85rem 1rem;
    background: rgba(196, 153, 58, .07);
    border-left: 2px solid var(--gold, #c4993a);
    border-radius: 0 4px 4px 0;
    max-width: 42ch;
  }

  .hero-note-glyph {
    color: var(--gold, #c4993a);
    opacity: .6;
    flex-shrink: 0;
    font-size: .75rem;
    margin-top: .12rem;
  }

  .hero-note-text {
    font-family: 'Mulish', sans-serif;
    font-size: .85rem;
    font-weight: 400;
    font-style: italic;
    color: var(--ink-soft);
    line-height: 1.68;
  }

  /* ── PORTAILS ── */
  .portal {
    display: block;
    text-decoration: none;
    padding: .95rem 1rem 1rem;
    border: 1px solid var(--rule);
    border-radius: 6px;
    background: rgba(245, 240, 232, .75);
    backdrop-filter: blur(2px);
    box-shadow: 0 2px 12px rgba(44, 36, 22, .07), 0 1px 3px rgba(44, 36, 22, .05);
    transition: transform .22s, box-shadow .22s, border-color .22s;
    position: relative;
    overflow: hidden;
  }

  .portal::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    border-radius: 6px 6px 0 0;
  }

  .portal-articles::before { background: #6b7fb8; }
  .portal-outils::before   { background: var(--orange, #e8724a); }

  /* ── EFFET PORTAILS : lueur douce ── */
  .portal:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(44, 36, 22, .1);
  }

  .portal-articles:hover {
    border-color: rgba(107, 127, 184, .35);
    background: rgba(107,127,184,.03);
  }
  .portal-outils:hover {
    border-color: rgba(232, 114, 74, .35);
    background: rgba(232,114,74,.025);
  }

  /* Barre supérieure qui s'intensifie */
  .portal-articles:hover::before { height: 3px; background: linear-gradient(to right, #6b7fb8, rgba(107,127,184,.4)); }
  .portal-outils:hover::before   { height: 3px; background: linear-gradient(to right, #e8724a, rgba(232,114,74,.4)); }

  /* Lueur radiale douce depuis la gauche */
  .portal::after {
    content: '';
    position: absolute;
    top: 50%; left: -40px;
    transform: translateY(-50%);
    width: 160px; height: 160px;
    border-radius: 50%;
    opacity: 0;
    pointer-events: none;
    transition: opacity .45s ease, left .45s ease;
  }
  .portal-articles::after { background: radial-gradient(circle, rgba(107,127,184,.1) 0%, transparent 70%); }
  .portal-outils::after   { background: radial-gradient(circle, rgba(232,114,74,.09) 0%, transparent 70%); }
  .portal:hover::after    { opacity: 1; left: 0px; }


  .portal-header {
    display: flex;
    align-items: center;
    gap: .5rem;
    margin-bottom: .45rem;
  }

  .portal-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .portal-articles .portal-dot { background: #6b7fb8; }
  .portal-outils   .portal-dot { background: var(--orange, #e8724a); }

  .portal-label {
    font-family: 'Mulish', sans-serif;
    font-size: .72rem;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--ink-mid);
  }

  /* Corps portail articles */
  .portal-articles-body {
    padding: .55rem 0 .45rem;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    margin-bottom: .1rem;
  }

  .portal-articles-count {
    display: flex;
    align-items: baseline;
    gap: .4rem;
    margin-bottom: .3rem;
  }

  .portal-count-n {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: 1.6rem;
    font-weight: 700;
    color: #6b7fb8;
    line-height: 1;
    letter-spacing: -.02em;
  }

  .portal-count-label {
    font-family: 'Mulish', sans-serif;
    font-size: .75rem;
    font-weight: 300;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--ink-mid);
  }

  .portal-articles-hint {
    font-family: 'Mulish', sans-serif;
    font-size: .75rem;
    font-weight: 300;
    font-style: italic;
    color: var(--ink-mid);
    opacity: .7;
  }

  .portal-desc {
    font-family: 'Mulish', sans-serif;
    font-size: .8rem;
    font-weight: 300;
    color: var(--ink-soft);
    line-height: 1.5;
    margin-bottom: .55rem;
  }

  .portal-items {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: .22rem;
  }

  .portal-items li {
    font-family: 'Mulish', sans-serif;
    font-size: .72rem;
    font-weight: 300;
    color: var(--ink-mid);
    opacity: .75;
    display: flex;
    align-items: baseline;
    gap: .35rem;
    line-height: 1.4;
  }

  .portal-items li::before {
    content: '—';
    font-size: .55rem;
    opacity: .35;
    flex-shrink: 0;
  }

  .portal-cta {
    display: inline-block;
    margin-top: .6rem;
    font-family: 'Mulish', sans-serif;
    font-size: .6rem;
    font-weight: 600;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--blizzard, #148EFF);
    opacity: 0;
    transform: translateX(-3px);
    transition: opacity .2s, transform .2s;
  }

  .portal:hover .portal-cta {
    opacity: 1;
    transform: translateX(0);
  }

  /* ── SÉPARATEUR ── */
  .ornament-sep {
    max-width: var(--max);
    margin: 3.5rem auto 0;
    padding: 0 1.75rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    opacity: 0;
    animation: rise .9s .3s ease forwards;
  }

  .orn-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--rule), transparent);
  }

  .orn-centre {
    display: flex;
    align-items: center;
    gap: .55rem;
  }

  .orn-diamond {
    width: 5px;
    height: 5px;
    background: var(--rule);
    transform: rotate(45deg);
  }

  .orn-label {
    font-family: 'Mulish', sans-serif;
    font-size: .58rem;
    font-weight: 700;
    letter-spacing: .25em;
    text-transform: uppercase;
    color: var(--ink-soft);
    opacity: .45;
  }

  /* ── GRILLE BAS ── */
  .bas-wrap {
    max-width: var(--max);
    margin: 0 auto;
    padding: 1.75rem 1.75rem 5rem;
    display: grid;
    grid-template-columns: 1fr 168px;
    gap: 2.5rem;
    align-items: start;
  }

  @media (max-width: 600px) {
    .bas-wrap { grid-template-columns: 1fr; }
    .legende-col { display: none; }
  }

  /* ── ARTICLES ── */
  .articles-col { min-width: 0; }

  .article-item {
    display: block;
    text-decoration: none;
    padding: 1.6rem 0;
    border-bottom: 1px solid var(--rule);
    opacity: 0;
    position: relative;
    animation: rise .7s ease forwards;
  }

  .article-item:last-child { border-bottom: none; }

  .article-item::before {
    content: '';
    position: absolute;
    left: -1.75rem;
    top: 0; bottom: 0;
    width: 2px;
    background: var(--accent);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform .28s ease;
    opacity: .5;
  }

  .article-item:hover::before { transform: scaleY(1); }

  .article-meta {
    display: flex;
    align-items: center;
    gap: .6rem;
    margin-bottom: .5rem;
    flex-wrap: wrap;
  }

  .article-date {
    font-family: 'Mulish', sans-serif;
    font-size: .6rem;
    font-weight: 300;
    letter-spacing: .15em;
    text-transform: uppercase;
    color: var(--ink-soft);
    opacity: .6;
  }

  .badge {
    font-family: 'Mulish', sans-serif;
    font-size: .55rem;
    font-weight: 700;
    letter-spacing: .13em;
    text-transform: uppercase;
    padding: .15rem .45rem;
    border-radius: 3px;
  }

  .badge-recit {
    background: rgba(196, 153, 58, .1);
    color: var(--gold, #c4993a);
    border: 1px solid rgba(196, 153, 58, .25);
  }

  .badge-analyse {
    background: rgba(107, 127, 184, .1);
    color: #6b7fb8;
    border: 1px solid rgba(107, 127, 184, .25);
  }

  .badge-wip {
    background: rgba(139, 94, 60, .07);
    color: var(--accent);
    border: 1px solid rgba(139, 94, 60, .2);
  }

  .badge-stade {
    display: inline-flex;
    align-items: center;
    gap: .28rem;
  }

  .badge-stade-icon { font-size: .65rem; line-height: 1; }

  .badge-graine {
    background: rgba(46, 125, 78, .07);
    color: #2e7d4e;
    border: 1px solid rgba(46, 125, 78, .2);
  }

  .badge-pousse {
    background: rgba(56, 120, 60, .09);
    color: #38783c;
    border: 1px solid rgba(56, 120, 60, .22);
  }

  .badge-arbre {
    background: rgba(46, 125, 78, .18);
    color: #224422;
    border: 1px solid rgba(34, 68, 34, .2);
  }

  .article-titre {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--ink);
    line-height: 1.35;
    margin-bottom: .5rem;
    transition: color .2s;
  }

  .article-item:hover .article-titre { color: var(--accent); }

  .est-recit .article-titre {
    font-style: italic;
    font-weight: 400;
    font-size: 1rem;
  }

  .article-desc {
    font-family: 'Mulish', sans-serif;
    font-size: .82rem;
    font-weight: 300;
    color: var(--ink-soft);
    line-height: 1.65;
    margin-bottom: .6rem;
    max-width: 56ch;
  }

  .article-lire {
    display: inline-flex;
    align-items: center;
    gap: .35rem;
    font-family: 'Mulish', sans-serif;
    font-size: .65rem;
    font-weight: 600;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--blizzard, #148EFF);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity .2s, transform .2s;
  }

  .article-item:hover .article-lire {
    opacity: 1;
    transform: translateX(0);
  }

  /* ── LÉGENDE MATURITÉ CLIQUABLE ── */
  .legende-col {
    padding-top: 1.6rem;
    position: sticky;
    top: 4.5rem;
    align-self: start;
    display: flex;
    flex-direction: column;
    gap: .75rem;
  }

  .legende-card {
    padding: 1rem;
    border: 1px solid var(--rule);
    border-radius: 6px;
    background: rgba(245, 240, 232, .6);
    box-shadow: 0 2px 12px rgba(44, 36, 22, .05);
    text-decoration: none;
    display: block;
    transition: border-color .2s, background .2s;
  }

  /* Carte série */
  .legende-card--serie {
    cursor: pointer;
    display: flex;
    flex-direction: column;
    gap: .6rem;
  }
  .legende-card--serie:hover {
    border-color: rgba(196,153,58,.35);
    background: rgba(196,153,58,.06);
  }
  .legende-serie-top {
    display: flex;
    align-items: flex-start;
    gap: .55rem;
  }
  .legende-serie-svg {
    width: 34px; height: 34px;
    flex-shrink: 0;
    margin-top: .1rem;
  }
  .legende-serie-eyebrow {
    font-family: 'Mulish', sans-serif;
    font-size: .49rem; font-weight: 700;
    letter-spacing: .2em; text-transform: uppercase;
    color: #c4993a; opacity: .65;
    margin-bottom: .18rem;
    display: block;
  }
  .sdot-a { animation: sdot 2.4s ease-in-out infinite; }
  .sdot-b { animation: sdot 2.4s ease-in-out infinite; animation-delay: .4s; }
  .sdot-c { animation: sdot 2.4s ease-in-out infinite; animation-delay: .8s; }
  .sdot-d { animation: sdot 2.8s ease-in-out infinite; animation-delay: .5s; }
  .sdot-e { animation: sdot 2.8s ease-in-out infinite; animation-delay: .9s; }
  .sdot-f { animation: sdot 2.8s ease-in-out infinite; animation-delay: 1.3s; }
  @keyframes sdot {
    0%, 100% { opacity: .25; transform: translateY(0); }
    50%       { opacity: .75; transform: translateY(-1.5px); }
  }
  .legende-serie-voix {
    display: flex;
    align-items: center;
  }
  .voix-i {
    width: 17px; height: 17px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: .52rem; font-weight: 700;
    border: 1.5px solid var(--bg, #f5f0e8);
    flex-shrink: 0;
  }
  .voix-e {
    background: rgba(196,153,58,.12); color: #c4993a;
    border-color: rgba(196,153,58,.25); z-index: 2;
  }
  .voix-n {
    background: rgba(139,94,60,.1); color: var(--accent);
    border-color: rgba(139,94,60,.2);
    margin-left: -5px; z-index: 1;
  }
  .voix-label {
    font-family: 'Mulish', sans-serif;
    font-size: .58rem; font-weight: 300; font-style: italic;
    color: var(--ink-soft); opacity: .5;
    margin-left: .4rem;
  }

  /* Carte stades cliquable */
  .legende-card--link {
    cursor: pointer;
  }
  .legende-card--link:hover {
    border-color: rgba(139,94,60,.25);
    background: rgba(139,94,60,.04);
  }

  .legende-titre {
    font-family: 'Mulish', sans-serif;
    font-size: .55rem;
    font-weight: 700;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--ink-mid);
    opacity: .75;
    margin-bottom: .75rem;
    padding-bottom: .5rem;
    border-bottom: 1px solid var(--rule);
  }

  .legende-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: .6rem;
    margin-bottom: .85rem;
  }

  .legende-list li {
    display: flex;
    flex-direction: column;
    gap: .25rem;
  }

  .legende-desc {
    font-family: 'Mulish', sans-serif;
    font-size: .62rem;
    font-weight: 300;
    font-style: italic;
    color: var(--ink-mid);
    opacity: .9;
    padding-left: .2rem;
  }

  .legende-note {
    font-family: 'Mulish', sans-serif;
    font-size: .72rem;
    font-weight: 300;
    font-style: italic;
    color: var(--ink-mid);
    opacity: .75;
    line-height: 1.6;
    padding-top: .75rem;
    border-top: 1px solid var(--rule);
    margin-bottom: .6rem;
  }

  .legende-cta {
    display: inline-block;
    font-family: 'Mulish', sans-serif;
    font-size: .6rem;
    font-weight: 600;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--blizzard, #148EFF);
    opacity: 0;
    transform: translateX(-3px);
    transition: opacity .2s, transform .2s;
  }

  .legende-card--serie:hover .legende-cta,
  .legende-card--link:hover .legende-cta {
    opacity: 1;
    transform: translateX(0);
  }

  /* ── EFFET SÉRIE : bulles en cascade + ondes ── */
  .sdot-bounce { transition: transform .15s ease, opacity .15s ease; }

  /* Cascade au hover de la carte série */
  .legende-card--serie:hover .sdot-a { animation: sdot-pop .5s .00s ease both; }
  .legende-card--serie:hover .sdot-b { animation: sdot-pop .5s .08s ease both; }
  .legende-card--serie:hover .sdot-c { animation: sdot-pop .5s .16s ease both; }
  .legende-card--serie:hover .sdot-d { animation: sdot-pop .5s .10s ease both; }
  .legende-card--serie:hover .sdot-e { animation: sdot-pop .5s .18s ease both; }
  .legende-card--serie:hover .sdot-f { animation: sdot-pop .5s .26s ease both; }

  @keyframes sdot-pop {
    0%   { transform: scale(1)   translateY(0);   opacity: .5; }
    35%  { transform: scale(2.2) translateY(-2px); opacity: 1; }
    65%  { transform: scale(.85) translateY(1px);  opacity: .8; }
    100% { transform: scale(1)   translateY(0);   opacity: .5; }
  }

  /* Onde sur la carte série */
  .legende-card--serie {
    position: relative;
    overflow: hidden;
  }
  .legende-card--serie::after {
    content: '';
    position: absolute;
    top: 50%; left: 50%;
    width: 0; height: 0;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(196,153,58,.12) 0%, transparent 70%);
    transform: translate(-50%, -50%);
    transition: width .5s ease, height .5s ease, opacity .5s ease;
    opacity: 0;
    pointer-events: none;
  }
  .legende-card--serie:hover::after {
    width: 220px; height: 220px;
    opacity: 1;
  }

  /* ── EFFET JARDIN : croissance séquentielle ── */
  .legende-card--jardin { overflow: hidden; }

  .stade-item { transition: transform .2s ease, opacity .2s ease; }

  /* Repos : légèrement comprimé */
  .stade-item--1 { transform: translateY(2px); opacity: .7; }
  .stade-item--2 { transform: translateY(2px); opacity: .7; }
  .stade-item--3 { transform: translateY(2px); opacity: .7; }

  /* Hover : croissance en séquence bas→haut, comme une plante */
  .legende-card--jardin:hover .stade-item--1 {
    animation: stade-grow .45s .00s ease forwards;
  }
  .legende-card--jardin:hover .stade-item--2 {
    animation: stade-grow .45s .12s ease forwards;
  }
  .legende-card--jardin:hover .stade-item--3 {
    animation: stade-grow .45s .24s ease forwards;
  }

  @keyframes stade-grow {
    from { transform: translateY(4px) scale(.96); opacity: .5; }
    60%  { transform: translateY(-1px) scale(1.02); opacity: 1; }
    to   { transform: translateY(0) scale(1); opacity: 1; }
  }

  /* Icônes emoji qui rebondissent dans le badge */
  .legende-card--jardin:hover .stade-item--1 .badge-stade-icon { animation: emoji-bounce .4s .05s ease both; }
  .legende-card--jardin:hover .stade-item--2 .badge-stade-icon { animation: emoji-bounce .4s .18s ease both; }
  .legende-card--jardin:hover .stade-item--3 .badge-stade-icon { animation: emoji-bounce .4s .32s ease both; }

  @keyframes emoji-bounce {
    0%   { transform: scale(1)   rotate(0deg); }
    40%  { transform: scale(1.5) rotate(-8deg); }
    70%  { transform: scale(.9)  rotate(4deg); }
    100% { transform: scale(1)   rotate(0deg); }
  }

  /* ── ANIMATION ── */
  @keyframes rise {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── BADGE SÉRIE ── */
  .badge-serie {
    display: inline-flex;
    align-items: center;
    gap: .32rem;
    background: rgba(107, 127, 184, .08);
    color: #4a5a8a;
    border: 1px solid rgba(107, 127, 184, .22);
    border-radius: 3px;
    padding: .15rem .42rem .15rem .32rem;
    font-family: 'Mulish', sans-serif;
    font-size: .52rem;
    font-weight: 700;
    letter-spacing: .11em;
    text-transform: uppercase;
    cursor: default;
    position: relative;
    transition: background .2s, border-color .2s;
  }

  .badge-serie:hover {
    background: rgba(107, 127, 184, .14);
    border-color: rgba(107, 127, 184, .38);
  }

  .badge-serie::after {
    content: attr(data-tooltip);
    position: absolute;
    bottom: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%);
    background: #2c2416;
    color: #f5f0e8;
    font-family: 'Mulish', sans-serif;
    font-size: .58rem;
    font-weight: 400;
    letter-spacing: .06em;
    text-transform: none;
    white-space: nowrap;
    padding: .3rem .55rem;
    border-radius: 3px;
    opacity: 0;
    pointer-events: none;
    transition: opacity .18s ease;
  }

  .badge-serie:hover::after { opacity: 1; }

  .badge-serie-bulles {
    display: inline-flex;
    align-items: flex-end;
    gap: 2px;
    height: 8px;
    margin-right: 1px;
  }

  .bulle {
    display: block;
    border-radius: 50%;
    background: #6b7fb8;
    opacity: .7;
  }

  .bulle-1 {
    width: 5px;
    height: 5px;
    animation: bulle-p 3.2s ease-in-out infinite;
  }

  .bulle-2 {
    width: 3.5px;
    height: 3.5px;
    animation: bulle-p 3.2s ease-in-out infinite;
    animation-delay: .8s;
  }

  @keyframes bulle-p {
    0%, 100% { opacity: .45; transform: translateY(0); }
    50%       { opacity: .9;  transform: translateY(-2px); }
  }

  /* ── BANDE FENÊTRES ── */
  .fenetre-bande {
    display: block;
    text-decoration: none;
    max-width: var(--max);
    margin: 2rem auto 0;
    padding: 0 1.5rem;
    animation: rise .6s .35s ease both;
  }
  .fenetre-bande-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.1rem 1.5rem;
    border: 1px solid var(--rule);
    border-left: 3px solid var(--accent);
    background: transparent;
    position: relative;
    overflow: hidden;
    transition: background .3s, border-color .3s;
  }

  /* Lueur nocturne qui filtre */
  .fenetre-bande-inner::before {
    content: '';
    position: absolute;
    top: 50%; left: -20px;
    transform: translateY(-50%);
    width: 180px; height: 180px;
    border-radius: 50%;
    background: radial-gradient(circle,
      rgba(196, 153, 58, .10) 0%,
      rgba(139, 94, 60, .04) 40%,
      transparent 70%
    );
    opacity: 0;
    pointer-events: none;
    transition: opacity .45s ease, left .45s ease;
  }

  .fenetre-bande:hover .fenetre-bande-inner::before {
    opacity: 1;
    left: 10px;
  }

  /* Reflet sur la bordure gauche */
  .fenetre-bande-inner::after {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: linear-gradient(to bottom,
      transparent,
      rgba(196,153,58,.5) 40%,
      rgba(196,153,58,.5) 60%,
      transparent
    );
    opacity: 0;
    transition: opacity .35s ease;
  }
  .fenetre-bande:hover .fenetre-bande-inner::after { opacity: 1; }

  .fenetre-bande:hover .fenetre-bande-inner {
    background: rgba(196, 153, 58, .04);
    border-color: rgba(196, 153, 58, .25);
    border-left-color: var(--accent);
  }
  .fenetre-bande-left {
    display: flex;
    align-items: baseline;
    gap: 1.25rem;
    flex-wrap: wrap;
  }
  .fenetre-bande-label {
    font-family: 'Mulish', sans-serif;
    font-size: .65rem;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--accent);
    flex-shrink: 0;
  }
  .fenetre-bande-amorce {
    font-family: 'Libre Baskerville', serif;
    font-size: .88rem;
    font-style: italic;
    color: var(--ink-mid);
    line-height: 1.5;
  }
  .fenetre-bande-cta {
    font-family: 'Mulish', sans-serif;
