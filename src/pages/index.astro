---
import BaseLayout from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');

const serieNotes = allArticles
  .filter(a => a.data.serie === "Notes d'un modèle en construction")
  .sort((a, b) => (a.data.episode ?? 0) - (b.data.episode ?? 0));

const serieDialogues = allArticles
  .filter(a => a.data.serie === "Les rencontres de Nathalie et Élodie")
  .sort((a, b) => (a.data.episode ?? 0) - (b.data.episode ?? 0));

const serieMecanique = allArticles
  .filter(a => a.data.serie === "Mécanique")
  .sort((a, b) => (a.data.episode ?? 0) - (b.data.episode ?? 0));

const fenetresAnalyses = allArticles
  .filter(a => !!a.data.lien_fenetre);

const nbReflexion = serieNotes.length;
const nbNathalie  = serieDialogues.length;

const recents = [...allArticles]
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

function stadeLabel(stade?: string) {
  if (stade === 'pousse') return '🌿 Pousse';
  if (stade === 'arbre')  return '🌳 Arbre';
  return '🌱 Graine';
}

function formatDate(date: Date) {
  return date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
}

const engagementRank: Record<string, number> = { pause: 1, lecture: 2, immersion: 3 };

function maxEngagement(articles: typeof allArticles) {
  let max = 0;
  for (const a of articles) {
    const r = engagementRank[a.data.engagement ?? ''] ?? 0;
    if (r > max) max = r;
  }
  return max;
}

function engagementLabel(rank: number) {
  if (rank === 1) return 'Pause';
  if (rank === 2) return 'Lecture';
  if (rank === 3) return 'Immersion';
  return '';
}
---

<BaseLayout title="Syncognie — Synergie · Cognition · Dialogue" description="Des concepts qui se rencontrent, se frottent, s'éclairent — et font naître ce qu'aucun ne contenait seul. Jardin numérique en croissance.">

<!-- ══ HERO ══ -->
<section class="hero">
  <div class="hero-left">
    <p class="hero-eyebrow">Synergie · Cognition · Dialogue</p>
    <h1 class="hero-titre">Rassembler les idées.<br><em>Accompagner la synergie.</em></h1>
    <p class="hero-sous">Des concepts qui se rencontrent, se frottent, s'éclairent — et font naître ce qu'aucun ne contenait seul. Pas un recueil. Un laboratoire.</p>
    <div class="hero-note">
      <span class="hero-note-g">✦</span>
      <p class="hero-note-t">Jardin numérique en croissance — un espace vivant où chaque note évolue à son rythme.</p>
    </div>
  </div>

  <div class="hero-graphe">
    <canvas id="emergence-canvas" width="240" height="320"
      aria-label="Graphe d'émergence — des concepts qui se rencontrent, se frottent et font naître une propriété nouvelle"></canvas>
  </div>

  <!--
  ══ BANDE RÉFLEXION — conservée pour usage futur ══
  <a class="bande-reflexion" href={serieNotes.length > 0 ? `/articles/${serieNotes[0].slug}` : '/'}>
    <div class="br-gauche">
      <span class="br-eyebrow">Série · Prismes</span>
      <span class="br-titre">Notes d'un modèle en construction</span>
      <span class="br-sous">Gottman · Argyris · Watzlawick · Kahneman · Damasio · Frankl — des notes qui s'enchaînent.</span>
    </div>
    <div class="br-droite">
      <div>
        <div class="br-num">{nbReflexion}</div>
        <div class="br-num-label">notes</div>
      </div>
      <span class="br-btn">Commencer ici →</span>
    </div>
  </a>
  -->
</section>

<!-- ══ PORTES D'ENTRÉE ══ -->
<div class="sep sep--explorer">
  <div class="sep-line"></div>
  <div class="sep-centre"><div class="sep-diamond"></div><span class="sep-label">Explorer</span><div class="sep-diamond"></div></div>
  <div class="sep-line"></div>
</div>

<div class="portes-wrap">

  <a class="porte porte--vies" href="/vies">
    <span class="porte-pill">Vies</span>
    <p class="porte-desc">Des personnages qui vivent, parlent, doutent — et se heurtent à l'écart entre comprendre et faire.</p>
    <p class="porte-formats">Dialogues · Fenêtres · Fragments</p>
    <div class="porte-footer">
      <div>
        <div class="porte-nb">{serieDialogues.length}</div>
        <div class="porte-nb-label">épisodes</div>
      </div>
      <span class="porte-cta">Entrer →</span>
    </div>
  </a>

  <a class="porte porte--cartes" href="/cartes">
    <span class="porte-pill">Cartes</span>
    <p class="porte-desc">Des penseurs convoqués, des mécanismes retournés. Certaines notes partent d'une scène. D'autres d'un concept. Toutes cartographient un territoire.</p>
    <p class="porte-formats">Analyses · Concepts · Penseurs</p>
    <div class="porte-footer">
      <div>
        <div class="porte-nb">{serieNotes.length + serieMecanique.length + fenetresAnalyses.length}</div>
        <div class="porte-nb-label">cartes</div>
      </div>
      <span class="porte-cta">Cartographier →</span>
    </div>
  </a>

</div>

<!-- ══ PUBLICATIONS RÉCENTES ══ -->
<div class="sep sep--pubs">
  <div class="sep-line"></div>
  <div class="sep-centre"><div class="sep-diamond"></div><span class="sep-label">Publications récentes</span><div class="sep-diamond"></div></div>
  <div class="sep-line"></div>
</div>

<div class="pubs-layout">
  <div class="articles-col">
    {recents.map((a) => (
      <a class="article-item" href={`/articles/${a.slug}`}>
        <div class="article-meta">
          <span class="article-date">{formatDate(a.data.date)}</span>
          {a.data.format && (
            <span class="badge badge-analyse">◈ {a.data.format.charAt(0).toUpperCase() + a.data.format.slice(1)}</span>
          )}
          <span class={`badge badge-${a.data.stade ?? 'graine'}`}>{stadeLabel(a.data.stade)}</span>
          {a.data.serie && a.data.episode && (
            <span class="badge badge-serie">
              {a.data.serie === "Notes d'un modèle en construction" ? 'Cartes' :
               a.data.serie === "Les rencontres de Nathalie et Élodie" ? 'Vies' :
               a.data.serie === "Mécanique" ? 'Cartes' : a.data.serie} · {String(a.data.episode).padStart(2, '0')}
            </span>
          )}
        </div>
        <p class="article-titre">{a.data.title}</p>
        <p class="article-desc">{a.data.description}</p>
        <span class="article-lire">Lire →</span>
      </a>
    ))}
  </div>

  <aside class="pubs-sidebar">
    <div class="sidebar-outils">
      <a class="sidebar-outil" href="/outils/constellation">
        <span class="sidebar-outil-icone" style="color:#c4993a">✦</span>
        <div>
          <div class="sidebar-outil-nom">Constellation</div>
          <div class="sidebar-outil-desc">28 penseurs, leurs concepts et filiations</div>
        </div>
      </a>
      <a class="sidebar-outil" href="/outils/boussole">
        <span class="sidebar-outil-icone" style="color:#6b7fb8">◈</span>
        <div>
          <div class="sidebar-outil-nom">Boussole dopaminergique</div>
          <div class="sidebar-outil-desc">Estimer sa charge nerveuse</div>
        </div>
      </a>
      <a class="sidebar-outil" href="/outils/barometre">
        <span class="sidebar-outil-icone" style="color:#3ab87a">⊕</span>
        <div>
          <div class="sidebar-outil-nom">Baromètre de charge</div>
          <div class="sidebar-outil-desc">Une photo de ce que tu portes</div>
        </div>
      </a>
      <a href="/outils" class="sidebar-outils-tous">Tous les outils →</a>
    </div>

    <div class="sidebar-sep"></div>

    <a href="/stades" class="sidebar-stades">
      <span>🌱</span>
      <span class="sidebar-stades-texte">Comment lire les stades →</span>
    </a>
  </aside>
</div>

<style>
/* Variables locales — tout le reste vient de Base.astro */
:root {
  --max: 740px;
}

/* HERO */
.hero {
  max-width: var(--max); margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 240px;
  grid-template-rows: auto;
  align-items: start;
  gap: 0;
}
@media (max-width: 580px) {
  .hero { grid-template-columns: 1fr; }
  .hero-graphe { display: none; }
}
@media (min-width: 581px) and (max-width: 720px) {
  .hero { grid-template-columns: 1fr 180px; }
}
.hero-left { grid-column: 1; grid-row: 1; padding: 3.4rem 1.75rem 2.4rem; }
.hero-eyebrow { font-family: 'Mulish', sans-serif; font-size: .68rem; font-weight: 300; letter-spacing: .28em; text-transform: uppercase; color: var(--accent); opacity: .72; margin-bottom: 1rem; }
.hero-titre { font-family: 'Libre Baskerville', Georgia, serif; font-size: clamp(1.4rem, 2.8vw, 1.9rem); font-weight: 700; line-height: 1.2; color: var(--ink); letter-spacing: -.018em; margin-bottom: .9rem; }
.hero-titre em { font-style: italic; font-weight: 400; color: var(--gold); }
.hero-sous { font-family: 'Mulish', sans-serif; font-size: .86rem; color: var(--ink-soft); line-height: 1.8; max-width: 40ch; margin-bottom: 1.4rem; }
.hero-note { display: flex; align-items: flex-start; gap: .55rem; padding: .65rem .9rem; background: var(--gold-bg); border-left: 2px solid var(--gold-dim); border-radius: 0 3px 3px 0; max-width: 40ch; }
.hero-note-g { color: var(--gold); font-size: .72rem; flex-shrink: 0; margin-top: .06rem; opacity: .55; }
.hero-note-t { font-family: 'Mulish', sans-serif; font-size: .78rem; font-style: italic; color: var(--ink-soft); line-height: 1.6; }
.hero-graphe { grid-column: 2; grid-row: 1; padding-top: 2.6rem; display: flex; align-items: flex-start; justify-content: flex-start; }
.hero-graphe canvas { display: block; width: 240px; height: 320px; -webkit-mask-image: linear-gradient(to right, transparent 0%, black 30%, black 72%, transparent 100%); mask-image: linear-gradient(to right, transparent 0%, black 30%, black 72%, transparent 100%); }

/* SÉPARATEUR */
.sep { display: flex; align-items: center; gap: .9rem; max-width: var(--max); margin: 0 auto 1.2rem; padding: 0 1.75rem; }
.sep-line { flex: 1; height: 1px; background: linear-gradient(to right, transparent, var(--rule), transparent); }
.sep-centre { display: flex; align-items: center; gap: .5rem; }
.sep-diamond { width: 5px; height: 5px; transform: rotate(45deg); }
.sep--series .sep-diamond,
.sep--outils .sep-diamond,
.sep--pubs   .sep-diamond,
.sep--explorer .sep-diamond { background: var(--gold); opacity: .62; }
.sep-label { font-family: 'Mulish', sans-serif; font-size: .68rem; font-weight: 700; letter-spacing: .18em; text-transform: uppercase; }
.sep--series .sep-label,
.sep--outils .sep-label,
.sep--pubs   .sep-label,
.sep--explorer .sep-label { color: var(--accent); }
.sep--explorer { margin-top: 2rem; }
.sep--series { margin-top: 2.4rem; }
.sep--outils { margin-top: 2.6rem; }
.sep--pubs   { margin-top: 2.8rem; }

/* ══ PORTES D'ENTRÉE ══ */
.portes-wrap {
  max-width: var(--max); margin: 0 auto; padding: 0 1.75rem;
  display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;
}
@media (max-width: 560px) { .portes-wrap { grid-template-columns: 1fr; } }

.porte {
  text-decoration: none;
  border: 1px solid var(--rule);
  border-radius: 10px;
  padding: 1.8rem 1.6rem 1.5rem;
  position: relative; overflow: hidden;
  display: flex; flex-direction: column; gap: .75rem;
  transition: transform .22s, box-shadow .28s, border-color .28s;
  min-height: 200px;
}
.porte:hover { transform: translateY(-3px); }

.porte--vies {
  border-left: 3px solid rgba(155,50,50,.45);
  background: linear-gradient(145deg, rgba(155,50,50,.05) 0%, rgba(155,50,50,.01) 50%, transparent 100%);
}
.porte--vies:hover {
  border-color: rgba(155,50,50,.3);
  border-left-color: rgba(155,50,50,.8);
  box-shadow: 0 6px 28px rgba(155,50,50,.1);
}
.porte--cartes {
  border-left: 3px solid rgba(232,184,50,.5);
  background: linear-gradient(145deg, rgba(232,184,50,.06) 0%, rgba(232,184,50,.01) 50%, transparent 100%);
}
.porte--cartes:hover {
  border-color: rgba(232,184,50,.38);
  border-left-color: rgba(232,184,50,.85);
  box-shadow: 0 6px 28px rgba(196,153,58,.12);
}

.porte-pill {
  display: inline-block;
  font-family: 'Mulish', sans-serif; font-size: .55rem; font-weight: 700;
  letter-spacing: .22em; text-transform: uppercase;
  padding: .25rem .65rem; border-radius: 3px; width: fit-content;
}
.porte--vies  .porte-pill { background: rgba(155,50,50,.09);  color: #7a2020; border: 1px solid rgba(155,50,50,.18); }
.porte--cartes .porte-pill { background: rgba(196,153,58,.1); color: #7a5a08; border: 1px solid rgba(196,153,58,.22); }

.porte-desc {
  font-family: 'Mulish', sans-serif;
  font-size: .82rem; font-weight: 300; line-height: 1.75;
  color: var(--ink-mid); flex: 1;
}
.porte-formats {
  font-family: 'Mulish', sans-serif;
  font-size: .6rem; font-weight: 700; letter-spacing: .18em; text-transform: uppercase;
  opacity: .45;
}
.porte--vies  .porte-formats { color: #9b3232; }
.porte--cartes .porte-formats { color: #a07828; }

.porte-footer {
  display: flex; align-items: flex-end; justify-content: space-between;
  margin-top: .3rem; padding-top: .9rem;
  border-top: 1px solid rgba(221,214,200,.5);
}
.porte-nb {
  font-family: 'Libre Baskerville', Georgia, serif;
  font-size: 1.9rem; font-weight: 700; line-height: 1; letter-spacing: -.02em;
}
.porte--vies  .porte-nb { color: #9b3232; }
.porte--cartes .porte-nb { color: #c4993a; }
.porte-nb-label {
  font-family: 'Mulish', sans-serif; font-size: .58rem;
  letter-spacing: .1em; text-transform: uppercase; color: var(--ink-soft); margin-top: .18rem;
}
.porte-cta {
  font-family: 'Mulish', sans-serif; font-size: .68rem; font-weight: 700;
  letter-spacing: .14em; text-transform: uppercase;
  opacity: 0; transform: translateX(-4px);
  transition: opacity .2s, transform .2s;
}
.porte:hover .porte-cta { opacity: 1; transform: translateX(0); }
@media (hover: none) { .porte-cta { opacity: .7; transform: translateX(0); } }
.porte--vies  .porte-cta { color: #9b3232; }
.porte--cartes .porte-cta { color: #a07828; }

/* ══ PUBLICATIONS + SIDEBAR ══ */
.pubs-layout {
  max-width: var(--max); margin: 0 auto; padding: 0 1.75rem;
  display: grid;
  grid-template-columns: 1fr 180px;
  gap: 2.4rem;
  align-items: start;
}
@media (max-width: 640px) {
  .pubs-layout { grid-template-columns: 1fr; }
  .pubs-sidebar { position: static; }
}

.articles-col { min-width: 0; }
.article-item { display: block; padding: .7rem 0 .78rem; border-bottom: 1px solid #ede8df; text-decoration: none; transition: transform .18s; }
.article-item:hover { transform: translateX(3px); }
.article-item:hover .article-titre { color: var(--accent); }
.article-item:hover .article-lire { opacity: 1; }
.article-meta { display: flex; align-items: center; gap: .4rem; margin-bottom: .25rem; flex-wrap: wrap; }
.article-date { font-family: 'Mulish', sans-serif; font-size: .6rem; font-weight: 300; letter-spacing: .15em; color: var(--ink-soft); opacity: .6; }
.badge { font-family: 'Mulish', sans-serif; font-size: .55rem; font-weight: 700; letter-spacing: .13em; text-transform: uppercase; padding: .15rem .45rem; border-radius: 3px; line-height: 1.5; }
.badge-analyse  { background: rgba(107,127,184,.1);  color: #6b7fb8; border: 1px solid rgba(107,127,184,.25); }
.badge-dialogue { background: rgba(196,153,58,.1);   color: #c4993a; border: 1px solid rgba(196,153,58,.25); }
.badge-graine   { background: rgba(46,125,78,.07);   color: #2e7d4e; border: 1px solid rgba(46,125,78,.2); }
.badge-pousse   { background: rgba(56,120,60,.09);   color: #38783c; border: 1px solid rgba(56,120,60,.22); }
.badge-arbre    { background: rgba(46,125,78,.18);   color: #224422; border: 1px solid rgba(34,68,34,.2); }
.badge-serie    { background: rgba(107,127,184,.08); color: #4a5a8a; border: 1px solid rgba(107,127,184,.22); }
.badge-stade { display: inline-flex; align-items: center; gap: .28rem; }
.badge-stade-icon { font-size: .65rem; line-height: 1; }
.article-titre { font-family: 'Libre Baskerville', Georgia, serif; font-size: .92rem; line-height: 1.35; color: var(--ink); margin-bottom: .2rem; }
.article-desc { font-family: 'Mulish', sans-serif; font-size: .71rem; color: var(--ink-mid); line-height: 1.52; margin-bottom: .3rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.article-lire { font-family: 'Mulish', sans-serif; font-size: .7rem; letter-spacing: .09em; text-transform: uppercase; color: var(--link); opacity: 0; transition: opacity .18s; }
@media (hover: none) { .article-lire { opacity: .6; } }

/* SIDEBAR OUTILS + STADES */
.pubs-sidebar { position: sticky; top: 4.5rem; align-self: start; }

.sidebar-outils { display: flex; flex-direction: column; gap: .5rem; }

.sidebar-outil {
  display: flex; align-items: flex-start; gap: .65rem;
  text-decoration: none; padding: .65rem .75rem;
  border: 1px solid var(--rule); border-radius: 7px;
  background: rgba(245,240,232,.5);
  transition: border-color .2s, transform .18s, box-shadow .2s;
}
.sidebar-outil:hover {
  border-color: rgba(196,153,58,.4);
  transform: translateY(-1px);
  box-shadow: 0 3px 14px rgba(196,153,58,.07);
}
.sidebar-outil-icone {
  font-size: .9rem; flex-shrink: 0; margin-top: .05rem; line-height: 1; opacity: .75;
}
.sidebar-outil-nom {
  font-family: 'Libre Baskerville', Georgia, serif;
  font-size: .76rem; font-weight: 700; color: var(--ink); line-height: 1.25; margin-bottom: .15rem;
}
.sidebar-outil-desc {
  font-family: 'Mulish', sans-serif;
  font-size: .67rem; font-weight: 300; color: var(--ink-soft); line-height: 1.5;
}
.sidebar-outils-tous {
  display: block; text-align: right; margin-top: .2rem;
  font-family: 'Mulish', sans-serif; font-size: .62rem; font-weight: 700;
  letter-spacing: .12em; text-transform: uppercase;
  color: var(--accent); text-decoration: none; opacity: .75;
  transition: opacity .2s;
}
.sidebar-outils-tous:hover { opacity: 1; }

.sidebar-sep {
  height: 1px; margin: .85rem 0;
  background: linear-gradient(to right, transparent, var(--rule), transparent);
}

.sidebar-stades {
  display: inline-flex; align-items: center; gap: .45rem;
  text-decoration: none; padding: .4rem .5rem;
  border-radius: 5px;
  transition: background .2s;
}
.sidebar-stades:hover { background: rgba(139,94,60,.05); }
.sidebar-stades-texte {
  font-family: 'Mulish', sans-serif; font-size: .63rem; font-weight: 400;
  font-style: italic; letter-spacing: .06em; color: var(--ink-soft);
}
</style>

<script>
