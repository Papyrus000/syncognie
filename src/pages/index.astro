}

/* ── Outils dans le sommaire ── */
.toc-sub--outils {
  padding-bottom: .3rem;
  border-left: 1px solid rgba(46,122,74,.06);
  margin-left: 1.1rem;
}

.toc-outil-item {
  display: flex; align-items: center; gap: .48rem;
  padding: .22rem .2rem;
  text-decoration: none; color: inherit;
