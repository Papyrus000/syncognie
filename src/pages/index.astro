    <a class="ohc" href="/outils/barometre" style="--oc:#3ab87a; --oc-mix:58,184,122;">
      <div class="ohc-num" aria-hidden="true">⊕</div>
      <svg class="ohc-svg" viewBox="0 0 48 48" fill="none" aria-hidden="true">
        <path d="M10 36 Q10 14 24 14 Q38 14 38 36" stroke="#3ab87a" stroke-width="1" opacity=".22" fill="none"/>
        <path d="M14 36 Q14 18 24 18 Q34 18 34 36" stroke="#3ab87a" stroke-width="1.1" opacity=".3" fill="none"/>
        <line x1="24" y1="36" x2="24" y2="14" stroke="#3ab87a" stroke-width=".6" opacity=".15" stroke-dasharray="2 4"/>
        <line x1="10" y1="36" x2="38" y2="36" stroke="#3ab87a" stroke-width="1.2" opacity=".4" stroke-linecap="round"/>
        <line x1="24" y1="36" x2="32" y2="22" stroke="#3ab87a" stroke-width="1.5" opacity=".6" stroke-linecap="round" class="ohc-aiguille-v"/>
        <circle cx="24" cy="36" r="2.2" fill="#3ab87a" opacity=".45"/>
      </svg>
      <span class="ohc-label">Immédiat</span>
      <h3 class="ohc-titre">Baromètre de charge</h3>
      <p class="ohc-desc">Une photo de ce que tu portes — physique, mental, émotionnel. Sans jugement, sans culpabilité.</p>
      <span class="ohc-cta">Explorer →</span>
    </a>

  </div>

  <div class="outils-pied">
    <a href="/outils" class="outils-lien-tous">Voir tous les outils →</a>
  </div>
</div>

<!-- ══ PUBLICATIONS RÉCENTES ══ -->
<div class="sep sep--pubs">
  <div class="sep-line"></div>
  <div class="sep-centre"><div class="sep-diamond"></div><span class="sep-label">Publications récentes</span><div class="sep-diamond"></div></div>
  <div class="sep-line"></div>
</div>

<div class="pubs-layout">
  <div class="articles-col">
    {recents.map((a) => (
      <a class="article-item" href={`/articles/${a.slug}`}>
        <div class="article-meta">
          <span class="article-date">{formatDate(a.data.date)}</span>
          {a.data.format && (
            <span class="badge badge-analyse">◈ {a.data.format.charAt(0).toUpperCase() + a.data.format.slice(1)}</span>
          )}
          <span class={`badge badge-${a.data.stade ?? 'graine'}`}>{stadeLabel(a.data.stade)}</span>
          {a.data.serie && a.data.episode && (
            <span class="badge badge-serie">
              {a.data.serie === "Notes d'un modèle en construction" ? 'Prismes' :
               a.data.serie === "Les rencontres de Nathalie et Élodie" ? 'Récit' :
               a.data.serie === "Mécanique" ? 'Mécanique' : a.data.serie} · {String(a.data.episode).padStart(2, '0')}
            </span>
          )}
        </div>
        <p class="article-titre">{a.data.title}</p>
        <p class="article-desc">{a.data.description}</p>
        <span class="article-lire">Lire →</span>
      </a>
    ))}
  </div>

  <aside class="pubs-sidebar">
    <a href="/stades" class="legende-card legende-card--jardin">
      <p class="legende-titre">Stades de maturité</p>
      <ul class="legende-list">
        <li class="stade-item stade-item--1">
          <span class="badge badge-graine badge-stade"><span class="badge-stade-icon">🌱</span> Graine</span>
          <span class="legende-desc">Idée posée, peu développée</span>
        </li>
        <li class="stade-item stade-item--2">
          <span class="badge badge-pousse badge-stade"><span class="badge-stade-icon">🌿</span> Pousse</span>
          <span class="legende-desc">En cours d'exploration</span>
        </li>
        <li class="stade-item stade-item--3">
          <span class="badge badge-arbre badge-stade"><span class="badge-stade-icon">🌳</span> Arbre</span>
          <span class="legende-desc">Consolidé, dense</span>
        </li>
      </ul>
      <p class="legende-note">
        Syncognie est un jardin numérique — les notes évoluent, se ramifient, mûrissent avec le temps.
      </p>
      <span class="legende-cta">En savoir plus →</span>
    </a>
  </aside>
</div>

<style>
:root {
  --gold:      #e8b832;
  --gold-dim:  rgba(232,184,50,.32);
  --gold-bg:   rgba(232,184,50,.07);
  --gold-text: #7a5a08;
  --terra:     #8b5e3c;
  --terra-h:   #a06a40;
  --blue-link: #3a9fd8;
  --parch:     #f5f0e8;
  --ink:       #1a1714;
  --ink-soft:  #9a9189;
  --ink-mid:   #7a7068;
  --rule:      #ddd6c8;
  --max:       740px;
}

/* HERO */
.hero {
  max-width: var(--max); margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 240px;
  grid-template-rows: auto;
  align-items: start;
  gap: 0;
}
@media (max-width: 580px) {
  .hero { grid-template-columns: 1fr; }
  .hero-graphe { display: none; }
}
@media (min-width: 581px) and (max-width: 720px) {
  .hero { grid-template-columns: 1fr 180px; }
}
.hero-left { grid-column: 1; grid-row: 1; padding: 3.4rem 1.75rem 2.4rem; }
.hero-eyebrow { font-family: 'Mulish', sans-serif; font-size: .68rem; font-weight: 300; letter-spacing: .28em; text-transform: uppercase; color: var(--terra); opacity: .72; margin-bottom: 1rem; }
.hero-titre { font-family: 'Libre Baskerville', Georgia, serif; font-size: clamp(1.4rem, 2.8vw, 1.9rem); font-weight: 700; line-height: 1.2; color: var(--ink); letter-spacing: -.018em; margin-bottom: .9rem; }
.hero-titre em { font-style: italic; font-weight: 400; color: var(--gold); }
.hero-sous { font-family: 'Mulish', sans-serif; font-size: .86rem; color: var(--ink-soft); line-height: 1.8; max-width: 40ch; margin-bottom: 1.4rem; }
.hero-note { display: flex; align-items: flex-start; gap: .55rem; padding: .65rem .9rem; background: var(--gold-bg); border-left: 2px solid var(--gold-dim); border-radius: 0 3px 3px 0; max-width: 40ch; }
.hero-note-g { color: var(--gold); font-size: .72rem; flex-shrink: 0; margin-top: .06rem; opacity: .55; }
.hero-note-t { font-family: 'Mulish', sans-serif; font-size: .78rem; font-style: italic; color: var(--ink-soft); line-height: 1.6; }
.hero-graphe { grid-column: 2; grid-row: 1; padding-top: 2.6rem; display: flex; align-items: flex-start; justify-content: flex-start; }
.hero-graphe canvas { display: block; width: 240px; height: 320px; -webkit-mask-image: linear-gradient(to right, transparent 0%, black 30%, black 72%, transparent 100%); mask-image: linear-gradient(to right, transparent 0%, black 30%, black 72%, transparent 100%); }

/* BANDE RÉFLEXION — styles conservés pour réactivation future */
.bande-reflexion { grid-column: 1; grid-row: 2; margin: 0 1.75rem 2.2rem; text-decoration: none; display: flex; align-items: stretch; border: 1px solid rgba(232,184,50,.28); border-left: 3px solid var(--gold); border-radius: 4px; background: linear-gradient(105deg, var(--gold-bg) 0%, rgba(245,240,232,0) 65%); position: relative; overflow: hidden; transition: border-color .22s, box-shadow .22s; }
.bande-reflexion:hover { border-color: rgba(232,184,50,.52); box-shadow: 0 3px 22px rgba(139,94,60,.1); }
.bande-reflexion::after { content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 1.5px; background: linear-gradient(to right, rgba(232,184,50,.5), transparent); transform: scaleX(0); transform-origin: left; transition: transform .36s ease; }
.bande-reflexion:hover::after { transform: scaleX(1); }
.br-gauche { padding: .95rem 1.2rem 1rem; flex: 1; display: flex; flex-direction: column; gap: .22rem; }
.br-eyebrow { font-family: 'Mulish', sans-serif; font-size: .66rem; font-weight: 700; letter-spacing: .18em; text-transform: uppercase; color: var(--gold-text); opacity: .85; }
.br-titre { font-family: 'Libre Baskerville', Georgia, serif; font-size: .94rem; font-style: italic; color: var(--ink); line-height: 1.3; }
.br-sous { font-family: 'Mulish', sans-serif; font-size: .7rem; color: var(--ink-mid); line-height: 1.48; max-width: 36ch; margin-top: .05rem; }
.br-droite { padding: .95rem 1.2rem .95rem .5rem; display: flex; flex-direction: column; align-items: flex-end; justify-content: space-between; gap: .45rem; flex-shrink: 0; }
.br-num { font-family: 'Libre Baskerville', Georgia, serif; font-size: 2.3rem; font-weight: 700; color: var(--gold); line-height: 1; letter-spacing: -.03em; opacity: .9; }
.br-num-label { font-family: 'Mulish', sans-serif; font-size: .62rem; letter-spacing: .1em; text-transform: uppercase; color: var(--gold-text); opacity: .55; text-align: right; margin-top: -.1rem; }
.br-btn { font-family: 'Mulish', sans-serif; font-size: .68rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: var(--parch); background: var(--terra); padding: .35rem .82rem; border-radius: 3px; white-space: nowrap; transition: background .18s; }
.bande-reflexion:hover .br-btn { background: var(--terra-h); }

/* SÉPARATEUR */
.sep { display: flex; align-items: center; gap: .9rem; max-width: var(--max); margin: 0 auto 1.2rem; padding: 0 1.75rem; }
.sep-line { flex: 1; height: 1px; background: linear-gradient(to right, transparent, var(--rule), transparent); }
.sep-centre { display: flex; align-items: center; gap: .5rem; }
.sep-diamond { width: 5px; height: 5px; transform: rotate(45deg); }
.sep--series .sep-diamond { background: var(--gold); opacity: .62; }
.sep--outils .sep-diamond { background: var(--gold); opacity: .62; }
.sep--pubs   .sep-diamond { background: var(--gold); opacity: .62; }
.sep-label { font-family: 'Mulish', sans-serif; font-size: .68rem; font-weight: 700; letter-spacing: .18em; text-transform: uppercase; }
.sep--series .sep-label { color: var(--terra); }
.sep--outils .sep-label { color: var(--terra); }
.sep--pubs   .sep-label { color: var(--terra); }
.sep--outils { margin-top: 2.6rem; }
.sep--pubs   { margin-top: 2.8rem; }

/* BANDES SÉRIE */
.series-wrap { max-width: var(--max); margin: 0 auto; padding: 0 1.75rem; display: flex; flex-direction: column; gap: .8rem; }
.serie-band { border: 1px solid var(--rule); border-radius: 6px; overflow: hidden; transition: border-color .25s, box-shadow .25s; }
.serie-band--notes     { border-left: 3px solid rgba(232,184,50,.4); }
.serie-band--recit     { border-left: 3px solid rgba(58,159,216,.28); }
.serie-band--mecanique { border-left: 3px solid rgba(124,92,191,.35); }
.serie-band--notes:hover     { border-color: rgba(232,184,50,.52);  box-shadow: 0 2px 18px rgba(139,94,60,.08); }
.serie-band--recit:hover     { border-color: rgba(58,159,216,.42);  box-shadow: 0 2px 14px rgba(58,159,216,.09); }
.serie-band--mecanique:hover { border-color: rgba(124,92,191,.45);  box-shadow: 0 2px 14px rgba(124,92,191,.09); }
.serie-head { display: flex; align-items: center; justify-content: space-between; padding: .7rem 1.1rem .65rem; gap: 1rem; border-bottom: 1px solid #ede8df; }
.serie-band--notes .serie-head     { background: rgba(232,184,50,.04);  border-bottom-color: rgba(232,184,50,.15); }
.serie-band--recit .serie-head     { background: rgba(58,159,216,.04);  border-bottom-color: rgba(58,159,216,.12); }
.serie-band--mecanique .serie-head { background: rgba(124,92,191,.04); border-bottom-color: rgba(124,92,191,.12); }
.serie-head-left  { display: flex; align-items: baseline; gap: .65rem; flex-wrap: wrap; }
.serie-head-right { display: flex; align-items: center; gap: .75rem; flex-shrink: 0; }
.serie-pill { font-family: 'Mulish', sans-serif; font-size: .66rem; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; padding: .14rem .44rem; border-radius: 3px; flex-shrink: 0; line-height: 1.6; }
.serie-pill--notes     { color: #6a4808; background: rgba(232,184,50,.12);  border: 1px solid rgba(232,184,50,.3); }
.serie-pill--recit     { color: #1a5a8a; background: rgba(58,159,216,.1);   border: 1px solid rgba(58,159,216,.25); }
.serie-pill--mecanique { color: #4a2a8a; background: rgba(124,92,191,.1);  border: 1px solid rgba(124,92,191,.28); }
.serie-titre { font-family: 'Libre Baskerville', Georgia, serif; font-size: .85rem; font-style: italic; color: #2c2416; }
.serie-cta { font-family: 'Mulish', sans-serif; font-size: .68rem; letter-spacing: .1em; text-transform: uppercase; text-decoration: none; color: var(--blue-link); flex-shrink: 0; white-space: nowrap; opacity: 0; transform: translateX(-3px); transition: opacity .2s, transform .2s; }
.serie-band:hover .serie-cta { opacity: 1; transform: translateX(0); }
.serie-cta--mecanique { color: #7c5cbf; }
@media (hover: none) { .serie-cta { opacity: .65; transform: translateX(0); } }
.serie-body { display: flex; overflow-x: auto; scrollbar-width: none; background: rgba(250,247,242,.75); }
.serie-body--recit     { background: rgba(245,250,255,.8); }
.serie-body--mecanique { background: rgba(248,245,255,.8); }
.serie-body::-webkit-scrollbar { display: none; }
.capsule { flex: 0 0 auto; width: 168px; padding: .8rem .95rem .85rem; border-right: 1px solid rgba(221,214,200,.7); text-decoration: none; display: flex; flex-direction: column; gap: .2rem; position: relative; transition: background .18s; }
.capsule--recit     { border-right-color: rgba(58,159,216,.15); }
.capsule--mecanique { border-right-color: rgba(124,92,191,.15); }
.capsule:last-child { border-right: none; }
.serie-band--notes .capsule:not(.capsule--ghost):hover     { background: rgba(232,184,50,.07); }
.serie-band--recit .capsule:not(.capsule--ghost):hover     { background: rgba(58,159,216,.07); }
.serie-band--mecanique .capsule:not(.capsule--ghost):hover { background: rgba(124,92,191,.07); }
.capsule:not(:last-child)::after { content: '›'; position: absolute; right: -8px; top: 50%; transform: translateY(-50%); font-size: .75rem; color: var(--rule); pointer-events: none; z-index: 2; }
.cap-num { font-family: 'Mulish', sans-serif; font-size: .68rem; font-weight: 700; letter-spacing: .13em; line-height: 1; }
.cap-num--notes     { color: var(--gold); }
.cap-num--recit     { color: var(--blue-link); }
.cap-num--mecanique { color: #7c5cbf; }
.cap-titre { font-family: 'Libre Baskerville', Georgia, serif; font-size: .77rem; line-height: 1.38; color: var(--ink); flex: 1; }
.cap-stade { font-family: 'Mulish', sans-serif; font-size: .68rem; color: var(--ink-soft); margin-top: .16rem; }
.capsule--entree { background: rgba(232,184,50,.055); }
.serie-band--mecanique .capsule--entree { background: rgba(124,92,191,.055); }
.capsule--entree .cap-titre { font-weight: 700; }
.capsule--entree::before { content: 'Commencer ici'; position: absolute; top: .45rem; right: .6rem; font-family: 'Mulish', sans-serif; font-size: .63rem; font-weight: 700; letter-spacing: .09em; text-transform: uppercase; color: var(--gold); opacity: .7; }
.serie-band--mecanique .capsule--entree::before { color: #7c5cbf; }
.capsule--ghost { opacity: .3; cursor: default; pointer-events: none; }
.capsule--ghost .cap-titre { font-style: italic; color: var(--ink-soft); }

/* INDICATEUR ENGAGEMENT + NIVEAU */
.eng-wrap { display: inline-flex; align-items: center; gap: .32rem; }
.eng-niveau { font-family: 'Mulish', sans-serif; font-size: .60rem; font-weight: 300; letter-spacing: .04em; color: var(--ink-soft); opacity: .55; white-space: nowrap; line-height: 1; vertical-align: middle; }
.eng-indicator { display: inline-flex; align-items: flex-end; gap: 5px; }
.eng-bar { display: inline-block; width: 4px; border-radius: 2px 2px 1px 1px; background: var(--rule); }
.eng-b1 { height: 6px; }
.eng-b2 { height: 10px; }
.eng-b3 { height: 14px; }
.eng-bar.on { background: var(--engagement, #7c5cbf); }

/* ══ OUTILS ══ */
.outils-section { max-width: var(--max); margin: 0 auto; padding: 0 1.75rem; }
.outils-chapeau { font-family: 'Mulish', sans-serif; font-size: .84rem; font-weight: 300; font-style: italic; color: var(--ink-mid); line-height: 1.65; margin-bottom: 1.5rem; }

.outils-grille-home {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
}
@media (max-width: 580px) { .outils-grille-home { grid-template-columns: 1fr; gap: .75rem; } }
@media (min-width: 581px) and (max-width: 720px) { .outils-grille-home { grid-template-columns: repeat(2, 1fr); } }

.ohc {
  display: flex; flex-direction: column;
  padding: 1.6rem 1.4rem 1.3rem;
  border: 1px solid color-mix(in srgb, var(--oc) 18%, transparent);
  border-top: 2.5px solid var(--oc);
  border-radius: 0 0 8px 8px;
  background: color-mix(in srgb, var(--oc) 3%, var(--parch));
  text-decoration: none; color: inherit;
  position: relative; overflow: hidden;
  transition: transform .22s, box-shadow .22s, background .25s;
}
.ohc::after {
  content: '';
  position: absolute; inset: 0;
  background: radial-gradient(ellipse 60% 40% at 5% 0%, color-mix(in srgb, var(--oc) 14%, transparent), transparent 70%);
  opacity: 0; transition: opacity .3s; pointer-events: none;
}
.ohc:hover { transform: translateY(-4px); box-shadow: 0 12px 32px color-mix(in srgb, var(--oc) 13%, transparent); background: color-mix(in srgb, var(--oc) 6%, var(--parch)); }
.ohc:hover::after { opacity: 1; }

.ohc-num { position: absolute; top: -.2rem; right: .6rem; font-size: 5.5rem; font-weight: 700; line-height: 1; color: var(--oc); opacity: .055; pointer-events: none; user-select: none; font-family: 'Libre Baskerville', Georgia, serif; }
.ohc-svg { width: 34px; height: 34px; flex-shrink: 0; margin-bottom: .7rem; position: relative; z-index: 1; }

.ohc-aiguille-b { transform-origin: 24px 24px; animation: ohc-tourne 6s ease-in-out infinite; }
.ohc-aiguille-v { transform-origin: 24px 36px; animation: ohc-balance 4s ease-in-out infinite; }
@keyframes ohc-tourne { 0%,100%{transform:rotate(-20deg)} 50%{transform:rotate(20deg)} }
@keyframes ohc-balance { 0%,100%{transform:rotate(-18deg)} 50%{transform:rotate(18deg)} }

.ohc-label { font-family: 'Mulish', sans-serif; font-size: .58rem; font-weight: 700; letter-spacing: .18em; text-transform: uppercase; color: var(--oc); opacity: .7; margin-bottom: .6rem; position: relative; z-index: 1; }
.ohc-titre { font-family: 'Libre Baskerville', Georgia, serif; font-size: .95rem; font-weight: 700; color: var(--ink); line-height: 1.25; letter-spacing: -.01em; margin-bottom: .7rem; position: relative; z-index: 1; }
.ohc-desc { font-family: 'Mulish', sans-serif; font-size: .76rem; font-weight: 300; color: var(--ink-mid); line-height: 1.7; flex: 1; margin-bottom: .9rem; position: relative; z-index: 1; }
.ohc-cta { font-family: 'Mulish', sans-serif; font-size: .6rem; font-weight: 600; letter-spacing: .14em; text-transform: uppercase; color: var(--blue-link); opacity: 0; transform: translateX(-4px); transition: opacity .2s, transform .2s; align-self: flex-end; position: relative; z-index: 1; }
.ohc:hover .ohc-cta { opacity: 1; transform: translateX(0); }
@media (hover: none) {
  .ohc-cta { opacity: .75; transform: translateX(0); }
  .ohc:hover { transform: none; box-shadow: none; }
  .ohc:hover::after { opacity: 0; }
}

.outils-pied { margin-top: 1.2rem; display: flex; justify-content: flex-end; }
.outils-lien-tous {
  font-family: 'Mulish', sans-serif;
  font-size: .6rem; font-weight: 600;
  letter-spacing: .14em; text-transform: uppercase;
  color: var(--blue-link);
  text-decoration: none;
  opacity: .7;
  transform: translateX(-3px);
  transition: opacity .2s, transform .2s, letter-spacing .25s;
  display: inline-block;
}
.outils-lien-tous:hover {
  opacity: 1;
  transform: translateX(0);
  letter-spacing: .2em;
}

/* ══ PUBLICATIONS + SIDEBAR ══ */
.pubs-layout {
