.badge-serie    { background: rgba(107,127,184,.08); color: #4a5a8a; border: 1px solid rgba(107,127,184,.22); }
.badge-stade { display: inline-flex; align-items: center; gap: .28rem; }
.legende-list .badge-stade { display: flex; width: 100%; }
.badge-stade-icon { font-size: .65rem; line-height: 1; }
.article-titre { font-family: 'Libre Baskerville', Georgia, serif; font-size: .92rem; line-height: 1.35; color: var(--ink); margin-bottom: .2rem; }
.article-desc { font-family: 'Mulish', sans-serif; font-size: .71rem; color: var(--ink-mid); line-height: 1.52; margin-bottom: .3rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
