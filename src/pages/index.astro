/* ── Liste des notes (Mécanique / Vies) ── */
.toc-mecanique {
  list-style: none;
  margin: .1rem 0 0;
  padding: 0 0 .2rem 1.5rem;
  border-left: 1px solid rgba(46,122,74,.06);
