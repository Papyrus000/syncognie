}
.toc-mec-ep {
  font-family: 'Mulish', sans-serif;
  font-size: .58rem; font-weight: 600;
  color: rgba(46,122,74,.42);
  background: rgba(58,124,78,.06);
  border: 1px solid rgba(58,124,78,.13);
  padding: .04rem .28rem; border-radius: 3px;
  white-space: nowrap; flex-shrink: 0; letter-spacing: .04em;
