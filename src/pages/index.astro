---
import BaseLayout from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');

const serieNotes = allArticles
  .filter(a => a.data.serie === "Notes d'un modèle en construction")
  .sort((a, b) => (a.data.episode ?? 0) - (b.data.episode ?? 0));

const serieDialogues = allArticles
  .filter(a => a.data.serie === "Les rencontres de Nathalie et Élodie")
  .sort((a, b) => (a.data.episode ?? 0) - (b.data.episode ?? 0));

const serieMecanique = allArticles
  .filter(a => a.data.serie === "Mécanique")
  .sort((a, b) => (a.data.episode ?? 0) - (b.data.episode ?? 0));

const nbReflexion = serieNotes.length;
const nbNathalie  = serieDialogues.length;

const recents = [...allArticles]
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

function stadeLabel(stade?: string) {
  if (stade === 'pousse') return '🌿 Pousse';
  if (stade === 'arbre')  return '🌳 Arbre';
  return '🌱 Graine';
}

function formatDate(date: Date) {
  return date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
}

const engagementRank: Record<string, number> = { pause: 1, lecture: 2, immersion: 3 };

function maxEngagement(articles: typeof allArticles) {
  let max = 0;
  for (const a of articles) {
    const r = engagementRank[a.data.engagement ?? ''] ?? 0;
    if (r > max) max = r;
  }
  return max;
}

function engagementLabel(rank: number) {
  if (rank === 1) return 'Pause';
  if (rank === 2) return 'Lecture';
  if (rank === 3) return 'Immersion';
  return '';
}
---

<BaseLayout title="Syncognie — Synergie · Cognition · Dialogue" description="Des concepts qui se rencontrent, se frottent, s'éclairent — et font naître ce qu'aucun ne contenait seul. Jardin numérique en croissance.">

<!-- ══ HERO ══ -->
<section class="hero">
  <div class="hero-left">
    <p class="hero-eyebrow">Synergie · Cognition · Dialogue</p>
    <h1 class="hero-titre">Rassembler les idées.<br><em>Accompagner la synergie.</em></h1>
    <p class="hero-sous">Des concepts qui se rencontrent, se frottent, s'éclairent — et font naître ce qu'aucun ne contenait seul. Pas un recueil. Un laboratoire.</p>
    <div class="hero-note">
      <span class="hero-note-g">✦</span>
      <p class="hero-note-t">Jardin numérique en croissance — un espace vivant où chaque note évolue à son rythme.</p>
    </div>
  </div>

  <div class="hero-graphe">
    <canvas id="emergence-canvas" width="240" height="320"
      aria-label="Graphe d'émergence — des concepts qui se rencontrent, se frottent et font naître une propriété nouvelle"></canvas>
  </div>

  <!--
  ══ BANDE RÉFLEXION — conservée pour usage futur ══
  <a class="bande-reflexion" href={serieNotes.length > 0 ? `/articles/${serieNotes[0].slug}` : '/'}>
    <div class="br-gauche">
      <span class="br-eyebrow">Série · Prismes</span>
      <span class="br-titre">Notes d'un modèle en construction</span>
      <span class="br-sous">Gottman · Argyris · Watzlawick · Kahneman · Damasio · Frankl — des notes qui s'enchaînent.</span>
    </div>
    <div class="br-droite">
      <div>
        <div class="br-num">{nbReflexion}</div>
        <div class="br-num-label">notes</div>
      </div>
      <span class="br-btn">Commencer ici →</span>
    </div>
  </a>
  -->
</section>

<!-- ══ SÉRIES ══ -->
<div class="sep sep--series">
  <div class="sep-line"></div>
  <div class="sep-centre"><div class="sep-diamond"></div><span class="sep-label">Séries en cours</span><div class="sep-diamond"></div></div>
  <div class="sep-line"></div>
</div>

<div class="series-wrap">

  <!-- PRISMES -->
  {(() => {
    const eng = maxEngagement(serieNotes);
    return (
      <div class="serie-band serie-band--notes">
        <div class="serie-head">
          <div class="serie-head-left">
            <span class="serie-pill serie-pill--notes">Prismes</span>
            <span class="serie-titre">Notes d'un modèle en construction</span>
          </div>
          <div class="serie-head-right">
            {eng > 0 && (
              <span class="eng-wrap">
                <span class="eng-niveau">Niveau&nbsp;:</span>
                <span class="eng-indicator">
                  <span class={`eng-bar eng-b1${eng >= 1 ? ' on' : ''}`}></span>
                  <span class={`eng-bar eng-b2${eng >= 2 ? ' on' : ''}`}></span>
                  <span class={`eng-bar eng-b3${eng >= 3 ? ' on' : ''}`}></span>
                </span>
              </span>
            )}
            <a class="serie-cta" href="/series/notes-d-un-modele-en-construction">Voir la série →</a>
          </div>
        </div>
        <div class="serie-body">
          {serieNotes.map((a) => (
            <a class="capsule" href={`/articles/${a.slug}`}>
              <span class="cap-num cap-num--notes">{String(a.data.episode ?? 0).padStart(2, '0')}</span>
              <span class="cap-titre">{a.data.title}</span>
              <span class="cap-stade">{stadeLabel(a.data.stade)}</span>
            </a>
          ))}
          <div class="capsule capsule--ghost">
            <span class="cap-num cap-num--notes">{String(serieNotes.length + 1).padStart(2, '0')}</span>
            <span class="cap-titre">Prochaine note</span>
            <span class="cap-stade">— à venir</span>
          </div>
        </div>
      </div>
    );
  })()}

  <!-- RÉCIT -->
  {(() => {
    const eng = maxEngagement(serieDialogues);
    return (
      <div class="serie-band serie-band--recit">
        <div class="serie-head">
          <div class="serie-head-left">
            <span class="serie-pill serie-pill--recit">Récit</span>
            <span class="serie-titre">Les rencontres de Nathalie et Élodie</span>
          </div>
          <div class="serie-head-right">
            {eng > 0 && (
              <span class="eng-wrap">
                <span class="eng-niveau">Niveau&nbsp;:</span>
                <span class="eng-indicator">
                  <span class={`eng-bar eng-b1${eng >= 1 ? ' on' : ''}`}></span>
                  <span class={`eng-bar eng-b2${eng >= 2 ? ' on' : ''}`}></span>
                  <span class={`eng-bar eng-b3${eng >= 3 ? ' on' : ''}`}></span>
                </span>
              </span>
            )}
            <a class="serie-cta serie-cta--recit" href="/series/les-rencontres-de-nathalie-et-elodie">Voir la série →</a>
          </div>
        </div>
        <div class="serie-body serie-body--recit">
          {serieDialogues.map((a) => (
            <a class="capsule" href={`/articles/${a.slug}`}>
              <span class="cap-num cap-num--recit">{String(a.data.episode ?? 0).padStart(2, '0')}</span>
              <span class="cap-titre">{a.data.title}</span>
              <span class="cap-stade">{stadeLabel(a.data.stade)}{a.data.statut === 'en-cours' ? ' · en cours' : ''}</span>
            </a>
          ))}
          <div class="capsule capsule--recit capsule--ghost">
            <span class="cap-num cap-num--recit">{String(serieDialogues.length + 1).padStart(2, '0')}</span>
            <span class="cap-titre">Prochain épisode</span>
            <span class="cap-stade">— à venir</span>
          </div>
        </div>
      </div>
    );
  })()}

  <!-- MÉCANIQUE -->
  {(() => {
    const eng = maxEngagement(serieMecanique);
    return (
      <div class="serie-band serie-band--mecanique">
        <div class="serie-head">
          <div class="serie-head-left">
            <span class="serie-pill serie-pill--mecanique">Mécanique</span>
            <span class="serie-titre">Le moteur silencieux</span>
          </div>
          <div class="serie-head-right">
            {eng > 0 && (
              <span class="eng-wrap">
                <span class="eng-niveau">Niveau&nbsp;:</span>
                <span class="eng-indicator">
                  <span class={`eng-bar eng-b1${eng >= 1 ? ' on' : ''}`}></span>
                  <span class={`eng-bar eng-b2${eng >= 2 ? ' on' : ''}`}></span>
                  <span class={`eng-bar eng-b3${eng >= 3 ? ' on' : ''}`}></span>
                </span>
              </span>
            )}
            <a class="serie-cta serie-cta--mecanique" href="/series/mecanique">Voir la série →</a>
          </div>
        </div>
        <div class="serie-body serie-body--mecanique">
          {serieMecanique.map((a) => (
            <a class="capsule" href={`/articles/${a.slug}`}>
              <span class="cap-num cap-num--mecanique">{String(a.data.episode ?? 1).padStart(2, '0')}</span>
              <span class="cap-titre">{a.data.title}</span>
              <span class="cap-stade">{stadeLabel(a.data.stade)}</span>
            </a>
          ))}
          <div class="capsule capsule--mecanique capsule--ghost">
            <span class="cap-num cap-num--mecanique">{String(serieMecanique.length + 1).padStart(2, '0')}</span>
            <span class="cap-titre">Prochaine note</span>
            <span class="cap-stade">— à venir</span>
          </div>
        </div>
      </div>
    );
  })()}

</div>

<!-- ══ OUTILS ══ -->
<div class="sep sep--outils">
  <div class="sep-line"></div>
  <div class="sep-centre"><div class="sep-diamond"></div><span class="sep-label">Outils</span><div class="sep-diamond"></div></div>
  <div class="sep-line"></div>
</div>

<div class="outils-section">
  <p class="outils-chapeau">Ces notes ont posé des questions — ces instruments tentent d'y répondre.</p>

  <div class="outils-grille-home">

    <a class="ohc" href="/outils/constellation" style="--oc:#c4993a; --oc-mix:196,153,58;">
      <div class="ohc-num" aria-hidden="true">✦</div>
      <svg class="ohc-svg" viewBox="0 0 48 48" fill="none" aria-hidden="true">
        <circle cx="24" cy="24" r="3.5" fill="#c4993a" opacity=".45"/>
        <circle cx="10" cy="12" r="2"   fill="#c4993a" opacity=".3"/>
        <circle cx="38" cy="11" r="2"   fill="#c4993a" opacity=".3"/>
        <circle cx="9"  cy="37" r="2"   fill="#c4993a" opacity=".3"/>
        <circle cx="39" cy="38" r="2"   fill="#c4993a" opacity=".3"/>
        <circle cx="24" cy="7"  r="1.5" fill="#c4993a" opacity=".2"/>
        <line x1="12" y1="13" x2="22" y2="21" stroke="#c4993a" stroke-width=".7" opacity=".3"/>
        <line x1="36" y1="13" x2="26" y2="21" stroke="#c4993a" stroke-width=".7" opacity=".3"/>
        <line x1="11" y1="35" x2="22" y2="27" stroke="#c4993a" stroke-width=".7" opacity=".3"/>
        <line x1="37" y1="36" x2="26" y2="27" stroke="#c4993a" stroke-width=".7" opacity=".3"/>
        <line x1="24" y1="9"  x2="24" y2="20" stroke="#c4993a" stroke-width=".7" opacity=".22"/>
      </svg>
      <span class="ohc-label">Exploration</span>
      <h3 class="ohc-titre">Constellation</h3>
      <p class="ohc-desc">28 penseurs, leurs concepts, leurs tensions et filiations. Naviguer dans le réseau des idées par domaine ou par contexte — plutôt que mémoriser.</p>
      <span class="ohc-cta">Explorer →</span>
    </a>

    <a class="ohc" href="/outils/boussole" style="--oc:#6b7fb8; --oc-mix:107,127,184;">
      <div class="ohc-num" aria-hidden="true">◈</div>
      <svg class="ohc-svg" viewBox="0 0 48 48" fill="none" aria-hidden="true">
        <circle cx="24" cy="24" r="14" stroke="#6b7fb8" stroke-width="1" opacity=".25"/>
        <circle cx="24" cy="24" r="9"  stroke="#6b7fb8" stroke-width=".8" opacity=".18"/>
        <line x1="24" y1="10" x2="24" y2="16" stroke="#6b7fb8" stroke-width="1.2" opacity=".35" stroke-linecap="round"/>
        <line x1="24" y1="32" x2="24" y2="38" stroke="#6b7fb8" stroke-width="1.2" opacity=".35" stroke-linecap="round"/>
        <line x1="10" y1="24" x2="16" y2="24" stroke="#6b7fb8" stroke-width="1.2" opacity=".35" stroke-linecap="round"/>
        <line x1="32" y1="24" x2="38" y2="24" stroke="#6b7fb8" stroke-width="1.2" opacity=".35" stroke-linecap="round"/>
        <line x1="24" y1="24" x2="30" y2="16" stroke="#6b7fb8" stroke-width="1.4" opacity=".55" stroke-linecap="round" class="ohc-aiguille-b"/>
        <circle cx="24" cy="24" r="2" fill="#6b7fb8" opacity=".4"/>
      </svg>
      <span class="ohc-label">Guide</span>
      <h3 class="ohc-titre">Boussole dopaminergique</h3>
