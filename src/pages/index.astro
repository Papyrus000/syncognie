  transition: color .15s;
}
.toc-outil-desc {
  font-family: 'Mulish', sans-serif;
  font-size: .68rem; font-weight: 300; font-style: italic;
  color: var(--ink-soft); flex: 1; opacity: .6;
  display: none;
  transition: opacity .15s;
}
.toc-outil-item:hover .toc-outil-desc { opacity: .85; }
@media (min-width: 480px) { .toc-outil-desc { display: block; } }

.toc-outil-arr {
  font-size: .60rem; color: rgba(196,153,58,.55);
  opacity: 0; transform: translateX(-4px);
  transition: opacity .15s, transform .2s cubic-bezier(.16,.84,.44,1);
  flex-shrink: 0;
}

.toc-outil-item--bientot,
.toc-outil-item--idee {
  cursor: default; pointer-events: none;
}
.toc-outil-nom--grise {
  color: var(--ink-soft); opacity: .4;
}
.toc-outil-statut {
  font-family: 'Mulish', sans-serif;
  font-size: .54rem; font-weight: 600;
  letter-spacing: .1em; text-transform: uppercase;
  padding: .06rem .28rem; border-radius: 3px;
  flex-shrink: 0; margin-left: auto;
}
.toc-outil-statut--bientot {
  color: #d4700a; background: rgba(255,128,0,.06);
  border: 1px solid rgba(255,128,0,.16);
}
.toc-outil-statut--idee {
  color: var(--ink-soft); background: transparent;
  border: 1px solid var(--rule); opacity: .55;
}

/* Carnet */
.carnet-list { list-style: none; }
.cn-item {
  display: flex; flex-direction: column; gap: .18rem;
  padding: .48rem 0;
  border-bottom: 1px solid rgba(180,95,30,.07);
  text-decoration: none;
}
.cn-item:last-child { border-bottom: none; }
.cn-item:hover .cn-titre { color: #a04818; }
.cn-meta { display: flex; align-items: center; gap: .3rem; flex-wrap: wrap; }
.cn-date {
  font-family: 'Mulish', sans-serif;
  font-size: .60rem; font-weight: 300;
  letter-spacing: .08em; color: var(--ink-soft); opacity: .6;
}
.cn-stade {
  font-family: 'Mulish', sans-serif;
  font-size: .60rem; padding: .12rem .42rem;
  border-radius: 4px; font-weight: 700; letter-spacing: .04em;
  line-height: 1.5; white-space: nowrap;
}
.cn-stade--graine { background: rgba(180,95,30,.10); color: #8a4a10; border: 1px solid rgba(180,95,30,.22); }
.cn-stade--pousse { background: rgba(180,95,30,.10); color: #8a4a10; border: 1px solid rgba(180,95,30,.22); }
.cn-stade--arbre  { background: rgba(180,95,30,.10); color: #8a4a10; border: 1px solid rgba(180,95,30,.22); }
.cn-titre {
  font-family: 'Mulish', sans-serif; font-weight: 400;
  font-size: .80rem; color: var(--ink);
  line-height: 1.3; transition: color .2s;
}
.cn-desc {
  font-family: 'Mulish', sans-serif;
  font-size: .70rem; color: var(--ink-soft);
  font-style: italic; line-height: 1.4;
  display: -webkit-box; -webkit-line-clamp: 2;
  -webkit-box-orient: vertical; overflow: hidden;
}
.cn-all {
  display: block; margin-top: .6rem; padding-top: .55rem;
  border-top: 1px solid rgba(180,95,30,.1);
  font-family: 'Mulish', sans-serif;
  font-size: .60rem; font-weight: 700;
  letter-spacing: .12em; text-transform: uppercase;
  color: #a04818; text-decoration: none;
  opacity: .65; transition: opacity .2s;
}
.cn-all:hover { opacity: 1; }
</style>

<script>
(function(){
  const canvas = document.getElementById('emergence-canvas');
  if(!canvas) return;
  const ctx = canvas.getContext('2d');
  const W = 240, H = 320;

  const DOMAINS = {
    neuro:  [215,85,30],
    repres: [35,135,225],
    exist:  [145,65,215],
    social: [12,160,100],
    sys:    [200,128,8],
  };

  const NODES = [
    {id:'plaisir',   label:'Balance plaisir / douleur', dom:'neuro',  bx:58,  by:58 },
    {id:'marqueurs', label:'Marqueurs somatiques',      dom:'neuro',  bx:108, by:35 },
    {id:'hemisph',   label:'Hémisphères',               dom:'neuro',  bx:38,  by:112},
    {id:'sys12',     label:'Système 1 / 2',             dom:'neuro',  bx:92,  by:92 },
    {id:'carte',     label:'Carte & territoire',        dom:'repres', bx:172, by:48 },
    {id:'narratif',  label:'Pensée narrative',          dom:'repres', bx:208, by:95 },
    {id:'disso',     label:'Dissonance cognitive',      dom:'repres', bx:158, by:105},
    {id:'sens',      label:'Volonté de sens',           dom:'exist',  bx:62,  by:195},
    {id:'flow',      label:'Flow',                      dom:'exist',  bx:125, by:220},
    {id:'resign',    label:'Résignation apprise',       dom:'exist',  bx:35,  by:248},
    {id:'cavaliers', label:'Quatre Cavaliers',          dom:'social', bx:188, by:178},
    {id:'desir',     label:'Désir & altérité',          dom:'social', bx:220, by:228},
    {id:'attach',    label:'Attachement sécure',        dom:'social', bx:192, by:275},
    {id:'double',    label:'Double contrainte',         dom:'sys',    bx:105, by:282},
    {id:'modele',    label:'Modèle I / II',             dom:'sys',    bx:158, by:258},
    {id:'intentions',label:"Intentions d'impl.",        dom:'sys',    bx:125, by:162},
    {id:'levier',    label:'Points de levier',          dom:'sys',    bx:75,  by:148},
    {id:'cinquieme', label:'Cinquième discipline',      dom:'sys',    bx:228, by:148},
  ];

  const LINKS = [
    {a:'plaisir',   b:'sens',       t:'t'},{a:'plaisir',   b:'sys12',     t:'c'},
    {a:'hemisph',   b:'sys12',      t:'t'},{a:'hemisph',   b:'carte',     t:'c'},
    {a:'hemisph',   b:'sens',       t:'c'},{a:'hemisph',   b:'flow',      t:'c'},
    {a:'hemisph',   b:'narratif',   t:'c'},{a:'marqueurs', b:'sys12',     t:'c'},
    {a:'marqueurs', b:'disso',      t:'c'},{a:'sys12',     b:'carte',     t:'c'},
    {a:'sys12',     b:'disso',      t:'c'},{a:'sys12',     b:'intentions',t:'c'},
    {a:'carte',     b:'disso',      t:'c'},{a:'carte',     b:'modele',    t:'t'},
    {a:'narratif',  b:'sens',       t:'c'},{a:'narratif',  b:'carte',     t:'c'},
    {a:'narratif',  b:'disso',      t:'c'},{a:'narratif',  b:'attach',    t:'c'},
    {a:'disso',     b:'modele',     t:'t'},{a:'disso',     b:'sens',      t:'t'},
    {a:'sens',      b:'flow',       t:'c'},{a:'sens',      b:'double',    t:'t'},
    {a:'flow',      b:'attach',     t:'c'},{a:'flow',      b:'intentions',t:'c'},
    {a:'cavaliers', b:'desir',      t:'t'},{a:'cavaliers', b:'attach',    t:'c'},
    {a:'cavaliers', b:'double',     t:'c'},{a:'desir',     b:'attach',    t:'t'},
    {a:'double',    b:'modele',     t:'c'},{a:'modele',    b:'cinquieme', t:'c'},
    {a:'levier',    b:'cinquieme',  t:'c'},{a:'resign',    b:'sens',      t:'c'},
    {a:'resign',    b:'flow',       t:'c'},{a:'intentions',b:'levier',    t:'c'},
  ];

  const nodeMap = {};
  const connCount = {};
  NODES.forEach(n => {
    nodeMap[n.id] = n;
    connCount[n.id] = 0;
    n.angle = Math.random()*Math.PI*2;
    n.orbitR = 4 + Math.random()*6;
    n.speed = (0.0003+Math.random()*0.0002)*(Math.random()<0.5?1:-1);
    n.x = n.bx; n.y = n.by;
    n.labelAlpha = 0;
  });
  LINKS.forEach(l => { connCount[l.a]++; connCount[l.b]++; });
  const maxConn = Math.max(...Object.values(connCount));
  NODES.forEach(n => {
    const ratio = connCount[n.id]/maxConn;
    n.radius = 2 + ratio*3;
    n.brightness = 0.22 + ratio*0.68;
    n.nebulaR = 28 + ratio*52;
    n.nebulaA = 0.025 + ratio*0.048;
  });

  const emergences = [];
  let t = 0;
  let hoveredId = null;

  canvas.addEventListener('mousemove', e => {
    const rect = canvas.getBoundingClientRect();
    const mx = (e.clientX-rect.left)*(W/rect.width);
    const my = (e.clientY-rect.top)*(H/rect.height);
    hoveredId = null;
    for(const n of NODES){
      if(Math.hypot(mx-n.x,my-n.y) < n.radius+10){ hoveredId=n.id; break; }
    }
  });
  canvas.addEventListener('mouseleave', () => { hoveredId = null; });

  function dc(dom,a,sMul){
    const c=DOMAINS[dom],s=sMul!==undefined?sMul:1;
    return `rgba(${Math.round(128+(c[0]-128)*s)},${Math.round(128+(c[1]-128)*s)},${Math.round(128+(c[2]-128)*s)},${a})`;
  }
  function mc(d1,d2,a){
    const c1=DOMAINS[d1],c2=DOMAINS[d2];
    return `rgba(${Math.round((c1[0]+c2[0])/2)},${Math.round((c1[1]+c2[1])/2)},${Math.round((c1[2]+c2[2])/2)},${a})`;
  }

  function draw(){
    ctx.clearRect(0,0,W,H);
    t++;
    NODES.forEach(n => {
      n.angle += n.speed;
      n.x = n.bx+Math.cos(n.angle)*n.orbitR;
      n.y = n.by+Math.sin(n.angle)*n.orbitR;
    });
    NODES.forEach(n => {
      const pulse=Math.sin(t*0.014+n.bx*0.03)*0.5+0.5;
      const r=n.nebulaR*(1+pulse*0.1);
      const a=n.nebulaA*(0.85+pulse*0.15);
      const grd=ctx.createRadialGradient(n.x,n.y,0,n.x,n.y,r);
      grd.addColorStop(0,  dc(n.dom,a*2.2,0.7));
      grd.addColorStop(0.3,dc(n.dom,a*1.0,0.55));
      grd.addColorStop(0.65,dc(n.dom,a*0.35,0.4));
      grd.addColorStop(1,  dc(n.dom,0,0.3));
      ctx.beginPath();ctx.arc(n.x,n.y,r,0,Math.PI*2);
      ctx.fillStyle=grd;ctx.fill();
    });
    LINKS.forEach(l => {
      const a=nodeMap[l.a],b=nodeMap[l.b];
      const dist=Math.hypot(b.x-a.x,b.y-a.y);
      if(dist>110) return;
      const prox=1-dist/110;
      const isHov=hoveredId===l.a||hoveredId===l.b;
      const alpha=isHov?prox*0.65:prox*(l.t==='t'?0.32:0.18);
      ctx.beginPath();ctx.moveTo(a.x,a.y);ctx.lineTo(b.x,b.y);
      ctx.lineWidth=l.t==='t'?0.9:0.6;
      ctx.strokeStyle=mc(a.dom,b.dom,alpha);
      ctx.setLineDash(l.t==='t'?[2,4]:[]);
      ctx.stroke();ctx.setLineDash([]);
      if(dist<58&&Math.random()<0.0005){
        emergences.push({x:(a.x+b.x)/2,y:(a.y+b.y)/2,life:1,type:l.t,d1:a.dom,d2:b.dom});
      }
    });
    for(let i=emergences.length-1;i>=0;i--){
      const e=emergences[i];
      e.life-=0.014;
      if(e.life<=0){emergences.splice(i,1);continue;}
      const p=Math.sin(e.life*Math.PI);
      const r=(e.type==='t'?14:9)*p;
      const grd=ctx.createRadialGradient(e.x,e.y,0,e.x,e.y,r);
      grd.addColorStop(0,`rgba(255,252,215,${0.95*p})`);
      grd.addColorStop(0.3,`rgba(255,215,55,${0.6*p})`);
      grd.addColorStop(1,`rgba(255,165,15,0)`);
      ctx.beginPath();ctx.arc(e.x,e.y,r,0,Math.PI*2);
      ctx.fillStyle=grd;ctx.fill();
      ctx.beginPath();ctx.arc(e.x,e.y,1.8*p,0,Math.PI*2);
      ctx.fillStyle=`rgba(255,255,240,${p})`;ctx.fill();
    }
    NODES.forEach(n => {
      const pulse=Math.sin(t*0.015+n.bx*0.04)*0.5+0.5;
      const isHov=hoveredId===n.id;
      const r=n.radius*(isHov?1.5:1)+pulse*0.5;
      const bright=isHov?Math.min(n.brightness*1.5,1):n.brightness;
      const grd=ctx.createRadialGradient(n.x,n.y,0,n.x,n.y,r*2.8);
      grd.addColorStop(0,dc(n.dom,bright*0.7,n.brightness));
      grd.addColorStop(0.5,dc(n.dom,bright*0.18,n.brightness));
      grd.addColorStop(1,dc(n.dom,0,n.brightness));
      ctx.beginPath();ctx.arc(n.x,n.y,r*2.8,0,Math.PI*2);
      ctx.fillStyle=grd;ctx.fill();
      ctx.beginPath();ctx.arc(n.x,n.y,r,0,Math.PI*2);
      ctx.fillStyle=dc(n.dom,bright,1);ctx.fill();
      ctx.beginPath();ctx.arc(n.x,n.y,r*0.38,0,Math.PI*2);
      ctx.fillStyle=`rgba(255,255,255,${0.45+n.brightness*0.35})`;ctx.fill();
      const target=isHov?1:0;
      n.labelAlpha+=(target-n.labelAlpha)*0.08;
      if(n.labelAlpha>0.015){
        const c=DOMAINS[n.dom];
        ctx.save();
        ctx.globalAlpha=n.labelAlpha;
        ctx.font='400 8px -apple-system,Arial,sans-serif';
        ctx.textAlign='center';ctx.textBaseline='bottom';
        const lx=n.x,ly=n.y-r-5;
        const tw=ctx.measureText(n.label).width;
        ctx.fillStyle='rgba(245,240,232,0.88)';
        ctx.beginPath();
        ctx.roundRect(lx-tw/2-5,ly-13,tw+10,15,2);
        ctx.fill();
        ctx.fillStyle=`rgba(${c[0]},${c[1]},${c[2]},0.92)`;
        ctx.fillText(n.label,lx,ly);
        ctx.restore();
      }
    });
    requestAnimationFrame(draw);
  }
  draw();
})();
</script>

</BaseLayout>
