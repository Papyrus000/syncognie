---
import BaseLayout from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');

const serieNotes = allArticles
  .filter(a => a.data.serie === "Notes d'un modèle en construction")
  .sort((a, b) => (a.data.episode ?? 0) - (b.data.episode ?? 0));

const serieDialogues = allArticles
  .filter(a => a.data.serie === "Les rencontres de Nathalie et Élodie")
  .sort((a, b) => (a.data.episode ?? 0) - (b.data.episode ?? 0));

const serieMecanique = allArticles
  .filter(a => a.data.serie === "Mécanique")
  .sort((a, b) => (a.data.episode ?? 0) - (b.data.episode ?? 0));

const fenetresAnalyses = allArticles
  .filter(a => !!a.data.lien_fenetre);

const nbCartes = serieNotes.length + serieMecanique.length + fenetresAnalyses.length;

const recents = [...allArticles]
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);

function stadeLabel(stade?: string) {
  if (stade === 'pousse') return '🌿 Pousse';
  if (stade === 'arbre')  return '🌳 Arbre';
  return '🌱 Graine';
}

function formatDate(date: Date) {
  return date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<BaseLayout title="Syncognie — Synergie · Cognition · Dialogue" description="Des concepts qui se rencontrent, se frottent, s'éclairent — et font naître ce qu'aucun ne contenait seul. Jardin numérique en croissance.">

<!-- ══ HERO ══ -->
<section class="hero">
  <div class="hero-left">
    <p class="hero-eyebrow">Synergie · Cognition · Dialogue</p>
    <h1 class="hero-titre">Rassembler les idées.<br><em>Accompagner la synergie.</em></h1>
    <p class="hero-sous">Des concepts qui se rencontrent, se frottent, s'éclairent — et font naître ce qu'aucun ne contenait seul. Pas un recueil. Un laboratoire.</p>
    <div class="hero-note">
      <span class="hero-note-g">✦</span>
      <p class="hero-note-t">Jardin numérique en croissance — un espace vivant où chaque note évolue à son rythme.</p>
    </div>
  </div>
  <div class="hero-graphe">
    <canvas id="emergence-canvas" width="240" height="320"
      aria-label="Graphe d'émergence — des concepts qui se rencontrent, se frottent et font naître une propriété nouvelle"></canvas>
  </div>
</section>

<!-- ══ PORTES — silence de 64px après le hero, pas de séparateur ══ -->
<div class="portes-wrap">

  <!-- VIES -->
  <a class="porte porte--vies" href="/vies">
    <div class="porte-barre"></div>
    <div class="porte-halo"></div>
    <div class="porte-inner">

      <div class="porte-eyebrow">Vies</div>

      <h2 class="porte-titre">Des personnages qui vivent<br><em>ce qu'ils ne comprennent pas encore.</em></h2>

      <p class="porte-sous">Des dialogues entre personnages où les concepts arrivent par la vie — avant d'être nommés.</p>

      <div class="dial-zone">
        <div class="dial-echanges">
          <div class="dial-rp">
            <span class="dial-nom dial-nom--n">Nathalie</span>
            <div class="dial-txt">Le mouvement qui continue parce que personne lui a dit d'arrêter.</div>
          </div>
          <div class="dial-rp">
            <span class="dial-nom dial-nom--e">Élodie</span>
            <div class="dial-txt">Exactement. Et ça peut se refermer sur n'importe quoi. Pas besoin d'une substance.</div>
          </div>
        </div>
        <p class="dial-ellipse">…</p>
        <div class="dial-echanges">
          <div class="dial-rp">
            <span class="dial-nom dial-nom--e">Élodie</span>
            <div class="dial-txt">Peut-être. Ou peut-être que c'est ce qu'on se dit pour se sentir moins démunis.</div>
          </div>
        </div>
      </div>

      <div class="porte-pied">
        <div class="porte-tags">
          <span class="ptag ptag--vies">Dialogues</span>
          <span class="ptag ptag--vies">Fenêtres</span>
          <span class="ptag ptag--vies">Fragments</span>
        </div>
        <span class="porte-cta">Entrer <span class="cta-arr">→</span></span>
      </div>

    </div>
  </a>

  <!-- CARTES -->
  <a class="porte porte--cartes" href="/cartes">
    <div class="porte-barre"></div>
    <div class="cartes-reglure"></div>
    <div class="porte-inner">

      <div class="porte-eyebrow">Cartes</div>

      <h2 class="porte-titre">Des mécanismes retournés<br><em>jusqu'à ce qu'ils parlent.</em></h2>

      <p class="porte-sous">Des analyses qui convoquent plusieurs penseurs sur un même phénomène — Gottman, McGilchrist, Kahneman et d'autres.</p>

      <div class="penseurs-zone">
        <div class="penseur">
          <span class="p-nom">Gödel</span>
          <span class="p-phrase">tout système assez riche contient des vérités qu'il ne peut pas prouver</span>
          <span class="p-badge p-badge--or">Prisme</span>
        </div>
        <div class="penseur">
          <span class="p-nom">McGilchrist</span>
          <span class="p-phrase">l'hémisphère gauche ne sait pas ce qu'il ne sait pas</span>
          <span class="p-badge p-badge--bl">Note</span>
        </div>
        <div class="penseur">
          <span class="p-nom">Gottman</span>
          <span class="p-phrase">ce n'est pas la crise qui détruit — c'est l'accumulation des micro-retraits</span>
          <span class="p-badge p-badge--or">Prisme</span>
        </div>
      </div>

      <div class="kz-encart">
        <span class="kz-q">"</span>
        <p class="kz-txt">La carte n'est pas le territoire.</p>
        <span class="kz-src">Alfred Korzybski · 1931</span>
      </div>

      <div class="porte-pied">
        <div class="porte-tags">
          <span class="ptag ptag--or">Prismes</span>
          <span class="ptag ptag--vi">Fenêtres→</span>
          <span class="ptag ptag--bl">Notes</span>
        </div>
        <span class="porte-cta">Cartographier <span class="cta-arr">→</span></span>
      </div>

    </div>
  </a>

</div>

<!-- ══ PUBLICATIONS RÉCENTES ══ -->
<div class="sep sep--pubs">
  <div class="sep-line"></div>
  <div class="sep-centre"><div class="sep-diamond"></div><span class="sep-label">Publications récentes</span><div class="sep-diamond"></div></div>
  <div class="sep-line"></div>
</div>

<div class="pubs-layout">
  <div class="articles-col">
    {recents.map((a) => (
      <a class="article-item" href={`/articles/${a.slug}`}>
        <div class="article-meta">
          <span class="article-date">{formatDate(a.data.date)}</span>
          {a.data.format && (
            <span class="badge badge-analyse">◈ {a.data.format.charAt(0).toUpperCase() + a.data.format.slice(1)}</span>
          )}
          <span class={`badge badge-${a.data.stade ?? 'graine'}`}>{stadeLabel(a.data.stade)}</span>
          {a.data.serie && a.data.episode && (
            <span class="badge badge-serie">
              {a.data.serie === "Notes d'un modèle en construction" ? 'Cartes' :
               a.data.serie === "Les rencontres de Nathalie et Élodie" ? 'Vies' :
               a.data.serie === "Mécanique" ? 'Cartes' : a.data.serie} · {String(a.data.episode).padStart(2, '0')}
            </span>
          )}
        </div>
        <p class="article-titre">{a.data.title}</p>
        <p class="article-desc">{a.data.description}</p>
        <span class="article-lire">Lire →</span>
      </a>
    ))}
  </div>

  <aside class="pubs-sidebar">
    <div class="sidebar-outils">
      <a class="sidebar-outil" href="/outils/constellation">
        <span class="sidebar-outil-icone" style="color:#c4993a">✦</span>
        <div>
          <div class="sidebar-outil-nom">Constellation</div>
          <div class="sidebar-outil-desc">28 penseurs, leurs concepts et filiations</div>
        </div>
      </a>
      <a class="sidebar-outil" href="/outils/boussole">
        <span class="sidebar-outil-icone" style="color:#6b7fb8">◈</span>
        <div>
          <div class="sidebar-outil-nom">Boussole dopaminergique</div>
          <div class="sidebar-outil-desc">Estimer sa charge nerveuse</div>
        </div>
      </a>
      <a class="sidebar-outil" href="/outils/barometre">
        <span class="sidebar-outil-icone" style="color:#3ab87a">⊕</span>
        <div>
          <div class="sidebar-outil-nom">Baromètre de charge</div>
          <div class="sidebar-outil-desc">Une photo de ce que tu portes</div>
        </div>
      </a>
      <a href="/outils" class="sidebar-outils-tous">Tous les outils →</a>
    </div>
    <div class="sidebar-sep"></div>
    <a href="/stades" class="sidebar-stades">
      <span>🌱</span>
      <span class="sidebar-stades-texte">Comment lire les stades →</span>
    </a>
  </aside>
</div>

<style>
/* ── Variables locales ── */
:root { --max: 740px; }

/* ══════════════════════════════════════
   HERO — inchangé
══════════════════════════════════════ */
.hero {
  max-width: var(--max); margin: 0 auto;
  display: grid; grid-template-columns: 1fr 240px;
  align-items: start; gap: 0;
}
@media (max-width: 580px) {
  .hero { grid-template-columns: 1fr; }
  .hero-graphe { display: none; }
}
@media (min-width: 581px) and (max-width: 720px) {
  .hero { grid-template-columns: 1fr 180px; }
}
.hero-left { grid-column: 1; grid-row: 1; padding: 3.4rem 1.75rem 2.4rem; }
.hero-eyebrow {
  font-family: 'Mulish', sans-serif; font-size: .74rem; font-weight: 300;
  letter-spacing: .28em; text-transform: uppercase;
  color: var(--accent); opacity: .72; margin-bottom: 1rem;
}
.hero-titre {
  font-family: 'Libre Baskerville', Georgia, serif;
  font-size: clamp(1.4rem, 2.8vw, 1.9rem); font-weight: 700;
  line-height: 1.2; color: var(--ink); letter-spacing: -.018em; margin-bottom: .9rem;
}
.hero-titre em { font-style: italic; font-weight: 400; color: var(--gold); }
.hero-sous {
  font-family: 'Mulish', sans-serif; font-size: .86rem;
  color: var(--ink-soft); line-height: 1.8; max-width: 40ch; margin-bottom: 1.4rem;
}
.hero-note {
  display: flex; align-items: flex-start; gap: .55rem;
  padding: .65rem .9rem;
  background: var(--gold-bg); border-left: 2px solid var(--gold-dim);
  border-radius: 0 3px 3px 0; max-width: 40ch;
}
.hero-note-g { color: var(--gold); font-size: .72rem; flex-shrink: 0; margin-top: .06rem; opacity: .55; }
.hero-note-t { font-family: 'Mulish', sans-serif; font-size: .78rem; font-style: italic; color: var(--ink-soft); line-height: 1.6; }
.hero-graphe { grid-column: 2; grid-row: 1; padding-top: 2.6rem; display: flex; align-items: flex-start; }
.hero-graphe canvas {
  display: block; width: 240px; height: 320px;
  -webkit-mask-image: linear-gradient(to right, transparent 0%, black 30%, black 72%, transparent 100%);
  mask-image: linear-gradient(to right, transparent 0%, black 30%, black 72%, transparent 100%);
}

/* ══════════════════════════════════════
   PORTES
══════════════════════════════════════ */
.portes-wrap {
  max-width: var(--max);
  margin: 4rem auto 0;       /* 64px silence — pas de séparateur */
  padding: 0 1.75rem;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.25rem;
  align-items: stretch;      /* hauteur identique */
}
@media (max-width: 560px) {
  .portes-wrap { grid-template-columns: 1fr; margin-top: 2.5rem; }
}

/* Base commune */
.porte {
  position: relative;
  display: flex; flex-direction: column;
  text-decoration: none;
  border-radius: 8px;
  overflow: hidden;
  transition: transform .3s cubic-bezier(.16,.84,.44,1);
}
.porte:hover { transform: translateY(-3px); }
.porte { transition: transform .3s cubic-bezier(.16,.84,.44,1), background .35s, border-color .3s; }

/* Trait de couleur en haut */
.porte-barre {
  position: absolute; top: 0; left: 0; right: 0; height: 3px; z-index: 3;
}
.porte--vies   .porte-barre { background: #9b3232; }
.porte--cartes .porte-barre { background: #c4993a; }

/* Halo Vies — soleil de terrasse haut droite */
.porte-halo {
  position: absolute; top: -60px; right: -60px;
  width: 320px; height: 280px; border-radius: 50%;
  background: radial-gradient(ellipse, rgba(220,150,50,0.18) 0%, rgba(210,130,40,0.07) 45%, transparent 72%);
  pointer-events: none; z-index: 0;
}

/* Réglure Cartes */
.cartes-reglure {
  position: absolute; inset: 0; pointer-events: none; z-index: 0;
  background-image: repeating-linear-gradient(
    to bottom, transparent 0, transparent 31px,
    rgba(150,110,20,0.05) 31px, rgba(150,110,20,0.05) 32px
  );
}

/* Couleurs de fond + dégradé directionnel */
.porte--vies   { background: #faf6ee; background-image: radial-gradient(ellipse 65% 55% at 85% 8%, rgba(220,150,50,0.20) 0%, rgba(210,130,40,0.08) 40%, transparent 68%), linear-gradient(145deg, rgba(200,120,30,.04) 0%, transparent 60%); border: 1px solid #e0d6c8; box-shadow: 0 2px 6px rgba(60,40,20,0.08), 0 1px 2px rgba(60,40,20,0.05); }
.porte--cartes { background: #f5f0e2; background-image: radial-gradient(ellipse 65% 55% at 15% 8%, rgba(196,160,58,0.22) 0%, rgba(180,140,40,0.08) 40%, transparent 68%), linear-gradient(225deg, rgba(160,120,20,.04) 0%, transparent 60%); border: 1px solid #ddd0aa; box-shadow: 0 2px 6px rgba(60,40,20,0.08), 0 1px 2px rgba(60,40,20,0.05); }

/* Hover */
.porte--vies:hover   { background-color: #f7efe2; background-image: radial-gradient(ellipse 70% 60% at 85% 8%, rgba(225,155,55,0.30) 0%, rgba(210,130,40,0.12) 40%, transparent 68%), linear-gradient(145deg, rgba(200,120,30,.06) 0%, transparent 60%); border-color: #cdb99a; box-shadow: 0 10px 28px rgba(60,40,20,0.12), 0 4px 14px rgba(200,130,40,0.14); }
.porte--cartes:hover { background-color: #f0e8cc; background-image: radial-gradient(ellipse 70% 60% at 15% 8%, rgba(210,172,65,0.32) 0%, rgba(190,150,45,0.13) 40%, transparent 68%), linear-gradient(225deg, rgba(160,120,20,.07) 0%, transparent 60%); border-color: #c4993a; box-shadow: 0 10px 28px rgba(60,40,20,0.12), 0 4px 14px rgba(196,153,58,0.18); }

/* Numéro décoratif en fond */
.porte--vies::after, .porte--cartes::after {
  position: absolute; top: 22px; right: 26px;
  font-family: 'Libre Baskerville', serif;
  font-size: 64px; font-weight: 700; line-height: 1;
  pointer-events: none; user-select: none; z-index: 0;
}
.porte--vies::after   { content: 'I';  color: rgba(155,50,50,0.045); }
.porte--cartes::after { content: 'II'; color: rgba(196,153,58,0.055); }

/* Inner */
.porte-inner {
  position: relative; z-index: 2;
  padding: 34px 30px 26px 34px;
  flex: 1; display: flex; flex-direction: column;
}

/* Eyebrow */
.porte-eyebrow {
  font-family: 'Mulish', sans-serif;
  font-size: .62rem; font-weight: 700;
  letter-spacing: .32em; text-transform: uppercase;
  margin-bottom: 1rem;
  display: flex; align-items: center; gap: 10px;
}
.porte-eyebrow::after { content: ''; width: 20px; height: 1px; }
.porte--vies   .porte-eyebrow { color: #9b3232; }
.porte--vies   .porte-eyebrow::after { background: rgba(155,50,50,0.35); }
.porte--cartes .porte-eyebrow { color: #9a7020; }
.porte--cartes .porte-eyebrow::after { background: rgba(196,153,58,0.4); }

/* Titre */
.porte-titre {
  font-family: 'Libre Baskerville', serif;
  font-size: 1.2rem; font-weight: 400;
  color: var(--ink); line-height: 1.28;
  letter-spacing: -.012em; margin-bottom: .8rem;
}
.porte--vies   .porte-titre em { font-style: italic; color: #9b3232; }
.porte--cartes .porte-titre em { font-style: italic; color: #9a7020; }

/* Sous-titre */
.porte-sous {
  font-family: 'Mulish', sans-serif;
  font-size: .86rem; font-weight: 300;
  color: var(--ink-mid); line-height: 1.8;
  margin-bottom: 1.5rem; max-width: 92%;
}

/* ── Dialogue ── */
.dial-zone {
  flex: 1;
  border-top: 1px solid rgba(155,50,50,0.1);
  padding-top: 1.1rem;
  margin-bottom: 1.5rem;
}
.dial-scene {
  font-family: 'Libre Baskerville', serif;
  font-size: .72rem; font-style: italic;
  color: #c0b0a0; margin-bottom: .8rem; line-height: 1.5;
}
.dial-echanges { display: flex; flex-direction: column; gap: 0; }
.dial-rp {
  display: grid; grid-template-columns: 70px 1fr;
  padding: .45rem 0;
}
.dial-rp:last-child { border-bottom: none; }
.dial-nom {
  font-family: 'Mulish', sans-serif;
  font-size: .62rem; font-weight: 700;
  letter-spacing: .14em; text-transform: uppercase;
  padding-top: .2rem; align-self: start; line-height: 1;
}
.dial-nom--n { color: rgba(210,100,15,0.85); }
.dial-nom--e { color: rgba(25,90,190,0.8); }
.dial-txt {
  font-family: 'Mulish', sans-serif;
  font-size: .84rem; font-weight: 300;
  color: #28201a; line-height: 1.68;
  padding-left: .7rem;
  border-left: 1px solid #ece3d8;
}
.dial-ellipse {
  font-family: 'Libre Baskerville', serif;
  font-size: 1rem; color: rgba(155,50,50,0.4);
  margin: 1.2rem 0 1rem;
  letter-spacing: .15em;
}
.dial-txt em {
  font-family: 'Libre Baskerville', serif;
  font-style: italic; font-size: .76rem; color: #a89888;
}

/* ── Penseurs ── */
.penseurs-zone {
  flex: 1;
  border-top: 1px solid rgba(196,153,58,0.15);
  padding-top: 1.1rem;
  margin-bottom: 1.1rem;
}
.penseur {
  display: grid; grid-template-columns: 86px 1fr auto;
  align-items: baseline; gap: .7rem;
  padding: .58rem 0;
  border-bottom: 1px solid rgba(196,153,58,0.07);
}
.penseur:last-child { border-bottom: none; }
.p-nom {
  font-family: 'Libre Baskerville', serif;
  font-size: .82rem; font-weight: 700; color: var(--ink);
}
.p-phrase {
  font-family: 'Mulish', sans-serif;
  font-size: .78rem; font-weight: 300; font-style: italic;
  color: #6a5c38; line-height: 1.5;
}
.p-badge {
  font-family: 'Mulish', sans-serif;
  font-size: .58rem; font-weight: 700;
  letter-spacing: .1em; text-transform: uppercase;
  padding: .18rem .5rem; border-radius: 1px; white-space: nowrap;
}
.p-badge--or { color: #5a3808; background: rgba(196,153,58,0.12); border: 1px solid rgba(196,153,58,0.28); }
.p-badge--bl { color: #223448; background: rgba(60,90,130,0.09); border: 1px solid rgba(60,90,130,0.2); }

/* ── Korzybski ── */
.kz-encart {
  position: relative;
  padding: .8rem 1rem .8rem 1.15rem;
  margin-bottom: 1.4rem;
  background: rgba(196,153,58,0.065);
  border-left: 2px solid rgba(196,153,58,0.42);
  box-shadow: 0 2px 8px rgba(196,153,58,0.10);
}
.kz-q {
  position: absolute; top: 2px; left: 4px;
  font-family: 'Libre Baskerville', serif;
  font-size: 20px; font-weight: 700;
  color: rgba(196,153,58,0.35); line-height: 1;
}
.kz-txt {
  font-family: 'Libre Baskerville', serif;
  font-size: .82rem; font-style: italic;
  color: #7a5c18; line-height: 1.6;
  position: relative; z-index: 1;
}
.kz-src {
  font-family: 'Mulish', sans-serif;
  font-size: .70rem; font-weight: 600;
  letter-spacing: .12em; text-transform: uppercase;
  color: #b09860; margin-top: .3rem; display: block;
}

/* ── Pied ── */
.porte-pied {
  display: flex; align-items: center; justify-content: space-between;
  padding-top: 1rem; margin-top: auto;
}
.porte--vies   .porte-pied { border-top: 1px solid #e4dbd0; }
.porte--cartes .porte-pied { border-top: 1px solid #ddd0aa; }

.porte-tags { display: flex; gap: .32rem; flex-wrap: wrap; }
.ptag {
  font-family: 'Mulish', sans-serif;
  font-size: .60rem; font-weight: 700;
  letter-spacing: .1em; text-transform: uppercase;
  padding: .2rem .52rem; border-radius: 1px;
}
.ptag--vies { color: #7a2020; background: rgba(155,50,50,0.07); border: 1px solid rgba(155,50,50,0.16); }
.ptag--or   { color: #684808; background: rgba(196,153,58,0.09); border: 1px solid rgba(196,153,58,0.22); }
.ptag--vi   { color: #382268; background: rgba(120,90,186,0.09); border: 1px solid rgba(120,90,186,0.22); }
.ptag--bl   { color: #223448; background: rgba(60,90,130,0.08);  border: 1px solid rgba(60,90,130,0.18); }

.porte-cta {
  font-family: 'Mulish', sans-serif;
  font-size: .68rem; font-weight: 700;
  letter-spacing: .2em; text-transform: uppercase;
  display: flex; align-items: center; gap: .35rem; white-space: nowrap;
}
.porte--vies   .porte-cta { color: #9b3232; }
.porte--cartes .porte-cta { color: #8a6020; }
.cta-arr { display: inline-block; transition: transform .2s; }
.porte:hover .cta-arr { transform: translateX(5px); }

/* ══════════════════════════════════════
   SÉPARATEUR publications
══════════════════════════════════════ */
.sep {
  display: flex; align-items: center; gap: .9rem;
  max-width: var(--max); margin: 0 auto 1.2rem; padding: 0 1.75rem;
}
.sep-line { flex: 1; height: 1px; background: linear-gradient(to right, transparent, var(--rule), transparent); }
.sep-centre { display: flex; align-items: center; gap: .5rem; }
.sep-diamond { width: 5px; height: 5px; transform: rotate(45deg); background: var(--gold); opacity: .62; }
.sep-label {
  font-family: 'Mulish', sans-serif; font-size: .68rem; font-weight: 700;
  letter-spacing: .18em; text-transform: uppercase; color: var(--accent);
}
.sep--pubs { margin-top: 3.8rem; }

/* ══════════════════════════════════════
   PUBLICATIONS + SIDEBAR — inchangés
══════════════════════════════════════ */
.pubs-layout {
  max-width: var(--max); margin: 0 auto; padding: 0 1.75rem;
  display: grid; grid-template-columns: 1fr 180px;
  gap: 2.4rem; align-items: start;
}
@media (max-width: 640px) {
  .pubs-layout { grid-template-columns: 1fr; }
  .pubs-sidebar { position: static; }
}
.articles-col { min-width: 0; }
.article-item {
  display: block; padding: .7rem 0 .78rem;
  border-bottom: 1px solid #ede8df;
  text-decoration: none; transition: transform .18s;
}
.article-item:hover { transform: translateX(3px); }
.article-item:hover .article-titre { color: var(--accent); }
.article-item:hover .article-lire { opacity: 1; }
.article-meta { display: flex; align-items: center; gap: .4rem; margin-bottom: .25rem; flex-wrap: wrap; }
.article-date { font-family: 'Mulish', sans-serif; font-size: .70rem; font-weight: 300; letter-spacing: .15em; color: var(--ink-soft); opacity: .6; }
.badge { font-family: 'Mulish', sans-serif; font-size: .55rem; font-weight: 700; letter-spacing: .13em; text-transform: uppercase; padding: .15rem .45rem; border-radius: 3px; line-height: 1.5; }
.badge-analyse  { background: rgba(107,127,184,.1);  color: #6b7fb8; border: 1px solid rgba(107,127,184,.25); }
.badge-graine   { background: rgba(46,125,78,.07);   color: #2e7d4e; border: 1px solid rgba(46,125,78,.2); }
.badge-pousse   { background: rgba(56,120,60,.09);   color: #38783c; border: 1px solid rgba(56,120,60,.22); }
.badge-arbre    { background: rgba(46,125,78,.18);   color: #224422; border: 1px solid rgba(34,68,34,.2); }
.badge-serie    { background: rgba(107,127,184,.08); color: #4a5a8a; border: 1px solid rgba(107,127,184,.22); }
.article-titre { font-family: 'Libre Baskerville', Georgia, serif; font-size: .92rem; line-height: 1.35; color: var(--ink); margin-bottom: .2rem; }
.article-desc  { font-family: 'Mulish', sans-serif; font-size: .78rem; color: var(--ink-mid); line-height: 1.52; margin-bottom: .3rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.article-lire  { font-family: 'Mulish', sans-serif; font-size: .76rem; letter-spacing: .09em; text-transform: uppercase; color: var(--link); opacity: 0; transition: opacity .18s; }
@media (hover: none) { .article-lire { opacity: .6; } }

.pubs-sidebar { position: sticky; top: 4.5rem; align-self: start; }
.sidebar-outils { display: flex; flex-direction: column; gap: .5rem; }
.sidebar-outil {
  display: flex; align-items: flex-start; gap: .65rem;
  text-decoration: none; padding: .65rem .75rem;
  border: 1px solid var(--rule); border-radius: 7px;
  background: rgba(245,240,232,.5);
  box-shadow: 0 1px 3px rgba(60,40,20,.06);
  transition: border-color .2s, background .22s, transform .18s, box-shadow .2s;
}
.sidebar-outil:hover { border-color: rgba(196,153,58,.45); background: rgba(196,153,58,.055); transform: translateY(-1px); box-shadow: 0 4px 14px rgba(196,153,58,.09); }
.sidebar-outil-icone { font-size: .9rem; flex-shrink: 0; margin-top: .05rem; line-height: 1; opacity: .75; }
.sidebar-outil-nom  { font-family: 'Libre Baskerville', Georgia, serif; font-size: .76rem; font-weight: 700; color: var(--ink); line-height: 1.25; margin-bottom: .15rem; }
.sidebar-outil-desc { font-family: 'Mulish', sans-serif; font-size: .74rem; font-weight: 300; color: var(--ink-soft); line-height: 1.5; }
.sidebar-outils-tous { display: block; text-align: right; margin-top: .2rem; font-family: 'Mulish', sans-serif; font-size: .70rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: var(--accent); text-decoration: none; opacity: .75; transition: opacity .2s; }
.sidebar-outils-tous:hover { opacity: 1; }
.sidebar-sep { height: 1px; margin: .85rem 0; background: linear-gradient(to right, transparent, var(--rule), transparent); }
.sidebar-stades { display: inline-flex; align-items: center; gap: .45rem; text-decoration: none; padding: .4rem .5rem; border-radius: 5px; transition: background .2s, box-shadow .2s, transform .18s; }
.sidebar-stades:hover { background: rgba(139,94,60,.05); box-shadow: 0 1px 4px rgba(60,40,20,.07); transform: translateY(-1px); }
.sidebar-stades-texte { font-family: 'Mulish', sans-serif; font-size: .72rem; font-weight: 400; font-style: italic; letter-spacing: .06em; color: var(--ink-soft); }
</style>

<script>
(function(){
  const canvas = document.getElementById('emergence-canvas');
  if(!canvas) return;
  const ctx = canvas.getContext('2d');
  const W = 240, H = 320;

  const DOMAINS = {
    neuro:  [215,85,30],
    repres: [35,135,225],
    exist:  [145,65,215],
    social: [12,160,100],
    sys:    [200,128,8],
  };

  const NODES = [
    {id:'plaisir',   label:'Balance plaisir / douleur', dom:'neuro',  bx:58,  by:58 },
    {id:'marqueurs', label:'Marqueurs somatiques',      dom:'neuro',  bx:108, by:35 },
    {id:'hemisph',   label:'Hémisphères',               dom:'neuro',  bx:38,  by:112},
    {id:'sys12',     label:'Système 1 / 2',             dom:'neuro',  bx:92,  by:92 },
    {id:'carte',     label:'Carte & territoire',        dom:'repres', bx:172, by:48 },
    {id:'narratif',  label:'Pensée narrative',          dom:'repres', bx:208, by:95 },
    {id:'disso',     label:'Dissonance cognitive',      dom:'repres', bx:158, by:105},
    {id:'sens',      label:'Volonté de sens',           dom:'exist',  bx:62,  by:195},
    {id:'flow',      label:'Flow',                      dom:'exist',  bx:125, by:220},
    {id:'resign',    label:'Résignation apprise',       dom:'exist',  bx:35,  by:248},
    {id:'cavaliers', label:'Quatre Cavaliers',          dom:'social', bx:188, by:178},
    {id:'desir',     label:'Désir & altérité',          dom:'social', bx:220, by:228},
    {id:'attach',    label:'Attachement sécure',        dom:'social', bx:192, by:275},
    {id:'double',    label:'Double contrainte',         dom:'sys',    bx:105, by:282},
    {id:'modele',    label:'Modèle I / II',             dom:'sys',    bx:158, by:258},
    {id:'intentions',label:"Intentions d'impl.",        dom:'sys',    bx:125, by:162},
    {id:'levier',    label:'Points de levier',          dom:'sys',    bx:75,  by:148},
    {id:'cinquieme', label:'Cinquième discipline',      dom:'sys',    bx:228, by:148},
  ];

  const LINKS = [
    {a:'plaisir',   b:'sens',       t:'t'},{a:'plaisir',   b:'sys12',     t:'c'},
    {a:'hemisph',   b:'sys12',      t:'t'},{a:'hemisph',   b:'carte',     t:'c'},
    {a:'hemisph',   b:'sens',       t:'c'},{a:'hemisph',   b:'flow',      t:'c'},
    {a:'hemisph',   b:'narratif',   t:'c'},{a:'marqueurs', b:'sys12',     t:'c'},
    {a:'marqueurs', b:'disso',      t:'c'},{a:'sys12',     b:'carte',     t:'c'},
    {a:'sys12',     b:'disso',      t:'c'},{a:'sys12',     b:'intentions',t:'c'},
    {a:'carte',     b:'disso',      t:'c'},{a:'carte',     b:'modele',    t:'t'},
    {a:'narratif',  b:'sens',       t:'c'},{a:'narratif',  b:'carte',     t:'c'},
    {a:'narratif',  b:'disso',      t:'c'},{a:'narratif',  b:'attach',    t:'c'},
    {a:'disso',     b:'modele',     t:'t'},{a:'disso',     b:'sens',      t:'t'},
    {a:'sens',      b:'flow',       t:'c'},{a:'sens',      b:'double',    t:'t'},
    {a:'flow',      b:'attach',     t:'c'},{a:'flow',      b:'intentions',t:'c'},
    {a:'cavaliers', b:'desir',      t:'t'},{a:'cavaliers', b:'attach',    t:'c'},
    {a:'cavaliers', b:'double',     t:'c'},{a:'desir',     b:'attach',    t:'t'},
    {a:'double',    b:'modele',     t:'c'},{a:'modele',    b:'cinquieme', t:'c'},
    {a:'levier',    b:'cinquieme',  t:'c'},{a:'resign',    b:'sens',      t:'c'},
    {a:'resign',    b:'flow',       t:'c'},{a:'intentions',b:'levier',    t:'c'},
  ];

  const nodeMap = {};
  const connCount = {};
  NODES.forEach(n => {
    nodeMap[n.id] = n;
    connCount[n.id] = 0;
    n.angle = Math.random()*Math.PI*2;
    n.orbitR = 4 + Math.random()*6;
    n.speed = (0.0003+Math.random()*0.0002)*(Math.random()<0.5?1:-1);
    n.x = n.bx; n.y = n.by;
    n.labelAlpha = 0;
  });
  LINKS.forEach(l => { connCount[l.a]++; connCount[l.b]++; });
  const maxConn = Math.max(...Object.values(connCount));
  NODES.forEach(n => {
    const ratio = connCount[n.id]/maxConn;
    n.radius = 2 + ratio*3;
    n.brightness = 0.22 + ratio*0.68;
    n.nebulaR = 28 + ratio*52;
    n.nebulaA = 0.025 + ratio*0.048;
  });

  const emergences = [];
  let t = 0;
  let hoveredId = null;

  canvas.addEventListener('mousemove', e => {
    const rect = canvas.getBoundingClientRect();
    const mx = (e.clientX-rect.left)*(W/rect.width);
    const my = (e.clientY-rect.top)*(H/rect.height);
    hoveredId = null;
    for(const n of NODES){
      if(Math.hypot(mx-n.x,my-n.y) < n.radius+10){ hoveredId=n.id; break; }
    }
  });
  canvas.addEventListener('mouseleave', () => { hoveredId = null; });

  function dc(dom,a,sMul){
    const c=DOMAINS[dom],s=sMul!==undefined?sMul:1;
    return `rgba(${Math.round(128+(c[0]-128)*s)},${Math.round(128+(c[1]-128)*s)},${Math.round(128+(c[2]-128)*s)},${a})`;
  }
  function mc(d1,d2,a){
    const c1=DOMAINS[d1],c2=DOMAINS[d2];
    return `rgba(${Math.round((c1[0]+c2[0])/2)},${Math.round((c1[1]+c2[1])/2)},${Math.round((c1[2]+c2[2])/2)},${a})`;
  }

  function draw(){
    ctx.clearRect(0,0,W,H);
    t++;
    NODES.forEach(n => {
      n.angle += n.speed;
      n.x = n.bx+Math.cos(n.angle)*n.orbitR;
      n.y = n.by+Math.sin(n.angle)*n.orbitR;
    });
    NODES.forEach(n => {
      const pulse=Math.sin(t*0.014+n.bx*0.03)*0.5+0.5;
      const r=n.nebulaR*(1+pulse*0.1);
      const a=n.nebulaA*(0.85+pulse*0.15);
      const grd=ctx.createRadialGradient(n.x,n.y,0,n.x,n.y,r);
      grd.addColorStop(0,  dc(n.dom,a*2.2,0.7));
      grd.addColorStop(0.3,dc(n.dom,a*1.0,0.55));
      grd.addColorStop(0.65,dc(n.dom,a*0.35,0.4));
      grd.addColorStop(1,  dc(n.dom,0,0.3));
      ctx.beginPath();ctx.arc(n.x,n.y,r,0,Math.PI*2);
      ctx.fillStyle=grd;ctx.fill();
    });
    LINKS.forEach(l => {
      const a=nodeMap[l.a],b=nodeMap[l.b];
      const dist=Math.hypot(b.x-a.x,b.y-a.y);
      if(dist>110) return;
      const prox=1-dist/110;
      const isHov=hoveredId===l.a||hoveredId===l.b;
      const alpha=isHov?prox*0.65:prox*(l.t==='t'?0.32:0.18);
      ctx.beginPath();ctx.moveTo(a.x,a.y);ctx.lineTo(b.x,b.y);
      ctx.lineWidth=l.t==='t'?0.9:0.6;
      ctx.strokeStyle=mc(a.dom,b.dom,alpha);
      ctx.setLineDash(l.t==='t'?[2,4]:[]);
      ctx.stroke();ctx.setLineDash([]);
      if(dist<58&&Math.random()<0.0005){
        emergences.push({x:(a.x+b.x)/2,y:(a.y+b.y)/2,life:1,type:l.t,d1:a.dom,d2:b.dom});
      }
    });
    for(let i=emergences.length-1;i>=0;i--){
      const e=emergences[i];
      e.life-=0.014;
      if(e.life<=0){emergences.splice(i,1);continue;}
      const p=Math.sin(e.life*Math.PI);
      const r=(e.type==='t'?14:9)*p;
      const grd=ctx.createRadialGradient(e.x,e.y,0,e.x,e.y,r);
      grd.addColorStop(0,`rgba(255,252,215,${0.95*p})`);
      grd.addColorStop(0.3,`rgba(255,215,55,${0.6*p})`);
      grd.addColorStop(1,`rgba(255,165,15,0)`);
      ctx.beginPath();ctx.arc(e.x,e.y,r,0,Math.PI*2);
      ctx.fillStyle=grd;ctx.fill();
      ctx.beginPath();ctx.arc(e.x,e.y,1.8*p,0,Math.PI*2);
      ctx.fillStyle=`rgba(255,255,240,${p})`;ctx.fill();
    }
    NODES.forEach(n => {
      const pulse=Math.sin(t*0.015+n.bx*0.04)*0.5+0.5;
      const isHov=hoveredId===n.id;
      const r=n.radius*(isHov?1.5:1)+pulse*0.5;
      const bright=isHov?Math.min(n.brightness*1.5,1):n.brightness;
      const grd=ctx.createRadialGradient(n.x,n.y,0,n.x,n.y,r*2.8);
      grd.addColorStop(0,dc(n.dom,bright*0.7,n.brightness));
      grd.addColorStop(0.5,dc(n.dom,bright*0.18,n.brightness));
      grd.addColorStop(1,dc(n.dom,0,n.brightness));
      ctx.beginPath();ctx.arc(n.x,n.y,r*2.8,0,Math.PI*2);
      ctx.fillStyle=grd;ctx.fill();
      ctx.beginPath();ctx.arc(n.x,n.y,r,0,Math.PI*2);
      ctx.fillStyle=dc(n.dom,bright,1);ctx.fill();
      ctx.beginPath();ctx.arc(n.x,n.y,r*0.38,0,Math.PI*2);
      ctx.fillStyle=`rgba(255,255,255,${0.45+n.brightness*0.35})`;ctx.fill();
      const target=isHov?1:0;
      n.labelAlpha+=(target-n.labelAlpha)*0.08;
      if(n.labelAlpha>0.015){
        const c=DOMAINS[n.dom];
        ctx.save();
        ctx.globalAlpha=n.labelAlpha;
        ctx.font='400 8px -apple-system,Arial,sans-serif';
        ctx.textAlign='center';ctx.textBaseline='bottom';
        const lx=n.x,ly=n.y-r-5;
        const tw=ctx.measureText(n.label).width;
        ctx.fillStyle='rgba(245,240,232,0.88)';
        ctx.beginPath();
        ctx.roundRect(lx-tw/2-5,ly-13,tw+10,15,2);
        ctx.fill();
        ctx.fillStyle=`rgba(${c[0]},${c[1]},${c[2]},0.92)`;
        ctx.fillText(n.label,lx,ly);
        ctx.restore();
      }
    });
    requestAnimationFrame(draw);
  }
  draw();
})();
</script>

</BaseLayout>
