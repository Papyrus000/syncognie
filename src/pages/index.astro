   PUBLICATIONS + SIDEBAR
══════════════════════════════════════ */
.pubs-layout {
  max-width: var(--max); margin: 0 auto; padding: 0 1.75rem;
  display: grid; grid-template-columns: 1fr 180px;
  gap: 2.4rem; align-items: start;
}
@media (max-width: 640px) {
  .pubs-layout { grid-template-columns: 1fr; }
  .pubs-sidebar { position: static; }
}
.articles-col { min-width: 0; }
.article-item {
  display: block; padding: .7rem 0 .78rem;
  border-bottom: 1px solid #ede8df;
  text-decoration: none; transition: transform .18s;
}
.article-item:hover { transform: translateX(3px); }
.article-item:hover .article-titre { color: var(--accent); }
.article-item:hover .article-lire { opacity: 1; }
.article-meta { display: flex; align-items: center; gap: .4rem; margin-bottom: .25rem; flex-wrap: wrap; }
.article-date { font-family: 'Mulish', sans-serif; font-size: .70rem; font-weight: 300; letter-spacing: .15em; color: var(--ink-soft); opacity: .6; }
.badge { font-family: 'Mulish', sans-serif; font-size: .55rem; font-weight: 700; letter-spacing: .13em; text-transform: uppercase; padding: .15rem .45rem; border-radius: 3px; line-height: 1.5; }
.badge-analyse  { background: rgba(107,127,184,.1);  color: #6b7fb8; border: 1px solid rgba(107,127,184,.25); }
.badge-graine   { background: rgba(46,125,78,.07);   color: #2e7d4e; border: 1px solid rgba(46,125,78,.2); }
.badge-pousse   { background: rgba(56,120,60,.09);   color: #38783c; border: 1px solid rgba(56,120,60,.22); }
.badge-arbre    { background: rgba(46,125,78,.18);   color: #224422; border: 1px solid rgba(34,68,34,.2); }
.badge-serie    { background: rgba(107,127,184,.08); color: #4a5a8a; border: 1px solid rgba(107,127,184,.22); }
.article-titre { font-family: 'Libre Baskerville', Georgia, serif; font-size: .92rem; line-height: 1.35; color: var(--ink); margin-bottom: .2rem; }
.article-desc  { font-family: 'Mulish', sans-serif; font-size: .78rem; color: var(--ink-mid); line-height: 1.52; margin-bottom: .3rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.article-lire  { font-family: 'Mulish', sans-serif; font-size: .76rem; letter-spacing: .09em; text-transform: uppercase; color: var(--link); opacity: 0; transition: opacity .18s; }
@media (hover: none) { .article-lire { opacity: .6; } }

.articles-tous {
  display: block; text-align: left; margin-top: 1.1rem;
  font-family: 'Mulish', sans-serif; font-size: .70rem; font-weight: 700;
  letter-spacing: .12em; text-transform: uppercase;
  color: var(--accent); text-decoration: none;
  opacity: .75; transition: opacity .2s;
  border-top: 1px solid var(--border); padding-top: .9rem;
}
.articles-tous:hover { opacity: 1; }

/* ── Sidebar positionnement ── */
.pubs-sidebar { position: sticky; top: 4.5rem; align-self: start; }

/* ══════════════════════════════════
   ENCART JARDIN — sidebar
══════════════════════════════════ */
.jardin-encart {
  display: flex; flex-direction: column; gap: 0;
  text-decoration: none; color: inherit;
  position: relative; overflow: hidden;
  border-radius: 10px;
  border: 1px solid rgba(46,122,74,.18);
  background: linear-gradient(160deg,
    rgba(245,249,245,.98) 0%,
    rgba(237,247,239,.95) 55%,
    rgba(245,248,242,.98) 100%
  );
  box-shadow:
    0 2px 8px rgba(46,122,74,.06),
    inset 0 0 0 1px rgba(255,255,255,.6);
  padding: 1.15rem 1rem 1rem;
  transition: border-color .3s, box-shadow .3s, transform .28s cubic-bezier(.16,.84,.44,1);
}
.jardin-encart:hover {
  border-color: rgba(46,122,74,.32);
  box-shadow:
    0 8px 24px rgba(46,122,74,.10),
    inset 0 0 0 1px rgba(255,255,255,.7);
  transform: translateY(-2px);
}

/* SVG filigrane en arrière-plan */
.jardin-svg {
  position: absolute;
  top: -8px; right: -12px;
  width: 88px; height: 88px;
  pointer-events: none;
  opacity: .55;
}
@keyframes jardin-rot { to { transform: rotate(360deg); } }
@keyframes jardin-pulse {
  0%,100% { transform: scale(1); opacity: .5; }
  50% { transform: scale(1.4); opacity: .25; }
}
@keyframes jardin-pulse2 {
  0%,100% { transform: scale(1); opacity: .4; }
  50% { transform: scale(1.3); opacity: .18; }
}
@keyframes jardin-pulse3 {
  0%,100% { transform: scale(1); opacity: .5; }
  50% { transform: scale(1.5); opacity: .22; }
}
.jardin-svg-rot { animation: jardin-rot 28s linear infinite; transform-origin: 60px 60px; }
.jardin-svg-p1  { animation: jardin-pulse  3.2s ease-in-out infinite; }
.jardin-svg-p2  { animation: jardin-pulse2 4.1s ease-in-out infinite; }
.jardin-svg-p3  { animation: jardin-pulse3 2.9s ease-in-out infinite; }

/* En-tête */
.jardin-hd {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: .62rem;
  position: relative; z-index: 1;
}
.jardin-eyebrow {
  font-family: 'Mulish', sans-serif;
  font-size: .55rem; font-weight: 700;
  letter-spacing: .26em; text-transform: uppercase;
  color: #3a7c4e;
  border-bottom: 1px solid rgba(46,122,74,.2);
  padding-bottom: .12rem;
}
.jardin-glyph {
  color: #3a7c4e; font-size: .62rem; opacity: .35;
  animation: jardin-pulse 3.5s ease-in-out infinite;
}

/* Phrase */
.jardin-phrase {
  font-family: 'Libre Baskerville', Georgia, serif;
  font-size: .74rem; font-style: italic; font-weight: 400;
  color: var(--ink); line-height: 1.55;
  margin-bottom: 1rem;
  position: relative; z-index: 1;
  opacity: .85;
}

/* Légende des stades */
.jardin-legende {
  display: flex; flex-direction: column; gap: 0;
  position: relative; z-index: 1;
  border-left: 1px solid rgba(46,122,74,.12);
  padding-left: .75rem;
  margin-left: .15rem;
}

.jardin-stade {
  display: flex; align-items: center; gap: .5rem;
  padding: .32rem 0;
  position: relative;
}
/* Point sur le liseré gauche */
.jardin-stade::before {
  content: '';
  position: absolute;
  left: -.88rem; top: 50%; transform: translateY(-50%);
  width: 5px; height: 5px; border-radius: 50%;
  background: rgba(46,122,74,.28);
  border: 1px solid rgba(46,122,74,.18);
  transition: background .2s, border-color .2s;
}
.jardin-encart:hover .jardin-stade::before {
  background: rgba(46,122,74,.45);
}

.jardin-stade-emoji {
  font-size: .9rem; line-height: 1; flex-shrink: 0;
  transition: transform .25s cubic-bezier(.16,.84,.44,1);
}
.jardin-encart:hover .jardin-stade-emoji { transform: scale(1.15); }

.jardin-stade-corps {
  display: flex; flex-direction: column; gap: .06rem; flex: 1; min-width: 0;
}
.jardin-stade-nom {
  font-family: 'Libre Baskerville', Georgia, serif;
  font-size: .74rem; font-weight: 700;
  color: var(--ink); letter-spacing: -.01em; line-height: 1;
}
.jardin-stade-desc {
  font-family: 'Mulish', sans-serif;
  font-size: .63rem; font-weight: 300; font-style: italic;
  color: var(--ink-soft); opacity: .65; line-height: 1.35;
}

/* Barre de maturité */
.jardin-stade-barre {
  width: 28px; height: 3px; border-radius: 2px;
  flex-shrink: 0; opacity: .55;
  transition: opacity .2s, width .3s;
}
.jardin-encart:hover .jardin-stade-barre { opacity: .8; }
.jardin-stade-barre--g { background: #7ac898; width: 10px; }
.jardin-stade-barre--p { background: #4aaa6a; width: 19px; }
.jardin-stade-barre--a { background: #2e7a4a; width: 28px; }
.jardin-encart:hover .jardin-stade-barre--g { width: 14px; }
.jardin-encart:hover .jardin-stade-barre--p { width: 22px; }
.jardin-encart:hover .jardin-stade-barre--a { width: 28px; }

/* Flèche entre stades */
.jardin-fleche {
  font-size: .5rem; color: rgba(46,122,74,.22);
  padding: 0 0 0 .02rem;
  line-height: 1; user-select: none;
  position: relative;
}
.jardin-fleche::before {
  content: '';
  position: absolute;
  left: -.88rem; top: 50%; transform: translateY(-50%);
  width: 1px; height: 12px;
  background: rgba(46,122,74,.1);
}

/* CTA pied */
.jardin-cta {
  display: flex; align-items: center; justify-content: space-between;
  margin-top: .95rem;
  padding-top: .75rem;
  border-top: 1px solid rgba(46,122,74,.09);
  position: relative; z-index: 1;
}
.jardin-cta-texte {
  font-family: 'Mulish', sans-serif;
  font-size: .56rem; font-weight: 700;
  letter-spacing: .16em; text-transform: uppercase;
  color: #3a7c4e; opacity: .6;
  transition: opacity .2s;
}
.jardin-encart:hover .jardin-cta-texte { opacity: 1; }
.jardin-cta-arr {
  font-size: .68rem; color: #3a7c4e; opacity: .35;
  transform: translateX(-3px);
  transition: opacity .2s, transform .25s cubic-bezier(.16,.84,.44,1);
}
.jardin-encart:hover .jardin-cta-arr {
  opacity: .75; transform: translateX(0);
}

/* ── Séparateur sidebar ── */
.sidebar-sep-line {
  height: 1px; margin: .85rem 0;
  background: linear-gradient(to right, transparent, rgba(139,94,60,.12), transparent);
}

/* ══════════════════════════════════════
   ENCART NIVEAUX D'ENGAGEMENT — sidebar
══════════════════════════════════════ */
.engage-encart {
  display: flex; flex-direction: column; gap: 0;
  text-decoration: none; color: inherit;
  position: relative; overflow: hidden;
  border-radius: 10px;
  border: 1px solid rgba(124,92,191,.16);
  background: linear-gradient(150deg,
    rgba(250,248,255,.98) 0%,
    rgba(245,242,254,.95) 55%,
    rgba(248,246,255,.98) 100%
  );
  box-shadow:
    0 2px 8px rgba(124,92,191,.05),
    inset 0 0 0 1px rgba(255,255,255,.65);
  padding: 1.15rem 1rem 1rem;
  transition: border-color .3s, box-shadow .3s, transform .28s cubic-bezier(.16,.84,.44,1);
}
.engage-encart:hover {
  border-color: rgba(124,92,191,.28);
  box-shadow:
    0 8px 24px rgba(124,92,191,.09),
    inset 0 0 0 1px rgba(255,255,255,.7);
  transform: translateY(-2px);
}

/* SVG ondes en fond */
.engage-svg {
  position: absolute;
  top: -6px; right: -14px;
  width: 96px; height: 64px;
  pointer-events: none;
  opacity: .7;
}
@keyframes engage-wave1 {
  0%,100% { r: 10; opacity: .15; }
  50%      { r: 12; opacity: .08; }
}
@keyframes engage-wave2 {
  0%,100% { r: 21; opacity: .10; }
  50%      { r: 24; opacity: .05; }
}
@keyframes engage-wave3 {
  0%,100% { r: 34; opacity: .07; }
  50%      { r: 38; opacity: .03; }
}
.engage-svg-w1 { animation: engage-wave1 3.0s ease-in-out infinite; }
.engage-svg-w2 { animation: engage-wave2 3.8s ease-in-out infinite; }
.engage-svg-w3 { animation: engage-wave3 4.6s ease-in-out infinite; }

/* En-tête */
.engage-hd {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: .62rem;
  position: relative; z-index: 1;
}
.engage-eyebrow {
  font-family: 'Mulish', sans-serif;
  font-size: .55rem; font-weight: 700;
  letter-spacing: .26em; text-transform: uppercase;
  color: #6b48b8;
  border-bottom: 1px solid rgba(107,72,184,.18);
  padding-bottom: .12rem;
}
.engage-glyph {
  color: #9b7fd4; font-size: .65rem; opacity: .4;
  transition: opacity .25s;
}
.engage-encart:hover .engage-glyph { opacity: .75; }

/* Phrase */
.engage-phrase {
  font-family: 'Libre Baskerville', Georgia, serif;
  font-size: .74rem; font-style: italic; font-weight: 400;
  color: var(--ink); line-height: 1.55;
  margin-bottom: .9rem;
  position: relative; z-index: 1;
  opacity: .8;
}

/* Légende niveaux */
.engage-legende {
  display: flex; flex-direction: column; gap: 0;
  position: relative; z-index: 1;
  border-left: 1px solid rgba(124,92,191,.1);
  padding-left: .75rem;
  margin-left: .15rem;
}

.engage-niveau {
  display: flex; align-items: center; gap: .55rem;
  padding: .28rem 0;
  position: relative;
  transition: padding-left .2s;
}
.engage-niveau::before {
  content: '';
  position: absolute;
  left: -.88rem; top: 50%; transform: translateY(-50%);
  width: 5px; height: 5px; border-radius: 50%;
  background: rgba(124,92,191,.2);
  border: 1px solid rgba(124,92,191,.15);
  transition: background .2s;
}
.engage-encart:hover .engage-niveau::before {
  background: rgba(124,92,191,.38);
}

/* Niveau actif (immersion) — légère mise en avant */
.engage-niveau--active .engage-corps .engage-nom {
  color: #6b48b8;
}
.engage-niveau--active::before {
  background: rgba(107,72,184,.35);
  border-color: rgba(107,72,184,.25);
  width: 6px; height: 6px;
}

/* Barres d'intensité — alignées par le bas, effet égaliseur */
.engage-barres {
  display: flex; gap: 2px; align-items: flex-end; flex-shrink: 0;
}
.engage-bar {
  display: block;
  width: 3px; border-radius: 2px 2px 1px 1px;
  background: rgba(124,92,191,.12);
  transition: background .2s;
}
/* Hauteurs croissantes ancrées en bas */
.engage-barres .engage-bar:nth-child(1) { height: 7px; }
.engage-barres .engage-bar:nth-child(2) { height: 11px; }
.engage-barres .engage-bar:nth-child(3) { height: 16px; }

.engage-bar--on { background: rgba(107,72,184,.45); }
.engage-niveau--active .engage-bar--on { background: #7c5cbf; }
.engage-encart:hover .engage-bar--on { background: rgba(107,72,184,.65); }
.engage-encart:hover .engage-niveau--active .engage-bar--on { background: #6b48b8; }

/* Texte niveau */
.engage-corps {
  display: flex; flex-direction: column; gap: .05rem; flex: 1; min-width: 0;
}
.engage-nom {
  font-family: 'Libre Baskerville', Georgia, serif;
  font-size: .74rem; font-weight: 700;
  color: var(--ink); letter-spacing: -.01em; line-height: 1;
  transition: color .2s;
}
.engage-desc {
  font-family: 'Mulish', sans-serif;
  font-size: .62rem; font-weight: 300; font-style: italic;
  color: var(--ink-soft); opacity: .6; line-height: 1.35;
}

/* CTA pied */
.engage-cta {
  display: flex; align-items: center; justify-content: space-between;
  margin-top: .9rem;
  padding-top: .72rem;
  border-top: 1px solid rgba(124,92,191,.08);
  position: relative; z-index: 1;
}
.engage-cta-texte {
  font-family: 'Mulish', sans-serif;
  font-size: .56rem; font-weight: 700;
  letter-spacing: .16em; text-transform: uppercase;
  color: #6b48b8; opacity: .6;
  transition: opacity .2s;
}
.engage-encart:hover .engage-cta-texte { opacity: 1; }
.engage-cta-arr {
  font-size: .68rem; color: #6b48b8; opacity: .35;
  transform: translateX(-3px);
  transition: opacity .2s, transform .25s cubic-bezier(.16,.84,.44,1);
}
.engage-encart:hover .engage-cta-arr {
  opacity: .75; transform: translateX(0);
}

/* ══════════════════════════════════════
   EXPLORER — Sommaire + Carnet
══════════════════════════════════════ */
.explorer {
  max-width: var(--max);
  margin: 2rem auto 0;
  padding: 0 1.75rem;
}

.explorer-sep {
  display: flex; align-items: center; gap: .9rem;
  margin-bottom: 1.3rem;
}
.explorer-sep .sep-line {
  flex: 1; height: 1px;
  background: linear-gradient(to right, transparent, var(--rule), transparent);
}
.sep-lbl {
  font-family: 'Mulish', sans-serif;
  font-size: .60rem; font-weight: 700;
  letter-spacing: .22em; text-transform: uppercase;
  color: var(--accent); opacity: .55; white-space: nowrap;
}

.explorer-row {
  display: grid;
  grid-template-columns: 3fr 1.15fr;
  gap: .8rem;
}
@media (max-width: 560px) {
  .explorer-row { grid-template-columns: 1fr; }
}

/* ══════════════════════════════════════
   CADRE GÉNÉRIQUE
══════════════════════════════════════ */
.cadre {
  border-radius: 0;
  border: none;
  overflow: visible;
  display: flex; flex-direction: column;
  transition: none;
  text-decoration: none;
  cursor: default;
  animation: cadre-fu .55s cubic-bezier(.16,.84,.44,1) both;
}
.cadre:hover { transform: none; box-shadow: none; }
@keyframes cadre-fu { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }
.cadre:nth-child(1) { animation-delay: .06s; }
.cadre:nth-child(2) { animation-delay: .18s; }

/* ── Cadre Vert — style annotation de marge ── */
.cadre--vert {
  background: transparent;
  border: none;
  border-left: 1.5px solid rgba(46,122,74,.28);
  padding-left: 1.25rem;
  position: relative;
}
/* Liseré vertical animé au survol */
.cadre--vert::before {
  content: '';
  position: absolute;
  left: -1.5px; top: 0; bottom: 0;
  width: 1.5px;
  background: linear-gradient(to bottom, transparent 0%, #3a7c4e 30%, #4aaa6a 60%, transparent 100%);
  opacity: 0;
  transform: scaleY(.6);
  transform-origin: top;
  transition: opacity .4s ease, transform .4s cubic-bezier(.16,.84,.44,1);
}
.cadre--vert:hover::before {
  opacity: 1;
  transform: scaleY(1);
}

.cadre--orange {
  background: #fef0e2;
  border: 1.5px solid rgba(180,95,30,.22);
  border-radius: 9px;
  align-self: start;
  overflow: hidden;
}
.cadre--orange:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 28px rgba(180,95,30,.10);
}

/* ── En-tête du cadre ── */
.cadre-hd {
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 0 .85rem 0;
  border-bottom: none;
  position: relative;
}
.cadre--orange .cadre-hd {
  padding: .8rem 1rem .6rem;
  border-bottom: 1px solid rgba(0,0,0,.05);
}
.cadre-ey { display: flex; align-items: center; gap: .55rem; }

/* Point pulsant — uniquement sur le cadre orange */
.cadre-dot {
  width: 7px; height: 7px; border-radius: 50%;
  animation: cadre-pulse 2.8s ease-in-out infinite;
}
.cadre--vert   .cadre-dot { display: none; }
.cadre--orange .cadre-dot { background: #e07a3a; box-shadow: 0 0 7px rgba(224,122,58,.5); }
@keyframes cadre-pulse { 0%,100%{transform:scale(1);opacity:1;} 50%{transform:scale(1.35);opacity:.65;} }

/* Label titre */
.cadre-lbl {
  font-family: 'Mulish', sans-serif;
  font-size: .58rem; font-weight: 700;
  letter-spacing: .28em; text-transform: uppercase;
}
.cadre--vert   .cadre-lbl {
  color: #3a7c4e;
  /* Fine ligne décorative sous le label */
  padding-bottom: .15rem;
  border-bottom: 1px solid rgba(46,122,74,.22);
}
.cadre--orange .cadre-lbl { color: #a04818; }

/* Lien "Tout voir" */
.cadre-lnk {
  font-family: 'Mulish', sans-serif;
  font-size: .56rem; font-weight: 400;
  letter-spacing: .12em; text-transform: uppercase;
  opacity: .3; transition: opacity .25s, color .2s;
  text-decoration: none;
}
.cadre--vert   .cadre-lnk { color: #3a7c4e; }
.cadre--orange .cadre-lnk { color: #a04818; }
.cadre--vert:hover   .cadre-lnk { opacity: .7; }
.cadre--orange:hover .cadre-lnk { opacity: 1; }

.cadre-bd { padding: 0; flex: 1; }
.cadre--orange .cadre-bd { padding: .65rem 1rem .9rem; }

/* ══════════════════════════════════════
   TOC — Sommaire — style manuscrit
══════════════════════════════════════ */
.toc {
  list-style: none; margin: 0; padding: 0;
  counter-reset: toc-section;
}

/* ── Section principale ── */
.toc-section {
  list-style: none;
  padding-bottom: .15rem;
}
.toc-section + .toc-section {
  margin-top: .55rem;
  padding-top: .55rem;
  border-top: 1px solid rgba(46,122,74,.07);
}
.toc-section--last .toc-row--section { border-bottom: none; }

.toc-row--section {
  display: flex; align-items: baseline; gap: .7rem;
  padding: .28rem 0;
  border-bottom: none;
  border-radius: 0;
  text-decoration: none;
  margin: 0;
  transition: padding-left .2s ease;
  position: relative;
}
.toc-row--section:hover { background: none; padding-left: .3rem; }

/* Numéro romain — sobre, doré pâle */
.toc-n {
  font-family: 'Libre Baskerville', serif;
  font-size: .68rem; font-weight: 400; font-style: italic;
  color: rgba(46,122,74,.42);
  flex-shrink: 0;
  width: 1.1rem; text-align: right;
  letter-spacing: .03em;
  user-select: none;
}

/* Titre de section */
.toc-name {
  font-family: 'Libre Baskerville', serif;
  font-size: .94rem; font-weight: 700;
  color: var(--ink);
  flex-shrink: 0;
  letter-spacing: -.01em;
