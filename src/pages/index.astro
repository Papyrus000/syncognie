---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');
articles.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Base title="Syncognie">
  <Header />

  <section class="hero">

    <!-- ✦ SPIRALE FILIGRANE — SVG inline, zéro dépendance -->
    <svg class="hero-filigrane" viewBox="0 0 420 420" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <circle cx="210" cy="210" r="185"
        stroke="#8b5e3c" stroke-width=".6"
        stroke-dasharray="2 10"
        opacity=".18"
        class="fil-rotate"/>
      <path d="M210 210
               C210 188, 224 174, 240 174
               C270 174, 295 199, 295 230
               C295 272, 260 305, 210 305
               C148 305, 96 253, 96 190
               C96 116, 151 62, 225 62"
            stroke="#c4993a" stroke-width="1.2"
            stroke-linecap="round" opacity=".28"/>
      <path d="M225 62
               C272 62, 332 98, 358 155
               C384 210, 370 285, 322 324"
            stroke="#c4993a" stroke-width=".8"
            stroke-linecap="round" opacity=".16"/>
      <line x1="210" y1="210" x2="240" y2="174" stroke="#8b5e3c" stroke-width=".7" opacity=".2"/>
      <line x1="210" y1="210" x2="295" y2="230" stroke="#8b5e3c" stroke-width=".7" opacity=".18"/>
      <line x1="210" y1="210" x2="210" y2="305" stroke="#8b5e3c" stroke-width=".7" opacity=".18"/>
      <line x1="210" y1="210" x2="96"  y2="190" stroke="#8b5e3c" stroke-width=".7" opacity=".16"/>
      <line x1="210" y1="210" x2="225" y2="62"  stroke="#8b5e3c" stroke-width=".7" opacity=".16"/>
      <circle cx="240" cy="174" r="4.5" fill="#c4993a" class="fil-pulse"/>
      <circle cx="295" cy="230" r="3.5" fill="#8b5e3c" class="fil-pulse-2"/>
      <circle cx="210" cy="305" r="4"   fill="#c4993a" class="fil-pulse-3"/>
      <circle cx="96"  cy="190" r="3.5" fill="#8b5e3c" class="fil-pulse"/>
      <circle cx="225" cy="62"  r="4"   fill="#c4993a" class="fil-pulse-2"/>
      <circle cx="210" cy="210" r="28"
        stroke="#8b5e3c" stroke-width="1"
        opacity=".18" class="fil-pulse"/>
      <circle cx="210" cy="210" r="52"
        stroke="#8b5e3c" stroke-width=".5"
        opacity=".1" class="fil-pulse-2"/>
      <circle cx="210" cy="210" r="5"
        fill="#8b5e3c" opacity=".25"
        class="fil-float"/>
      <circle cx="210" cy="210" r="2.5"
        fill="#f5f0e8" opacity=".6"
        class="fil-float"/>
    </svg>

    <div class="hero-left">
      <p class="hero-eyebrow">Cerveau · Habitudes · Énergie</p>
      <h1 class="hero-titre">
        Relier les idées.<br>
        <em>Voir ce qui émerge.</em>
      </h1>
      <p class="hero-sous">
        Notes, articles et outils autour du cerveau, des habitudes et de l'énergie.
        Un carnet de bord ouvert — pas un manuel.
      </p>
      <div class="hero-note">
        <span class="hero-note-glyph">✦</span>
        <p class="hero-note-text">
          Un terrain d'expérimentation : Astro, Cloudflare, Claude —
          et des idées qui méritent d'être explorées.
        </p>
      </div>
    </div>

    <div class="hero-portals">
      <a class="portal portal-articles" href="/articles">
        <div class="portal-header">
          <div class="portal-dot"></div>
          <span class="portal-label">Articles</span>
        </div>
        <div class="portal-articles-body">
          <p class="portal-articles-count">
            <span class="portal-count-n">{articles.length}</span>
            <span class="portal-count-label">{articles.length > 1 ? 'publications' : 'publication'}</span>
          </p>
          <p class="portal-articles-hint">Notes, récits & analyses</p>
        </div>
        <span class="portal-cta">Explorer →</span>
      </a>

      <a class="portal portal-outils" href="/outils">
        <div class="portal-header">
          <div class="portal-dot"></div>
          <span class="portal-label">Outils</span>
        </div>
        <p class="portal-desc">Des boussoles, pas des diagnostics</p>
        <ul class="portal-items">
          <li>Baromètre de charge</li>
          <li>Tracker d'habitudes</li>
          <li>Boussole dopamine</li>
          <li>Récits conceptuels…</li>
        </ul>
        <span class="portal-cta">Explorer →</span>
      </a>
    </div>

  </section>

  <div class="ornament-sep">
    <div class="orn-line"></div>
    <div class="orn-centre">
      <div class="orn-diamond"></div>
      <span class="orn-label">Publications récentes</span>
      <div class="orn-diamond"></div>
    </div>
    <div class="orn-line"></div>
  </div>

  <div class="bas-wrap">

    <!-- Colonne gauche : articles -->
    <div class="articles-col">
      {articles.slice(0, 5).map((article, i) => {
        const estRecit = article.data.format === 'dialogue' || article.data.format === 'recit';
        return (
          <a
            class={`article-item${estRecit ? ' est-recit' : ''}`}
            href={`/articles/${article.slug}`}
            style={`animation-delay: ${0.42 + i * 0.1}s`}
          >
            <div class="article-meta">
              <span class="article-date">
                {article.data.date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}
              </span>
              {estRecit && <span class="badge badge-recit">◈ Récit</span>}
              {article.data.statut === 'en-cours' && <span class="badge badge-wip">En cours</span>}
              {article.data.stade === 'graine' && <span class="badge badge-graine badge-stade"><span class="badge-stade-icon">🌱</span> Graine</span>}
              {article.data.stade === 'pousse' && <span class="badge badge-pousse badge-stade"><span class="badge-stade-icon">🌿</span> Pousse</span>}
              {article.data.stade === 'arbre'  && <span class="badge badge-arbre  badge-stade"><span class="badge-stade-icon">🌳</span> Arbre</span>}
            </div>
            <p class="article-titre">{article.data.title}</p>
            {article.data.description && (
              <p class="article-desc">{article.data.description}</p>
            )}
            <span class="article-lire">
              {estRecit ? 'Lire le récit →' : 'Lire →'}
            </span>
          </a>
        );
      })}
    </div>

    <!-- Colonne droite : légende maturité -->
    <aside class="legende-col">
      <div class="legende-card">
        <p class="legende-titre">Stades de maturité</p>
        <ul class="legende-list">
          <li>
            <span class="badge badge-graine badge-stade"><span class="badge-stade-icon">🌱</span> Graine</span>
            <span class="legende-desc">Idée posée, peu développée</span>
          </li>
          <li>
            <span class="badge badge-pousse badge-stade"><span class="badge-stade-icon">🌿</span> Pousse</span>
            <span class="legende-desc">En cours d'exploration</span>
          </li>
          <li>
            <span class="badge badge-arbre badge-stade"><span class="badge-stade-icon">🌳</span> Arbre</span>
            <span class="legende-desc">Consolidé, dense</span>
          </li>
        </ul>
        <p class="legende-note">
          Syncognie est un jardin numérique — les notes évoluent, se ramifient, mûrissent avec le temps.
        </p>
      </div>
    </aside>

  </div>

  <Footer />
</Base>

<style>
  /* ── HERO ── */
  .hero {
    max-width: var(--max);
    margin: 0 auto;
    padding: 4.5rem 1.75rem 0;
    display: grid;
    grid-template-columns: 1fr 168px;
    gap: 2.5rem;
    align-items: start;
    opacity: 0;
    animation: rise .9s .1s ease forwards;
    position: relative;
  }

  @media (max-width: 600px) {
    .hero { grid-template-columns: 1fr; gap: 2rem; }
    .hero-filigrane { display: none; }
  }

  /* ── SPIRALE FILIGRANE ── */
  .hero-filigrane {
    position: absolute;
    top: 50%;
    left: 64%;
    transform: translate(-50%, -50%);
    width: 420px;
    height: 420px;
    pointer-events: none;
    z-index: 0;
  }

  .fil-rotate {
    transform-origin: 210px 210px;
    animation: fil-spin 32s linear infinite;
  }
  @keyframes fil-spin { to { transform: rotate(360deg); } }

  .fil-pulse   { animation: fil-p 6s ease-in-out infinite; }
  .fil-pulse-2 { animation: fil-p 6s ease-in-out infinite; animation-delay: 1.5s; }
  .fil-pulse-3 { animation: fil-p 6s ease-in-out infinite; animation-delay: 3s; }
  @keyframes fil-p {
    0%,100% { opacity: .18; }
    50%      { opacity: .55; }
  }

  .fil-float {
    animation: fil-f 8s ease-in-out infinite;
    transform-origin: 210px 210px;
  }
  @keyframes fil-f {
    0%,100% { transform: translateY(0); }
    50%      { transform: translateY(-6px); }
  }

  /* ── CONTENU HERO ── */
  .hero-left {
    position: relative;
    z-index: 1;
  }

  .hero-portals {
    display: flex;
    flex-direction: column;
    gap: .8rem;
    padding-top: .6rem;
    position: relative;
    z-index: 1;
  }

  .hero-eyebrow {
    font-family: 'Mulish', sans-serif;
    font-size: .6rem;
    font-weight: 300;
    letter-spacing: .3em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1.2rem;
    opacity: .75;
  }

  .hero-titre {
    font-size: clamp(1.7rem, 3.2vw, 2.2rem);
    font-weight: 700;
    color: var(--ink);
    line-height: 1.22;
    margin-bottom: 1.3rem;
    letter-spacing: -.015em;
  }

  .hero-titre em {
    font-style: italic;
    font-weight: 400;
    color: var(--gold, #c4993a);
  }

  .hero-sous {
    font-family: 'Mulish', sans-serif;
    font-size: .875rem;
    font-weight: 300;
    color: var(--ink-soft);
    line-height: 1.8;
    max-width: 42ch;
    margin-bottom: 1.75rem;
  }

  .hero-note {
    display: flex;
    align-items: flex-start;
    gap: .7rem;
    padding: .85rem 1rem;
    background: rgba(196, 153, 58, .07);
    border-left: 2px solid var(--gold, #c4993a);
    border-radius: 0 4px 4px 0;
    max-width: 42ch;
  }

  .hero-note-glyph {
    color: var(--gold, #c4993a);
    opacity: .6;
    flex-shrink: 0;
    font-size: .75rem;
    margin-top: .12rem;
  }

  .hero-note-text {
    font-family: 'Mulish', sans-serif;
    font-size: .78rem;
    font-weight: 300;
    font-style: italic;
    color: var(--ink-soft);
    line-height: 1.68;
  }

  /* ── PORTAILS ── */
  .portal {
    display: block;
    text-decoration: none;
    padding: .95rem 1rem 1rem;
    border: 1px solid var(--rule);
    border-radius: 6px;
    background: rgba(245, 240, 232, .75);
    backdrop-filter: blur(2px);
    transition: transform .22s, box-shadow .22s, border-color .22s;
    position: relative;
    overflow: hidden;
  }

  .portal::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    border-radius: 6px 6px 0 0;
  }

  .portal-articles::before { background: #6b7fb8; }
  .portal-outils::before   { background: var(--orange, #e8724a); }

  .portal:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(44, 36, 22, .09);
  }

  .portal-articles:hover { border-color: rgba(107, 127, 184, .3); }
  .portal-outils:hover   { border-color: rgba(232, 114, 74, .3); }

  .portal-header {
    display: flex;
    align-items: center;
    gap: .5rem;
    margin-bottom: .45rem;
  }

  .portal-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .portal-articles .portal-dot { background: #6b7fb8; }
  .portal-outils   .portal-dot { background: var(--orange, #e8724a); }

  .portal-label {
    font-family: 'Mulish', sans-serif;
    font-size: .6rem;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--ink-mid);
  }

  /* Corps portail articles — minimaliste */
  .portal-articles-body {
    padding: .55rem 0 .45rem;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    margin-bottom: .1rem;
  }

  .portal-articles-count {
    display: flex;
    align-items: baseline;
    gap: .4rem;
    margin-bottom: .3rem;
  }

  .portal-count-n {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: 1.6rem;
    font-weight: 700;
    color: #6b7fb8;
    line-height: 1;
    letter-spacing: -.02em;
  }

  .portal-count-label {
    font-family: 'Mulish', sans-serif;
    font-size: .62rem;
    font-weight: 300;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  .portal-articles-hint {
    font-family: 'Mulish', sans-serif;
    font-size: .65rem;
    font-weight: 300;
    font-style: italic;
    color: var(--ink-soft);
    opacity: .6;
  }

  .portal-label {
    font-family: 'Mulish', sans-serif;
    font-size: .6rem;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--ink-mid);
  }

  .portal-desc {
    font-family: 'Mulish', sans-serif;
    font-size: .71rem;
    font-weight: 300;
    color: var(--ink-soft);
    line-height: 1.5;
    margin-bottom: .55rem;
  }

  .portal-items {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: .22rem;
  }

  .portal-items li {
    font-family: 'Mulish', sans-serif;
    font-size: .64rem;
    font-weight: 300;
    color: var(--ink-soft);
    opacity: .65;
    display: flex;
    align-items: baseline;
    gap: .35rem;
    line-height: 1.4;
  }

  .portal-items li::before {
    content: '—';
    font-size: .55rem;
    opacity: .35;
    flex-shrink: 0;
  }

  .portal-cta {
    display: inline-block;
    margin-top: .6rem;
    font-family: 'Mulish', sans-serif;
    font-size: .6rem;
    font-weight: 600;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--blizzard, #148EFF);
    opacity: 0;
    transform: translateX(-3px);
    transition: opacity .2s, transform .2s;
  }

  .portal:hover .portal-cta {
    opacity: 1;
    transform: translateX(0);
  }

  /* ── SÉPARATEUR ── */
  .ornament-sep {
    max-width: var(--max);
    margin: 3.5rem auto 0;
    padding: 0 1.75rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    opacity: 0;
    animation: rise .9s .3s ease forwards;
  }

  .orn-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--rule), transparent);
  }

  .orn-centre {
    display: flex;
    align-items: center;
    gap: .55rem;
  }

  .orn-diamond {
    width: 5px;
    height: 5px;
    background: var(--rule);
    transform: rotate(45deg);
  }

  .orn-label {
    font-family: 'Mulish', sans-serif;
    font-size: .58rem;
    font-weight: 700;
    letter-spacing: .25em;
    text-transform: uppercase;
    color: var(--ink-soft);
    opacity: .45;
  }

  /* ── GRILLE BAS (articles + légende) ── */
  .bas-wrap {
    max-width: var(--max);
    margin: 0 auto;
    padding: 1.75rem 1.75rem 5rem;
    display: grid;
    grid-template-columns: 1fr 168px;
    gap: 2.5rem;
    align-items: start;
  }

  @media (max-width: 600px) {
    .bas-wrap { grid-template-columns: 1fr; }
    .legende-col { display: none; }
  }

  /* ── ARTICLES ── */
  .articles-col { min-width: 0; }

  .article-item {
    display: block;
    text-decoration: none;
    padding: 1.6rem 0;
    border-bottom: 1px solid var(--rule);
    opacity: 0;
    position: relative;
    animation: rise .7s ease forwards;
  }

  .article-item:last-child { border-bottom: none; }

  .article-item::before {
    content: '';
    position: absolute;
    left: -1.75rem;
    top: 0; bottom: 0;
    width: 2px;
    background: var(--accent);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform .28s ease;
    opacity: .5;
  }

  .article-item:hover::before { transform: scaleY(1); }

  .article-meta {
    display: flex;
    align-items: center;
    gap: .6rem;
    margin-bottom: .5rem;
    flex-wrap: wrap;
  }

  .article-date {
    font-family: 'Mulish', sans-serif;
    font-size: .6rem;
    font-weight: 300;
    letter-spacing: .15em;
    text-transform: uppercase;
    color: var(--ink-soft);
    opacity: .6;
  }

  .badge {
    font-family: 'Mulish', sans-serif;
    font-size: .55rem;
    font-weight: 700;
    letter-spacing: .13em;
    text-transform: uppercase;
    padding: .15rem .45rem;
    border-radius: 3px;
  }

  .badge-recit {
    background: rgba(196, 153, 58, .1);
    color: var(--gold, #c4993a);
    border: 1px solid rgba(196, 153, 58, .25);
  }

  .badge-wip {
    background: rgba(139, 94, 60, .07);
    color: var(--accent);
    border: 1px solid rgba(139, 94, 60, .2);
  }

  /* Badges maturité */
  .badge-stade {
    display: inline-flex;
    align-items: center;
    gap: .28rem;
  }

  .badge-stade-icon { font-size: .65rem; line-height: 1; }

  .badge-graine {
    background: rgba(46, 125, 78, .07);
    color: #2e7d4e;
    border: 1px solid rgba(46, 125, 78, .2);
  }

  .badge-pousse {
    background: rgba(56, 120, 60, .09);
    color: #38783c;
    border: 1px solid rgba(56, 120, 60, .22);
  }

  .badge-arbre {
  background: rgba(46, 125, 78, .18);
    color: #224422;
    border: 1px solid rgba(34, 68, 34, .2);
  }

  .article-titre {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--ink);
    line-height: 1.35;
    margin-bottom: .5rem;
    transition: color .2s;
  }

  .article-item:hover .article-titre { color: var(--accent); }

  .est-recit .article-titre {
    font-style: italic;
    font-weight: 400;
    font-size: 1rem;
  }

  .article-desc {
    font-family: 'Mulish', sans-serif;
    font-size: .82rem;
    font-weight: 300;
    color: var(--ink-soft);
    line-height: 1.65;
    margin-bottom: .6rem;
    max-width: 56ch;
  }

  .article-lire {
    display: inline-flex;
    align-items: center;
    gap: .35rem;
    font-family: 'Mulish', sans-serif;
    font-size: .65rem;
    font-weight: 600;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--blizzard, #148EFF);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity .2s, transform .2s;
  }

  .article-item:hover .article-lire {
    opacity: 1;
    transform: translateX(0);
  }

  /* ── LÉGENDE MATURITÉ ── */
  .legende-col {
    padding-top: 1.6rem;
  }

  .legende-card {
    position: sticky;
    top: 4.5rem;
    padding: 1rem;
    border: 1px solid var(--rule);
    border-radius: 6px;
    background: rgba(245, 240, 232, .6);
    box-shadow: 0 2px 12px rgba(44, 36, 22, .05);
  }

  .legende-titre {
    font-family: 'Mulish', sans-serif;
    font-size: .55rem;
    font-weight: 700;
    letter-spacing: .22em;
    text-transform: uppercase;
  color: var(--ink-mid);
    opacity: .75;
    margin-bottom: .75rem;
    padding-bottom: .5rem;
    border-bottom: 1px solid var(--rule);
  }

  .legende-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: .6rem;
    margin-bottom: .85rem;
  }

  .legende-list li {
    display: flex;
    flex-direction: column;
    gap: .25rem;
  }

  .legende-desc {
    font-family: 'Mulish', sans-serif;
    font-size: .62rem;
    font-weight: 300;
    font-style: italic;
  color: var(--ink-mid);
    opacity: .9;
    padding-left: .2rem;
  }

  .legende-note {
    font-family: 'Mulish', sans-serif;
    font-size: .72rem;
    font-weight: 300;
    font-style: italic;
  color: var(--ink-mid);
    opacity: .75;
    line-height: 1.6;
    padding-top: .75rem;
    border-top: 1px solid var(--rule);
  }

  /* ── ANIMATION ── */
  @keyframes rise {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
