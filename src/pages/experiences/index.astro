---
// src/pages/experiences/index.astro

import BaseLayout from '../../layouts/Base.astro';

const experiences = [
  {
    slug: 'fenetre-tolerance-couple',
    titre: '22h14',
    description: 'Un appartement. Deux personnes qui dérivent. Vos choix influencent la relation en temps réel.',
    personnages: 'Mélanie & Johan',
    concepts: ['Fenêtre de tolérance', 'Flooding', 'Attachement', 'Réparation'],
    articleLie: '/sous-la-surface/fenetre-tolerance-couple',
    date: new Date('2026-05-06'),
    phase: 0,
  },
];

function formatDate(d: Date) {
  return d.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
}

const roadmap = [
  {
    phase: 0,
    label: 'Phase 0',
    titre: 'Le simulateur',
    desc: 'Une scène. Des choix. Des stats en temps réel. Le proof of concept.',
    statut: 'en-cours',
  },
  {
    phase: 1,
    label: 'Phase 1',
    titre: 'La scène vivante',
    desc: 'Cavaliers de Gottman, deux états nerveux, scènes émergentes. Trois runs vraiment différents.',
    statut: 'bientot',
  },
  {
    phase: 2,
    label: 'Phase 2',
    titre: 'La feuille de personnage',
    desc: 'Construire son profil avant d\'entrer dans la scène. L\'alimentation, le sommeil, l\'attachement.',
    statut: 'bientot',
  },
  {
    phase: 3,
    label: 'Phase 3',
    titre: 'Le modèle',
    desc: 'Bowlby, Gottman, Siegel, Young traduits en variables avec des poids relatifs. La biologie entre dans le calcul.',
    statut: 'idee',
  },
  {
    phase: 4,
    label: 'Phase 4',
    titre: 'D\'autres scènes',
    desc: 'Le profil persiste. D\'autres situations — le travail, la famille, l\'ami qui annonce quelque chose.',
    statut: 'idee',
  },
];
---

<BaseLayout
  title="Expériences — Syncognie"
  description="Simulateurs narratifs interactifs. Construisez votre profil, jouez la scène, observez ce qui était possible pour vous."
>

<!-- ══ HERO ══ -->
<section class="exp-hero">
  <div class="exp-hero-bg" aria-hidden="true">
    <div class="exp-hero-orb exp-hero-orb--1"></div>
    <div class="exp-hero-orb exp-hero-orb--2"></div>
  </div>
  <div class="exp-hero-inner">
    <div class="exp-phase-badge">
      <span class="exp-phase-dot"></span>
      Phase 0 · En construction
    </div>
    <p class="exp-eyebrow">Syncognie · Mode expérience</p>
    <h1 class="exp-titre">Expériences</h1>
    <p class="exp-sous">
      Ce n'est pas un jeu sur Johan et Mélanie.<br>
      <em>C'est un jeu sur soi, habillé en Johan et Mélanie.</em>
    </p>
    <p class="exp-intro">
      Construisez votre profil — énergie, sommeil, style d'attachement, état nerveux. 
      Entrez dans la scène avec ce que vous êtes ce soir-là. 
      Observez ce qui était possible pour vous — et pourquoi.
    </p>
    <div class="exp-concept-band" aria-hidden="true">
      <span>Profil joueur</span>
      <span class="exp-sep">·</span>
      <span>Choix conditionnels</span>
      <span class="exp-sep">·</span>
      <span>Gottman · Siegel · Bowlby</span>
      <span class="exp-sep">·</span>
      <span>Biologie incarnée</span>
    </div>
  </div>
</section>

<!-- ══ ACCÈS FICHE PERSONNAGE ══ -->
<section class="exp-perso">
  <div class="exp-perso-inner">
    <div class="exp-perso-texte">
      <div class="exp-perso-eyebrow">Avant de jouer</div>
      <h2 class="exp-perso-titre">Construisez votre profil</h2>
      <p class="exp-perso-desc">
        Qui entrez-vous dans la scène ? Épuisé ou disponible. 
        Avec un attachement évitant ou anxieux. Une journée difficile ou neutre.
        Ces paramètres déterminent les choix qui vous seront accessibles — 
        pas ce qui est optimal, ce qui est <em>possible pour vous</em>.
      </p>
      <div class="exp-perso-tags">
        <span class="exp-ptag exp-ptag--bio">Biologie</span>
        <span class="exp-ptag exp-ptag--psy">Psychologie</span>
        <span class="exp-ptag exp-ptag--env">Environnement</span>
        <span class="exp-ptag exp-ptag--som">Sommeil</span>
        <span class="exp-ptag exp-ptag--ali">Alimentation</span>
        <span class="exp-ptag exp-ptag--his">Historique</span>
      </div>
      <a class="exp-perso-cta" href="/experiences/personnage">
        Ouvrir la fiche personnage
        <span class="exp-cta-arr">→</span>
      </a>
      <div class="exp-perso-note">Phase 0 · Paramètres de base disponibles</div>
    </div>
    <div class="exp-perso-visuel" aria-hidden="true">
      <div class="exp-fiche-preview">
        <div class="exp-fiche-cat exp-fiche-cat--env">◎ Environnement</div>
        <div class="exp-fiche-var">
          <span class="exp-fiche-var-label">Charge émotionnelle</span>
          <div class="exp-fiche-slider">
            <div class="exp-fiche-fill" style="width:62%"></div>
          </div>
          <span class="exp-fiche-val" style="color:#2E9E6B">62</span>
        </div>
        <div class="exp-fiche-cat exp-fiche-cat--bio">⬡ Biologie</div>
        <div class="exp-fiche-var">
          <span class="exp-fiche-var-label">État nerveux</span>
          <div class="exp-fiche-slider">
            <div class="exp-fiche-fill" style="width:55%;background:#E85D26"></div>
          </div>
          <span class="exp-fiche-val" style="color:#E85D26">55</span>
        </div>
        <div class="exp-fiche-cat exp-fiche-cat--psy">◉ Psychologie</div>
        <div class="exp-fiche-var">
          <span class="exp-fiche-var-label">Attachement</span>
          <div class="exp-fiche-choix">
            <span class="exp-fiche-opt">Sécure</span>
            <span class="exp-fiche-opt exp-fiche-opt--sel" style="--oc:#5B6FE0">Évitant</span>
            <span class="exp-fiche-opt exp-fiche-opt--grise">Anxieux</span>
          </div>
        </div>
        <div class="exp-fiche-locked">
          <span>◇ BHB</span>
          <span>◇ Cortisol</span>
          <span>◇ Schémas</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ EXPÉRIENCES DISPONIBLES ══ -->
<section class="exp-grille-section">
  <div class="exp-section-header">
    <div class="exp-section-sep"></div>
    <span class="exp-section-label">Expériences disponibles</span>
    <div class="exp-section-sep"></div>
  </div>
  <div class="exp-grille">
    {experiences.map((exp) => (
      <a class="exp-carte" href={`/experiences/${exp.slug}`}>
        <div class="exp-carte-halo" aria-hidden="true"></div>
        <div class="exp-carte-inner">
          <div class="exp-carte-meta">
            <time class="exp-carte-date" datetime={exp.date.toISOString()}>
              {formatDate(exp.date)}
            </time>
            {exp.personnages && (
              <span class="exp-carte-persos">{exp.personnages}</span>
            )}
            <span class="exp-carte-phase">Phase {exp.phase}</span>
          </div>
          <h2 class="exp-carte-titre">{exp.titre}</h2>
          <p class="exp-carte-desc">{exp.description}</p>
        </div>
        <div class="exp-carte-footer">
          <div class="exp-carte-concepts">
            {exp.concepts.slice(0, 4).map((c) => (
              <span class="exp-tag">{c}</span>
            ))}
          </div>
          <span class="exp-carte-cta">
            Jouer <span class="exp-arr">→</span>
          </span>
        </div>
      </a>
    ))}
  </div>
</section>

<!-- ══ ROADMAP ══ -->
<section class="exp-roadmap">
  <div class="exp-section-header">
    <div class="exp-section-sep"></div>
    <span class="exp-section-label">Feuille de route</span>
    <div class="exp-section-sep"></div>
  </div>
  <div class="exp-roadmap-liste">
    {roadmap.map((etape, i) => (
      <div class={`exp-etape exp-etape--${etape.statut}`}>
        <div class="exp-etape-indicateur">
          <div class="exp-etape-num">{etape.phase}</div>
          {i < roadmap.length - 1 && <div class="exp-etape-ligne"></div>}
        </div>
        <div class="exp-etape-corps">
          <div class="exp-etape-meta">
            <span class="exp-etape-label">{etape.label}</span>
            <span class={`exp-etape-statut exp-etape-statut--${etape.statut}`}>
              {etape.statut === 'en-cours' ? '● En cours' : etape.statut === 'bientot' ? '○ Bientôt' : '◇ À venir'}
            </span>
          </div>
          <div class="exp-etape-titre">{etape.titre}</div>
          <p class="exp-etape-desc">{etape.desc}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<!-- ══ RETOUR ══ -->
<div class="exp-back">
  <a href="/" class="exp-back-lnk">← Retour à l'accueil</a>
</div>

</BaseLayout>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;1,400;1,500&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&family=DM+Mono:wght@300;400&display=swap');

  :root {
    --exp-ink:       #1C1811;
    --exp-ink-mid:   #4A4438;
    --exp-ink-soft:  #8A8478;
    --exp-bg:        #F7F4EF;
    --exp-white:     #FEFCF8;
    --exp-rule:      #E8E2D8;
    --exp-serif:     'Lora', Georgia, serif;
    --exp-sans:      'DM Sans', sans-serif;
    --exp-mono:      'DM Mono', monospace;
    --exp-max:       860px;

    /* Couleurs catégories */
    --c-env: #2E9E6B;
    --c-bio: #E85D26;
    --c-som: #7B5EA7;
    --c-ali: #D4821A;
    --c-psy: #5B6FE0;
    --c-his: #C0394B;
  }

  /* ── HERO ── */
  .exp-hero {
    position: relative;
    padding: 4.5rem 1.75rem 2.5rem;
    overflow: hidden;
  }
  .exp-hero-bg {
    position: absolute; inset: 0; pointer-events: none;
  }
  .exp-hero-orb {
    position: absolute; border-radius: 50%; filter: blur(90px); opacity: .07;
  }
  .exp-hero-orb--1 { width: 500px; height: 400px; top: -150px; left: -100px; background: #E85D26; }
  .exp-hero-orb--2 { width: 350px; height: 300px; top: 80px; right: -80px; background: #5B6FE0; }

  .exp-hero-inner {
    position: relative;
    max-width: var(--exp-max);
    margin: 0 auto;
  }

  /* Badge Phase 0 */
  .exp-phase-badge {
    display: inline-flex;
    align-items: center;
    gap: .45rem;
    font-family: var(--exp-sans);
    font-size: .62rem;
    font-weight: 600;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: #C0394B;
    background: rgba(192,57,75,.07);
    border: 1px solid rgba(192,57,75,.25);
    padding: .3em .8em;
    border-radius: 20px;
    margin-bottom: 1.25rem;
  }
  .exp-phase-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #C0394B;
    animation: phasepulse 2s ease-in-out infinite;
  }
  @keyframes phasepulse {
    0%,100% { opacity:1; transform:scale(1); }
    50% { opacity:.3; transform:scale(1.5); }
  }

  .exp-eyebrow {
    font-family: var(--exp-sans);
    font-size: .65rem; font-weight: 500;
    letter-spacing: .28em; text-transform: uppercase;
    color: var(--exp-ink-soft); margin-bottom: .9rem;
  }
  .exp-titre {
    font-family: var(--exp-serif);
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 600; color: var(--exp-ink);
    letter-spacing: -.025em; line-height: 1.1;
    margin-bottom: .9rem;
  }
  .exp-sous {
    font-family: var(--exp-serif);
    font-style: italic; font-size: 1.1rem;
    color: var(--exp-ink-mid); line-height: 1.65;
    max-width: 50ch; margin-bottom: 1rem;
  }
  .exp-sous em { color: var(--exp-ink); font-style: italic; }
  .exp-intro {
    font-family: var(--exp-sans);
    font-size: .86rem; font-weight: 300;
    color: var(--exp-ink-soft); line-height: 1.8;
    max-width: 52ch; margin-bottom: 1.75rem;
  }
  .exp-concept-band {
    display: flex; flex-wrap: wrap; gap: .4rem .8rem;
    font-family: var(--exp-mono);
    font-size: .66rem; color: var(--exp-ink-soft); opacity: .55;
  }
  .exp-sep { opacity: .4; }

  /* ── SECTION FICHE PERSONNAGE ── */
  .exp-perso {
    border-top: 1px solid var(--exp-rule);
    border-bottom: 1px solid var(--exp-rule);
    padding: 3rem 1.75rem;
    margin-bottom: 3rem;
  }
  .exp-perso-inner {
    max-width: var(--exp-max);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 3rem;
    align-items: center;
  }
  @media (max-width: 680px) {
    .exp-perso-inner { grid-template-columns: 1fr; }
    .exp-perso-visuel { display: none; }
  }

  .exp-perso-eyebrow {
    font-family: var(--exp-sans);
    font-size: .6rem; font-weight: 700;
    letter-spacing: .22em; text-transform: uppercase;
    color: var(--c-psy); margin-bottom: .7rem; opacity: .8;
  }
  .exp-perso-titre {
    font-family: var(--exp-serif);
    font-size: 1.5rem; font-weight: 600;
    color: var(--exp-ink); margin-bottom: .9rem;
    letter-spacing: -.02em;
  }
  .exp-perso-desc {
    font-family: var(--exp-sans);
    font-size: .86rem; font-weight: 300;
    color: var(--exp-ink-mid); line-height: 1.75;
    max-width: 48ch; margin-bottom: 1.25rem;
  }
  .exp-perso-desc em { font-style: italic; color: var(--exp-ink); }

  .exp-perso-tags {
    display: flex; flex-wrap: wrap; gap: .35rem;
    margin-bottom: 1.5rem;
  }
  .exp-ptag {
    font-family: var(--exp-sans);
    font-size: .6rem; font-weight: 600;
    letter-spacing: .08em; text-transform: uppercase;
    padding: .22em .65em; border-radius: 3px; border: 1px solid;
  }
  .exp-ptag--bio { color: var(--c-bio); border-color: rgba(232,93,38,.3); background: rgba(232,93,38,.07); }
  .exp-ptag--psy { color: var(--c-psy); border-color: rgba(91,111,224,.3); background: rgba(91,111,224,.07); }
  .exp-ptag--env { color: var(--c-env); border-color: rgba(46,158,107,.3); background: rgba(46,158,107,.07); }
  .exp-ptag--som { color: var(--c-som); border-color: rgba(123,94,167,.3); background: rgba(123,94,167,.07); }
  .exp-ptag--ali { color: var(--c-ali); border-color: rgba(212,130,26,.3); background: rgba(212,130,26,.07); }
  .exp-ptag--his { color: var(--c-his); border-color: rgba(192,57,75,.3); background: rgba(192,57,75,.07); }

  .exp-perso-cta {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    font-family: var(--exp-sans);
    font-size: .82rem; font-weight: 500;
    color: var(--exp-white);
    background: var(--exp-ink);
    border: none;
    padding: .7rem 1.4rem;
    border-radius: 5px;
    text-decoration: none;
    transition: background .2s, transform .15s;
  }
  .exp-perso-cta:hover {
    background: #2E2820;
    transform: translateY(-1px);
  }
  .exp-cta-arr { transition: transform .2s; }
  .exp-perso-cta:hover .exp-cta-arr { transform: translateX(4px); }

  .exp-perso-note {
    font-family: var(--exp-sans);
    font-size: .65rem; font-weight: 300;
    color: var(--exp-ink-soft);
    margin-top: .75rem;
    letter-spacing: .04em;
  }

  /* Preview fiche */
  .exp-fiche-preview {
    background: white;
    border: 1px solid var(--exp-rule);
    border-radius: 8px;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: .6rem;
    box-shadow: 0 4px 24px rgba(28,24,17,.06);
  }
  .exp-fiche-cat {
    font-family: var(--exp-mono);
    font-size: .64rem; font-weight: 400;
    padding: .18em .5em;
    border-radius: 3px;
    display: inline-block;
    align-self: flex-start;
  }
  .exp-fiche-cat--env { color: var(--c-env); background: rgba(46,158,107,.1); }
  .exp-fiche-cat--bio { color: var(--c-bio); background: rgba(232,93,38,.1); }
  .exp-fiche-cat--psy { color: var(--c-psy); background: rgba(91,111,224,.1); }

  .exp-fiche-var {
    display: flex; align-items: center; gap: .6rem;
    padding: .5rem .6rem;
    background: #F7F4EF;
    border-radius: 5px;
  }
  .exp-fiche-var-label {
    font-family: var(--exp-mono);
    font-size: .62rem; color: #6A6258;
    flex: 1;
  }
  .exp-fiche-slider {
    width: 70px; height: 3px;
    background: #E8E2D8; border-radius: 2px;
    overflow: hidden;
  }
  .exp-fiche-fill {
    height: 100%; background: var(--c-env);
    border-radius: 2px; transition: width .3s;
  }
  .exp-fiche-val {
    font-family: var(--exp-mono);
    font-size: .7rem; min-width: 1.5rem; text-align: right;
  }
  .exp-fiche-choix {
    display: flex; gap: .25rem; flex-wrap: wrap;
  }
  .exp-fiche-opt {
    font-size: .6rem; padding: .15em .4em;
    border: 1px solid #D8D2C8; border-radius: 20px;
    color: #8A8478;
  }
  .exp-fiche-opt--sel {
    border-color: var(--oc);
    color: var(--oc);
    background: color-mix(in srgb, var(--oc) 10%, transparent);
    font-weight: 500;
  }
  .exp-fiche-opt--grise { opacity: .4; }
  .exp-fiche-locked {
    display: flex; gap: .4rem; flex-wrap: wrap;
    padding-top: .3rem;
    border-top: 1px dashed #E8E2D8;
  }
  .exp-fiche-locked span {
    font-family: var(--exp-mono);
    font-size: .6rem; color: #C8C2B8;
  }

  /* ── GRILLE EXPÉRIENCES ── */
  .exp-grille-section {
    max-width: var(--exp-max); margin: 0 auto;
    padding: 0 1.75rem 3rem;
  }
  .exp-section-header {
    display: flex; align-items: center; gap: .9rem;
    margin-bottom: 1.5rem;
  }
  .exp-section-sep {
    flex: 1; height: 1px;
    background: linear-gradient(to right, transparent, var(--exp-rule), transparent);
  }
  .exp-section-label {
    font-family: var(--exp-sans);
    font-size: .62rem; font-weight: 700;
    letter-spacing: .2em; text-transform: uppercase;
    color: var(--exp-ink-soft); opacity: .6; white-space: nowrap;
  }

  .exp-grille {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  .exp-carte {
    position: relative; display: flex; flex-direction: column;
    text-decoration: none;
    border: 1px solid var(--exp-rule);
    border-radius: 6px; overflow: hidden;
    background: var(--exp-white);
    transition: border-color .25s, transform .2s cubic-bezier(.16,.84,.44,1), box-shadow .25s;
  }
  .exp-carte:hover {
    border-color: #A89880;
    transform: translateY(-3px);
    box-shadow: 0 8px 28px rgba(28,24,17,.08);
  }
  .exp-carte-halo {
    position: absolute; top: -60px; left: -60px;
    width: 200px; height: 200px; border-radius: 50%;
    background: #b8956a; filter: blur(60px);
    opacity: 0; transition: opacity .4s; pointer-events: none;
  }
  .exp-carte:hover .exp-carte-halo { opacity: .05; }

  .exp-carte-inner {
    position: relative;
    padding: 1.5rem 1.5rem 0.5rem; flex: 1;
  }
  .exp-carte-meta {
    display: flex; align-items: center; gap: .6rem;
    margin-bottom: .8rem;
  }
  .exp-carte-date {
    font-family: var(--exp-sans);
    font-size: .65rem; font-weight: 300;
    color: var(--exp-ink-soft); opacity: .6; letter-spacing: .04em;
  }
  .exp-carte-persos {
    font-family: var(--exp-sans);
    font-size: .62rem; font-weight: 500;
    letter-spacing: .1em; text-transform: uppercase;
    color: #b8956a;
    background: rgba(184,149,106,.1);
    padding: .15em .55em; border-radius: 2px;
  }
  .exp-carte-phase {
    font-family: var(--exp-sans);
    font-size: .58rem; font-weight: 600;
    letter-spacing: .1em; text-transform: uppercase;
    color: #C0394B;
    background: rgba(192,57,75,.08);
    border: 1px solid rgba(192,57,75,.2);
    padding: .12em .45em; border-radius: 3px;
  }
  .exp-carte-titre {
    font-family: var(--exp-serif);
    font-size: 1.05rem; font-weight: 600;
    color: var(--exp-ink); letter-spacing: -.01em;
    margin-bottom: .6rem;
  }
  .exp-carte-desc {
    font-family: var(--exp-serif);
    font-style: italic; font-size: .86rem;
    color: var(--exp-ink-mid); line-height: 1.6;
  }
  .exp-carte-footer {
    padding: .6rem 1.5rem 1.5rem; margin-top: auto;
  }
  .exp-carte-concepts {
    display: flex; flex-wrap: wrap; gap: .3rem; margin-bottom: 1rem;
  }
  .exp-tag {
    font-family: var(--exp-sans);
    font-size: .6rem; font-weight: 400; letter-spacing: .05em;
    color: #b8956a; border: 1px solid rgba(184,149,106,.35);
    padding: .2em .6em; border-radius: 20px;
