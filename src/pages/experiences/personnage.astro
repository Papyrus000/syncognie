---
// src/pages/experiences/personnage.astro

import BaseLayout from '../../layouts/Base.astro';
import CharacterSheet from '../../components/game/CharacterSheet';
---

<BaseLayout
  title="Fiche personnage — Syncognie Expériences"
  description="Construisez le profil de Johan ou Mélanie avant d'entrer dans la scène. Biologie, psychologie, environnement, attachement."
>
  <div class="perso-wrap">
    <div class="perso-header">
      <a class="perso-back" href="/experiences">← Expériences</a>
      <div class="perso-phase">
        <span class="perso-phase-dot"></span>
        Phase 0 · Paramètres de base
      </div>
    </div>

    <div class="perso-intro">
      <h1 class="perso-titre">Fiche personnage</h1>
      <p class="perso-sous">
        Qui entrez-vous dans la scène ce soir ?
        Ces paramètres détermineront les choix qui vous seront accessibles.
      </p>
    </div>

    <CharacterSheet client:load />

    <div class="perso-footer">
      <a class="perso-jouer" href="/experiences/fenetre-tolerance-couple">
        Entrer dans la scène avec ce profil
        <span>→</span>
      </a>
      <p class="perso-footer-note">
        Phase 0 — le profil n'est pas encore connecté au moteur de jeu. 
        C'est la fondation de ce qui vient.
      </p>
    </div>
  </div>
</BaseLayout>

<style>
  .perso-wrap {
    max-width: 1140px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .perso-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
  }

  .perso-back {
    font-family: 'DM Sans', sans-serif;
    font-size: .68rem;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: #8A8478;
    text-decoration: none;
    transition: color .18s;
  }
  .perso-back:hover { color: #1C1811; }

  .perso-phase {
    display: flex;
    align-items: center;
    gap: .4rem;
    font-family: 'DM Sans', sans-serif;
    font-size: .62rem;
    font-weight: 600;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: #C0394B;
    opacity: .75;
  }
  .perso-phase-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #C0394B;
    animation: pdot 2s ease-in-out infinite;
  }
  @keyframes pdot {
    0%,100% { opacity:1; transform:scale(1); }
    50% { opacity:.3; transform:scale(1.5); }
  }

  .perso-intro {
    margin-bottom: 2rem;
  }
  .perso-titre {
    font-family: 'Lora', Georgia, serif;
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 600;
    color: #1C1811;
    letter-spacing: -.02em;
    margin-bottom: .5rem;
  }
  .perso-sous {
    font-family: 'DM Sans', sans-serif;
    font-size: .88rem;
    font-weight: 300;
    color: #6A6258;
    font-style: italic;
    line-height: 1.6;
  }

  .perso-footer {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid #E8E2D8;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: .75rem;
  }

  .perso-jouer {
    display: inline-flex;
    align-items: center;
    gap: .6rem;
    font-family: 'DM Sans', sans-serif;
    font-size: .85rem;
    font-weight: 500;
    color: #FEFCF8;
    background: #1C1811;
    padding: .75rem 1.5rem;
    border-radius: 5px;
    text-decoration: none;
    transition: background .2s, transform .15s;
  }
  .perso-jouer:hover {
    background: #2E2820;
    transform: translateY(-1px);
  }

  .perso-footer-note {
    font-family: 'DM Sans', sans-serif;
    font-size: .72rem;
    font-weight: 300;
    color: #A89880;
    font-style: italic;
    line-height: 1.55;
    max-width: 52ch;
  }
</style>
