---
// src/pages/entree/index.astro
// Entrée adaptative — V4 premium
// Page-pivot compacte : trois modes d’entrée, réponses immédiates,
// besoins activables, et exploration profonde vers /profil.

import BaseLayout from '../../layouts/Base.astro';
import LabMelanie from '../../components/entry/LabMelanie.astro';
import LifeSimulator from '../../components/entry/LifeSimulator.astro';

type DirectPath = {
  label: string;
  href: string;
  kicker: string;
  desc: string;
  icon: string;
};

type Need = {
  label: string;
  href?: string;
  desc: string;
  tone: 'coral' | 'amber' | 'blue' | 'green' | 'violet' | 'rose';
};

const pistesRapides: DirectPath[] = [
  {
    label: 'Voir ce qui se joue sous un silence',
    href: '/sous-la-surface/message-non-repondu',
    kicker: 'conversation',
    desc: 'Une scène annotée où les mécanismes apparaissent dans la vie réelle.',
    icon: '◱',
  },
  {
    label: 'Explorer les émotions plus finement',
    href: '/atelier/nuancier',
    kicker: 'nuances',
    desc: 'Dix scénarios pour différencier des ressentis très proches.',
    icon: '✦',
  },
  {
    label: 'Comprendre pourquoi certaines habitudes reviennent',
    href: '/articles/syst-recompense-5',
    kicker: 'boucles',
    desc: 'Dopamine, récompense et répétition comportementale.',
    icon: '◎',
  },
  {
    label: 'Voir comment deux personnes fabriquent deux réalités',
    href: '/articles/deux-escaliers-inference-argyris',
    kicker: 'perception',
    desc: 'Une lecture cognitive des interprétations humaines.',
    icon: '◇',
  },
  {
    label: 'Comprendre ce que l’on cherche parfois sans le savoir',
    href: '/articles/ce-quon-attend-sans-savoir-quoi',
    kicker: 'attente',
    desc: 'Une exploration des attentes implicites et du manque diffus.',
    icon: '✺',
  },
  {
    label: 'Entrer par une scène courte',
    href: '/fenetres',
    kicker: 'lecture',
    desc: 'Des fragments rapides à lire quand l’attention est limitée.',
    icon: '✎',
  },
];

const besoins: Need[] = [
  {
    label: 'Je tourne en boucle',
    href: '/articles/ce-quon-attend-sans-savoir-quoi',
    desc: 'attente · dopamine · boucle',
    tone: 'coral',
  },
  {
    label: 'Je suis épuisé(e)',
    href: '/outils/cortisol',
    desc: 'stress · cortisol · récupération',
    tone: 'amber',
  },
  {
    label: 'Une relation me travaille',
    href: '/articles/gottman-couple-attachement-desir',
    desc: 'attachement · désir · système',
    tone: 'rose',
  },
  {
    label: 'Je réagis trop vite',
    href: '/sous-la-surface/fenetre-tolerance-couple',
    desc: 'fenêtre · corps · régulation',
    tone: 'green',
  },
  {
    label: 'Je comprends mais je recommence',
    href: '/articles/ce-qu-on-sait-et-ce-qu-on-fait',
    desc: 'savoir · réaction · changement',
    tone: 'blue',
  },
  {
    label: 'Je veux voir plus clair',
    href: '/articles/deux-escaliers-inference-argyris',
    desc: 'inférence · récit · réalité',
    tone: 'violet',
  },
  {
    label: 'Je cherche du sens',
    href: '/articles/pourquoi-c-est-ainsi',
    desc: 'décision · évolution · liberté',
    tone: 'violet',
  },
  {
    label: 'Je veux retrouver de l’élan',
    href: '/atelier/deci-ryan',
    desc: 'motivation · autonomie · appartenance',
    tone: 'amber',
  },
  {
    label: 'Mieux nommer ce que je ressens',
    href: '/atelier/nuancier',
    desc: 'nuance · émotion · précision',
    tone: 'blue',
  },
  {
    label: 'Dire quelque chose sans blesser',
    href: '/atelier/rosenberg',
    desc: 'CNV · besoin · demande',
    tone: 'green',
  },
  {
    label: 'Je suis attiré sans aimer vraiment',
    href: '/articles/dialogue-02',
    desc: 'désir · wanting · liking',
    tone: 'coral',
  },
  {
    label: 'Je veux comprendre mon rapport aux autres',
    href: '/planches/bowlby',
    desc: 'attachement · sécurité · distance',
    tone: 'rose',
  },
  {
    label: 'Mieux dormir',
    desc: 'sommeil · irritabilité · réparation',
    tone: 'blue',
  },
  {
    label: 'Apaiser une émotion',
    desc: 'retour au calme · ancrage',
    tone: 'green',
  },
];

const toneVars = {
  coral: '--need-tone:#ff6b35; --need-soft:#fff0e8; --need-glow:rgba(255,107,53,.20);',
  amber: '--need-tone:#f7b731; --need-soft:#fff7dc; --need-glow:rgba(247,183,49,.22);',
  blue: '--need-tone:#37a7d8; --need-soft:#eaf8ff; --need-glow:rgba(55,167,216,.18);',
  green: '--need-tone:#31bd91; --need-soft:#eafff6; --need-glow:rgba(49,189,145,.18);',
  violet: '--need-tone:#8b5cf6; --need-soft:#f1ecff; --need-glow:rgba(139,92,246,.19);',
  rose: '--need-tone:#e85d8f; --need-soft:#fff0f6; --need-glow:rgba(232,93,143,.18);',
};

---

<BaseLayout
  title="Entrée — Syncognie"
  description="Choisir une façon d’entrer dans Syncognie selon sa disponibilité, son besoin du moment ou son envie d’explorer."
>
  <main class="entry-page">
    <nav class="entry-version-switch" aria-label="Version de la page d’entrée">
      <a class="entry-version-link is-active" href="/entree" data-entry-version="legacy" aria-current="page">Actuel</a>
      <a class="entry-version-link" href="/entree?v=2" data-entry-version="v2">V2 laboratoire</a>
      <a class="entry-version-link" href="/entree?v=3" data-entry-version="v3">V3 simulateur</a>
    </nav>

    <div data-entry-panel="v3" hidden>
      <LifeSimulator />
    </div>

    <div data-entry-panel="v2" hidden>
      <LabMelanie />
    </div>

    <div data-entry-panel="legacy">
    <div class="entry-ambient" aria-hidden="true">
      <span class="entry-wash entry-wash--cyan"></span>
      <span class="entry-wash entry-wash--coral"></span>
      <span class="entry-wash entry-wash--violet"></span>
      <span class="entry-thread entry-thread--left"></span>
      <span class="entry-thread entry-thread--right"></span>
      <span class="entry-pulse entry-pulse--1"></span>
      <span class="entry-pulse entry-pulse--2"></span>
      <span class="entry-pulse entry-pulse--3"></span>
      <span class="entry-pulse entry-pulse--4"></span>
    </div>

    <section class="entry-shell" aria-labelledby="entry-title">
      <header class="entry-hero">
        <div class="entry-hero-copy">
          <p class="entry-eyebrow">Entrée adaptative</p>
          <h1 id="entry-title">Par où <em>commencer</em>&nbsp;?</h1>
          <p class="entry-lead">
            Le même site, trois façons d’entrer. Choisissez selon votre disponibilité du moment.
          </p>
        </div>

        <aside class="entry-timeline" aria-label="Temps estimé par mode d’entrée">
          <div class="entry-time-row entry-time-row--quick">
            <span></span><strong>30 s</strong><small>une piste directe</small>
          </div>
          <div class="entry-time-row entry-time-row--need">
            <span></span><strong>1 min</strong><small>un besoin vécu</small>
          </div>
          <div class="entry-time-row entry-time-row--deep">
            <span></span><strong>3–5 min</strong><small>un parcours approfondi</small>
          </div>
        </aside>
      </header>

      <section class="entry-modes" aria-label="Trois modes d’entrée">
        <article class="entry-card entry-card--quick">
          <div class="entry-card-mark" aria-hidden="true">01</div>
          <div class="entry-card-glint" aria-hidden="true">✦</div>
          <header class="entry-card-head">
            <p class="entry-card-mode">Peu disponible</p>
            <h2>Une réponse immédiate.</h2>
            <p>Quatre entrées directes. Aucun questionnaire, aucune préparation.</p>
          </header>

          <div class="entry-direct-list">
            {pistesRapides.map((item) => (
              <a class="entry-direct" href={item.href}>
                <span class="entry-direct-icon" aria-hidden="true">{item.icon}</span>
                <span class="entry-direct-copy">
                  <small>{item.kicker}</small>
                  <strong>{item.label}</strong>
                  <em>{item.desc}</em>
                </span>
                <span class="entry-arrow" aria-hidden="true">→</span>
              </a>
            ))}
          </div>
        </article>

        <article class="entry-card entry-card--need">
          <div class="entry-card-mark" aria-hidden="true">02</div>
          <div class="entry-card-glint" aria-hidden="true">✦</div>
          <header class="entry-card-head">
            <p class="entry-card-mode">Besoin précis</p>
            <h2>Partir de ce qui vous préoccupe.</h2>
            <p>Sélectionnez ce qui ressemble le plus à votre situation. Les pistes disponibles ouvrent directement une lecture.</p>
          </header>

          <div class="entry-need-cloud" aria-label="Besoins disponibles ou en construction">
            {besoins.map((besoin) => (
              besoin.href ? (
                <a class="entry-need" style={toneVars[besoin.tone]} href={besoin.href}>
                  <span>{besoin.label}</span>
                  <small>{besoin.desc}</small>
                </a>
              ) : (
                <div class="entry-need entry-need--soon" style={toneVars[besoin.tone]} aria-disabled="true">
                  <span>{besoin.label}</span>
                  <small>bientôt</small>
                </div>
              )
            ))}
          </div>

          <p class="entry-growing-note">✣ Les pistes grisées signalent les prochains parcours à écrire.</p>
        </article>

        <article class="entry-card entry-card--deep">
          <div class="entry-card-mark" aria-hidden="true">03</div>
          <div class="entry-card-glint" aria-hidden="true">✦</div>
          <header class="entry-card-head">
            <p class="entry-card-mode">Temps pour explorer</p>
            <h2>Entrer plus en profondeur.</h2>
            <p>Affinez le parcours avec le profil complet : ressources, disponibilité, attachement, régulation.</p>
          </header>

          <a class="entry-profile" href="/profil">
            <span class="entry-radar" aria-hidden="true">
              <i></i><i></i><i></i><i></i><i></i><i></i>
            </span>
            <span class="entry-profile-copy">
              <strong>Explorer mon profil</strong>
              <small>~ 3 à 5 minutes</small>
              <em>Parcours complet et personnalisé</em>
            </span>
            <span class="entry-profile-arrow" aria-hidden="true">→</span>
          </a>

          <div class="entry-profile-tags" aria-hidden="true">
            <span>ressources</span>
            <span>régulation</span>
            <span>attachement</span>
            <span>disponibilité</span>
          </div>
        </article>
      </section>

      <footer class="entry-footer-note">
        <span></span>
        <p>Choisir peu, mais choisir juste : une scène, un besoin ou une exploration complète.</p>
        <span></span>
      </footer>
    </section>
    </div>
  </main>

  <script is:inline>
    const links = document.querySelectorAll('[data-entry-version]');
    const panels = document.querySelectorAll('[data-entry-panel]');
    const entryPage = document.querySelector('.entry-page');

    document.documentElement.classList.add('entry-route');

    function showEntryVersion(version) {
      panels.forEach((panel) => {
        panel.hidden = panel.dataset.entryPanel !== version;
      });

      entryPage?.classList.toggle('is-v2', version === 'v2' || version === 'v3');
      document.documentElement.classList.toggle('entry-route-v2', version === 'v2' || version === 'v3');

      links.forEach((link) => {
        const isActive = link.dataset.entryVersion === version;
        link.classList.toggle('is-active', isActive);
        if (isActive) {
          link.setAttribute('aria-current', 'page');
        } else {
          link.removeAttribute('aria-current');
        }
      });
    }

    function getVersionFromUrl() {
      const v = new URLSearchParams(window.location.search).get('v');
      if (v === '2') return 'v2';
      if (v === '3') return 'v3';
      return 'legacy';
    }

    showEntryVersion(getVersionFromUrl());

    links.forEach((link) => {
      link.addEventListener('click', (event) => {
        event.preventDefault();
        const version = link.dataset.entryVersion;
        const url = version === 'v2' ? '/entree?v=2' : version === 'v3' ? '/entree?v=3' : '/entree';
        window.history.pushState({}, '', url);
        showEntryVersion(version);
      });
    });

    window.addEventListener('popstate', () => {
      showEntryVersion(getVersionFromUrl());
    });
  </script>
</BaseLayout>

<style>
  .entry-version-switch {
    position: absolute;
    top: .75rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 5;
    width: min(100% - 2rem, 1180px);
    display: flex;
    justify-content: flex-end;
    gap: .5rem;
    pointer-events: none;
  }

  .entry-version-switch > * {
    pointer-events: auto;
  }

  .entry-version-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: .48rem .76rem;
    border: 1px solid rgba(42, 37, 32, .10);
    border-radius: 999px;
    background: rgba(255, 255, 255, .48);
    color: rgba(42, 37, 32, .68);
    font-family: var(--entry-sans);
    font-size: .72rem;
    font-weight: 700;
    text-decoration: none;
    box-shadow: 0 10px 24px rgba(42, 37, 32, .045);
    backdrop-filter: blur(12px);
    transition: opacity .18s, transform .18s, background .18s, color .18s, border-color .18s;
  }

  .entry-version-link:hover {
    transform: translateY(-1px);
    color: rgba(42, 37, 32, .92);
    border-color: rgba(42, 37, 32, .18);
  }

  .entry-version-link.is-active {
    background: rgba(42, 37, 32, .88);
    color: #fffaf3;
    border-color: rgba(42, 37, 32, .88);
  }

  @import url('https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600;9..40,700&family=DM+Mono:wght@400;500&display=swap');

  :root {
    --entry-ink: var(--ink, #1C1811);
    --entry-mid: var(--ink-mid, #5F564C);
    --entry-soft: var(--ink-soft, #9C9081);
    --entry-rule: var(--rule, #E8E2D8);
    --entry-bg: var(--bg, #F8F6F2);
    --entry-paper: rgba(255, 252, 246, .72);
    --entry-glass: rgba(255, 252, 246, .54);
    --entry-serif: 'Lora', Georgia, serif;
    --entry-sans: 'DM Sans', system-ui, sans-serif;
    --entry-mono: 'DM Mono', ui-monospace, monospace;
    --entry-max: 1040px;
    --quick: #34c6a3;
    --quick-rgb: 52, 198, 163;
    --need: #ff7447;
    --need-rgb: 255, 116, 71;
    --deep: #8b64ee;
    --deep-rgb: 139, 100, 238;
    --gold: #f5c24c;
    --sky: #58bfe7;
  }

  .entry-page {
    position: relative;
    overflow: hidden;
    min-height: calc(100vh - 72px);
    color: var(--entry-ink);
    background:
      radial-gradient(ellipse 48rem 32rem at 22% 24%, rgba(107, 214, 225, .18), transparent 68%),
      radial-gradient(ellipse 44rem 30rem at 78% 22%, rgba(255, 138, 92, .18), transparent 70%),
      radial-gradient(ellipse 42rem 28rem at 66% 90%, rgba(154, 119, 246, .15), transparent 72%),
      linear-gradient(180deg, #fffdf8 0%, #fbf8f1 68%, #f8f4eb 100%);
  }

  .entry-ambient {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .entry-wash {
    position: absolute;
    display: block;
    border-radius: 999px;
    filter: blur(28px);
    opacity: .72;
    transform: translateZ(0);
  }
  .entry-wash--cyan {
    width: 21rem;
    height: 21rem;
    left: 4%;
    top: 10rem;
    background: radial-gradient(circle, rgba(52,198,163,.18), rgba(88,191,231,.08) 48%, transparent 72%);
  }
  .entry-wash--coral {
    width: 25rem;
    height: 25rem;
    right: 2%;
    top: 6.5rem;
    background: radial-gradient(circle, rgba(255,116,71,.20), rgba(245,194,76,.08) 50%, transparent 74%);
  }
  .entry-wash--violet {
    width: 24rem;
    height: 24rem;
    right: 18%;
    bottom: -5rem;
    background: radial-gradient(circle, rgba(139,100,238,.18), rgba(255,255,255,.05) 52%, transparent 74%);
  }

  .entry-thread {
    position: absolute;
    width: 32rem;
    height: 32rem;
    border: 1px solid rgba(255,255,255,.58);
    border-radius: 48% 52% 46% 54%;
    opacity: .8;
  }
  .entry-thread--left { left: -12rem; top: 12rem; transform: rotate(21deg); }
  .entry-thread--right { right: -9rem; bottom: -4rem; transform: rotate(-13deg); }

  .entry-pulse {
    position: absolute;
    width: .48rem;
    height: .48rem;
    border-radius: 999px;
    background: currentColor;
    box-shadow: 0 0 0 .42rem rgba(255,255,255,.55), 0 0 1.5rem currentColor;
    opacity: .7;
  }
  .entry-pulse--1 { color: var(--quick); left: 6%; bottom: 19%; }
  .entry-pulse--2 { color: var(--gold); left: 11%; top: 43%; }
  .entry-pulse--3 { color: var(--need); right: 17%; top: 28%; }
  .entry-pulse--4 { color: var(--deep); right: 6%; bottom: 24%; }

  .entry-shell {
    position: relative;
    width: min(var(--entry-max), calc(100% - 3rem));
    margin: 0 auto;
    padding: clamp(3rem, 5.2vw, 4.5rem) 0 2.9rem;
  }

  .entry-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 310px;
    align-items: end;
    gap: clamp(1.5rem, 5vw, 4rem);
    margin-bottom: clamp(1.7rem, 3.8vw, 2.7rem);
  }

  .entry-eyebrow,
  .entry-card-mode,
  .entry-direct small,
  .entry-profile-tags span {
    font-family: var(--entry-mono);
    text-transform: uppercase;
    letter-spacing: .22em;
  }

  .entry-eyebrow {
    margin: 0 0 .8rem;
    font-size: .62rem;
    color: color-mix(in srgb, var(--deep) 62%, #4f8bb8);
  }

  .entry-hero h1 {
    margin: 0;
    font-family: var(--entry-serif);
    font-weight: 500;
    font-size: clamp(2.15rem, 3.8vw, 3.1rem);
    line-height: 1.02;
    letter-spacing: -.045em;
  }

  .entry-hero h1 em {
    font-style: italic;
    font-weight: 400;
    background: linear-gradient(100deg, #ff7447 0%, #c481ee 56%, #5aa7d8 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .entry-lead {
    max-width: 46ch;
    margin: 1rem 0 0;
    font-family: var(--entry-serif);
    font-size: .9rem;
    line-height: 1.72;
    color: var(--entry-mid);
  }

  .entry-timeline {
    position: relative;
    display: grid;
    gap: .65rem;
    padding: .95rem 1rem;
    border: 1px solid rgba(232,226,216,.68);
    border-radius: 18px;
    background: rgba(255,255,255,.42);
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,.68),
      0 20px 46px rgba(74, 44, 25, .055);
    backdrop-filter: blur(18px) saturate(135%);
    -webkit-backdrop-filter: blur(18px) saturate(135%);
  }

  .entry-timeline::before {
    content: '';
    position: absolute;
    left: 1.24rem;
    top: 1.26rem;
    bottom: 1.26rem;
    width: 1px;
    background: linear-gradient(var(--quick), var(--need), var(--deep));
    opacity: .34;
  }

  .entry-time-row {
    --tone: var(--quick);
    display: grid;
    grid-template-columns: .8rem 3.7rem 1fr;
    align-items: baseline;
    gap: .6rem;
    font-family: var(--entry-sans);
  }
  .entry-time-row--quick { --tone: var(--quick); }
  .entry-time-row--need { --tone: var(--need); }
  .entry-time-row--deep { --tone: var(--deep); }
  .entry-time-row span {
    position: relative;
    z-index: 1;
    width: .5rem;
    height: .5rem;
    border-radius: 999px;
    background: var(--tone);
    box-shadow: 0 0 0 .34rem color-mix(in srgb, var(--tone) 15%, white), 0 0 1.15rem color-mix(in srgb, var(--tone) 44%, transparent);
  }
  .entry-time-row strong {
    font-size: .72rem;
    color: var(--entry-ink);
  }
  .entry-time-row small {
    font-family: var(--entry-serif);
    font-size: .75rem;
    font-style: italic;
    color: var(--entry-soft);
  }

  .entry-modes {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(.78rem, 1.1vw, .95rem);
    align-items: stretch;
  }

  .entry-card {
    --lane: var(--quick);
    --lane-rgb: var(--quick-rgb);
    position: relative;
    min-width: 0;
    overflow: hidden;
    border: 1px solid rgba(var(--lane-rgb), .26);
    border-radius: 24px;
    background:
      linear-gradient(180deg, rgba(255,255,255,.67), rgba(255,252,246,.50)),
      radial-gradient(circle at 8% -4%, rgba(var(--lane-rgb), .14), transparent 42%);
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,.68),
      0 22px 55px rgba(76, 53, 31, .065),
      0 0 0 1px rgba(255,255,255,.38);
    backdrop-filter: blur(20px) saturate(142%);
    -webkit-backdrop-filter: blur(20px) saturate(142%);
  }

  .entry-card--quick { --lane: var(--quick); --lane-rgb: var(--quick-rgb); }
  .entry-card--need { --lane: var(--need); --lane-rgb: var(--need-rgb); }
  .entry-card--deep { --lane: var(--deep); --lane-rgb: var(--deep-rgb); }

  .entry-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background:
      radial-gradient(circle at 88% 7%, rgba(var(--lane-rgb), .20), transparent 20%),
      linear-gradient(140deg, rgba(255,255,255,.40), transparent 32%, rgba(var(--lane-rgb), .04) 100%);
    pointer-events: none;
  }

  .entry-card::after {
    content: '';
    position: absolute;
    inset: 1px;
    border-radius: 23px;
    border: 1px solid rgba(255,255,255,.30);
    pointer-events: none;
  }

  .entry-card-mark {
    position: absolute;
