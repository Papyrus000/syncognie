---
// src/pages/entree/besoin/index.astro

import EntryLayout from '../../../layouts/EntryLayout.astro';
---

<EntryLayout
  title="Choisir un besoin — Syncognie"
  description="Choisir un besoin ou une situation pour arriver directement sur une ressource adaptée."
>
  <div class="entry-container">
    <a class="entry-back" href="/entree">← Choisir une autre entrée</a>

    <section class="entry-hero">
      <p class="entry-eyebrow">mode besoin · 1 minute</p>
      <h1 class="entry-title">Partir de ce qui se passe maintenant.</h1>
      <p class="entry-intro">
        Cette page peut lister les besoins disponibles, avec les besoins à venir grisés
        pour garder la sensation de jardin numérique en croissance.
      </p>
    </section>
  </div>
</EntryLayout>
