---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

// ── SYSTÈME DE CLASSEMENT ──────────────────────────────────────────────────
// usage:  immediat | guide | exploration
//         immediat    = utilisable sans contexte, fait sens tout de suite
//         guide       = mieux avec un peu de contexte du site
//         exploration = enrichi par la lecture des articles
//
// public: tous | initie | avance
//         tous    = accessible sans prérequis
//         initie  = mieux après quelques articles lus
//         avance  = pour lecteurs réguliers du site
//
// Tri automatique : usage (0-2) × 2 + public (0-2) → score croissant
// Les outils de même statut sont triés par score, puis par ordre d'écriture.
//
// color:  couleur propre à l'outil — se propage en cascade via --outil-color
//         Tracker   #e8724a  corail, énergie matinale
//         Boussole  #6b7fb8  bleu ardoise, introspection
//         Baromètre #3ab87a  vert émeraude, équilibre
//         Récits    #c4993a  or chaud, bibliothèque
// ──────────────────────────────────────────────────────────────────────────

const outils = [
  {
    id: 'barometre',
    titre: 'Baromètre de charge',
    description: 'Une photo de ce que tu portes — physique, mental, émotionnel. Sans jugement, sans culpabilité.',
    tags: ['fatigue', 'charge mentale', 'bienveillance'],
    statut: 'en-cours',
    color: '#3ab87a',
    lien: '/outils/barometre',
    version: 'v1',
    usage: 'immediat',
    public: 'tous',
  },
  {
    id: 'tracker',
    titre: 'Tracker d\'habitudes',
    description: 'Trois ancres quotidiennes. Intensité 1 à 3. Mémoire 7 jours. Pas des objectifs — des signaux.',
    tags: ['habitudes', 'ancres', 'dopamine'],
    statut: 'en-cours',
    color: '#e8724a',
    lien: '/outils/tracker',
    version: 'v1',
    usage: 'immediat',
    public: 'tous',
  },
  {
    id: 'boussole',
    titre: 'Boussole dopaminergique',
    description: 'Quelques questions pour estimer ton niveau de charge dopaminergique, ta fatigue nerveuse, et obtenir des pistes d\'équilibre adaptées.',
    tags: ['dopamine', 'fatigue', 'bien-être'],
    statut: 'en-cours',
    color: '#6b7fb8',
    lien: '/outils/boussole',
    version: 'v1',
    usage: 'guide',
    public: 'tous',
  },
  {
    id: 'narratif',
    titre: 'Récits conceptuels',
    description: 'Des concepts complexes mis en scène dans des dialogues. Comprendre en lisant, pas en étudiant.',
    tags: ['apprentissage', 'cognition', 'dialogue'],
    statut: 'en-cours',
    color: '#c4993a',
    lien: '/outils/recits',
    version: 'v1',
    usage: 'exploration',
    public: 'initie',
  },
  {
    id: 'homeostasie',
    titre: 'Tableau de bord homéostatique',
    description: 'Visualiser en temps réel l\'équilibre entre stimuli et récupération — basé sur le modèle de la balance plaisir/douleur.',
    tags: ['homéostasie', 'comportement'],
    statut: 'bientot',
    color: '#2ecc71',
    usage: 'immediat',
    public: 'tous',
  },
  {
    id: 'minuteur',
    titre: 'Minuteur de décompression',
    description: 'Un minuteur intentionnel pour les pauses — avec un contexte neuroscientifique sur ce qui se passe dans le cerveau pendant le repos actif.',
    tags: ['récupération', 'pauses', 'attention'],
    statut: 'idee',
    color: '#9a9189',
    usage: 'immediat',
    public: 'tous',
  },
  {
    id: 'journal',
    titre: 'Journal de gratifications',
    description: 'Noter chaque jour ses gratifications consommées — pas pour culpabiliser, mais pour développer la conscience du circuit.',
    tags: ['conscience', 'habitudes', 'journal'],
    statut: 'idee',
    color: '#9a9189',
    usage: 'guide',
    public: 'initie',
  },
  {
    id: 'ancres',
    titre: 'Générateur d\'ancres',
    description: 'Trouver ses propres ancres matinales selon son profil, ses contraintes et ses objectifs — personnalisé, pas prescriptif.',
    tags: ['ancres', 'personnalisation', 'matin'],
    statut: 'idee',
    color: '#9a9189',
    usage: 'guide',
    public: 'tous',
  },
];

// ── Tri automatique ────────────────────────────────────────────────────────
const ORDRE_STATUT: Record<string, number> = { 'actif': 0, 'en-cours': 1, 'bientot': 2, 'idee': 3 };
const ORDRE_USAGE: Record<string, number>  = { 'immediat': 0, 'guide': 1, 'exploration': 2 };
const ORDRE_PUBLIC: Record<string, number> = { 'tous': 0, 'initie': 1, 'avance': 2 };

const outilsTries = [...outils].sort((a, b) => {
  const statutDiff = (ORDRE_STATUT[a.statut] ?? 9) - (ORDRE_STATUT[b.statut] ?? 9);
  if (statutDiff !== 0) return statutDiff;
  const scoreA = (ORDRE_USAGE[a.usage ?? 'immediat'] ?? 0) * 2 + (ORDRE_PUBLIC[a.public ?? 'tous'] ?? 0);
  const scoreB = (ORDRE_USAGE[b.usage ?? 'immediat'] ?? 0) * 2 + (ORDRE_PUBLIC[b.public ?? 'tous'] ?? 0);
  return scoreA - scoreB;
});

const BADGES: Record<string, string> = {
  'actif':    'Disponible →',
  'en-cours': 'En cours',
  'bientot':  'Bientôt',
  'idee':     'En réflexion',
};
---

<Base title="Outils — Syncognie">
  <Header />
  <div class="outils-wrap">
    <div class="outils-header">
      <p class="surtitre">Expérimentation</p>
      <h1 class="titre">Outils</h1>
      <p class="sous">Des instruments pour explorer les concepts — pas des diagnostics, des boussoles.</p>
    </div>
    <div class="outils-grille">
      {outilsTries.map(outil => (
        (outil.statut === 'actif' || outil.statut === 'en-cours') ? (
          <a
            href={outil.lien}
            class="outil-card outil-card--live"
            style={`--outil-color: ${outil.color}`}
          >
            <div class="outil-top">
              <div class="outil-dot"></div>
              <div class="outil-top-right">
                {outil.version && <span class="outil-version">{outil.version}</span>}
                <span class="outil-badge badge-live">{BADGES[outil.statut]}</span>
              </div>
            </div>
            <h2 class="outil-titre">{outil.titre}</h2>
            <p class="outil-desc">{outil.description}</p>
            <div class="outil-tags">
              {outil.tags.map(tag => <span class="outil-tag">{tag}</span>)}
            </div>
          </a>
        ) : (
          <div class={`outil-card statut-${outil.statut}`}>
            <div class="outil-top">
              <div class="outil-dot" style={`background:${outil.color}`}></div>
              <span class={`outil-badge badge-${outil.statut}`}>{BADGES[outil.statut]}</span>
            </div>
            <h2 class="outil-titre">{outil.titre}</h2>
            <p class="outil-desc">{outil.description}</p>
            <div class="outil-tags">
              {outil.tags.map(tag => <span class="outil-tag">{tag}</span>)}
            </div>
          </div>
        )
      ))}
    </div>
    <div class="outils-note">
      <div class="note-dot"></div>
      <p>Ces outils naissent des articles. Chaque concept exploré devient potentiellement un instrument pratique.</p>
    </div>
  </div>
  <Footer />
</Base>

<style>
  .outils-wrap {
    max-width: var(--max);
    margin: 0 auto;
    padding: 4rem 1.75rem 5rem;
  }
  .outils-header {
    margin-bottom: 3.5rem;
    opacity: 0;
    animation: rise .9s .1s ease forwards;
  }
  .surtitre {
    font-family: 'Mulish', sans-serif;
    font-size: .65rem;
    font-weight: 300;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: .75rem;
  }
  .titre {
    font-size: 1.9rem;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 1rem;
  }
  .sous {
    font-family: 'Mulish', sans-serif;
    font-size: .9rem;
    font-weight: 300;
    color: var(--ink-soft);
    line-height: 1.7;
  }
  .outils-grille {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    opacity: 0;
    animation: rise .9s .25s ease forwards;
  }

  /* ── Carte base ── */
  .outil-card {
    border: 1px solid var(--rule);
    border-radius: 10px;
    padding: 1.5rem;
    transition: box-shadow .2s, transform .2s, border-color .2s;
    background: rgba(26,23,20,.015);
    text-decoration: none;
    display: block;
    color: inherit;
    position: relative;
    overflow: hidden;
  }

  /* ── Cartes vivantes — tout en cascade depuis --outil-color ── */
  .outil-card--live {
    background: color-mix(in srgb, var(--outil-color) 4%, var(--bg));
  }
  .outil-card--live::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--outil-color);
    border-radius: 10px 10px 0 0;
    opacity: .75;
    transition: height .2s, opacity .2s;
  }
  .outil-card--live:hover::before {
    height: 4px;
    opacity: 1;
  }
  .outil-card--live:hover {
    box-shadow: 0 8px 28px color-mix(in srgb, var(--outil-color) 18%, transparent);
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--outil-color) 35%, var(--rule));
  }
  /* Dot couleur automatique */
  .outil-card--live .outil-dot {
    background: var(--outil-color);
  }
  /* Badge couleur automatique */
  .badge-live {
    font-family: 'Mulish', sans-serif;
    font-size: .6rem;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
    padding: .25rem .6rem;
    border-radius: 4px;
    background: color-mix(in srgb, var(--outil-color) 10%, transparent);
    color: var(--outil-color);
    border: 1px solid color-mix(in srgb, var(--outil-color) 30%, transparent);
  }

  /* ── Cartes passives ── */
  .statut-bientot:hover {
    box-shadow: 0 6px 20px rgba(26,23,20,.06);
    transform: translateY(-1px);
  }
  .statut-idee { opacity: .45; }

  /* ── Éléments communs ── */
  .outil-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }
  .outil-top-right {
    display: flex;
    align-items: center;
    gap: .5rem;
  }
  .outil-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }
  .outil-version {
    font-family: 'Courier New', Courier, monospace;
    font-size: .62rem;
    color: var(--ink-soft);
    border: 1px solid var(--rule);
    border-radius: 3px;
    padding: .15rem .35rem;
    opacity: .75;
    line-height: 1;
  }
  .outil-badge {
    font-family: 'Mulish', sans-serif;
    font-size: .6rem;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
    padding: .25rem .6rem;
    border-radius: 4px;
  }
  .badge-bientot {
    background: rgba(255,128,0,.08);
    color: #ff8000;
    border: 1px solid rgba(255,128,0,.2);
  }
  .badge-idee {
    background: rgba(154,145,137,.08);
    color: var(--ink-soft);
    border: 1px solid var(--rule);
  }
  .outil-titre {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: .6rem;
  }
  .outil-desc {
    font-family: 'Mulish', sans-serif;
    font-size: .85rem;
    font-weight: 300;
    color: var(--ink-mid);
    line-height: 1.7;
    margin-bottom: 1rem;
  }
  .outil-tags {
    display: flex;
    flex-wrap: wrap;
    gap: .4rem;
  }
  .outil-tag {
    font-family: 'Mulish', sans-serif;
    font-size: .65rem;
    font-weight: 300;
    color: var(--ink-soft);
    border: 1px solid var(--rule);
    border-radius: 4px;
    padding: .2rem .5rem;
  }
  .outils-note {
    display: flex;
    align-items: flex-start;
    gap: .75rem;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--rule);
  }
  .note-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
    margin-top: .35rem;
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.3} }
  .outils-note p {
    font-family: 'Mulish', sans-serif;
    font-size: .82rem;
    font-weight: 300;
    color: var(--ink-soft);
    line-height: 1.7;
    font-style: italic;
  }
</style>
