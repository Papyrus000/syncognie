---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const outils = [
  {
    id: 'tracker',
    titre: 'Tracker d\'habitudes',
    description: 'Trois ancres quotidiennes. Intensité 1 à 3. Mémoire 7 jours. Pas des objectifs — des signaux.',
    tags: ['habitudes', 'ancres', 'dopamine'],
    statut: 'en-cours',
    color: '#0070dd',
    lien: '/outils/tracker',
    version: 'v1',
  },
  {
    id: 'boussole',
    titre: 'Boussole dopaminergique',
    description: 'Quelques questions pour estimer ton niveau de charge dopaminergique, ta fatigue nerveuse, et obtenir des pistes d\'équilibre adaptées.',
    tags: ['dopamine', 'fatigue', 'bien-être'],
    statut: 'en-cours',
    color: '#0070dd',
    lien: '/outils/boussole',
    version: 'v1',
  },
  {
    id: 'homeostasie',
    titre: 'Tableau de bord homéostatique',
    description: 'Visualiser en temps réel l\'équilibre entre stimuli et récupération — basé sur le modèle de la balance plaisir/douleur.',
    tags: ['homéostasie', 'comportement'],
    statut: 'bientot',
    color: '#2ecc71',
  },
  {
    id: 'narratif',
    titre: 'Récits conceptuels',
    description: 'Des concepts complexes mis en scène dans des dialogues et des narratifs — comprendre en lisant, pas en étudiant.',
    tags: ['apprentissage', 'cognition'],
    statut: 'idee',
    color: '#9a9189',
  },
];

const ORDRE = { 'actif': 0, 'en-cours': 1, 'bientot': 2, 'idee': 3 };
const outilsTries = [...outils].sort((a, b) => (ORDRE[a.statut] ?? 9) - (ORDRE[b.statut] ?? 9));

const BADGES: Record<string, string> = {
  'actif':    'Disponible →',
  'en-cours': 'En cours',
  'bientot':  'Bientôt',
  'idee':     'En réflexion',
};
---

<Base title="Outils — Syncognie">
  <Header />
  <div class="outils-wrap">
    <div class="outils-header">
      <p class="surtitre">Expérimentation</p>
      <h1 class="titre">Outils</h1>
      <p class="sous">Des instruments pour explorer les concepts — pas des diagnostics, des boussoles.</p>
    </div>
    <div class="outils-grille">
      {outilsTries.map(outil => (
        (outil.statut === 'actif' || outil.statut === 'en-cours') ? (
          <a href={outil.lien} class={`outil-card statut-${outil.statut}`}>
            <div class="outil-top">
              <div class="outil-dot" style={`background:${outil.color}`}></div>
              <div class="outil-top-right">
                {outil.version && <span class="outil-version">{outil.version}</span>}
                <span class={`outil-badge badge-${outil.statut}`}>{BADGES[outil.statut]}</span>
              </div>
            </div>
            <h2 class="outil-titre">{outil.titre}</h2>
            <p class="outil-desc">{outil.description}</p>
            <div class="outil-tags">
              {outil.tags.map(tag => <span class="outil-tag">{tag}</span>)}
            </div>
          </a>
        ) : (
          <div class={`outil-card statut-${outil.statut}`}>
            <div class="outil-top">
              <div class="outil-dot" style={`background:${outil.color}`}></div>
              <span class={`outil-badge badge-${outil.statut}`}>{BADGES[outil.statut]}</span>
            </div>
            <h2 class="outil-titre">{outil.titre}</h2>
            <p class="outil-desc">{outil.description}</p>
            <div class="outil-tags">
              {outil.tags.map(tag => <span class="outil-tag">{tag}</span>)}
            </div>
          </div>
        )
      ))}
    </div>
    <div class="outils-note">
      <div class="note-dot"></div>
      <p>Ces outils naissent des articles. Chaque concept exploré devient potentiellement un instrument pratique.</p>
    </div>
  </div>
  <Footer />
</Base>

<style>
  .outils-wrap {
    max-width: var(--max);
    margin: 0 auto;
    padding: 4rem 1.75rem 5rem;
  }
  .outils-header {
    margin-bottom: 3.5rem;
    opacity: 0;
    animation: rise .9s .1s ease forwards;
  }
  .surtitre {
    font-family: 'Mulish', sans-serif;
    font-size: .65rem;
    font-weight: 300;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: .75rem;
  }
  .titre {
    font-size: 1.9rem;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: 1rem;
  }
  .sous {
    font-family: 'Mulish', sans-serif;
    font-size: .9rem;
    font-weight: 300;
    color: var(--ink-soft);
    line-height: 1.7;
  }
  .outils-grille {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    opacity: 0;
    animation: rise .9s .25s ease forwards;
  }
  .outil-card {
    border: 1px solid var(--rule);
    border-radius: 10px;
    padding: 1.5rem;
    transition: box-shadow .2s, transform .2s, border-color .2s;
    background: rgba(26,23,20,.015);
    text-decoration: none;
    display: block;
    color: inherit;
  }
  .statut-actif:hover {
    box-shadow: 0 8px 24px rgba(46,204,113,.12);
    transform: translateY(-2px);
    border-color: #2ecc71;
  }
  .statut-en-cours:hover {
    box-shadow: 0 6px 20px rgba(26,23,20,.07);
    transform: translateY(-2px);
    border-color: var(--rule);
  }
  .statut-bientot:hover {
    box-shadow: 0 6px 20px rgba(26,23,20,.06);
    transform: translateY(-1px);
  }
  .statut-idee { opacity: .45; }

  .outil-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }
  .outil-top-right {
    display: flex;
    align-items: center;
    gap: .5rem;
  }
  .outil-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  /* Pastille version — petite, monospace, très discrète */
  .outil-version {
    font-family: 'Courier New', Courier, monospace;
font-size: .75rem;
    font-weight: 400;
    color: var(--ink-soft);
    background: transparent;
    border: 1px solid var(--rule);
    border-radius: 3px;
    padding: .15rem .35rem;
opacity: .80;
    line-height: 1;
  }

  .outil-badge {
    font-family: 'Mulish', sans-serif;
    font-size: .6rem;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
    padding: .25rem .6rem;
    border-radius: 4px;
  }
  .badge-actif {
    background: rgba(46,204,113,.08);
    color: #2ecc71;
    border: 1px solid rgba(46,204,113,.25);
  }
  .badge-en-cours {
    background: rgba(0,112,221,.07);
    color: #0070dd;
    border: 1px solid rgba(0,112,221,.2);
  }
  .badge-bientot {
    background: rgba(255,128,0,.08);
    color: #ff8000;
    border: 1px solid rgba(255,128,0,.2);
  }
  .badge-idee {
    background: rgba(154,145,137,.08);
    color: var(--ink-soft);
    border: 1px solid var(--rule);
  }
  .outil-titre {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: .6rem;
  }
  .outil-desc {
    font-family: 'Mulish', sans-serif;
    font-size: .85rem;
    font-weight: 300;
    color: var(--ink-mid);
    line-height: 1.7;
    margin-bottom: 1rem;
  }
  .outil-tags {
    display: flex;
    flex-wrap: wrap;
    gap: .4rem;
  }
  .outil-tag {
    font-family: 'Mulish', sans-serif;
    font-size: .65rem;
    font-weight: 300;
    color: var(--ink-soft);
    border: 1px solid var(--rule);
    border-radius: 4px;
    padding: .2rem .5rem;
  }
  .outils-note {
    display: flex;
    align-items: flex-start;
    gap: .75rem;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--rule);
  }
  .note-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
    margin-top: .35rem;
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: .3; }
  }
  .outils-note p {
    font-family: 'Mulish', sans-serif;
    font-size: .82rem;
    font-weight: 300;
    color: var(--ink-soft);
    line-height: 1.7;
    font-style: italic;
  }
</style>
