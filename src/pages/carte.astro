---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');
articles.sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());

const concepts = [
  { id: 'recompense', label: 'Système de récompense', description: 'Comment le cerveau oriente nos comportements vers la survie.', tags: ['dopamine', 'cerveau', 'neurosciences'], color: '#ff8000', statut: 'actif' },
  { id: 'homeostasie', label: 'Homéostasie', description: "L'équilibre comme principe universel — du cerveau au métabolisme.", tags: ['homéostasie', 'bien-être'], color: '#2ecc71', statut: 'actif' },
  { id: 'comportement', label: 'Comportement & Biais', description: 'Les mécanismes invisibles qui pilotent nos décisions.', tags: ['comportement', 'addiction'], color: '#8b5e3c', statut: 'en-cours' },
  { id: 'plasticite', label: 'Neuroplasticité', description: 'La capacité du cerveau à se reconfigurer — apprentissage, habitudes, récupération.', tags: ['neuroplasticité', 'apprentissage'], color: '#457b9d', statut: 'a-venir' },
  { id: 'metabolisme', label: 'Métabolisme & Énergie', description: 'Cétose, jeûne, énergie cellulaire — le carburant qui change tout.', tags: ['cétose', 'jeûne', 'métabolisme'], color: '#9b5de5', statut: 'a-venir' },
];

const recits = articles.filter(a => a.data.format === 'dialogue' || a.data.format === 'recit');

const laboratoire = [
  { id: 'conscience', label: 'Conscience & Émergence', etat: 'actif', branches: ['Qualia et expérience subjective', "Théorie de l'information intégrée (IIT)", 'Conscience comme propriété émergente', 'IA et conscience — frontière floue'] },
  { id: 'chronobio', label: 'Chronobiologie & Rythmes', etat: 'germination', branches: ['Horloge circadienne et dopamine', 'Lumière bleue et désynchronisation', 'Jeûne intermittent et rythmes ultradian'] },
  { id: 'stress', label: 'Stress & Allostasie', etat: 'actif', branches: ["Charge allostatique — quand l'adaptation épuise", 'Cortisol, mémoire, hippocampe', 'Résilience — le rebond neurobiologique', 'Burnout comme effondrement allostasique'] },
  { id: 'epigenetique', label: 'Épigénétique & Environnement', etat: 'germination', branches: ['Méthylation et expression génique', 'Transmission intergénérationnelle du stress', 'Alimentation comme signal épigénétique'] },
  { id: 'cognition', label: 'Cognition incarnée', etat: 'germination', branches: ['Le corps comme organe cognitif', 'Microbiote et axe intestin-cerveau', 'Mouvement, posture et pensée'] },
  { id: 'identite', label: 'Plasticité identitaire', etat: 'pause', branches: ['Le soi comme construction dynamique', 'Habitudes et identité narrative', 'Crises comme catalyseurs de reconfiguration'] },
];

const conceptsActifs = concepts.filter(c => c.statut === 'actif' || c.statut === 'en-cours').length;
const conceptsAvenir = concepts.filter(c => c.statut === 'a-venir').length;
const noeudsActifs   = laboratoire.filter(n => n.etat === 'actif').length;
const totalBranches  = laboratoire.reduce((acc, n) => acc + n.branches.length, 0);
---

<Base title="Carte des idées — Syncognie">
  <Header />
  <div class="page-wrap">

    <header class="page-header">

      <!-- ✦ FILIGRANE CARTE : réseau de nœuds reliés — topographie des idées -->
      <svg class="header-filigrane" viewBox="0 0 420 420" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <!-- Arêtes du graphe — connexions entre concepts -->
        <line x1="210" y1="90"  x2="320" y2="170" stroke="#8b5e3c" stroke-width=".7" opacity=".15" class="edge"/>
        <line x1="210" y1="90"  x2="100" y2="170" stroke="#8b5e3c" stroke-width=".7" opacity=".15" class="edge"/>
        <line x1="320" y1="170" x2="340" y2="290" stroke="#c4993a" stroke-width=".6" opacity=".13" class="edge"/>
        <line x1="100" y1="170" x2="80"  y2="290" stroke="#c4993a" stroke-width=".6" opacity=".13" class="edge"/>
        <line x1="340" y1="290" x2="210" y2="350" stroke="#8b5e3c" stroke-width=".7" opacity=".15" class="edge"/>
        <line x1="80"  y1="290" x2="210" y2="350" stroke="#8b5e3c" stroke-width=".7" opacity=".15" class="edge"/>
        <!-- Connexions transversales -->
        <line x1="210" y1="90"  x2="210" y2="210" stroke="#c4993a" stroke-width=".5" opacity=".12" stroke-dasharray="3 7" class="edge"/>
        <line x1="100" y1="170" x2="340" y2="290" stroke="#8b5e3c" stroke-width=".4" opacity=".1"  stroke-dasharray="2 8" class="edge"/>
        <line x1="320" y1="170" x2="80"  y2="290" stroke="#8b5e3c" stroke-width=".4" opacity=".1"  stroke-dasharray="2 8" class="edge"/>
        <line x1="210" y1="210" x2="340" y2="290" stroke="#c4993a" stroke-width=".4" opacity=".1"  stroke-dasharray="3 7" class="edge"/>
        <line x1="210" y1="210" x2="80"  y2="290" stroke="#c4993a" stroke-width=".4" opacity=".1"  stroke-dasharray="3 7" class="edge"/>
        <line x1="210" y1="210" x2="210" y2="350" stroke="#8b5e3c" stroke-width=".4" opacity=".1"  stroke-dasharray="2 8" class="edge"/>

        <!-- Nœuds principaux -->
        <circle cx="210" cy="90"  r="7"   fill="#c4993a" opacity=".28" class="node-pulse-a"/>
        <circle cx="320" cy="170" r="5.5" fill="#8b5e3c" opacity=".22" class="node-pulse-b"/>
        <circle cx="100" cy="170" r="5.5" fill="#8b5e3c" opacity=".22" class="node-pulse-c"/>
        <circle cx="340" cy="290" r="5"   fill="#c4993a" opacity=".2"  class="node-pulse-b"/>
        <circle cx="80"  cy="290" r="5"   fill="#c4993a" opacity=".2"  class="node-pulse-c"/>
        <circle cx="210" cy="350" r="6"   fill="#8b5e3c" opacity=".25" class="node-pulse-a"/>

        <!-- Nœud central — point de convergence -->
        <circle cx="210" cy="210" r="10"  fill="#c4993a" opacity=".18" class="node-center"/>
        <circle cx="210" cy="210" r="5"   fill="#c4993a" opacity=".32" class="node-center"/>
        <circle cx="210" cy="210" r="2.5" fill="#f5f0e8" opacity=".7"/>
        <circle cx="210" cy="210" r="20"  fill="none" stroke="#c4993a" stroke-width=".6" opacity=".1" class="node-halo"/>

        <!-- Halos sur nœuds secondaires -->
        <circle cx="210" cy="90"  r="13" fill="none" stroke="#c4993a" stroke-width=".5" opacity=".1" class="node-pulse-a"/>
        <circle cx="210" cy="350" r="11" fill="none" stroke="#8b5e3c" stroke-width=".5" opacity=".1" class="node-pulse-b"/>
      </svg>

      <p class="page-eyebrow">Navigation conceptuelle</p>
      <h1 class="page-titre">Carte des idées</h1>
      <p class="page-sous">Un fil conducteur entre les concepts — pas une table des matières, mais une topographie vivante.</p>
      <div class="page-stats">
        <span class="stat"><span class="stat-n">{conceptsActifs}</span><span class="stat-label">concepts actifs</span></span>
        <span class="stat-sep">·</span>
        <span class="stat"><span class="stat-n">{conceptsAvenir}</span><span class="stat-label">à venir</span></span>
        <span class="stat-sep">·</span>
        <span class="stat"><span class="stat-n">{noeudsActifs}</span><span class="stat-label">nœuds actifs</span></span>
        <span class="stat-sep">·</span>
        <span class="stat"><span class="stat-n">{totalBranches}</span><span class="stat-label">pistes ouvertes</span></span>
      </div>
    </header>

    <!-- Séparateur chemin -->
    <div class="ornament-sep">
      <div class="orn-line"></div>
      <div class="orn-centre"><div class="orn-diamond"></div><span class="orn-label">Le Chemin</span><div class="orn-diamond"></div></div>
      <div class="orn-line"></div>
    </div>
    <p class="section-desc">Les concepts explorés, en exploration, et programmés — du plus construit au plus ouvert.</p>

    <!-- Jalons -->
    <div class="chemin-body">
      {concepts.map((concept, i) => {
        const linked = articles.filter(a =>
          a.data.tags?.some((t: string) => concept.tags.includes(t)) &&
          a.data.format !== 'dialogue' && a.data.format !== 'recit'
        );
        const recitsLies = recits.filter(a =>
          a.data.tags?.some((t: string) => concept.tags.includes(t))
        );
        const estGrise = concept.statut === 'a-venir';
        return (
          <div class={`jalon ${estGrise ? 'jalon-avenir' : ''}`}>
            <div class="jalon-line">
              <div class="jalon-dot" style={`background:${estGrise ? 'var(--rule)' : concept.color}`}>
                {concept.statut === 'en-cours' && <div class="jalon-pulse"></div>}
              </div>
              {i < concepts.length - 1 && <div class="jalon-trait"></div>}
            </div>
            <div class="jalon-content">
              <div class="jalon-header-row">
                <p class="jalon-label" style={`color:${estGrise ? 'var(--ink-soft)' : concept.color}`}>{concept.label}</p>
                {concept.statut === 'en-cours' && <span class="jalon-badge badge-encours">En exploration</span>}
                {concept.statut === 'a-venir'  && <span class="jalon-badge badge-avenir">À venir</span>}
              </div>
              <p class="jalon-desc">{concept.description}</p>
              {!estGrise && (
                <div class="jalon-liens">
                  {linked.length > 0 ? (
                    <ul class="jalon-articles">
                      {linked.map(a => (
                        <li><a href={`/articles/${a.slug}`} class="jalon-link"><span class="jalon-arrow">→</span>{a.data.title}</a></li>
                      ))}
                    </ul>
                  ) : <p class="jalon-empty">Articles à venir</p>}
                  {recitsLies.length > 0 && (
                    <ul class="jalon-recits">
                      {recitsLies.map(r => (
                        <li><a href={`/articles/${r.slug}`} class="jalon-recit-link"><span class="recit-icon">◈</span><span class="recit-label">Récit ·</span> {r.data.title}</a></li>
                      ))}
                    </ul>
                  )}
                </div>
              )}
            </div>
          </div>
        );
      })}
    </div>

    <!-- Séparateur laboratoire -->
    <div class="ornament-sep ornament-sep--labo">
      <div class="orn-line"></div>
      <div class="orn-centre orn-centre--labo">
        <div class="orn-diamond"></div>
        <div class="orn-labo-inner">
          <span class="orn-label">Laboratoire de pensée</span>
          <span class="orn-sublabel">En réflexion — peut évoluer, bifurquer, disparaître</span>
        </div>
        <div class="orn-diamond"></div>
      </div>
      <div class="orn-line"></div>
    </div>

    <!-- Nœuds laboratoire -->
    <div class="labo-body">
      {laboratoire.map((noeud) => (
        <div class={`noeud noeud-${noeud.etat}`}>
          <div class="noeud-gauche">
            <div class="noeud-cercle"><div class="noeud-inner"></div></div>
            <div class="noeud-fil"></div>
          </div>
          <div class="noeud-droite">
            <div class="noeud-header">
              <span class="noeud-titre">{noeud.label}</span>
              <span class={`noeud-etat etat-${noeud.etat}`}>
                {noeud.etat === 'actif'      && 'En réflexion active'}
                {noeud.etat === 'germination' && 'Germination'}
                {noeud.etat === 'pause'       && 'En suspens'}
              </span>
            </div>
            <ul class="noeud-branches">
              {noeud.branches.map(b => (
                <li class="branche"><span class="branche-tiret">—</span><span class="branche-texte">{b}</span></li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>

  </div>
  <Footer />
</Base>

<style>
  .page-wrap{max-width:var(--max);margin:0 auto;padding:0 1.75rem 6rem}
  .page-header{padding:4rem 0 2.5rem;position:relative;overflow:visible;opacity:0;animation:rise .9s .05s ease forwards}
  .page-eyebrow{font-family:'Mulish',sans-serif;font-size:.6rem;font-weight:300;letter-spacing:.32em;text-transform:uppercase;color:var(--accent);opacity:.7;margin-bottom:1rem;position:relative;z-index:1}
  .page-titre{font-size:clamp(1.8rem,3.5vw,2.4rem);font-weight:700;color:var(--ink);line-height:1.15;letter-spacing:-.02em;margin-bottom:.9rem;position:relative;z-index:1}
  .page-sous{font-family:'Mulish',sans-serif;font-size:.95rem;font-weight:400;color:var(--ink-soft);line-height:1.8;max-width:52ch;margin-bottom:1.5rem;position:relative;z-index:1}
  .page-stats{display:flex;align-items:baseline;gap:.75rem;flex-wrap:wrap;position:relative;z-index:1}
  .stat{display:flex;align-items:baseline;gap:.35rem}
  .stat-n{font-family:'Libre Baskerville',Georgia,serif;font-size:1.4rem;font-weight:700;color:var(--accent);line-height:1;letter-spacing:-.02em}
  .stat-label{font-family:'Mulish',sans-serif;font-size:.62rem;font-weight:300;letter-spacing:.12em;text-transform:uppercase;color:var(--ink-soft)}
  .stat-sep{color:var(--rule);font-size:.9rem}

  /* ── FILIGRANE RÉSEAU ── */
  .header-filigrane{position:absolute;top:50%;right:-60px;transform:translateY(-50%);width:300px;height:300px;pointer-events:none;z-index:0}
  @media(max-width:600px){.header-filigrane{display:none}}
  .edge{animation:edge-fade 7s ease-in-out infinite}
  .edge:nth-child(2){animation-delay:.8s}
  .edge:nth-child(3){animation-delay:1.6s}
  .edge:nth-child(4){animation-delay:2.4s}
  .edge:nth-child(5){animation-delay:3.2s}
  @keyframes edge-fade{0%,100%{opacity:.13}50%{opacity:.28}}
  .node-pulse-a{animation:np 5s ease-in-out infinite}
  .node-pulse-b{animation:np 5s ease-in-out infinite;animation-delay:1.5s}
  .node-pulse-c{animation:np 5s ease-in-out infinite;animation-delay:3s}
  @keyframes np{0%,100%{opacity:.2}50%{opacity:.48}}
  .node-center{animation:nc 4s ease-in-out infinite}
  @keyframes nc{0%,100%{opacity:.18}50%{opacity:.38}}
  .node-halo{animation:nh 4s ease-in-out infinite}
  @keyframes nh{0%,100%{opacity:.1;r:20}50%{opacity:.22;r:28}}

  /* Séparateurs */
  .ornament-sep{display:flex;align-items:center;gap:1rem;opacity:0;animation:rise .9s .2s ease forwards}
  .ornament-sep--labo{margin:4rem 0 0;animation-delay:.4s}
  .orn-line{flex:1;height:1px;background:linear-gradient(to right,transparent,var(--rule),transparent)}
  .orn-centre{display:flex;align-items:center;gap:.55rem}
  .orn-centre--labo{gap:.55rem}
  .orn-labo-inner{display:flex;flex-direction:column;align-items:center;gap:.2rem}
  .orn-diamond{width:5px;height:5px;background:var(--rule);transform:rotate(45deg);flex-shrink:0}
  .orn-label{font-family:'Mulish',sans-serif;font-size:.58rem;font-weight:700;letter-spacing:.25em;text-transform:uppercase;color:var(--ink-soft);opacity:.45;white-space:nowrap}
  .orn-sublabel{font-family:'Mulish',sans-serif;font-size:.52rem;font-weight:300;font-style:italic;color:var(--ink-soft);opacity:.35;white-space:nowrap}

  .section-desc{font-family:'Mulish',sans-serif;font-size:.85rem;font-weight:400;color:var(--ink-soft);opacity:.7;margin:1rem 0 2.5rem;animation:rise .9s .25s ease forwards}

  /* Jalons */
  .chemin-body{opacity:0;animation:rise .9s .3s ease forwards}
  .jalon{display:flex;gap:1.5rem}
  .jalon-line{display:flex;flex-direction:column;align-items:center;flex-shrink:0;width:20px}
  .jalon-dot{width:12px;height:12px;border-radius:50%;flex-shrink:0;margin-top:.3rem;position:relative;box-shadow:0 0 0 3px var(--bg,#f5f0e8)}
  .jalon-trait{width:1px;flex:1;min-height:2.5rem;background:var(--rule);margin:.4rem 0}
  .jalon-content{padding-bottom:2.5rem;flex:1}
  .jalon-header-row{display:flex;align-items:center;gap:.75rem;margin-bottom:.5rem;flex-wrap:wrap}
  .jalon-label{font-family:'Mulish',sans-serif;font-size:.72rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase}
  .jalon-badge{font-family:'Mulish',sans-serif;font-size:.55rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;padding:.18rem .45rem;border-radius:3px}
  .badge-encours{background:rgba(139,94,60,.07);color:var(--accent);border:1px solid rgba(139,94,60,.2)}
  .badge-avenir{background:rgba(154,145,137,.07);color:var(--ink-soft);border:1px solid var(--rule)}
  .jalon-desc{font-family:'Mulish',sans-serif;font-size:.9rem;font-weight:400;color:var(--ink-mid);line-height:1.7;margin-bottom:.9rem}
  .jalon-liens{display:flex;flex-direction:column;gap:.5rem}
  .jalon-articles{list-style:none;padding:0;display:flex;flex-direction:column;gap:.4rem}
  .jalon-link{display:flex;align-items:baseline;gap:.5rem;font-family:'Mulish',sans-serif;font-size:.85rem;font-weight:300;color:var(--ink-mid);text-decoration:none;transition:color .2s}
  .jalon-link:hover{color:var(--accent)}
  .jalon-arrow{font-size:.7rem;color:var(--accent);opacity:.5;transition:opacity .2s,transform .2s;display:inline-block}
  .jalon-link:hover .jalon-arrow{opacity:1;transform:translateX(3px)}
  .jalon-empty{font-family:'Mulish',sans-serif;font-size:.8rem;font-weight:300;color:var(--ink-soft);font-style:italic;opacity:.55}
  .jalon-recits{list-style:none;padding:0;display:flex;flex-direction:column;gap:.35rem;margin-top:.2rem}
  .jalon-recit-link{display:flex;align-items:baseline;gap:.45rem;font-family:'Mulish',sans-serif;font-size:.8rem;font-weight:300;color:var(--ink-soft);text-decoration:none;transition:color .2s}
  .jalon-recit-link:hover{color:#c4993a}
  .recit-icon{font-size:.68rem;color:#c4993a;opacity:.6;transition:opacity .2s}
  .jalon-recit-link:hover .recit-icon{opacity:1}
  .recit-label{font-weight:600;color:#c4993a;opacity:.65}
  .jalon-avenir{opacity:.38}
  .jalon-pulse{position:absolute;width:20px;height:20px;border-radius:50%;background:currentColor;opacity:.2;animation:ripple 2s ease-out infinite;top:50%;left:50%;transform:translate(-50%,-50%)}
  @keyframes ripple{0%{transform:translate(-50%,-50%) scale(.5);opacity:.3}100%{transform:translate(-50%,-50%) scale(2.5);opacity:0}}

  /* Laboratoire */
  .labo-body{display:flex;flex-direction:column;padding-top:2rem;opacity:0;animation:rise .9s .5s ease forwards}
  .noeud{display:flex;gap:1.25rem}
  .noeud-gauche{display:flex;flex-direction:column;align-items:center;flex-shrink:0;width:20px}
  .noeud-cercle{width:14px;height:14px;border-radius:50%;border:1.5px solid var(--rule);display:flex;align-items:center;justify-content:center;margin-top:.25rem;flex-shrink:0;background:var(--bg,#f5f0e8);transition:border-color .3s}
  .noeud-actif .noeud-cercle{border-color:#a89080}
  .noeud-inner{width:5px;height:5px;border-radius:50%;background:var(--rule);transition:background .3s}
  .noeud-actif .noeud-inner{background:#9e7d65}
  .noeud-fil{width:1px;flex:1;min-height:2rem;background:var(--rule);opacity:.4;margin:.35rem 0}
  .noeud-droite{padding-bottom:2rem;flex:1}
  .noeud-header{display:flex;align-items:center;gap:.75rem;margin-bottom:.6rem;flex-wrap:wrap}
  .noeud-titre{font-family:'Mulish',sans-serif;font-size:.7rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--ink-soft);opacity:.55}
  .noeud-actif .noeud-titre{opacity:.8}
  .noeud-etat{font-family:'Mulish',sans-serif;font-size:.55rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;padding:.18rem .45rem;border-radius:3px}
  .etat-actif{background:rgba(139,94,60,.06);color:var(--accent);border:1px solid rgba(139,94,60,.15);opacity:.75}
  .etat-germination{background:rgba(154,145,137,.06);color:var(--ink-soft);border:1px solid var(--rule);opacity:.6}
  .etat-pause{background:transparent;color:var(--ink-soft);border:1px dashed var(--rule);opacity:.4}
  .noeud-branches{list-style:none;padding:0;display:flex;flex-direction:column;gap:.3rem}
  .branche{display:flex;align-items:baseline;gap:.6rem}
  .branche-tiret{font-size:.65rem;color:var(--ink-soft);opacity:.28;flex-shrink:0;font-family:'Mulish',sans-serif}
  .branche-texte{font-family:'Mulish',sans-serif;font-size:.8rem;font-weight:300;color:var(--ink-soft);opacity:.5;line-height:1.6}
  .noeud-actif .branche-texte{opacity:.7}
  .noeud-pause{opacity:.32}

  @keyframes rise{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
</style>
