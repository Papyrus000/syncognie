---
// src/pages/nouvelles/[slug].astro

import NouvellesLayout from '../../layouts/NouvellesLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('nouvelles', ({ data }) => !data.draft);
  const sorted  = entries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

  return sorted.map((entry, i) => ({
    params: { slug: entry.id },
    props:  {
      entry,
      prev: sorted[i + 1] ?? null,
      next: sorted[i - 1] ?? null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);

function estimateLecture(body: string): number {
  const words = body.trim().split(/\s+/).length;
  return Math.max(1, Math.ceil(words / 180));
}

const readTime = entry.data.lecture ?? estimateLecture(entry.body ?? '');
---

<NouvellesLayout
  title={entry.data.title}
  date={entry.data.date}
  lecture={readTime}
  genre={entry.data.genre}
  stade={entry.data.stade}
  slug={entry.id}
  prev={prev ? { slug: prev.id, title: prev.data.title } : undefined}
  next={next ? { slug: next.id, title: next.data.title } : undefined}
>
  <Content />
</NouvellesLayout>
