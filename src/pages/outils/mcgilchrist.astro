.mcg-synthese.visible { opacity: 1; transform: translateY(0); }

.mcg-synth-inner {
  background: var(--mcg-parch);
  border-radius: 12px; padding: 1.6rem 1.75rem;
  border-left: 3px solid var(--mcg-gold);
}
.mcg-synth-titre {
  font-family: 'Mulish', sans-serif;
  font-size: .55rem; font-weight: 700;
  letter-spacing: .2em; text-transform: uppercase;
  color: var(--mcg-droit-mid); margin-bottom: .8rem;
}
.mcg-synth-texte {
  font-family: 'Mulish', sans-serif;
  font-size: .88rem; font-weight: 300;
  color: var(--ink-mid, #7a7068); line-height: 1.8;
  margin-bottom: .5rem;
}

.mcg-synth-citation {
  margin: 1.2rem 0;
  padding: 1rem 1.2rem;
  background: white; border-radius: 8px;
  border-left: 3px solid var(--mcg-gold);
}
.mcg-synth-cit-texte {
  font-family: 'Libre Baskerville', serif;
  font-size: .92rem; font-style: italic;
  color: var(--ink, #1a1714); line-height: 1.6;
  margin-bottom: .4rem;
}
.mcg-synth-cit-source {
  font-family: 'Mulish', sans-serif;
  font-size: .62rem; font-weight: 600;
  letter-spacing: .1em;
  color: var(--ink-soft, #9a9189);
}

.mcg-synth-liens-label {
  font-family: 'Mulish', sans-serif;
  font-size: .55rem; font-weight: 700;
  letter-spacing: .2em; text-transform: uppercase;
  color: var(--ink-soft, #9a9189); margin-bottom: .6rem;
  margin-top: 1.2rem;
}
.mcg-synth-liens-grille { display: flex; gap: .55rem; flex-wrap: wrap; }
.mcg-synth-lien {
  display: inline-flex; align-items: center; gap: .4rem;
  font-family: 'Mulish', sans-serif;
  font-size: .7rem; font-weight: 600;
  color: var(--accent, #c4993a); text-decoration: none;
  background: white; border: 1px solid rgba(196,153,58,.28);
  border-radius: 5px; padding: .4rem .75rem;
  transition: all .18s;
}
.mcg-synth-lien:hover {
  background: rgba(196,153,58,.06);
  border-color: rgba(196,153,58,.5);
  transform: translateY(-1px);
}
.mcg-synth-lien--article {
  background: rgba(92,58,30,.05);
  border-color: rgba(92,58,30,.25);
  color: var(--mcg-droit-mid);
}
.mcg-synth-lien--article:hover {
  background: rgba(92,58,30,.1);
  border-color: rgba(92,58,30,.45);
}
.mcg-sl-icon { opacity: .6; }

/* ══ NOTE BAS ══ */
.mcg-note-bas {
  display: flex; align-items: flex-start; gap: .75rem;
  margin-top: 3rem; padding-top: 2rem;
  border-top: 1px solid var(--rule, #ddd6c8);
  opacity: 0; animation: rise .9s .6s ease forwards;
}
.mcg-note-bas p {
  font-family: 'Mulish', sans-serif;
  font-size: .82rem; font-weight: 300;
  color: var(--ink-soft, #9a9189);
  line-height: 1.7; font-style: italic;
}

/* ══ MOMENT DE SILENCE ══ */
.mcg-silence {
  display: flex; flex-direction: column; align-items: center;
  justify-content: center;
  min-height: 260px;
  padding: 3rem 0;
  text-align: center;
}
.mcg-silence-mot {
  font-family: 'Libre Baskerville', serif;
  font-size: clamp(3rem, 8vw, 5.5rem);
  font-weight: 400; font-style: italic;
  color: var(--ink, #1a1714);
  letter-spacing: -.02em; line-height: 1;
  margin-bottom: 2.5rem;
  opacity: 0;
  animation: mcg-mot-apparait 1.2s ease forwards;
}
@keyframes mcg-mot-apparait {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}
.mcg-silence-sous {
  font-family: 'Mulish', sans-serif;
  font-size: .75rem; font-weight: 300;
  letter-spacing: .18em; text-transform: uppercase;
  color: var(--ink-faint, #9a9189);
  min-height: 1.5rem;
  transition: opacity .6s ease;
}

/* ══ PHRASE-SEUIL ══ */
.mcg-seuil {
  display: flex; flex-direction: column;
  align-items: center; text-align: center;
  padding: 1rem 0;
}
.mcg-seuil--inter {
  margin-top: 1rem;
}
.mcg-seuil-espace { height: 3.5rem; }
.mcg-seuil-texte {
  font-family: 'Libre Baskerville', serif;
  font-size: clamp(1.6rem, 4vw, 2.2rem);
  font-weight: 400; line-height: 1.35;
  color: var(--ink, #1a1714);
  max-width: 18ch;
  opacity: 0;
  animation: mcg-seuil-in 1s ease forwards;
}
.mcg-seuil-texte em { font-style: italic; color: var(--mcg-droit, #5c3a1e); }
@keyframes mcg-seuil-in {
  from { opacity: 0; transform: translateY(10px); }
  to   { opacity: 1; transform: translateY(0); }
}
.mcg-seuil-sous {
  font-family: 'Mulish', sans-serif;
  font-size: .78rem; font-weight: 300; font-style: italic;
  color: var(--ink-soft, #9a9189); line-height: 1.7;
  max-width: 42ch; min-height: 2rem;
  margin-top: 1.4rem;
  transition: opacity .6s ease;
  opacity: 0;
}
.mcg-seuil-sous.visible { opacity: 1; }
.mcg-seuil-btn {
  margin-top: 1.8rem !important;
  transition: opacity .4s ease, transform .4s ease !important;
}
.mcg-seuil-btn.hidden {
  opacity: 0 !important; pointer-events: none;
  transform: translateY(6px);
}
.mcg-seuil-btn:not(.hidden) {
  opacity: 1 !important; pointer-events: auto;
  transform: translateY(0);
}

/* ══ CITATION GRANDE ══ */
.mcg-synth-citation-grande {
  margin: 2rem -1.75rem;
  padding: 3.5rem 2.5rem;
  background: var(--ink, #1a1714);
  text-align: center;
  position: relative;
}
.mcg-synth-citation-grande::before {
  content: '«';
  position: absolute; top: 1.5rem; left: 2rem;
  font-family: 'Libre Baskerville', serif;
  font-size: 5rem; line-height: 1;
  color: var(--mcg-gold, #c4993a); opacity: .15;
  pointer-events: none;
}
.mcg-scg-texte {
  font-family: 'Libre Baskerville', serif;
  font-size: clamp(1.1rem, 2.8vw, 1.6rem);
  font-weight: 400; font-style: italic;
  color: rgba(245,240,232,.88);
  line-height: 1.65; margin-bottom: 1.2rem;
}
.mcg-scg-source {
  font-family: 'Mulish', sans-serif;
  font-size: .7rem; font-weight: 600;
  letter-spacing: .18em; text-transform: uppercase;
  color: var(--mcg-gold, #c4993a); opacity: .7;
}

/* ══ RESPIRATION ENTRE ACTES ══ */
.mcg-acte { padding-bottom: 1.5rem; }
.mcg-acte-label { margin-bottom: 2rem; padding-bottom: 1rem; }

/* ══ RESPONSIVE seuil ══ */
@media (max-width: 580px) {
  .mcg-synth-citation-grande { margin: 2rem -1rem; padding: 2.5rem 1.5rem; }
  .mcg-seuil-espace { height: 2rem; }
}
@media (max-width: 580px) {
  .mcg-wrap { padding: 0 1rem 4rem; }
  .mcg-rev-split    { grid-template-columns: 1fr; }
  .mcg-duel         { grid-template-columns: 1fr; }
  .mcg-duel-sep     { flex-direction: row; padding: .2rem 0; }
  .mcg-duel-sep-line{ flex: 1; height: 1px; width: auto; }
  .mcg-duel-gauche  { border-radius: 10px 10px 0 0; border-top: 3px solid var(--mcg-gauche); }
  .mcg-duel-droit   { border-radius: 0 0 10px 10px; }
  .mcg-frise-contenu{ grid-template-columns: 1fr; }
  .mcg-fi-gain      { border-right: none; border-bottom: 1px solid var(--rule); }
  .mcg-choix-grille { grid-template-columns: 1fr; }
  .mcg-sit-split    { grid-template-columns: 1fr; }
  .mcg-sit-g        { border-right: none; border-bottom: 1px solid var(--rule); }
}
</style>

<script>
  // ── PROGRESSION ──
  let acteActuel = 0;
  const totalActes = 4;

  function updateProgress(acte) {
    const fill = document.getElementById('mcg-prog-fill');
    if (fill) fill.style.width = ((acte / (totalActes - 1)) * 100) + '%';
    document.querySelectorAll('.mcg-prog-acte').forEach((el, i) => {
      el.classList.toggle('active', i === acte);
      el.classList.toggle('done', i < acte);
    });
  }

  function showActe(n) {
    document.querySelectorAll('.mcg-acte').forEach((el, i) => {
      if (i === n) {
        el.classList.remove('hidden');
        el.style.animation = 'none';
        void el.offsetWidth;
        el.style.animation = '';
      } else {
        el.classList.add('hidden');
      }
    });
    acteActuel = n;
    updateProgress(n);
    window.scrollTo({ top: document.getElementById('mcg-progress')?.offsetTop - 80 || 0, behavior: 'smooth' });
  }

  // ── ACTE I — choix mot oiseau ──
  function showStep(acte, step) {
    const id = `step-${acte}-${step}`;
    document.querySelectorAll(`#acte-${acte} .mcg-step`).forEach(el => {
      el.classList.toggle('hidden', el.id !== id);
    });
  }

  // Après le choix oiseau → silence d'abord
  document.querySelectorAll('#choix-oiseau .mcg-choix').forEach(btn => {
    btn.addEventListener('click', () => {
      showStep(0, 1);
      // Silence : le mot apparaît seul. Après 2s, une phrase apparaît.
      // Après 4s, transition vers la révélation.
      const sous = document.getElementById('silence-sous');
      setTimeout(() => {
        if (sous) { sous.textContent = 'votre cerveau vient de faire deux choses en même temps'; }
      }, 2200);
      setTimeout(() => { showStep(0, '1b'); }, 4200);
    });
  });

  document.getElementById('suite-0-1')?.addEventListener('click', () => showStep(0, 2));

  document.querySelectorAll('#choix-main .mcg-choix').forEach(btn => {
    btn.addEventListener('click', () => {
      showStep(0, 3);
      // Seuil : la phrase est là. Après 2.5s, la note apparaît. Après 4.5s, le bouton.
      const sousSeuil = document.getElementById('seuil-sous-01');
      const btnSeuil  = document.getElementById('seuil-btn-01');
      setTimeout(() => {
        if (sousSeuil) {
          sousSeuil.textContent = "Ce n'est pas une métaphore. C'est la thèse d'Iain McGilchrist — neurologue, philosophe, auteur de The Master and His Emissary.";
          sousSeuil.classList.add('visible');
        }
      }, 2600);
      setTimeout(() => {
        if (btnSeuil) btnSeuil.classList.remove('hidden');
      }, 4600);
    });
  });

  // ── SUITE acte suivant (boutons directs) ──
  document.querySelectorAll('.mcg-suite--acte:not(.mcg-seuil-btn)').forEach(btn => {
    btn.addEventListener('click', () => {
      const next = parseInt(btn.dataset.nextActe);
      // Afficher le seuil inter si existant, sinon aller directement
      const seuilId = `seuil-vers-${next + 1}`;
      const seuilEl = document.getElementById(seuilId);
      if (seuilEl && !seuilEl.classList.contains('hidden-perm')) {
        // Cacher le bouton, montrer le seuil dans l'acte courant
        btn.style.display = 'none';
        seuilEl.classList.remove('hidden');
        // Déclencher les sous-éléments du seuil
        const idx = next === 2 ? '02' : '03';
        const sousSeuil = document.getElementById(`seuil-sous-${idx}`);
        const btnSeuil  = document.getElementById(`seuil-btn-${idx}`);
        setTimeout(() => {
          if (sousSeuil) {
            sousSeuil.textContent = next === 2
              ? "McGilchrist s'intéresse à quelque chose de plus grand : comment ce déséquilibre a façonné l'histoire de la civilisation occidentale."
              : "Pas dans les livres. Dans votre dispute d'hier, votre décision de ce matin.";
            sousSeuil.classList.add('visible');
          }
        }, 2400);
        setTimeout(() => {
          if (btnSeuil) btnSeuil.classList.remove('hidden');
        }, 4200);
      } else {
        showActe(next);
      }
    });
  });

  // ── Boutons seuil inter ──
  document.querySelectorAll('.mcg-seuil-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const next = parseInt(btn.dataset.nextActe);
      showActe(next);
    });
  });

  // ── ACTE IV — situations accordéon ──
  document.querySelectorAll('.mcg-sit-header').forEach(header => {
    header.addEventListener('click', () => {
      const sit = header.closest('.mcg-sit');
      const wasOpen = sit.classList.contains('open');
      document.querySelectorAll('.mcg-sit').forEach(s => s.classList.remove('open'));
      if (!wasOpen) {
        sit.classList.add('open');
        // révéler synthèse après ouverture de la dernière
        const allSits = document.querySelectorAll('.mcg-sit');
        const lastSit = allSits[allSits.length - 1];
        if (sit === lastSit) {
          setTimeout(() => {
            const synth = document.getElementById('mcg-synthese');
            if (synth) synth.classList.add('visible');
          }, 500);
        }
      }
    });
    header.addEventListener('keydown', e => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); header.click(); }
    });
  });

  // Init
  updateProgress(0);
</script>
