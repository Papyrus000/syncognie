let domaineActif = 'mathematiques';

// ── RENDU GRILLE ─────────────────────────────
function renderGrille() {
  const modeles = MODELES.filter(m => m.domaine_principal === domaineActif);
  document.getElementById('bep-domaine-nom').textContent = DOMAINES_LABELS[domaineActif] || domaineActif;
  document.getElementById('bep-domaine-count').textContent = pluriel(modeles.length,'modèle','modèles');
  const grille = document.getElementById('bep-grille');
  grille.innerHTML = modeles.map((m, i) => `
    <button class="bep-carte" data-id="${m.id}" style="animation-delay:${i*0.07}s">
      <div class="bep-carte-bord"></div>
      <div class="bep-carte-corps">
        <div class="bep-carte-top">
          <span class="bep-carte-auteur">${m.auteur}</span>
          <span class="bep-carte-annee">${m.annee}</span>
        </div>
        <h3 class="bep-carte-nom">${m.nom}</h3>
        <p class="bep-carte-resume">${m.resume}</p>
        <div class="bep-carte-indics">
          <div class="bep-indic"><span class="bep-indic-dot" style="background:#2e7d4e"></span><span class="bep-indic-label">${pluriel(m.territoire.length,'territoire','territoires')}</span></div>
          <div class="bep-indic"><span class="bep-indic-dot" style="background:#c4993a"></span><span class="bep-indic-label">${pluriel(m.limites.length,'limite','limites')}</span></div>
          <div class="bep-indic"><span class="bep-indic-dot" style="background:#8b3a2a"></span><span class="bep-indic-label">${pluriel(m.zones_risquees.length,'risque','risques')}</span></div>
        </div>
      </div>
    </button>
  `).join('');
  grille.querySelectorAll('.bep-carte').forEach(btn => {
    btn.addEventListener('click', () => { const m = MODELES.find(x => x.id === btn.dataset.id); if(m) ouvrirDetail(m); });
  });
}

// ── RENDU DÉTAIL ─────────────────────────────
function buildConnexions(m) {
  let html = '';
  if (m.connexions.complementaires.length) {
    html += `<div class="bep-conn-groupe"><p class="bep-conn-titre"><span class="bep-conn-puce" style="background:#2e7d4e"></span>Modèles complémentaires</p><div class="bep-conn-grille">`;
    m.connexions.complementaires.forEach(id => {
      const rel = MODELES.find(x => x.id === id); if(!rel) return;
      const syn = m.connexions.synergie?.find(s => s.avec === id);
      html += `<div class="bep-conn-card"><div class="bep-conn-card-top"><span class="bep-conn-nom">${rel.nom}</span><button class="bep-conn-lien" data-nav="${id}">${rel.auteur} →</button></div>${syn?`<p class="bep-conn-synergie">${syn.texte}</p>`:''}</div>`;
    });
    html += `</div></div>`;
  }
  if (m.connexions.contradictoires.length) {
    html += `<div class="bep-conn-groupe"><p class="bep-conn-titre"><span class="bep-conn-puce" style="background:#8b3a2a"></span>Modèles en tension</p><div class="bep-conn-grille">`;
    m.connexions.contradictoires.forEach(id => {
      const rel = MODELES.find(x => x.id === id); if(!rel) return;
      html += `<div class="bep-conn-card bep-conn-card--tension"><div class="bep-conn-card-top"><span class="bep-conn-nom">${rel.nom}</span><button class="bep-conn-lien" data-nav="${id}">${rel.auteur} →</button></div></div>`;
    });
    html += `</div></div>`;
  }
  if (m.domaines_secondaires.length) {
    html += `<div class="bep-conn-groupe"><p class="bep-conn-titre"><span class="bep-conn-puce" style="background:#c4993a"></span>Domaines secondaires touchés</p><div class="bep-doms-sec">${m.domaines_secondaires.map(d=>`<span class="bep-dom-badge">${DOMAINES_LABELS[d]||d}</span>`).join('')}</div></div>`;
  }
  return html || '<p style="font-size:.85rem;color:rgba(26,23,20,.4);font-style:italic">Aucune connexion recensée pour l\'instant.</p>';
}

function renderDetail(m) {
  const domLabel = DOMAINES_LABELS[m.domaine_principal] || m.domaine_principal;
  document.getElementById('bep-detail-contenu').innerHTML = `
    <div class="bep-detail-badge">${domLabel}</div>
    <h2 class="bep-detail-nom">${m.nom}</h2>
    <p class="bep-detail-auteur">${m.auteur} · ${m.annee}</p>
    <p class="bep-detail-resume">${m.resume}</p>
    <div class="bep-detail-indics">
      <div class="bep-detail-indic"><span class="bep-detail-indic-dot" style="background:#2e7d4e"></span><span class="bep-detail-indic-label">${pluriel(m.territoire.length,'territoire','territoires')}</span></div>
      <div class="bep-detail-indic"><span class="bep-detail-indic-dot" style="background:#c4993a"></span><span class="bep-detail-indic-label">${pluriel(m.limites.length,'limite','limites')}</span></div>
      <div class="bep-detail-indic"><span class="bep-detail-indic-dot" style="background:#8b3a2a"></span><span class="bep-detail-indic-label">${pluriel(m.zones_risquees.length,'zone risquée','zones risquées')}</span></div>
    </div>
    <div class="bep-onglets" id="bep-onglets">
      <button class="bep-onglet active" data-onglet="territoire" style="border-bottom-color:#2e7d4e;color:#2e7d4e">Territoire</button>
      <button class="bep-onglet" data-onglet="limites">Limites</button>
      <button class="bep-onglet" data-onglet="risques">Zones risquées</button>
      <button class="bep-onglet" data-onglet="connexions">Connexions</button>
    </div>
    <div id="bep-panneau-territoire" class="bep-panneau"><div class="bep-panneau-filet" style="background:#2e7d4e"></div><ul class="bep-liste">${m.territoire.map(t=>`<li class="bep-liste-item"><span class="bep-liste-puce" style="background:#2e7d4e"></span><span>${t}</span></li>`).join('')}</ul></div>
    <div id="bep-panneau-limites" class="bep-panneau bep-hidden"><div class="bep-panneau-filet" style="background:#c4993a"></div><ul class="bep-liste">${m.limites.map(t=>`<li class="bep-liste-item"><span class="bep-liste-puce" style="background:#c4993a"></span><span>${t}</span></li>`).join('')}</ul></div>
    <div id="bep-panneau-risques" class="bep-panneau bep-hidden"><div class="bep-panneau-filet" style="background:#8b3a2a"></div><ul class="bep-liste">${m.zones_risquees.map(t=>`<li class="bep-liste-item"><span class="bep-liste-puce" style="background:#8b3a2a"></span><span>${t}</span></li>`).join('')}</ul></div>
    <div id="bep-panneau-connexions" class="bep-panneau bep-hidden"><div class="bep-panneau-filet" style="background:#1a1714"></div>${buildConnexions(m)}</div>
  `;
  const couleurs = {territoire:'#2e7d4e',limites:'#c4993a',risques:'#8b3a2a',connexions:'#1a1714'};
  document.getElementById('bep-onglets').querySelectorAll('.bep-onglet').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('#bep-onglets .bep-onglet').forEach(b => { b.classList.remove('active'); b.style.borderBottomColor='transparent'; b.style.color=''; });
      btn.classList.add('active'); btn.style.borderBottomColor=couleurs[btn.dataset.onglet]; btn.style.color=couleurs[btn.dataset.onglet];
      ['territoire','limites','risques','connexions'].forEach(p => document.getElementById('bep-panneau-'+p).classList.toggle('bep-hidden', p !== btn.dataset.onglet));
    });
  });
  document.getElementById('bep-detail-contenu').querySelectorAll('.bep-conn-lien[data-nav]').forEach(btn => {
    btn.addEventListener('click', () => naviguerVers(btn.dataset.nav));
  });
}

function ouvrirDetail(m) {
  renderDetail(m);
  setVue('detail');
  document.getElementById('bep-vue-detail').scrollIntoView({behavior:'smooth',block:'start'});
}

function naviguerVers(id) {
  const m = MODELES.find(x => x.id === id); if(!m) return;
  domaineActif = m.domaine_principal;
  document.querySelectorAll('.bep-nav-item[data-domaine]').forEach(el => el.classList.toggle('active', el.dataset.domaine === domaineActif));
  renderGrille();
  ouvrirDetail(m);
}

// ── RÉSULTATS ────────────────────────────────
function renderResultats(res) {
  const el = document.getElementById('bep-question-resultat');
  if (!res || (!res.utiles.length && !res.eviter.length)) {
    el.innerHTML = `<div class="bep-resultat"><p class="bep-resultat-note">${res?.note||'Aucun résultat.'}</p></div>`;
    el.classList.remove('bep-hidden'); return;
  }
  const carteHtml = (item, eviter) => {
    const m = MODELES.find(x => x.id === item.id); if(!m) return '';
    return `<div class="bep-res-card ${eviter?'bep-res-card--eviter':''}" data-nav="${m.id}">
      <div class="bep-res-card-top"><span class="bep-res-nom">${m.nom}</span><span class="bep-res-auteur">${m.auteur}</span></div>
      <p class="bep-res-raison">${item.raison}</p>
      <span class="bep-res-lien">${eviter?'Voir ses zones risquées →':'Voir le détail →'}</span>
    </div>`;
  };
  el.innerHTML = `<div class="bep-resultat">
    ${res.note?`<p class="bep-resultat-note">${res.note}</p>`:''}
    ${res.utiles.length?`<div class="bep-resultat-section"><p class="bep-resultat-titre"><span class="bep-res-puce" style="background:#2e7d4e"></span>Modèles à mobiliser</p><div class="bep-res-grille">${res.utiles.map(i=>carteHtml(i,false)).join('')}</div></div>`:''}
    ${res.eviter.length?`<div class="bep-resultat-section"><p class="bep-resultat-titre"><span class="bep-res-puce" style="background:#8b3a2a"></span>Utiliser avec précaution</p><div class="bep-res-grille">${res.eviter.map(i=>carteHtml(i,true)).join('')}</div></div>`:''}
  </div>`;
  el.classList.remove('bep-hidden');
  el.querySelectorAll('.bep-res-card[data-nav]').forEach(card => card.addEventListener('click', () => naviguerVers(card.dataset.nav)));
}

// ── VUES ─────────────────────────────────────
function setVue(vue) {
  document.getElementById('bep-vue-grille').classList.toggle('bep-hidden', vue !== 'grille');
  document.getElementById('bep-vue-detail').classList.toggle('bep-hidden', vue !== 'detail');
  document.getElementById('bep-vue-question').classList.toggle('bep-hidden', vue !== 'question');
}

// ── EVENTS ───────────────────────────────────
document.querySelectorAll('.bep-nav-item[data-domaine]').forEach(btn => {
  btn.addEventListener('click', () => {
    domaineActif = btn.dataset.domaine;
    document.querySelectorAll('.bep-nav-item[data-domaine]').forEach(el => el.classList.remove('active'));
    btn.classList.add('active');
    renderGrille(); setVue('grille');
  });
});

document.getElementById('bep-retour').addEventListener('click', () => { renderGrille(); setVue('grille'); });
document.getElementById('bep-retour-question').addEventListener('click', () => setVue('grille'));
document.getElementById('bep-question-toggle').addEventListener('click', () => setVue('question'));

document.querySelectorAll('.bep-theme').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.bep-theme').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('bep-question-input').value = '';
    renderResultats(THEMES[btn.dataset.theme]);
  });
});

document.getElementById('bep-question-submit').addEventListener('click', () => {
  const texte = document.getElementById('bep-question-input').value.trim();
  if (!texte) return;
  document.querySelectorAll('.bep-theme').forEach(b => b.classList.remove('active'));
  renderResultats(suggererLibre(texte));
});

document.getElementById('bep-question-input').addEventListener('keydown', e => {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); document.getElementById('bep-question-submit').click(); }
});

// ── INIT ─────────────────────────────────────
updateCompteur();
renderGrille();
setVue('grille');
</script>

</Base>
