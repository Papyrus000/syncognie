---
import Base from '../../layouts/Base.astro';
---
<Base
  title="La Boussole épistémique — Syncognie"
  description="Naviguer entre les modèles de pensée selon la question qu'on se pose. Leurs territoires, leurs limites, leurs angles morts."
>

<div class="bep-wrap">

  <!-- BREADCRUMB -->
  <nav class="bep-breadcrumb">
    <a href="/outils" class="bep-back">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
        <path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Tous les outils
    </a>
    <span class="bep-bread-sep">·</span>
    <span class="bep-bread-current">La Boussole épistémique</span>
  </nav>

  <!-- HEADER -->
  <div class="bep-header">
    <p class="bep-surtitre">Outil · Épistémologie</p>
    <h1 class="bep-titre">La <em>Boussole</em> épistémique</h1>
    <p class="bep-sous">Chaque modèle de pensée répond à certaines questions et reste aveugle à d'autres. La compétence clé n'est pas de maîtriser un modèle — c'est de savoir naviguer entre eux.</p>
    <div class="bep-meta">
      <span class="bep-version">v0.2</span>
      <span class="bep-meta-sep">·</span>
      <span class="bep-metainfo" id="bep-compteur">— modèles · — domaines</span>
    </div>
  </div>

  <!-- INTERFACE -->
  <div class="bep-interface">

    <!-- COLONNE DOMAINES -->
    <nav class="bep-nav" id="bep-nav">
      <p class="bep-nav-label">Domaines</p>
      <button class="bep-nav-item active" data-domaine="mathematiques">Mathématiques</button>
      <button class="bep-nav-item" data-domaine="physique">Physique</button>
      <button class="bep-nav-item" data-domaine="biologie">Biologie</button>
      <button class="bep-nav-item" data-domaine="neurosciences">Neurosciences cognitives</button>
      <button class="bep-nav-item" data-domaine="psychologie">Psychologie</button>
      <button class="bep-nav-item" data-domaine="linguistique">Linguistique · Sémiotique</button>
      <button class="bep-nav-item" data-domaine="epistemologie">Épistémologie</button>
      <button class="bep-nav-item" data-domaine="philosophie">Philosophie</button>
      <button class="bep-nav-item" data-domaine="ethique">Éthique</button>
      <button class="bep-nav-item" data-domaine="anthropologie">Anthropologie</button>
      <button class="bep-nav-item" data-domaine="cybernetique">Cybernétique · Systèmes</button>
      <button class="bep-nav-item" data-domaine="sciences_sociales">Sciences sociales</button>
      <button class="bep-nav-item" data-domaine="economie">Économie</button>
      <button class="bep-nav-item" data-domaine="histoire">Histoire</button>

      <div class="bep-nav-question-btn-wrap">
        <button class="bep-question-toggle" id="bep-question-toggle">
          Quelle question<br>je me pose ?
        </button>
      </div>
    </nav>

    <!-- ZONE -->
    <div class="bep-zone">

      <div id="bep-vue-grille">
        <div class="bep-domaine-header">
          <h2 class="bep-domaine-nom" id="bep-domaine-nom">Mathématiques</h2>
          <span class="bep-domaine-count" id="bep-domaine-count"></span>
        </div>
        <div class="bep-grille" id="bep-grille"></div>
      </div>

      <div id="bep-vue-detail" class="bep-hidden">
        <button class="bep-retour" id="bep-retour">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
            <path d="M8 2L4 6l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Retour aux modèles
        </button>
        <div id="bep-detail-contenu"></div>
      </div>

      <div id="bep-vue-question" class="bep-hidden">
        <button class="bep-retour" id="bep-retour-question">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
            <path d="M8 2L4 6l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Retour à la navigation
        </button>
        <div class="bep-question-zone">
          <h2 class="bep-question-titre">Quelle question je me pose ?</h2>
          <p class="bep-question-sous">Décrivez votre situation ou choisissez un thème. L'outil identifie les modèles pertinents — et ceux à utiliser avec précaution.</p>
          <div class="bep-themes">
            <p class="bep-themes-label">Thèmes</p>
            <div class="bep-themes-grille">
              <button class="bep-theme" data-theme="decision">Prendre une décision</button>
              <button class="bep-theme" data-theme="changement">Comprendre un changement</button>
              <button class="bep-theme" data-theme="limite">Atteindre une limite</button>
              <button class="bep-theme" data-theme="conflit">Naviguer un conflit</button>
              <button class="bep-theme" data-theme="connaissance">Acquérir une connaissance</button>
              <button class="bep-theme" data-theme="apprendre">Apprendre et transmettre</button>
              <button class="bep-theme" data-theme="systeme">Analyser un système</button>
              <button class="bep-theme" data-theme="institution">Comprendre une institution</button>
              <button class="bep-theme" data-theme="valeur">Questionner une valeur</button>
            </div>
          </div>
          <p class="bep-ou">Ou décrivez librement</p>
          <textarea class="bep-question-input" id="bep-question-input"
            placeholder="Ex : Je dois prendre une décision importante sous incertitude…" rows="3"></textarea>
          <button class="bep-question-submit" id="bep-question-submit">
            Trouver les modèles pertinents →
          </button>
          <div id="bep-question-resultat" class="bep-hidden"></div>
        </div>
      </div>

    </div>
  </div>

  <!-- NOTE META -->
  <div class="bep-meta-note">
    <p class="bep-meta-note-texte">Cette boussole est elle-même une carte. Elle a ses domaines d'origine, ses limites, ses angles morts.</p>
    <p class="bep-meta-note-citation">La carte n'est pas le territoire — Korzybski</p>
  </div>

</div>

<style is:global>
  .bep-wrap { max-width:var(--max,740px); margin:0 auto; padding:0 1.75rem 5rem; font-family:'Mulish',sans-serif; color:var(--ink,#1a1714); }
  .bep-hidden { display:none !important; }

  .bep-breadcrumb { display:flex; align-items:center; gap:.5rem; padding:1.5rem 0 0; }
  .bep-back { display:inline-flex; align-items:center; gap:.35rem; font-size:.72rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:var(--ink-soft,#9a9189); text-decoration:none; transition:color .15s; }
  .bep-back:hover { color:var(--ink,#1a1714); }
  .bep-bread-sep { font-size:.7rem; color:var(--rule,#ddd6c8); }
  .bep-bread-current { font-size:.72rem; font-weight:600; letter-spacing:.06em; color:var(--ink-soft,#9a9189); opacity:.65; }

  .bep-header { padding:2.5rem 0 2rem; border-bottom:1px solid var(--rule,#ddd6c8); margin-bottom:2rem; }
  .bep-surtitre { font-size:.7rem; font-weight:700; letter-spacing:.2em; text-transform:uppercase; color:#c4993a; margin-bottom:.5rem; }
  .bep-titre { font-family:'Libre Baskerville',serif; font-size:clamp(2rem,5vw,3rem); font-weight:400; line-height:1.15; margin-bottom:.8rem; }
  .bep-titre em { font-style:italic; }
  .bep-sous { font-family:'Libre Baskerville',serif; font-size:1rem; font-style:italic; color:rgba(26,23,20,.7); line-height:1.6; max-width:600px; margin-bottom:1.2rem; }
  .bep-meta { display:flex; align-items:center; gap:.6rem; }
  .bep-version { font-size:.65rem; font-weight:700; letter-spacing:.15em; text-transform:uppercase; color:#c4993a; border:1px solid #c4993a; border-radius:2px; padding:.15rem .4rem; }
  .bep-meta-sep { color:var(--rule,#ddd6c8); }
  .bep-metainfo { font-size:.72rem; font-weight:600; letter-spacing:.08em; text-transform:uppercase; color:rgba(26,23,20,.4); }

  .bep-interface { display:grid; grid-template-columns:200px 1fr; gap:3rem; align-items:start; }

  .bep-nav { position:sticky; top:80px; }
  .bep-nav-label { font-size:.6rem; font-weight:700; letter-spacing:.22em; text-transform:uppercase; color:rgba(26,23,20,.35); margin-bottom:.6rem; margin-top:0; }
  .bep-nav-item { display:block; width:100%; text-align:left; background:none; border:none; border-left:2px solid transparent; padding:.35rem .75rem; font-family:'Mulish',sans-serif; font-size:.76rem; font-weight:600; color:rgba(26,23,20,.6); cursor:pointer; letter-spacing:.02em; margin-bottom:.05rem; transition:all .12s; border-radius:0 2px 2px 0; }
  .bep-nav-item:hover { color:var(--ink,#1a1714); }
  .bep-nav-item.active { border-left-color:#c4993a; color:var(--ink,#1a1714); background:rgba(196,153,58,.07); }
  .bep-nav-question-btn-wrap { margin-top:1.5rem; }
  .bep-question-toggle { display:block; width:100%; font-family:'Mulish',sans-serif; font-size:.65rem; font-weight:700; letter-spacing:.08em; text-transform:uppercase; color:var(--ink,#1a1714); background:none; border:1px solid var(--rule,#ddd6c8); border-radius:3px; padding:.5rem .75rem; cursor:pointer; transition:all .15s; text-align:left; line-height:1.5; }
  .bep-question-toggle:hover { border-color:#c4993a; color:#c4993a; background:rgba(196,153,58,.05); }

  .bep-zone { min-height:400px; }

  .bep-domaine-header { display:flex; align-items:baseline; gap:.8rem; margin-bottom:1.5rem; padding-bottom:1rem; border-bottom:1px solid var(--rule,#ddd6c8); }
  .bep-domaine-nom { font-family:'Libre Baskerville',serif; font-size:1.3rem; font-weight:400; color:var(--ink,#1a1714); margin:0; }
  .bep-domaine-count { font-size:.68rem; font-weight:600; letter-spacing:.12em; text-transform:uppercase; color:rgba(26,23,20,.4); }

  .bep-grille { display:grid; grid-template-columns:repeat(auto-fill,minmax(230px,1fr)); gap:1rem; }

  .bep-carte { display:flex; background:rgba(255,255,255,.4); border:1px solid var(--rule,#ddd6c8); border-radius:4px; cursor:pointer; text-align:left; overflow:hidden; transition:all .15s; animation:bep-rise .4s ease both; padding:0; font-family:'Mulish',sans-serif; width:100%; }
  .bep-carte:hover { background:rgba(255,255,255,.7); transform:translateY(-2px); box-shadow:0 4px 16px rgba(26,23,20,.08); }
  .bep-carte-bord { width:3px; background:#c4993a; flex-shrink:0; }
  .bep-carte-corps { padding:1rem 1rem .9rem; flex:1; }
  .bep-carte-top { display:flex; justify-content:space-between; align-items:center; margin-bottom:.5rem; }
  .bep-carte-auteur { font-size:.65rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:rgba(26,23,20,.45); }
  .bep-carte-annee { font-size:.62rem; color:rgba(26,23,20,.3); font-weight:600; }
  .bep-carte-nom { font-family:'Libre Baskerville',serif; font-size:.9rem; font-weight:700; color:var(--ink,#1a1714); margin-bottom:.45rem; line-height:1.3; }
  .bep-carte-resume { font-size:.76rem; color:rgba(26,23,20,.65); line-height:1.5; margin-bottom:.75rem; }
  .bep-carte-indics { display:flex; gap:.6rem; flex-wrap:wrap; }
  .bep-indic { display:flex; align-items:center; gap:.28rem; }
  .bep-indic-dot { width:5px; height:5px; border-radius:50%; flex-shrink:0; }
  .bep-indic-label { font-size:.6rem; font-weight:600; letter-spacing:.05em; color:rgba(26,23,20,.4); }

  .bep-retour { display:inline-flex; align-items:center; gap:.4rem; background:none; border:none; color:rgba(26,23,20,.5); font-family:'Mulish',sans-serif; font-size:.72rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase; cursor:pointer; padding:0; margin-bottom:1.5rem; transition:color .12s; }
  .bep-retour:hover { color:var(--ink,#1a1714); }

  .bep-detail-badge { font-size:.62rem; font-weight:700; letter-spacing:.16em; text-transform:uppercase; color:#c4993a; border:1px solid #c4993a; border-radius:2px; padding:.15rem .45rem; display:inline-block; margin-bottom:.7rem; }
  .bep-detail-nom { font-family:'Libre Baskerville',serif; font-size:clamp(1.2rem,3vw,1.7rem); font-weight:700; color:var(--ink,#1a1714); margin-bottom:.3rem; line-height:1.2; }
  .bep-detail-auteur { font-size:.72rem; font-weight:600; letter-spacing:.1em; text-transform:uppercase; color:rgba(26,23,20,.4); margin-bottom:.9rem; }
  .bep-detail-resume { font-family:'Libre Baskerville',serif; font-size:.95rem; font-style:italic; color:rgba(26,23,20,.75); line-height:1.65; margin-bottom:1rem; padding-bottom:1.5rem; border-bottom:1px solid var(--rule,#ddd6c8); }
  .bep-detail-indics { display:flex; gap:1.2rem; flex-wrap:wrap; margin-bottom:1.5rem; }
  .bep-detail-indic { display:flex; align-items:center; gap:.35rem; }
  .bep-detail-indic-dot { width:8px; height:8px; border-radius:50%; flex-shrink:0; }
  .bep-detail-indic-label { font-size:.7rem; font-weight:600; letter-spacing:.07em; color:rgba(26,23,20,.5); }

  .bep-onglets { display:flex; border-bottom:1px solid var(--rule,#ddd6c8); overflow-x:auto; }
  .bep-onglet { font-family:'Mulish',sans-serif; font-size:.72rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase; background:none; border:none; border-bottom:2px solid transparent; padding:.8rem 1rem; cursor:pointer; color:rgba(26,23,20,.4); transition:all .12s; white-space:nowrap; margin-right:.2rem; }
  .bep-onglet:hover { color:rgba(26,23,20,.7); }
  .bep-onglet.active { font-weight:800; }

  .bep-panneau { padding:1.5rem 0; }
  .bep-panneau-filet { width:28px; height:2px; border-radius:1px; margin-bottom:1rem; }
  .bep-liste { list-style:none; padding:0; margin:0; }
  .bep-liste-item { display:flex; align-items:flex-start; gap:.6rem; margin-bottom:.75rem; font-size:.87rem; line-height:1.55; color:rgba(26,23,20,.8); }
  .bep-liste-puce { width:6px; height:6px; border-radius:50%; flex-shrink:0; margin-top:.45rem; }

  .bep-conn-groupe { margin-bottom:1.5rem; }
  .bep-conn-titre { display:flex; align-items:center; gap:.5rem; font-size:.65rem; font-weight:700; letter-spacing:.16em; text-transform:uppercase; color:rgba(26,23,20,.4); margin-bottom:.8rem; }
  .bep-conn-puce { display:inline-block; width:7px; height:7px; border-radius:50%; flex-shrink:0; }
  .bep-conn-grille { display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr)); gap:.75rem; }
  .bep-conn-card { background:rgba(255,255,255,.4); border:1px solid var(--rule,#ddd6c8); border-left:2px solid #2e7d4e; border-radius:3px; padding:.9rem 1rem; }
  .bep-conn-card--tension { border-left-color:#8b3a2a; }
  .bep-conn-card-top { display:flex; justify-content:space-between; align-items:flex-start; gap:.5rem; margin-bottom:.4rem; }
  .bep-conn-nom { font-family:'Libre Baskerville',serif; font-size:.82rem; font-weight:700; color:var(--ink,#1a1714); line-height:1.3; }
  .bep-conn-lien { background:none; border:none; font-family:'Mulish',sans-serif; font-size:.68rem; font-weight:700; letter-spacing:.08em; text-transform:uppercase; color:#c4993a; cursor:pointer; padding:0; white-space:nowrap; }
  .bep-conn-lien:hover { opacity:.7; }
  .bep-conn-synergie { font-size:.78rem; color:rgba(26,23,20,.62); line-height:1.5; margin:0; }
  .bep-doms-sec { display:flex; flex-wrap:wrap; gap:.5rem; }
  .bep-dom-badge { font-size:.68rem; font-weight:600; letter-spacing:.1em; text-transform:uppercase; color:rgba(26,23,20,.5); border:1px solid var(--rule,#ddd6c8); border-radius:2px; padding:.2rem .55rem; }

  .bep-question-zone { padding-top:.5rem; }
  .bep-question-titre { font-family:'Libre Baskerville',serif; font-size:1.3rem; font-weight:400; color:var(--ink,#1a1714); margin-bottom:.5rem; }
  .bep-question-sous { font-family:'Libre Baskerville',serif; font-size:.9rem; font-style:italic; color:rgba(26,23,20,.65); line-height:1.6; margin-bottom:1.5rem; }
  .bep-themes { margin-bottom:1.2rem; }
  .bep-themes-label { font-size:.65rem; font-weight:700; letter-spacing:.16em; text-transform:uppercase; color:rgba(26,23,20,.4); margin-bottom:.6rem; }
  .bep-themes-grille { display:flex; flex-wrap:wrap; gap:.4rem; }
  .bep-theme { font-family:'Mulish',sans-serif; font-size:.72rem; font-weight:600; color:rgba(26,23,20,.6); background:rgba(255,255,255,.5); border:1px solid var(--rule,#ddd6c8); border-radius:3px; padding:.35rem .7rem; cursor:pointer; transition:all .12s; }
  .bep-theme:hover, .bep-theme.active { border-color:#c4993a; color:var(--ink,#1a1714); background:rgba(196,153,58,.08); }
  .bep-ou { font-size:.65rem; font-weight:700; letter-spacing:.16em; text-transform:uppercase; color:rgba(26,23,20,.35); margin:1.2rem 0 .5rem; }
  .bep-question-input { width:100%; box-sizing:border-box; font-family:'Mulish',sans-serif; font-size:.9rem; color:var(--ink,#1a1714); background:rgba(255,255,255,.5); border:1px solid var(--rule,#ddd6c8); border-radius:3px; padding:.8rem 1rem; resize:vertical; outline:none; transition:border-color .15s; margin-bottom:1rem; }
  .bep-question-input:focus { border-color:#c4993a; }
  .bep-question-submit { font-family:'Mulish',sans-serif; font-size:.72rem; font-weight:700; letter-spacing:.12em; text-transform:uppercase; color:#f5f0e8; background:var(--ink,#1a1714); border:none; border-radius:2px; padding:.6rem 1.2rem; cursor:pointer; transition:opacity .15s; }
  .bep-question-submit:hover { opacity:.8; }

  .bep-resultat { margin-top:2rem; padding-top:1.5rem; border-top:1px solid var(--rule,#ddd6c8); }
  .bep-resultat-note { font-family:'Libre Baskerville',serif; font-size:.9rem; font-style:italic; color:rgba(26,23,20,.65); line-height:1.6; margin-bottom:1.5rem; }
  .bep-resultat-section { margin-bottom:1.5rem; }
  .bep-resultat-titre { display:flex; align-items:center; gap:.5rem; font-size:.65rem; font-weight:700; letter-spacing:.16em; text-transform:uppercase; color:rgba(26,23,20,.4); margin-bottom:.8rem; }
  .bep-res-puce { display:inline-block; width:8px; height:8px; border-radius:50%; flex-shrink:0; }
  .bep-res-grille { display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:.75rem; }
  .bep-res-card { background:rgba(255,255,255,.45); border:1px solid var(--rule,#ddd6c8); border-left:3px solid #2e7d4e; border-radius:3px; padding:1rem; cursor:pointer; transition:all .15s; }
  .bep-res-card:hover { transform:translateY(-1px); background:rgba(255,255,255,.7); }
  .bep-res-card--eviter { border-left-color:#8b3a2a; }
  .bep-res-card-top { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:.4rem; }
  .bep-res-nom { font-family:'Libre Baskerville',serif; font-size:.85rem; font-weight:700; color:var(--ink,#1a1714); }
  .bep-res-auteur { font-size:.68rem; font-weight:600; letter-spacing:.08em; color:rgba(26,23,20,.4); text-transform:uppercase; }
  .bep-res-raison { font-size:.82rem; color:rgba(26,23,20,.7); line-height:1.5; margin-bottom:.6rem; }
  .bep-res-lien { font-size:.68rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:#c4993a; }

  .bep-meta-note { margin-top:4rem; padding-top:1.5rem; border-top:1px solid var(--rule,#ddd6c8); text-align:center; }
  .bep-meta-note-texte { font-family:'Libre Baskerville',serif; font-size:.78rem; font-style:italic; color:rgba(26,23,20,.4); margin-bottom:.3rem; }
  .bep-meta-note-citation { font-size:.65rem; font-weight:700; letter-spacing:.15em; text-transform:uppercase; color:rgba(196,153,58,.6); }

  @keyframes bep-rise { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }

  @media (max-width:640px) {
    .bep-interface { grid-template-columns:1fr; gap:1.5rem; }
    .bep-nav { position:static; display:flex; flex-wrap:wrap; gap:.25rem; }
    .bep-nav-label { width:100%; }
    .bep-nav-item { width:auto; border-left:none; border-bottom:2px solid transparent; border-radius:3px; font-size:.7rem; padding:.3rem .55rem; }
    .bep-nav-item.active { border-bottom-color:#c4993a; border-left:none; }
    .bep-nav-question-btn-wrap { width:100%; margin-top:.5rem; }
    .bep-wrap { padding:0 1rem 4rem; }
  }
</style>

<script>
const DOMAINES_LABELS = {
  mathematiques:'Mathématiques', physique:'Physique', biologie:'Biologie',
  neurosciences:'Neurosciences cognitives', psychologie:'Psychologie',
  linguistique:'Linguistique · Sémiotique', epistemologie:'Épistémologie',
  philosophie:'Philosophie', ethique:'Éthique', anthropologie:'Anthropologie',
  cybernetique:'Cybernétique · Systèmes', sciences_sociales:'Sciences sociales',
  economie:'Économie', histoire:'Histoire',
};

const MODELES = [

  // ── MATHÉMATIQUES ──────────────────────────
  {
    id:'godel', nom:'Incomplétude des systèmes formels', auteur:'Kurt Gödel', annee:'1931',
    domaine_principal:'mathematiques', domaines_secondaires:['epistemologie','philosophie'],
    resume:'Tout système formel suffisamment puissant contient des vérités qu\'il ne peut pas démontrer.',
