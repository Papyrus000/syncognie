// ── LOGIQUE MOTS-CLÉS ────────────────────────
function suggererLibre(texte) {
  const t = texte.toLowerCase();
  const scores = MODELES.map(m => ({
    id: m.id,
    score: m.mots_cles.reduce((acc, mot) => acc + (t.includes(mot) ? 1 : 0), 0),
  })).sort((a, b) => b.score - a.score);
  const utiles = scores.filter(s => s.score > 0).slice(0, 3).map(s => {
    const m = MODELES.find(x => x.id === s.id);
    return { id: s.id, raison: m.territoire.slice(0, 2).join(' · ') };
  });
  const eviter = scores.filter(s => s.score === 0).slice(0, 1).map(s => ({
    id: s.id,
    raison: 'Ce modèle n\'a pas de prise directe sur votre question telle qu\'elle est formulée.',
  }));
  if (!utiles.length) return { note: 'Aucune correspondance forte. Essayez un thème prédéfini ou reformulez.', utiles:[], eviter:[] };
  return { note: 'Suggestions basées sur les mots-clés. La pertinence dépend du sens réel de votre contexte.', utiles, eviter };
}

// ── UTILITAIRES ──────────────────────────────
function pluriel(n, sing, plur) {
  return n === 1 ? `${n} ${sing}` : `${n} ${plur}`;
}

function updateCompteur() {
  const domaines = [...new Set(MODELES.map(m => m.domaine_principal))];
  const el = document.getElementById('bep-compteur');
  if (el) el.textContent = `${pluriel(MODELES.length,'modèle','modèles')} · ${pluriel(domaines.length,'domaine','domaines')}`;
}

