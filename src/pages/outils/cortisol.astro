  const recos = [];

  // Sélection selon les scores
  if (scores[0] > 55) recos.push(...RECOS.stress_high);
  else if (scores[0] > 30) recos.push(...RECOS.stress_mid);

  if (scores[1] > 50) recos.push(...RECOS.sleep_high.slice(0, 2));
  else if (scores[1] > 25) recos.push(...RECOS.sleep_mid);

  if (scores[2] > 50) recos.push(RECOS.phys_high[0]);
  else if (scores[2] > 25) recos.push(...RECOS.phys_mid);

  if (scores[3] > 50) recos.push(RECOS.emo_high[0]);
  else if (scores[3] > 25) recos.push(...RECOS.emo_mid);

  if (scores[4] > 50) recos.push(...RECOS.behav_high);
  else if (scores[4] > 25) recos.push(...RECOS.behav_mid);

  // Toujours afficher l'universelle si profil non-équilibré
  if (profile.id !== 'equilibre') recos.push(RECOS.universal);

  // Limiter à 6 max, diversifiées
  return recos.slice(0, 6);
}

// ── Résultats ──
function computeAndShowResults() {
  const scores = computeDimScores();
  const {profile} = detectProfile(scores);
  const estCurve = buildEstimatedCurve(scores, profile);

  showSection('section-results');
  updateProgress(TOTAL_Q, 5, 'Résultats');
  document.querySelectorAll('.cort-prog-step').forEach(el => el.classList.add('done'));

  // Profil
  const icon = $id('profil-icon');
  icon.textContent = profile.icon;
  icon.style.background = profile.iconBg;
  $id('profil-label').textContent = profile.label;
  $id('profil-name').textContent = profile.name;
  $id('profil-name').style.color = profile.nameCss;
  $id('profil-desc').textContent = profile.desc;

  // Courbe
  setTimeout(() => drawLineChart('cortisol-chart', REF_CURVE, estCurve), 80);

  // Annotations
  const ann = [];
  if (profile.id === 'equilibre') ann.push({text:'Amplitude normale', bg:'#dcfce7', color:'#15803d', border:'#86efac'});
  if (profile.id === 'eleve' || scores[0] > 60) ann.push({text:'Pic matinal élevé', bg:'#fee2e2', color:'#b91c1c', border:'#fca5a5'});
  if (scores[1] > 55) ann.push({text:'Déclin insuffisant', bg:'#fef3c7', color:'#b45309', border:'#fcd34d'});
  if (profile.id === 'epuisement') ann.push({text:'Courbe aplatie', bg:'#fee2e2', color:'#b91c1c', border:'#fca5a5'});
  if (scores[4] > 50) ann.push({text:'Plancher nocturne élevé', bg:'#fef3c7', color:'#b45309', border:'#fcd34d'});
  if (!ann.length) ann.push({text:'Rythme circadien cohérent', bg:'#eff6ff', color:'#1d4ed8', border:'#bfdbfe'});
  $id('courbe-annot').innerHTML = ann.map(a =>
    `<span class="cort-annot-tag" style="background:${a.bg};color:${a.color};border-color:${a.border}">${a.text}</span>`
  ).join('');

  // Radar
  setTimeout(() => drawRadar('radar-chart', scores), 120);

  // Dimensions
  const dimsEl = $id('dims-grid');
  dimsEl.innerHTML = scores.map((s,i) => {
    const col = s>65?'#dc2626':s>40?'#d97706':'#16a34a';
    return `<div class="cort-dim-row">
      <div class="cort-dim-row-top">
        <span class="cort-dim-row-name" style="color:${DIM_COLORS[i]}">${DIM_NAMES[i]}</span>
        <span class="cort-dim-row-score" style="color:${col}">${s}%</span>
      </div>
      <div class="cort-dim-bar"><div class="cort-dim-bar-fill" style="width:${s}%;background:${col}"></div></div>
    </div>`;
  }).join('');

  // Insights
  const insEl = $id('cort-insights');
  insEl.innerHTML = profile.insights.map(ins => `
    <div class="cort-insight" style="border-left-color:${ins.color}">
      <span class="cort-insight-ico">${ins.icon}</span>
      <div>
        <p class="cort-insight-title">${ins.title}</p>
        <p class="cort-insight-text">${ins.text}</p>
      </div>
    </div>`).join('');

  // Insight réveil tardif
  if (wakeTime === 'very-late' && scores[1] > 40) {
    insEl.innerHTML += `<div class="cort-insight" style="border-left-color:#0ea5e9">
      <span class="cort-insight-ico">🕐</span>
      <div>
        <p class="cort-insight-title">Réveil tardif & rythme cortisol</p>
        <p class="cort-insight-text">Le cortisol atteint son pic dans les 30-60 min post-réveil (CAR). Un réveil après 9h30 décale l'ensemble du cycle circadien, ce qui perturbe le métabolisme énergétique et la qualité du sommeil nocturne.</p>
      </div>
    </div>`;
  }

  // Recommandations personnalisées
  const recos = buildRecommendations(scores, profile, wakeTime);
  const recoGrid = $id('reco-grid');
  if (recoGrid) {
    recoGrid.innerHTML = recos.map((r, idx) => `
      <div class="cort-reco-card" style="animation-delay:${idx * 0.08}s">
        <div class="cort-reco-bar" style="background:${r.color}"></div>
        <div class="cort-reco-body">
          <div class="cort-reco-ico" style="background:${r.color}20">${r.ico}</div>
          <div class="cort-reco-meta">
            <span class="cort-reco-cat" style="color:${r.color}">${r.cat}</span>
            <p class="cort-reco-titre">${r.titre}</p>
          </div>
          <p class="cort-reco-text">${r.text}</p>
          <div class="cort-reco-ref">
            <span class="cort-reco-ref-dot" style="background:${r.color}"></span>
            <span>${r.ref}</span>
          </div>
        </div>
      </div>`).join('');
  }
}

// ── Recommencer ──
$id('btn-refaire')?.addEventListener('click', () => {
  answers = {}; wakeTime = null;
  document.querySelectorAll('.cort-scale-btn, .cort-choice-btn').forEach(b => b.classList.remove('selected'));
  document.querySelectorAll('.cort-q-card').forEach(el => {
    const qid = parseInt(el.dataset.qid);
    if (isNaN(qid)) return;
    const sIdx = Q_SECTION[qid];
    el.classList.toggle('hidden', SECTION_QS[sIdx][0] !== qid);
  });
  document.querySelectorAll('.cort-next-btn').forEach(b => b.classList.add('hidden'));
  $id('cort-prog-fill').style.width = '0';
  $id('prog-count').textContent = '0 / 20';
  $id('prog-dim-label').textContent = 'Début';
  document.querySelectorAll('.cort-prog-step').forEach(el => el.classList.remove('active','done'));
  document.querySelectorAll('.cort-prog-step')[0]?.classList.add('active');
  showSection('section-intro');
  window.scrollTo({top:0, behavior:'smooth'});
});

// Init
document.querySelectorAll('.cort-section').forEach(s => s.classList.add('hidden'));
$id('section-intro')?.classList.remove('hidden');
</script>


