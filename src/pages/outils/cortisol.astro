<script>
const TOTAL_Q = 20;
const REF_CURVE = [85,95,88,78,68,58,50,44,38,34,30,27,25,24,23,22,22,24,26,28,28,26,22,18];
const DIM_NAMES = ['Stress perçu','Rythme & sommeil','Signaux physiques','Régulation émotionnelle','Comportements'];
const DIM_COLORS = ['#6366f1','#0ea5e9','#10b981','#f59e0b','#ef4444'];

const PROFILS = [
