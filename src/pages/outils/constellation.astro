---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---
<Base title="Constellation — Navigateur de pensée · Syncognie">
  <Header />
  <div class="cst-wrap">

    <nav class="cst-breadcrumb">
      <a href="/outils" class="cst-back">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Tous les outils
      </a>
      <span class="cst-bread-sep">·</span>
      <span class="cst-bread-current">Constellation</span>
    </nav>

    <div class="cst-header">
      <p class="cst-surtitre">Outil · Connaissance</p>
      <h1 class="cst-titre">Constellation</h1>
      <p class="cst-sous">Un réseau de penseurs et de concepts — leurs projecteurs sur la réalité, leurs tensions, leurs filiations. Naviguer plutôt que mémoriser.</p>
      <div class="cst-meta">
        <span class="cst-version">v0.1.4</span>
        <span class="cst-meta-sep">·</span>
        <span class="cst-count" id="cst-count">28 auteurs</span>
      </div>
    </div>

    <!-- RANG 1 : chips domaine (filtre + légende fusionnés) -->
    <div class="cst-chips-row">
      <span class="cst-chips-label">Domaine</span>
      <div class="cst-chips" id="cst-domaine-chips">
        <button class="cst-chip active" data-niveau="tous">
          <span class="chip-dots">
            <span class="chip-dot" style="background:#c85a2a"></span>
            <span class="chip-dot" style="background:#4a7fc1"></span>
            <span class="chip-dot" style="background:#4a9e6e"></span>
            <span class="chip-dot" style="background:#8a6bbf"></span>
            <span class="chip-dot" style="background:#c4993a"></span>
            <span class="chip-dot" style="background:#3a8c7e"></span>
          </span>
          Tous
        </button>
        <button class="cst-chip" data-niveau="neurologique" style="--chip-c:#c85a2a">
          <span class="chip-dot single" style="background:#c85a2a"></span>Neurologique
        </button>
        <button class="cst-chip" data-niveau="représentationnel" style="--chip-c:#4a7fc1">
          <span class="chip-dot single" style="background:#4a7fc1"></span>Représentation
        </button>
        <button class="cst-chip" data-niveau="social" style="--chip-c:#4a9e6e">
          <span class="chip-dot single" style="background:#4a9e6e"></span>Social
        </button>
        <button class="cst-chip" data-niveau="existentiel" style="--chip-c:#8a6bbf">
          <span class="chip-dot single" style="background:#8a6bbf"></span>Existentiel
        </button>
        <button class="cst-chip" data-niveau="systèmes" style="--chip-c:#c4993a">
          <span class="chip-dot single" style="background:#c4993a"></span>Systèmes
        </button>
        <button class="cst-chip" data-niveau="développement" style="--chip-c:#3a8c7e">
          <span class="chip-dot single" style="background:#3a8c7e"></span>Développement
        </button>
      </div>
    </div>

    <!-- RANG 2 : chips contexte (topographie dynamique sans API) -->
    <div class="cst-chips-row cst-chips-row--context">
      <span class="cst-chips-label">Contexte</span>
      <div class="cst-chips cst-chips--context" id="cst-context-chips">
        <button class="cst-chip-ctx active" data-ctx="tous">Tous les contextes</button>
        <button class="cst-chip-ctx" data-ctx="apprentissage">Apprentissage bloqué</button>
        <button class="cst-chip-ctx" data-ctx="epuisement">Épuisement</button>
        <button class="cst-chip-ctx" data-ctx="conflit">Conflit relationnel</button>
        <button class="cst-chip-ctx" data-ctx="decision">Décision difficile</button>
        <button class="cst-chip-ctx" data-ctx="motivation">Motivation absente</button>
        <button class="cst-chip-ctx" data-ctx="croyance">Croyance résistante</button>
        <button class="cst-chip-ctx" data-ctx="compulsion">Comportement compulsif</button>
        <button class="cst-chip-ctx" data-ctx="sens">Sens perdu</button>
        <button class="cst-chip-ctx" data-ctx="enfant">Enfant en difficulté</button>
      </div>
    </div>

    <div class="cst-interface">
      <div class="cst-toolbar">
        <div class="cst-search-wrap">
          <svg class="cst-search-icon" width="15" height="15" viewBox="0 0 15 15" fill="none"><circle cx="6.5" cy="6.5" r="4.5" stroke="currentColor" stroke-width="1.4"/><path d="M10.5 10.5L13 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          <input type="text" id="cst-search" placeholder="Chercher un auteur, un concept…" autocomplete="off">
        </div>
        <span class="cst-ctx-indicator hidden" id="cst-ctx-indicator"></span>
      </div>

      <div class="cst-body">
        <aside class="cst-sidebar" id="cst-sidebar">
          <div id="cst-list"></div>
        </aside>
        <section class="cst-detail" id="cst-detail">
          <div class="cst-welcome" id="cst-welcome">
            <svg class="cst-welcome-svg" viewBox="0 0 100 100" fill="none">
              <circle cx="50" cy="50" r="5" fill="#c4993a" opacity=".7"/>
              <circle cx="20" cy="28" r="3.5" fill="#c85a2a" opacity=".5"/>
              <circle cx="76" cy="22" r="2.5" fill="#4a7fc1" opacity=".5"/>
              <circle cx="80" cy="64" r="3.5" fill="#4a9e6e" opacity=".5"/>
              <circle cx="18" cy="70" r="2.5" fill="#8a6bbf" opacity=".5"/>
              <circle cx="72" cy="80" r="2" fill="#3a8c7e" opacity=".5"/>
              <line x1="50" y1="50" x2="20" y2="28" stroke="#c85a2a" stroke-width="1" opacity=".25"/>
              <line x1="50" y1="50" x2="76" y2="22" stroke="#4a7fc1" stroke-width="1" opacity=".25"/>
              <line x1="50" y1="50" x2="80" y2="64" stroke="#4a9e6e" stroke-width="1" opacity=".25"/>
              <line x1="50" y1="50" x2="18" y2="70" stroke="#8a6bbf" stroke-width="1" opacity=".25"/>
              <line x1="50" y1="50" x2="72" y2="80" stroke="#3a8c7e" stroke-width="1" opacity=".25"/>
            </svg>
            <p class="cst-welcome-title">Sélectionne un auteur<br>pour explorer sa pensée</p>
            <p class="cst-welcome-sub">Ou choisis un contexte pour voir quels auteurs l'éclairent le mieux</p>
            <div class="cst-welcome-stats">
              <div class="cst-stat"><span class="cst-stat-n" id="ws-auteurs">28</span><span class="cst-stat-label">Auteurs</span></div>
              <div class="cst-stat"><span class="cst-stat-n" id="ws-concepts">28</span><span class="cst-stat-label">Concepts</span></div>
              <div class="cst-stat"><span class="cst-stat-n" id="ws-connexions">0</span><span class="cst-stat-label">Connexions</span></div>
            </div>
          </div>
          <div class="cst-author-detail hidden" id="cst-author-detail"></div>
        </section>
      </div>
    </div>

    <div class="cst-note">
      <div class="note-dot"></div>
      <p>Constellation grandit avec Syncognie — chaque épisode apporte ses auteurs, chaque concept lu devient une entrée potentielle.</p>
    </div>
  </div>
  <Footer />
</Base>

<style is:global>
.cst-wrap { max-width:var(--max); margin:0 auto; padding:2.5rem 1.75rem 5rem; }

/* BREADCRUMB */
.cst-breadcrumb { display:flex; align-items:center; gap:.6rem; margin-bottom:2rem; opacity:0; animation:rise .7s .02s ease forwards; }
.cst-back { display:inline-flex; align-items:center; gap:.45rem; font-family:'Mulish',sans-serif; font-size:.82rem; font-weight:600; color:var(--accent); text-decoration:none; transition:gap .2s; }
.cst-back:hover { gap:.7rem; }
.cst-back svg { transition:transform .2s; }
.cst-back:hover svg { transform:translateX(-2px); }
.cst-bread-sep { color:var(--rule); }
.cst-bread-current { font-family:'Mulish',sans-serif; font-size:.82rem; font-weight:300; color:var(--ink-soft); }

/* HEADER */
.cst-header { margin-bottom:1.4rem; opacity:0; animation:rise .9s .06s ease forwards; }
.cst-surtitre { font-family:'Mulish',sans-serif; font-size:.67rem; font-weight:600; letter-spacing:.28em; text-transform:uppercase; color:var(--accent); margin-bottom:.65rem; }
.cst-titre { font-size:clamp(1.8rem,3.5vw,2.4rem); font-weight:700; color:var(--ink); line-height:1.15; letter-spacing:-.02em; margin-bottom:.75rem; }
.cst-sous { font-family:'Mulish',sans-serif; font-size:.96rem; font-weight:400; color:#5a5248; line-height:1.8; max-width:58ch; margin-bottom:.9rem; }
.cst-meta { display:flex; align-items:center; gap:.65rem; }
.cst-version { font-family:'Courier New',monospace; font-size:.7rem; color:#6a6058; border:1px solid var(--rule); border-radius:3px; padding:.2rem .5rem; }
.cst-meta-sep { color:var(--rule); }
.cst-count { font-family:'Mulish',sans-serif; font-size:.75rem; color:var(--ink-soft); }

/* CHIPS ROW — conteneur avec label aligné */
.cst-chips-row {
  display:flex; align-items:flex-start; gap:.75rem;
  margin-bottom:.6rem;
  opacity:0; animation:rise .8s .1s ease forwards;
}
.cst-chips-row--context {
  margin-bottom:1.1rem;
  animation-delay:.13s;
}
.cst-chips-label {
  font-family:'Mulish',sans-serif; font-size:.6rem; font-weight:700;
  letter-spacing:.18em; text-transform:uppercase; color:#9a9088;
  padding-top:.45rem; white-space:nowrap; flex-shrink:0; min-width:52px;
}

/* CHIPS DOMAINE */
.cst-chips { display:flex; gap:.32rem; flex-wrap:wrap; }
.cst-chip {
  display:inline-flex; align-items:center; gap:.4rem;
  padding:.36rem .78rem; border-radius:20px;
  border:1px solid var(--rule);
  background:rgba(245,240,232,.5);
  color:#6a6058;
  font-family:'Mulish',sans-serif; font-size:.71rem; font-weight:600;
  cursor:pointer; transition:all .18s; white-space:nowrap;
}
.cst-chip:hover { border-color:rgba(139,94,60,.3); background:rgba(245,240,232,.95); color:#3a3330; }
.cst-chip.active {
  background:color-mix(in srgb, var(--chip-c,#c4993a) 12%, rgba(245,240,232,1));
  border-color:color-mix(in srgb, var(--chip-c,#c4993a) 38%, transparent);
  color:color-mix(in srgb, var(--chip-c,#c4993a) 80%, #3a2a10);
  font-weight:700;
}
.cst-chip[data-niveau="tous"].active { background:rgba(196,153,58,.1); border-color:rgba(196,153,58,.32); color:#8a6820; }
.chip-dots { display:flex; gap:2px; align-items:center; }
.chip-dot { width:6px; height:6px; border-radius:50%; flex-shrink:0; }
.chip-dot.single { width:7px; height:7px; }

/* CHIPS CONTEXTE — visuellement plus légers */
.cst-chips--context { gap:.28rem; }
.cst-chip-ctx {
  display:inline-flex; align-items:center;
  padding:.28rem .68rem; border-radius:14px;
  border:1px solid var(--rule);
  background:transparent;
  color:#8a8078;
  font-family:'Mulish',sans-serif; font-size:.67rem; font-weight:500;
  cursor:pointer; transition:all .18s; white-space:nowrap;
}
.cst-chip-ctx:hover { border-color:rgba(139,94,60,.28); color:#5a5248; background:rgba(245,240,232,.7); }
.cst-chip-ctx.active {
  background:rgba(58,56,52,.07);
  border-color:rgba(58,56,52,.22);
  color:#3a3330; font-weight:700;
}

/* INTERFACE */
.cst-interface {
  border:1px solid var(--rule); border-radius:10px; overflow:hidden;
  background:rgba(245,240,232,.45);
  opacity:0; animation:rise .9s .16s ease forwards;
  box-shadow:0 2px 20px rgba(26,23,20,.055);
  display:flex; flex-direction:column; min-height:680px;
}

/* TOOLBAR */
.cst-toolbar { display:flex; align-items:center; gap:.75rem; padding:.8rem 1.1rem; border-bottom:1px solid var(--rule); background:rgba(245,240,232,.85); }
.cst-search-wrap { position:relative; flex:1; max-width:300px; }
.cst-search-icon { position:absolute; left:.72rem; top:50%; transform:translateY(-50%); color:var(--ink-soft); pointer-events:none; opacity:.42; }
.cst-search-wrap input {
  width:100%; background:rgba(245,240,232,.9); border:1px solid var(--rule);
  border-radius:6px; padding:.5rem .85rem .5rem 2.1rem;
  color:#3a3330; font-family:'Mulish',sans-serif; font-size:.88rem;
  outline:none; transition:border-color .2s,box-shadow .2s;
}
.cst-search-wrap input::placeholder { color:var(--ink-soft); opacity:.5; }
.cst-search-wrap input:focus { border-color:var(--accent); box-shadow:0 0 0 3px rgba(196,153,58,.1); }
.cst-ctx-indicator {
  font-family:'Mulish',sans-serif; font-size:.69rem; font-weight:600;
  color:#6a6058; background:rgba(58,56,52,.06);
  border:1px solid rgba(58,56,52,.15); border-radius:12px;
  padding:.22rem .62rem; white-space:nowrap;
}
.cst-ctx-indicator.hidden { display:none; }

/* BODY */
.cst-body { display:grid; grid-template-columns:185px 1fr; flex:1; min-height:600px; }

/* SIDEBAR */
.cst-sidebar { border-right:1px solid var(--rule); overflow-y:auto; padding:.45rem .4rem; background:rgba(245,240,232,.28); }
.cst-sidebar::-webkit-scrollbar { width:3px; }
.cst-sidebar::-webkit-scrollbar-thumb { background:rgba(139,94,60,.15); border-radius:2px; }

.cst-niveau-label {
  font-family:'Mulish',sans-serif; font-size:.59rem; font-weight:700;
  letter-spacing:.18em; text-transform:uppercase; color:#8a8078;
  padding:.6rem .5rem .2rem;
  display:flex; align-items:center; gap:.42rem;
}
.cst-niveau-label::after { content:''; flex:1; height:1px; background:var(--rule); opacity:.7; }

/* Item sidebar : transition douce de padding */
.cst-author-item {
  display:flex; align-items:center; gap:.48rem;
  padding:.5rem .55rem; border-radius:5px; cursor:pointer;
  transition:background .15s, border-color .15s, padding .22s, opacity .22s;
  border:1px solid transparent; margin-bottom:.05rem;
}
.cst-author-item:hover  { background:rgba(196,153,58,.07); border-color:rgba(196,153,58,.2); }
.cst-author-item.active { background:rgba(196,153,58,.13); border-color:rgba(196,153,58,.3); }

/* Mode condensé : sidebar.has-selection */
.cst-sidebar.has-selection .cst-author-item:not(.active) { padding-top:.28rem; padding-bottom:.28rem; opacity:.6; }
.cst-sidebar.has-selection .cst-author-item:not(.active):hover { opacity:1; }
.cst-sidebar.has-selection .cst-author-item:not(.active) .cst-aname-prenom { display:none; }
.cst-sidebar.has-selection .cst-niveau-label { padding-top:.32rem; font-size:.55rem; }
/* Actif : prénom toujours visible */
.cst-author-item.active .cst-aname-prenom { display:block !important; }

/* Badge de pertinence contextuelle */
.cst-relevance {
  flex-shrink:0; display:flex; gap:2px; align-items:center; margin-left:auto;
}
.rel-pip {
  width:4px; height:10px; border-radius:2px;
  background:rgba(58,56,52,.12);
  transition:background .2s;
}
.rel-pip.on { background:rgba(58,130,90,.5); }
.cst-author-item.active .rel-pip.on { background:rgba(196,153,58,.7); }

.cst-adot { width:7px; height:7px; border-radius:50%; flex-shrink:0; }
.cst-adot-neurologique      { background:#c85a2a; }
.cst-adot-representationnel { background:#4a7fc1; }
.cst-adot-social            { background:#4a9e6e; }
.cst-adot-existentiel       { background:#8a6bbf; }
.cst-adot-systemes          { background:#c4993a; }
.cst-adot-developpement     { background:#3a8c7e; }

.cst-aname { flex:1; line-height:1.25; min-width:0; overflow:hidden; }
.cst-aname-prenom { font-family:'Mulish',sans-serif; font-size:.67rem; font-weight:300; color:#8a8078; display:block; line-height:1.1; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; transition:all .2s; }
.cst-aname-nom { font-family:'Libre Baskerville',Georgia,serif; font-size:.84rem; font-weight:700; color:#3a3330; display:block; line-height:1.2; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }

/* DETAIL */
.cst-detail { overflow-y:auto; padding:2rem 2.5rem 2.5rem; position:relative; }
.cst-detail::-webkit-scrollbar { width:3px; }
.cst-detail::-webkit-scrollbar-thumb { background:rgba(139,94,60,.14); border-radius:2px; }

.cst-close-btn {
  position:absolute; top:1.1rem; right:1.35rem;
  display:inline-flex; align-items:center; gap:.35rem;
  font-family:'Mulish',sans-serif; font-size:.68rem; font-weight:600; letter-spacing:.07em; text-transform:uppercase;
  color:#8a8078; background:rgba(245,240,232,.85);
  border:1px solid var(--rule); border-radius:4px; padding:.3rem .68rem; cursor:pointer; transition:all .18s;
}
.cst-close-btn:hover { border-color:var(--accent); color:var(--accent); background:rgba(245,240,232,1); }

/* WELCOME */
.cst-welcome { display:flex; flex-direction:column; align-items:center; justify-content:center; min-height:480px; text-align:center; gap:1.2rem; }
.cst-welcome-svg { width:74px; height:74px; opacity:.55; }
.cst-welcome-title { font-family:'Libre Baskerville',Georgia,serif; font-size:1.12rem; font-weight:700; color:#3a3330; line-height:1.55; }
.cst-welcome-sub { font-family:'Mulish',sans-serif; font-size:.87rem; color:var(--ink-soft); max-width:36ch; line-height:1.7; }
.cst-welcome-stats { display:flex; gap:2.5rem; margin-top:.5rem; }
.cst-stat { text-align:center; }
.cst-stat-n { font-family:'Libre Baskerville',Georgia,serif; font-size:1.95rem; font-weight:700; color:var(--accent); display:block; line-height:1; }
.cst-stat-label { font-family:'Mulish',sans-serif; font-size:.64rem; font-weight:600; letter-spacing:.12em; text-transform:uppercase; color:#8a8078; margin-top:.28rem; display:block; }

/* FICHE */
.cst-author-detail { max-width:760px; animation:rise .28s ease; }
.cst-author-detail.hidden { display:none; }
.cst-welcome.hidden { display:none; }

.cst-dheader { padding-bottom:1.5rem; border-bottom:1px solid var(--rule); margin-bottom:1.65rem; }
.cst-dniveau { font-family:'Mulish',sans-serif; font-size:.66rem; font-weight:700; letter-spacing:.16em; text-transform:uppercase; display:flex; align-items:center; gap:.42rem; margin-bottom:.6rem; }
.cst-dniveau-dot { width:7px; height:7px; border-radius:50%; display:inline-block; }
.cst-dprenom { font-family:'Mulish',sans-serif; font-size:1rem; font-weight:300; color:#8a8078; display:block; line-height:1.2; letter-spacing:.02em; }
.cst-dnom { font-family:'Libre Baskerville',Georgia,serif; font-size:clamp(1.65rem,3vw,2.3rem); font-weight:700; color:#2a2420; line-height:1.1; letter-spacing:-.025em; display:block; }
.cst-ddates { font-family:'Mulish',sans-serif; font-size:.82rem; color:#8a8078; font-style:italic; margin-bottom:.8rem; margin-top:.35rem; }
.cst-dtagline { font-family:'Libre Baskerville',Georgia,serif; font-size:1.05rem; font-style:italic; color:#5a5248; line-height:1.7; }
.cst-quote { border-left:2px solid var(--accent); padding:.95rem 1.4rem; margin:1.1rem 0 1.75rem; font-family:'Libre Baskerville',Georgia,serif; font-size:.97rem; font-style:italic; color:#5a5248; line-height:1.78; background:rgba(245,240,232,.6); border-radius:0 6px 6px 0; }

.cst-section { margin-bottom:1.85rem; }
.cst-section-title { font-family:'Mulish',sans-serif; font-size:.67rem; font-weight:700; letter-spacing:.2em; text-transform:uppercase; color:#7a7068; margin-bottom:.9rem; display:flex; align-items:center; gap:.65rem; }
.cst-section-title::after { content:''; flex:1; height:1px; background:var(--rule); }

.cst-concept { border:1px solid var(--rule); border-radius:8px; padding:1.45rem; background:rgba(245,240,232,.55); margin-bottom:.85rem; position:relative; overflow:hidden; }
.cst-concept::before { content:''; position:absolute; top:0; left:0; right:0; height:2px; background:var(--accent); opacity:.45; }
.cst-concept-name { font-family:'Libre Baskerville',Georgia,serif; font-size:1.02rem; font-weight:700; color:#9a7030; margin-bottom:.62rem; }
.cst-concept-def { font-family:'Mulish',sans-serif; font-size:.92rem; color:#3a3330; line-height:1.82; margin-bottom:.95rem; }
.cst-projecteur { border-radius:0 6px 6px 0; padding:.82rem 1.1rem; margin-bottom:.5rem; }
.cst-projecteur-eclaire { background:rgba(196,153,58,.065); border-left:2px solid rgba(196,153,58,.38); }
.cst-projecteur-limites { background:rgba(200,90,42,.048); border-left:2px solid rgba(200,90,42,.28); margin-top:.5rem; }
.cst-projecteur-label { font-family:'Mulish',sans-serif; font-size:.67rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase; margin-bottom:.36rem; }
.cst-projecteur-eclaire .cst-projecteur-label { color:#8a6820; }
.cst-projecteur-limites .cst-projecteur-label { color:#9a3818; }
.cst-projecteur-text { font-family:'Mulish',sans-serif; font-size:.9rem; color:#5a5248; line-height:1.72; }
.cst-limite { display:flex; gap:.52rem; align-items:flex-start; margin-bottom:.4rem; }
.cst-limite-dash { color:#b04020; font-size:.85rem; margin-top:.1rem; flex-shrink:0; }
.cst-limite-text { font-family:'Mulish',sans-serif; font-size:.88rem; color:#5a5248; line-height:1.65; }

.cst-situation { border:1px solid var(--rule); border-left:2px solid rgba(196,153,58,.45); border-radius:0 6px 6px 0; padding:.78rem 1.1rem; margin-bottom:.48rem; background:rgba(245,240,232,.4); }
.cst-situation-text { font-family:'Mulish',sans-serif; font-size:.9rem; color:#5a5248; line-height:1.7; font-style:italic; }

.cst-connexions-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(210px,1fr)); gap:.62rem; }
.cst-connexion { border:1px solid var(--rule); border-radius:8px; padding:.95rem 1rem; cursor:pointer; transition:all .18s; background:rgba(245,240,232,.55); }
.cst-connexion:hover { border-color:var(--accent); background:rgba(196,153,58,.06); transform:translateY(-2px); box-shadow:0 4px 14px rgba(26,23,20,.06); }
.cst-connexion-type { font-family:'Mulish',sans-serif; font-size:.63rem; font-weight:700; letter-spacing:.1em; text-transform:uppercase; margin-bottom:.36rem; }
.cst-connexion-name { font-family:'Libre Baskerville',Georgia,serif; font-size:.9rem; font-weight:700; color:#3a3330; margin-bottom:.36rem; }
.cst-connexion-why { font-family:'Mulish',sans-serif; font-size:.81rem; color:#7a7068; line-height:1.55; font-style:italic; }
.ctype-filiation   { color:#9a7030; }
.ctype-tension     { color:#c05020; }
.ctype-convergence { color:#3a6fa8; }
.ctype-application { color:#3a8e58; }

.cst-oeuvres { display:flex; flex-wrap:wrap; gap:.38rem; }
.cst-oeuvre { font-family:'Mulish',sans-serif; font-size:.81rem; font-style:italic; color:#6a6058; border:1px solid var(--rule); border-radius:16px; padding:.28rem .72rem; background:rgba(245,240,232,.6); }

.cst-note { display:flex; align-items:flex-start; gap:.75rem; margin-top:2.5rem; padding-top:1.75rem; border-top:1px solid var(--rule); opacity:0; animation:rise .9s .4s ease forwards; }
.cst-note .note-dot { width:6px; height:6px; border-radius:50%; background:var(--accent); flex-shrink:0; margin-top:.3rem; animation:pulse 2s ease-in-out infinite; }
.cst-note p { font-family:'Mulish',sans-serif; font-size:.88rem; color:var(--ink-soft); line-height:1.7; font-style:italic; }

@media (max-width:820px) { .cst-body { grid-template-columns:172px 1fr; } .cst-detail { padding:1.75rem 1.75rem; } }
@media (max-width:640px) {
  .cst-wrap { padding:1.75rem 1.1rem 4rem; }
  .cst-body { grid-template-columns:1fr; grid-template-rows:auto 1fr; }
  .cst-sidebar { border-right:none; border-bottom:1px solid var(--rule); max-height:210px; }
  .cst-detail { padding:1.5rem 1rem; }
  .cst-chips-row { flex-direction:column; gap:.4rem; }
  .cst-chips-label { padding-top:0; }
  .cst-chips, .cst-chips--context { overflow-x:auto; flex-wrap:nowrap; padding-bottom:.2rem; }
  .cst-connexions-grid { grid-template-columns:1fr; }
  .cst-dnom { font-size:1.55rem; }
  .cst-close-btn { top:.75rem; right:.75rem; }
}
@keyframes rise { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.3} }
