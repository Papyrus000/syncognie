---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('carnet');

const sorted = [...entries].sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const dialogues = sorted.filter(e => e.data.type === 'dialogue');
const notes     = sorted.filter(e => e.data.type === 'note');
const total     = sorted.length;

function formatDate(date: Date) {
  return date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'short', year: 'numeric' });
}
---

<Base title="Carnet — Syncognie" description="Dialogues construits et notes au fil des jours — le cheminement de la pensée en mouvement.">

<div class="page-wrap">

  <!-- ── En-tête ── -->
  <header class="page-header">
    <p class="page-eyebrow">Carnet</p>
    <h1 class="page-titre">La pensée<br><em>en construction... 🚧</em></h1>
    <p class="page-sous">Recherches, dialogues, notes... — ce qui se passe quand on pense à l'écrit.  
    Le cheminement peut se raconter de la même manière que le résultat.</p>

    <div class="page-compteurs">
      <div class="compteur">
        <span class="compteur-n">{dialogues.length}</span>
        <span class="compteur-label">{dialogues.length > 1 ? 'dialogues' : 'dialogue'}</span>
      </div>
      <span class="compteur-sep">·</span>
      <div class="compteur">
        <span class="compteur-n">{notes.length}</span>
        <span class="compteur-label">{notes.length > 1 ? 'notes' : 'note'}</span>
      </div>
    </div>

    <!-- Badges = filtres interactifs -->
    <div class="page-filtres">
      <button class="filtre-btn filtre-btn--dialogue actif" data-filtre="dialogue">◈ Dialogue</button>
      <button class="filtre-btn filtre-btn--note actif" data-filtre="note">◦ Note</button>
    </div>
  </header>


  <!-- ── Notes ── -->
  {notes.length > 0 && (
    <section class="bloc" data-section="note" style="animation-delay:.2s">
      <div class="bloc-sep">
        <span class="bloc-sep-label">◦ {notes.length > 1 ? `${notes.length} notes` : '1 note'}</span>
        <span class="bloc-sep-line"/>
      </div>
      <div class="entrees-liste">
        {notes.map((entry, i) => {
          const isRiche = !!(entry.data.description || (entry.data.tags && entry.data.tags.length > 0));
          return (
            <a href={`/carnet/${entry.slug}`}
               class={`entree-carte ${isRiche ? '' : 'entree-carte--note'}`}
               style={`animation-delay:${0.2 + i * 0.06}s`}>

              {isRiche ? (
                /* ── Mode carte complète (style dialogue) ── */
                <>
                  <div class="entree-meta">
                    <span class="entree-date">{formatDate(entry.data.date)}</span>
                    {entry.data.stade && (
                      <span class="entree-stade">
                        {entry.data.stade === 'arbre' ? '🌳' : entry.data.stade === 'pousse' ? '🌿' : '🌱'}
                      </span>
                    )}
                    {entry.data.tags?.slice(0, 3).map((tag: string) => (
                      <span class="entree-tag">{tag}</span>
                    ))}
                  </div>
                  <h3 class="entree-titre">{entry.data.title}</h3>
                  {entry.data.description && (
                    <p class="entree-desc">{entry.data.description}</p>
                  )}
                  <span class="entree-lire">Lire →</span>
                </>
              ) : (
                /* ── Mode compact ligne ── */
                <>
                  <div class="note-ligne-unique">
                    <span class="entree-date">{formatDate(entry.data.date)}</span>
                    {entry.data.stade && (
                      <span class="entree-stade">
                        {entry.data.stade === 'arbre' ? '🌳' : entry.data.stade === 'pousse' ? '🌿' : '🌱'}
                      </span>
                    )}
                    <span class="note-sep">·</span>
                    <h3 class="entree-titre note-titre-inline">{entry.data.title}</h3>
                  </div>
                  <span class="entree-lire">Lire →</span>
                </>
              )}

            </a>
          );
        })}
      </div>
    </section>
  )}


  <!-- ── Dialogues ── -->
  {dialogues.length > 0 && (
    <section class="bloc" data-section="dialogue" style="animation-delay:.1s">
      <div class="bloc-sep">
        <span class="bloc-sep-label">◈ {dialogues.length > 1 ? `${dialogues.length} dialogues` : '1 dialogue'}</span>
        <span class="bloc-sep-line"/>
      </div>
      <div class="entrees-liste">
        {dialogues.map((entry, i) => (
          <a href={`/carnet/${entry.slug}`} class="entree-carte" style={`animation-delay:${0.15 + i * 0.07}s`}>
            <div class="entree-meta">
              <span class="entree-date">{formatDate(entry.data.date)}</span>
              {entry.data.stade && (
                <span class="entree-stade">
                  {entry.data.stade === 'arbre' ? '🌳' : entry.data.stade === 'pousse' ? '🌿' : '🌱'}
                </span>
              )}
              {entry.data.tags?.slice(0, 3).map((tag: string) => (
                <span class="entree-tag">{tag}</span>
              ))}
            </div>
            <h3 class="entree-titre">{entry.data.title}</h3>
            {entry.data.description && (
              <p class="entree-desc">{entry.data.description}</p>
            )}
            {entry.data.extrait && (
              <blockquote class="entree-extrait">{entry.data.extrait}</blockquote>
            )}
            <span class="entree-lire">Lire →</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- ── Vide ── -->
  {total === 0 && (
    <div class="vide-encart">
      <span class="vide-glyph">◦</span>
      <p class="vide-texte">Le carnet commence à s'écrire.<br/>Les premières entrées arrivent bientôt.</p>
    </div>
  )}

  <!-- ── Pied ── -->
  <div class="pied-encart">
    <span class="pied-glyph">◈</span>
    <p class="pied-texte">Ce carnet recuille les notes, les recherches et les dialogues qui ont précédé les changements sur le site.</p>
  </div>

</div>

<style>
  :root {
    --feu:       #ea580c;
    --feu-deep:  #9a3412;
    --or:        #b45309;
    --or-vif:    #f59e0b;
    --or-border: #fde68a;
    --or-bg:     #fff8f0;
    --page-bg:   #fffaf5;
  }

  /* ── Page & irradiation ── */
  .page-wrap {
    max-width: var(--max, 760px);
    margin: 0 auto;
    padding: 0 1.5rem 6rem;
    position: relative;
  }
/* ── En-tête ── */
  .page-header {
    padding: 3rem 0 2.5rem;
    opacity: 0;
    animation: rise .9s .05s ease forwards;
    position: relative;
    z-index: 1;
  }

  .page-eyebrow {
    font-family: 'Mulish', sans-serif;
    font-size: .58rem;
    font-weight: 700;
    letter-spacing: .32em;
    text-transform: uppercase;
    color: var(--feu-deep);
    margin-bottom: .85rem;
  }

  .page-titre {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: clamp(2rem, 4.5vw, 2.9rem);
    font-weight: 700;
    color: #1a0800;
    line-height: 1.1;
    letter-spacing: -.025em;
    margin-bottom: .9rem;
  }

  .page-titre em {
    font-style: italic;
    font-weight: 400;
    color: var(--feu);
    display: block;
  }

  .page-sous {
    font-family: 'Mulish', sans-serif;
    font-size: .95rem;
    font-weight: 300;
    color: #78350f;
    line-height: 1.82;
    max-width: 52ch;
    margin-bottom: 1.75rem;
  }

  .page-compteurs {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
    opacity: 0;
    animation: rise .9s .15s ease forwards;
  }

  .compteur { display: flex; align-items: baseline; gap: .38rem; }

  .compteur-n {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: 1.85rem;
    font-weight: 700;
    color: var(--feu);
    line-height: 1;
    letter-spacing: -.03em;
  }

  .compteur-label {
    font-family: 'Mulish', sans-serif;
    font-size: .68rem;
    font-weight: 300;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--or);
  }

  .compteur-sep { color: var(--or-border); font-size: 1.1rem; }

  /* ── Filtres ── */
  .page-filtres {
    display: flex;
    gap: .6rem;
    opacity: 0;
    animation: rise .9s .25s ease forwards;
  }

  .filtre-btn {
    font-family: 'Mulish', sans-serif;
    font-size: .63rem;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
    padding: .3rem .8rem;
    border-radius: 4px;
    border: 1px solid;
    cursor: pointer;
    transition: opacity .2s, background .2s, transform .15s;
    background: transparent;
  }

  .filtre-btn--dialogue {
    color: var(--feu-deep);
    border-color: rgba(234,88,12,.28);
  }
  .filtre-btn--dialogue.actif {
    background: rgba(234,88,12,.08);
  }
  .filtre-btn--dialogue:hover {
    background: rgba(234,88,12,.13);
    transform: translateY(-1px);
  }

  .filtre-btn--note {
    color: var(--or);
    border-color: rgba(251,191,36,.42);
  }
  .filtre-btn--note.actif {
    background: rgba(251,191,36,.09);
  }
  .filtre-btn--note:hover {
    background: rgba(251,191,36,.15);
    transform: translateY(-1px);
  }

  .filtre-btn.inactif {
    opacity: .35;
    background: transparent;
  }

  /* ── Blocs ── */
  .bloc {
    margin-bottom: 3rem;
    opacity: 0;
    animation: rise .8s ease forwards;
    position: relative;
    z-index: 1;
    transition: opacity .3s;
  }

  .bloc.masque {
    display: none;
  }

  .bloc-sep {
    display: flex;
    align-items: center;
    gap: .85rem;
    margin-bottom: 1.25rem;
  }

  .bloc-sep-label {
    font-family: 'Mulish', sans-serif;
    font-size: .68rem;
    font-weight: 700;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--or);
    white-space: nowrap;
  }

  .bloc-sep-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, var(--or-border), transparent);
  }

  /* ── Cartes — style unifié dialogue & note ── */
  .entrees-liste { display: flex; flex-direction: column; gap: .85rem; }

  .entree-carte {
    display: flex;
    flex-direction: column;
    gap: .5rem;
    text-decoration: none;
    padding: 1.25rem 1.45rem;
    border: 1px solid var(--or-border);
    border-left: 3px solid var(--or-vif);
    border-radius: 0 10px 10px 0;
    background: var(--or-bg);
    opacity: 0;
    animation: rise .7s ease forwards;
    transition: border-color .22s, border-left-color .22s, background .22s, transform .22s, box-shadow .22s;
    box-shadow: 0 2px 10px rgba(180,83,9,.08), 0 1px 3px rgba(180,83,9,.05);
  }

  .entree-carte:hover {
    border-color: rgba(245,158,11,.55);
    border-left-color: var(--feu);
    background: #fff4e8;
    transform: translateX(4px);
    box-shadow: 0 6px 24px rgba(234,88,12,.11), 0 2px 8px rgba(180,83,9,.07);
  }

  /* ── Méta ── */
  .entree-meta { display: flex; align-items: center; gap: .5rem; flex-wrap: wrap; }

  .entree-type {
    font-family: 'Mulish', sans-serif;
    font-size: .6rem;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
    padding: .14rem .42rem;
    border-radius: 3px;
    border: 1px solid;
  }

  .entree-type--dialogue {
    color: var(--feu-deep);
    background: rgba(234,88,12,.07);
    border-color: rgba(234,88,12,.25);
  }

  .entree-type--note {
    color: var(--or);
    background: rgba(251,191,36,.08);
    border-color: rgba(251,191,36,.38);
  }

  .entree-date {
    font-family: 'Mulish', sans-serif;
    font-size: .67rem;
    font-weight: 300;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: #92700a;
  }

  .entree-stade { font-size: .78rem; line-height: 1; }

  .entree-tag {
    font-family: 'Mulish', sans-serif;
    font-size: .6rem;
    font-weight: 300;
    color: #a86010;
    padding: .1rem .36rem;
    border: 1px solid rgba(253,230,138,.8);
    border-radius: 20px;
    background: rgba(251,191,36,.07);
  }

  /* ── Contenu ── */
  .entree-titre {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: 1.08rem;
    font-weight: 700;
    color: #1a1000;
    line-height: 1.35;
    transition: color .2s;
  }

  .entree-carte:hover .entree-titre { color: var(--feu-deep); }

  .entree-desc {
    font-family: 'Mulish', sans-serif;
    font-size: .87rem;
    font-weight: 300;
    color: #78580a;
    line-height: 1.7;
    max-width: 60ch;
  }

  .entree-extrait {
    margin: .1rem 0 0;
    padding: .6rem 1rem;
    border-left: 2px solid rgba(245,158,11,.35);
    background: rgba(251,191,36,.06);
    border-radius: 0 4px 4px 0;
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: .88rem;
    font-style: italic;
    color: #78480a;
    line-height: 1.72;
  }

  .entree-lire {
    font-family: 'Mulish', sans-serif;
    font-size: .67rem;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--feu);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity .2s, transform .2s;
    align-self: flex-start;
  }

  .entree-carte:hover .entree-lire { opacity: 1; transform: translateX(0); }
  @media (hover: none) { .entree-lire { opacity: .65; transform: translateX(0); } }

  /* ── Vide ── */
  .vide-encart {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: 4rem 2rem;
    border: 1px dashed var(--or-border);
    border-radius: 10px;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .vide-glyph { font-size: 1.8rem; color: var(--or); opacity: .3; }

  .vide-texte {
    font-family: 'Mulish', sans-serif;
    font-size: .9rem;
    font-weight: 300;
    font-style: italic;
    color: #92700a;
    line-height: 1.78;
  }

  /* ── Pied ── */
  .pied-encart {
    display: flex;
    align-items: flex-start;
    gap: .8rem;
    margin-top: 3.5rem;
    padding: 1rem 1.3rem;
    border: 1px solid var(--or-border);
    border-left: 3px solid rgba(245,158,11,.38);
    border-radius: 0 6px 6px 0;
    background: rgba(253,230,138,.07);
    opacity: 0;
    animation: rise .9s .7s ease forwards;
    position: relative;
    z-index: 1;
  }

  .pied-glyph {
    color: var(--or);
    font-size: .88rem;
    flex-shrink: 0;
    margin-top: .12rem;
    opacity: .55;
  }

  .pied-texte {
    font-family: 'Mulish', sans-serif;
    font-size: .87rem;
    font-weight: 300;
    font-style: italic;
    color: #78580a;
    line-height: 1.78;
  }

  /* ── Responsive ── */
  @media (max-width: 600px) {
    .page-wrap { padding: 0 1rem 4rem; }
    .entree-carte { padding: 1rem 1.1rem; }

  }

  /* ── Note compacte ── */
  .entree-carte--note {
    padding: .75rem 1.2rem;
  }

  .note-ligne-unique {
    display: flex;
    align-items: center;
    gap: .65rem;
    flex-wrap: nowrap;
    overflow: hidden;
  }

  .note-sep {
    color: var(--or-border);
    flex-shrink: 0;
  }

  .note-titre-inline {
    font-size: .97rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    flex: 1;
    margin: 0;
  }

  .note-lire {
    flex-shrink: 0;
    white-space: nowrap;
  }

    @keyframes rise {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  document.body.classList.add('page-carnet');

  const btns = document.querySelectorAll<HTMLButtonElement>('.filtre-btn');
  const blocs = document.querySelectorAll<HTMLElement>('.bloc[data-section]');

  // État : quels filtres sont actifs
  const actifs = new Set(['dialogue', 'note']);

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      const filtre = btn.dataset.filtre!;

      if (actifs.has(filtre)) {
        // Désactiver seulement si l'autre est encore actif
        const autresActifs = [...actifs].filter(f => f !== filtre);
        if (autresActifs.length === 0) return; // garder au moins un actif
        actifs.delete(filtre);
        btn.classList.remove('actif');
        btn.classList.add('inactif');
      } else {
        actifs.add(filtre);
        btn.classList.add('actif');
        btn.classList.remove('inactif');
      }

      blocs.forEach(bloc => {
        const section = bloc.dataset.section!;
        if (actifs.has(section)) {
          bloc.classList.remove('masque');
        } else {
          bloc.classList.add('masque');
        }
      });
    });
  });
</script>

</Base>
