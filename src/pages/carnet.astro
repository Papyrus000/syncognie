---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('carnet');

const sorted = [...entries].sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const TYPE_CONFIG: Record<string, { label: string; couleur: string; glyph: string }> = {
  'dialogue':  { label: 'Dialogue',  couleur: '#6a8fa8', glyph: '◈' },
  'note':      { label: 'Note',      couleur: '#7a9e7e', glyph: '◇' },
  'essai':     { label: 'Essai',     couleur: '#8b5e3c', glyph: '◉' },
  'fragment':  { label: 'Fragment',  couleur: '#9a7a5a', glyph: '◌' },
};

function formatDate(date: Date) {
  return date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
}

function formatDateCourt(date: Date) {
  return date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'short' });
}

function getYear(date: Date) {
  return date.getFullYear();
}

// Grouper par année
const parAnnee: Record<number, typeof sorted> = {};
for (const entry of sorted) {
  const y = getYear(entry.data.date);
  if (!parAnnee[y]) parAnnee[y] = [];
  parAnnee[y].push(entry);
}
const annees = Object.keys(parAnnee).map(Number).sort((a, b) => b - a);

const total = sorted.length;
const types = [...new Set(sorted.map(e => e.data.type))];
---

<Base title="Carnet — Syncognie" description="Notes, dialogues, essais — le cheminement de la pensée en mouvement.">
<div class="page-wrap">

  <!-- Filigrane SVG -->
  <svg class="header-filigrane" viewBox="0 0 420 340" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <circle cx="210" cy="170" r="110" stroke="#6a8fa8" stroke-width=".6" stroke-dasharray="2 10" opacity=".12" class="orb-a"/>
    <circle cx="210" cy="170" r="68"  stroke="#6a8fa8" stroke-width="1"   opacity=".08" class="orb-a-inner"/>
    <circle cx="210" cy="170" r="30"  fill="#6a8fa8" opacity=".03"/>
    <line x1="60"  y1="170" x2="360" y2="170" stroke="#6a8fa8" stroke-width=".4" opacity=".10" stroke-dasharray="2 10"/>
    <line x1="210" y1="60"  x2="210" y2="280" stroke="#6a8fa8" stroke-width=".4" opacity=".08" stroke-dasharray="2 10"/>
    <circle cx="210" cy="170" r="5"   fill="#6a8fa8" opacity=".22" class="node-c"/>
    <circle cx="210" cy="170" r="2"   fill="#f5f0e8" opacity=".60"/>
    <circle cx="130" cy="120" r="2.5" fill="#6a8fa8" opacity=".15" class="node-a"/>
    <circle cx="290" cy="220" r="2"   fill="#8b5e3c" opacity=".12" class="node-b"/>
    <circle cx="155" cy="230" r="1.5" fill="#6a8fa8" opacity=".12" class="node-a"/>
    <circle cx="270" cy="115" r="2"   fill="#6a8fa8" opacity=".10" class="node-b"/>
  </svg>

  <!-- En-tête -->
  <header class="page-header">
    <p class="page-eyebrow">Carnet</p>
    <h1 class="page-titre">La pensée<br><em>en mouvement.</em></h1>
    <p class="page-sous">Notes prises au fil des conversations, des lectures, des questions qui ne lâchent pas. Dialogues avec une IA, fragments, essais. Le cheminement compte autant que l'arrivée.</p>
    <div class="page-stats">
      <span class="stat"><span class="stat-n">{total}</span><span class="stat-label">entrées</span></span>
      <span class="stat-sep">·</span>
      <span class="stat"><span class="stat-n">{annees.length}</span><span class="stat-label">{annees.length > 1 ? 'années' : 'année'}</span></span>
      <span class="stat-sep">·</span>
      <span class="stat"><span class="stat-n">{types.length}</span><span class="stat-label">formats</span></span>
    </div>
  </header>

  <!-- Légende des types -->
  <div class="legende-wrap">
    {Object.entries(TYPE_CONFIG).map(([key, cfg]) => (
      <span class="legende-item">
        <span class="legende-glyph" style={`color:${cfg.couleur}`}>{cfg.glyph}</span>
        <span class="legende-label">{cfg.label}</span>
      </span>
    ))}
  </div>

  <!-- Entrées groupées par année -->
  {annees.map((annee, ai) => (
    <section class="annee-section" style={`animation-delay:${0.15 + ai * 0.08}s`}>

      <div class="section-sep">
        <span class="sep-line"/>
        <span class="sep-centre">
          <span class="sep-diamond"/>
          <span class="sep-annee">{annee}</span>
          <span class="sep-diamond"/>
        </span>
        <span class="sep-line"/>
      </div>

      <div class="entries-list">
        {parAnnee[annee].map((entry, i) => {
          const cfg = TYPE_CONFIG[entry.data.type] ?? TYPE_CONFIG['note'];
          const idx = sorted.indexOf(entry) + 1;
          const numTotal = total - sorted.indexOf(entry);

          return (
            <div class="entry-row" style={`animation-delay:${0.2 + i * 0.06}s`}>

              <!-- Fil chronologique -->
              <div class="entry-fil-wrap">
                <div class="entry-num" style={`color:${cfg.couleur}; border-color:${cfg.couleur}33; background:${cfg.couleur}0d`}>
                  {String(numTotal).padStart(2, '0')}
                </div>
                {i < parAnnee[annee].length - 1 && <div class="entry-trait" style={`background:linear-gradient(to bottom, ${cfg.couleur}33, transparent)`}/>}
              </div>

              <!-- Carte -->
              <a href={`/carnet/${entry.slug}`} class="entry-card" style={`--c:${cfg.couleur}`}>
                <div class="entry-card-lueur"/>

                <div class="entry-meta">
                  <span class="entry-type-badge" style={`color:${cfg.couleur}; background:${cfg.couleur}12; border-color:${cfg.couleur}30`}>
                    <span class="entry-glyph">{cfg.glyph}</span>
                    {cfg.label}
                  </span>
                  <span class="entry-date">{formatDate(entry.data.date)}</span>
                  {entry.data.tags?.slice(0, 2).map((tag: string) => (
                    <span class="entry-tag">{tag}</span>
                  ))}
                </div>

                <h2 class="entry-titre">{entry.data.title}</h2>

                {entry.data.description && (
                  <p class="entry-desc">{entry.data.description}</p>
                )}

                {entry.data.extrait && (
                  <blockquote class="entry-extrait" style={`border-color:${cfg.couleur}40`}>
                    {entry.data.extrait}
                  </blockquote>
                )}

                <span class="entry-lire">Lire &rarr;</span>
              </a>

            </div>
          );
        })}
      </div>

    </section>
  ))}

  <!-- État vide -->
  {total === 0 && (
    <div class="vide-encart">
      <span class="vide-glyph">◇</span>
      <p class="vide-texte">Le carnet est vide pour l'instant.<br/>Les premières entrées arrivent bientôt.</p>
    </div>
  )}

  <!-- Note de bas de page -->
  <div class="invitation-encart">
    <span class="invitation-glyph">◈</span>
    <p class="invitation-texte">Ce carnet ne prétend pas à la complétude. Chaque entrée est une carte — utile pour ce qu'elle montre, honnête sur ce qu'elle ne montre pas.</p>
  </div>

</div>

<style>
  :root {
    --carnet:      #6a8fa8;
    --carnet-dim:  rgba(106,143,168,.28);
    --carnet-bg:   rgba(106,143,168,.06);
    --carnet-deep: #3d6478;
  }

  .page-wrap { max-width: var(--max); margin: 0 auto; padding: 0 1.5rem 6rem; position: relative; }

  /* ── Filigrane ── */
  .header-filigrane { position: absolute; top: 1rem; right: -1rem; width: 340px; height: 270px; pointer-events: none; z-index: 0; }
  @keyframes orb-pulse { 0%,100%{ opacity:.10 } 50%{ opacity:.06 } }
  .orb-a       { animation: orb-pulse 9s ease-in-out infinite; }
  .orb-a-inner { animation: orb-pulse 9s 1s ease-in-out infinite; }
  @keyframes node-drift { 0%,100%{transform:translate(0,0)} 33%{transform:translate(1.5px,-2px)} 66%{transform:translate(-1px,1.5px)} }
  .node-a { animation: node-drift 9s ease-in-out infinite; }
  .node-b { animation: node-drift 9s 2s ease-in-out infinite; }
  .node-c { animation: node-drift 7s 1s ease-in-out infinite; }

  /* ── En-tête ── */
  .page-header { position: relative; z-index: 1; padding: 2.8rem 0 1.75rem; opacity: 0; animation: rise .9s .05s ease forwards; }
  .page-eyebrow { font-family: 'Mulish', sans-serif; font-size: .58rem; font-weight: 700; letter-spacing: .28em; text-transform: uppercase; color: var(--carnet-deep); opacity: .8; margin-bottom: .85rem; }
  .page-titre { font-family: 'Libre Baskerville', Georgia, serif; font-size: clamp(1.9rem, 3.8vw, 2.5rem); font-weight: 700; color: var(--ink); line-height: 1.15; letter-spacing: -.02em; margin-bottom: .9rem; }
  .page-titre em { font-style: italic; font-weight: 400; color: var(--carnet); }
  .page-sous { font-family: 'Mulish', sans-serif; font-size: .95rem; font-weight: 300; color: var(--ink-soft); line-height: 1.8; max-width: 52ch; margin-bottom: 1.5rem; }
  .page-stats { display: flex; align-items: center; gap: .75rem; flex-wrap: wrap; opacity: 0; animation: rise .9s .15s ease forwards; }
  .stat { display: flex; align-items: baseline; gap: .35rem; }
  .stat-n { font-family: 'Libre Baskerville', Georgia, serif; font-size: 1.4rem; font-weight: 700; color: var(--carnet); line-height: 1; letter-spacing: -.02em; }
  .stat-label { font-family: 'Mulish', sans-serif; font-size: .72rem; font-weight: 300; letter-spacing: .12em; text-transform: uppercase; color: var(--ink-soft); }
  .stat-sep { color: var(--rule); }

  /* ── Légende ── */
  .legende-wrap { display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; margin-bottom: 2.2rem; padding: 1rem 1.35rem; border: 1px solid var(--carnet-dim); border-top: 2.5px solid var(--carnet); border-radius: 0 0 6px 6px; background: var(--carnet-bg); opacity: 0; animation: rise .9s .2s ease forwards; box-shadow: 0 2px 6px rgba(60,30,10,.06), 0 1px 2px rgba(60,30,10,.04); }
  .legende-item { display: flex; align-items: center; gap: .45rem; }
  .legende-glyph { font-size: .9rem; line-height: 1; }
  .legende-label { font-family: 'Mulish', sans-serif; font-size: .72rem; font-weight: 300; letter-spacing: .08em; color: var(--ink-mid); }

  /* ── Séparateur année ── */
  .annee-section { opacity: 0; animation: rise .8s ease forwards; }
  .section-sep { display: flex; align-items: center; gap: .9rem; margin: 2.5rem 0 .75rem; }
  .sep-line { flex: 1; height: 1px; background: linear-gradient(to right, transparent, var(--rule), transparent); }
  .sep-centre { display: flex; align-items: center; gap: .5rem; }
  .sep-diamond { width: 5px; height: 5px; transform: rotate(45deg); background: var(--carnet); opacity: .6; }
  .sep-annee { font-family: 'Mulish', sans-serif; font-size: .75rem; font-weight: 700; letter-spacing: .2em; text-transform: uppercase; color: var(--carnet-deep); }

  /* ── Liste des entrées ── */
  .entries-list { display: flex; flex-direction: column; }
  .entry-row { display: flex; gap: 1.5rem; align-items: flex-start; opacity: 0; animation: rise .7s ease forwards; }

  /* Fil numéroté */
  .entry-fil-wrap { display: flex; flex-direction: column; align-items: center; flex-shrink: 0; width: 32px; padding-top: .15rem; }
  .entry-num { width: 28px; height: 28px; border-radius: 50%; border: 1px solid var(--carnet-dim); display: flex; align-items: center; justify-content: center; font-family: 'Libre Baskerville', Georgia, serif; font-size: .78rem; font-weight: 700; color: var(--carnet); background: var(--carnet-bg); flex-shrink: 0; }
  .entry-trait { width: 1px; flex: 1; min-height: 2.5rem; background: linear-gradient(to bottom, var(--carnet-dim), transparent); margin: .35rem 0; }

  /* Carte entrée */
  .entry-card { flex: 1; display: flex; flex-direction: column; gap: .45rem; text-decoration: none; padding: 1.1rem 1.35rem; margin-bottom: 1rem; border: 1px solid var(--rule); border-radius: 7px; background: rgba(245,240,232,.55); position: relative; overflow: hidden; opacity: 0; animation: rise .7s ease forwards; transition: border-color .2s, background .2s, transform .2s, box-shadow .2s; box-shadow: 0 2px 6px rgba(60,30,10,.07), 0 1px 2px rgba(60,30,10,.05); }
  .entry-card-lueur { position: absolute; inset: 0; background: radial-gradient(ellipse 55% 35% at 5% 0%, color-mix(in srgb, var(--c) 10%, transparent), transparent 70%); opacity: 0; transition: opacity .3s; pointer-events: none; }
  .entry-card::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 2px; background: var(--c); border-radius: 2px 0 0 2px; transform: scaleY(0); transform-origin: top; transition: transform .28s ease; }
  .entry-card:hover { border-color: color-mix(in srgb, var(--c) 35%, transparent); background: color-mix(in srgb, var(--c) 4%, var(--bg)); transform: translateX(3px); box-shadow: 0 6px 20px color-mix(in srgb, var(--c) 12%, transparent), 0 2px 6px rgba(60,30,10,.08); }
  .entry-card:hover::before { transform: scaleY(1); }
  .entry-card:hover .entry-card-lueur { opacity: 1; }

  /* Méta */
  .entry-meta { display: flex; align-items: center; gap: .55rem; flex-wrap: wrap; }
  .entry-type-badge { display: inline-flex; align-items: center; gap: .3rem; font-family: 'Mulish', sans-serif; font-size: .65rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; padding: .12rem .4rem; border-radius: 3px; border: 1px solid; }
  .entry-glyph { font-size: .85rem; line-height: 1; }
  .entry-date { font-family: 'Mulish', sans-serif; font-size: .72rem; font-weight: 300; letter-spacing: .12em; text-transform: uppercase; color: var(--ink-mid); }
  .entry-tag { font-family: 'Mulish', sans-serif; font-size: .65rem; font-weight: 300; color: var(--ink-soft); padding: .1rem .38rem; border: 1px solid var(--rule); border-radius: 20px; }

  /* Titre & contenu */
  .entry-titre { font-family: 'Libre Baskerville', Georgia, serif; font-size: 1.05rem; font-weight: 400; font-style: italic; color: var(--ink); line-height: 1.4; transition: color .2s; }
  .entry-card:hover .entry-titre { color: var(--carnet-deep); }
  .entry-desc { font-family: 'Mulish', sans-serif; font-size: .88rem; font-weight: 300; color: var(--ink-soft); line-height: 1.65; max-width: 58ch; }
  .entry-extrait { margin: .2rem 0 0; padding: .55rem .85rem; border-left: 2px solid var(--carnet-dim); background: var(--carnet-bg); border-radius: 0 3px 3px 0; font-family: 'Libre Baskerville', Georgia, serif; font-size: .86rem; font-style: italic; color: var(--ink-mid); line-height: 1.65; }
  .entry-lire { font-family: 'Mulish', sans-serif; font-size: .72rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: var(--carnet); opacity: 0; transform: translateX(-4px); transition: opacity .2s, transform .2s; }
  .entry-card:hover .entry-lire { opacity: 1; transform: translateX(0); }
  @media (hover: none) { .entry-lire { opacity: .6; transform: translateX(0); } }

  /* ── État vide ── */
  .vide-encart { display: flex; flex-direction: column; align-items: center; gap: 1rem; padding: 3rem 2rem; border: 1px dashed var(--rule); border-radius: 8px; text-align: center; opacity: 0; animation: rise .9s .3s ease forwards; }
  .vide-glyph { font-size: 2rem; color: var(--carnet); opacity: .4; }
  .vide-texte { font-family: 'Mulish', sans-serif; font-size: .9rem; font-weight: 300; font-style: italic; color: var(--ink-soft); line-height: 1.75; }

  /* ── Note de bas ── */
  .invitation-encart { display: flex; align-items: flex-start; gap: .75rem; margin-top: 2.5rem; padding: 1rem 1.25rem; border: 1px solid var(--carnet-dim); border-left: 3px solid var(--carnet-dim); border-radius: 0 4px 4px 0; background: var(--carnet-bg); opacity: 0; animation: rise .9s .6s ease forwards; }
  .invitation-glyph { color: var(--carnet); font-size: .9rem; flex-shrink: 0; margin-top: .1rem; }
  .invitation-texte { font-family: 'Mulish', sans-serif; font-size: .88rem; font-weight: 300; font-style: italic; color: var(--ink-mid); line-height: 1.7; }

  /* ── Responsive ── */
  @media (max-width: 600px) { .page-wrap { padding: 0 1rem 4rem; } .header-filigrane { width: 220px; right: -1rem; top: 1rem; } .entry-fil-wrap { width: 28px; } .entry-num { width: 26px; height: 26px; font-size: .65rem; } }
  @keyframes rise { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
</style>

<script>document.body.classList.add('page-carnet');</script>
</Base>
