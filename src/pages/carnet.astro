---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('carnet');

const sorted = [...entries].sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);

const dialogues = sorted.filter(e => e.data.type === 'dialogue');
const notes     = sorted.filter(e => e.data.type === 'note');
const total     = sorted.length;

function formatDate(date: Date) {
  return date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
}
function formatJour(date: Date) {
  return date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'short' });
}
---

<Base title="Carnet — Syncognie" description="Dialogues construits et notes au fil des jours — le cheminement de la pensée en mouvement.">

<div class="page-wrap">

  <!-- ── En-tête ── -->
  <header class="page-header">
    <p class="page-eyebrow">Carnet</p>
    <h1 class="page-titre">La pensée<br><em>en mouvement.</em></h1>
    <p class="page-sous">Dialogues construits avec une IA, notes du quotidien — ce qui se passe quand on pense à voix haute. Le cheminement compte autant que l'arrivée.</p>

    <div class="page-compteurs">
      <div class="compteur">
        <span class="compteur-n">{dialogues.length}</span>
        <span class="compteur-label">{dialogues.length > 1 ? 'dialogues' : 'dialogue'}</span>
      </div>
      <span class="compteur-sep">·</span>
      <div class="compteur">
        <span class="compteur-n">{notes.length}</span>
        <span class="compteur-label">{notes.length > 1 ? 'notes' : 'note'}</span>
      </div>
    </div>

    <div class="page-badges">
      <span class="type-badge type-badge--dialogue">◈ Dialogue</span>
      <span class="type-badge type-badge--note">◦ Note</span>
    </div>
  </header>

  <!-- ── Dialogues ── -->
  {dialogues.length > 0 && (
    <section class="bloc" style="animation-delay:.1s">

      <div class="bloc-sep">
        <span class="bloc-sep-label">◈ {dialogues.length > 1 ? `${dialogues.length} dialogues` : '1 dialogue'}</span>
        <span class="bloc-sep-line"/>
      </div>

      <div class="dialogues-liste">
        {dialogues.map((entry, i) => (
          <a href={`/carnet/${entry.slug}`} class="dialogue-carte" style={`animation-delay:${0.15 + i * 0.07}s`}>

            <div class="dialogue-meta">
              <span class="dialogue-date">{formatDate(entry.data.date)}</span>
              {entry.data.stade && (
                <span class="dialogue-stade">
                  {entry.data.stade === 'arbre' ? '🌳' : entry.data.stade === 'pousse' ? '🌿' : '🌱'}
                </span>
              )}
              {entry.data.tags?.slice(0, 3).map((tag: string) => (
                <span class="dialogue-tag">{tag}</span>
              ))}
            </div>

            <h3 class="dialogue-titre">{entry.data.title}</h3>

            {entry.data.description && (
              <p class="dialogue-desc">{entry.data.description}</p>
            )}

            {entry.data.extrait && (
              <blockquote class="dialogue-extrait">{entry.data.extrait}</blockquote>
            )}

            <span class="dialogue-lire">Lire le dialogue →</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- ── Notes ── -->
  {notes.length > 0 && (
    <section class="bloc" style="animation-delay:.2s">

      <div class="bloc-sep">
        <span class="bloc-sep-label">◦ {notes.length > 1 ? `${notes.length} notes` : '1 note'}</span>
        <span class="bloc-sep-line"/>
      </div>

      <div class="notes-liste">
        {notes.map((entry, i) => (
          <a href={`/carnet/${entry.slug}`} class="note-ligne" style={`animation-delay:${0.2 + i * 0.05}s`}>
            <span class="note-jour">{formatJour(entry.data.date)}</span>
            <div class="note-trait"/>
            <span class="note-titre">{entry.data.title}</span>
            <span class="note-fleche">→</span>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- ── Vide ── -->
  {total === 0 && (
    <div class="vide-encart">
      <span class="vide-glyph">◦</span>
      <p class="vide-texte">Le carnet commence à s'écrire.<br/>Les premières entrées arrivent bientôt.</p>
    </div>
  )}

  <!-- ── Pied ── -->
  <div class="pied-encart">
    <span class="pied-glyph">◈</span>
    <p class="pied-texte">Ce carnet ne prétend pas à la complétude. Chaque entrée est une carte — utile pour ce qu'elle montre, honnête sur ce qu'elle ne montre pas.</p>
  </div>

</div>

<style>
  :root {
    --feu:       #ea580c;
    --feu-deep:  #9a3412;
    --or:        #b45309;
    --or-vif:    #f59e0b;
    --or-border: #fde68a;
    --or-bg:     #fff8f0;
    --or-bg2:    #fffdf5;
    --page-bg:   #fffaf5;
  }

  .page-wrap {
    max-width: var(--max, 760px);
    margin: 0 auto;
    padding: 0 1.5rem 6rem;
  }

  /* ── En-tête ── */
  .page-header {
    padding: 3rem 0 2.5rem;
    opacity: 0;
    animation: rise .9s .05s ease forwards;
  }

  .page-eyebrow {
    font-family: 'Mulish', sans-serif;
    font-size: .58rem;
    font-weight: 700;
    letter-spacing: .32em;
    text-transform: uppercase;
    color: var(--feu-deep);
    margin-bottom: .85rem;
  }

  .page-titre {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: clamp(2rem, 4.5vw, 2.9rem);
    font-weight: 700;
    color: #1a0800;
    line-height: 1.1;
    letter-spacing: -.025em;
    margin-bottom: .9rem;
  }

  .page-titre em {
    font-style: italic;
    font-weight: 400;
    color: var(--feu);
    display: block;
  }

  .page-sous {
    font-family: 'Mulish', sans-serif;
    font-size: .95rem;
    font-weight: 300;
    color: #78350f;
    line-height: 1.82;
    max-width: 52ch;
    margin-bottom: 1.75rem;
  }

  .page-compteurs {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
    opacity: 0;
    animation: rise .9s .15s ease forwards;
  }

  .compteur { display: flex; align-items: baseline; gap: .38rem; }

  .compteur-n {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: 1.85rem;
    font-weight: 700;
    color: var(--feu);
    line-height: 1;
    letter-spacing: -.03em;
  }

  .compteur-label {
    font-family: 'Mulish', sans-serif;
    font-size: .68rem;
    font-weight: 300;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--or);
  }

  .compteur-sep { color: var(--or-border); font-size: 1.1rem; }

  .page-badges {
    display: flex;
    gap: .6rem;
    opacity: 0;
    animation: rise .9s .25s ease forwards;
  }

  .type-badge {
    font-family: 'Mulish', sans-serif;
    font-size: .63rem;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
    padding: .26rem .72rem;
    border-radius: 4px;
    border: 1px solid;
  }

  .type-badge--dialogue {
    background: rgba(234,88,12,.07);
    color: var(--feu-deep);
    border-color: rgba(234,88,12,.28);
  }

  .type-badge--note {
    background: rgba(251,191,36,.09);
    color: var(--or);
    border-color: rgba(251,191,36,.42);
  }

  /* ── Blocs ── */
  .bloc {
    margin-bottom: 3rem;
    opacity: 0;
    animation: rise .8s ease forwards;
  }

  .bloc-sep {
    display: flex;
    align-items: center;
    gap: .85rem;
    margin-bottom: 1.25rem;
  }

  .bloc-sep-label {
    font-family: 'Mulish', sans-serif;
    font-size: .68rem;
    font-weight: 700;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--or);
    white-space: nowrap;
  }

  .bloc-sep-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, var(--or-border), transparent);
  }

  /* ── Cartes dialogue ── */
  .dialogues-liste { display: flex; flex-direction: column; gap: .85rem; }

  .dialogue-carte {
    display: flex;
    flex-direction: column;
    gap: .5rem;
    text-decoration: none;
    padding: 1.25rem 1.45rem;
    border: 1px solid var(--or-border);
    border-left: 3px solid var(--or-vif);
    border-radius: 0 10px 10px 0;
    background: var(--or-bg);
    opacity: 0;
    animation: rise .7s ease forwards;
    transition: border-color .22s, border-left-color .22s, background .22s, transform .22s, box-shadow .22s;
    box-shadow: 0 2px 8px rgba(180,83,9,.06);
  }

  .dialogue-carte:hover {
    border-color: rgba(245,158,11,.55);
    border-left-color: var(--feu);
    background: #fff4e8;
    transform: translateX(4px);
    box-shadow: 0 6px 22px rgba(234,88,12,.09);
  }

  .dialogue-meta { display: flex; align-items: center; gap: .55rem; flex-wrap: wrap; }

  .dialogue-date {
    font-family: 'Mulish', sans-serif;
    font-size: .67rem;
    font-weight: 300;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: #92700a;
  }

  .dialogue-stade { font-size: .78rem; line-height: 1; }

  .dialogue-tag {
    font-family: 'Mulish', sans-serif;
    font-size: .6rem;
    font-weight: 300;
    color: #a86010;
    padding: .1rem .36rem;
    border: 1px solid rgba(253,230,138,.8);
    border-radius: 20px;
    background: rgba(251,191,36,.08);
  }

  .dialogue-titre {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: 1.08rem;
    font-weight: 700;
    color: #1a1000;
    line-height: 1.35;
    transition: color .2s;
  }

  .dialogue-carte:hover .dialogue-titre { color: var(--feu-deep); }

  .dialogue-desc {
    font-family: 'Mulish', sans-serif;
    font-size: .87rem;
    font-weight: 300;
    color: #78580a;
    line-height: 1.7;
    max-width: 60ch;
  }

  .dialogue-extrait {
    margin: .1rem 0 0;
    padding: .6rem 1rem;
    border-left: 2px solid rgba(245,158,11,.35);
    background: rgba(251,191,36,.06);
    border-radius: 0 4px 4px 0;
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: .88rem;
    font-style: italic;
    color: #78480a;
    line-height: 1.72;
  }

  .dialogue-lire {
    font-family: 'Mulish', sans-serif;
    font-size: .67rem;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--feu);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity .2s, transform .2s;
    align-self: flex-start;
  }

  .dialogue-carte:hover .dialogue-lire { opacity: 1; transform: translateX(0); }
  @media (hover: none) { .dialogue-lire { opacity: .65; transform: translateX(0); } }

  /* ── Liste notes ── */
  .notes-liste { display: flex; flex-direction: column; gap: .5rem; }

  .note-ligne {
    display: flex;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
    padding: .75rem .95rem;
    border: 1px solid var(--or-border);
    border-radius: 8px;
    background: var(--or-bg2);
    opacity: 0;
    animation: rise .6s ease forwards;
    transition: background .18s, border-color .18s, transform .18s;
  }

  .note-ligne:hover {
    background: #fff8e8;
    border-color: rgba(245,158,11,.55);
    transform: translateX(3px);
  }

  .note-jour {
    font-family: 'Mulish', sans-serif;
    font-size: .62rem;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--or);
    flex-shrink: 0;
    min-width: 44px;
    text-align: center;
    line-height: 1.3;
  }

  .note-trait {
    width: 1px;
    height: 26px;
    background: linear-gradient(to bottom, rgba(245,158,11,.45), transparent);
    flex-shrink: 0;
  }

  .note-titre {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: .97rem;
    font-style: italic;
    color: #1a1000;
    line-height: 1.4;
    flex: 1;
    transition: color .18s;
  }

  .note-ligne:hover .note-titre { color: var(--or); }

  .note-fleche {
    font-size: .88rem;
    color: var(--or-vif);
    opacity: 0;
    transform: translateX(-3px);
    transition: opacity .18s, transform .18s;
    flex-shrink: 0;
  }

  .note-ligne:hover .note-fleche { opacity: 1; transform: translateX(0); }
  @media (hover: none) { .note-fleche { opacity: .45; transform: translateX(0); } }

  /* ── Vide ── */
  .vide-encart {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: 4rem 2rem;
    border: 1px dashed var(--or-border);
    border-radius: 10px;
    text-align: center;
  }

  .vide-glyph { font-size: 1.8rem; color: var(--or); opacity: .3; }

  .vide-texte {
    font-family: 'Mulish', sans-serif;
    font-size: .9rem;
    font-weight: 300;
    font-style: italic;
    color: #92700a;
    line-height: 1.78;
  }

  /* ── Pied ── */
  .pied-encart {
    display: flex;
    align-items: flex-start;
    gap: .8rem;
    margin-top: 3.5rem;
    padding: 1rem 1.3rem;
    border: 1px solid var(--or-border);
    border-left: 3px solid rgba(245,158,11,.38);
    border-radius: 0 6px 6px 0;
    background: rgba(253,230,138,.07);
    opacity: 0;
    animation: rise .9s .7s ease forwards;
  }

  .pied-glyph {
    color: var(--or);
    font-size: .88rem;
    flex-shrink: 0;
    margin-top: .12rem;
    opacity: .55;
  }

  .pied-texte {
    font-family: 'Mulish', sans-serif;
    font-size: .87rem;
    font-weight: 300;
    font-style: italic;
    color: #78580a;
    line-height: 1.78;
  }

  /* ── Responsive ── */
  @media (max-width: 600px) {
    .page-wrap { padding: 0 1rem 4rem; }
    .dialogue-carte { padding: 1rem 1.1rem; }
  }

  @keyframes rise {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>

<script>document.body.classList.add('page-carnet');</script>

</Base>
