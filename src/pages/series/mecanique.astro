---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');

const episodes = allArticles
  .filter(a => a.data.serie === "Mécanique")
  .sort((a, b) => (a.data.episode ?? 0) - (b.data.episode ?? 0));

const totalEpisodes = episodes.length;
const nbConsolidés  = episodes.filter(e => e.data.stade === 'arbre').length;

const stadeConfig: Record<string, { emoji: string; label: string; color: string }> = {
  graine: { emoji: '🌱', label: 'Graine', color: '#2e7d4e' },
  pousse: { emoji: '🌿', label: 'Pousse', color: '#38783c' },
  arbre:  { emoji: '🌳', label: 'Arbre',  color: '#224422' },
};

const engagementRank: Record<string, number> = { pause: 1, lecture: 2, immersion: 3 };
function maxEngagement(arts: typeof allArticles) {
  let max = 0;
  for (const a of arts) {
    const r = engagementRank[a.data.engagement ?? ''] ?? 0;
    if (r > max) max = r;
  }
  return max;
}
const eng = maxEngagement(episodes);
---

<Base title="Mécanique — Le moteur silencieux · Syncognie">
<div class="page-wrap">

  <header class="page-header">

    <!-- ══ Filigrane chantier : structure métallique, échafaudage, poutrelles ══ -->
    <svg class="header-filigrane" viewBox="0 0 440 320" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">

      <!-- Poutrelle verticale gauche -->
      <line x1="52" y1="28" x2="52" y2="292" stroke="#34302a" stroke-width="3" opacity=".22" stroke-linecap="square"/>
      <!-- Rivets le long de la poutrelle gauche -->
      <circle cx="52" cy="62"  r="3" fill="#34302a" opacity=".28"/>
      <circle cx="52" cy="114" r="3" fill="#34302a" opacity=".24"/>
      <circle cx="52" cy="166" r="3" fill="#34302a" opacity=".26"/>
      <circle cx="52" cy="218" r="3" fill="#34302a" opacity=".22"/>
      <circle cx="52" cy="270" r="3" fill="#34302a" opacity=".20"/>

      <!-- Poutrelle verticale droite -->
      <line x1="174" y1="40" x2="174" y2="280" stroke="#34302a" stroke-width="2.2" opacity=".17" stroke-linecap="square"/>
      <circle cx="174" cy="80"  r="2.5" fill="#34302a" opacity=".22"/>
      <circle cx="174" cy="136" r="2.5" fill="#34302a" opacity=".20"/>
      <circle cx="174" cy="192" r="2.5" fill="#34302a" opacity=".18"/>
      <circle cx="174" cy="248" r="2.5" fill="#34302a" opacity=".16"/>

      <!-- Traverse horizontale haute -->
      <line x1="40" y1="62" x2="186" y2="62" stroke="#34302a" stroke-width="2.4" opacity=".18" stroke-linecap="square"/>
      <!-- Traverse horizontale milieu -->
      <line x1="40" y1="166" x2="186" y2="166" stroke="#34302a" stroke-width="2.4" opacity=".15" stroke-linecap="square"/>
      <!-- Traverse horizontale basse -->
      <line x1="40" y1="270" x2="186" y2="270" stroke="#34302a" stroke-width="2" opacity=".14" stroke-linecap="square"/>

      <!-- Contreventements diagonaux — croix Saint-André -->
      <line x1="52"  y1="62"  x2="174" y2="166" stroke="#e85d04" stroke-width="1"   opacity=".28" stroke-dasharray="4 6"/>
      <line x1="174" y1="62"  x2="52"  y2="166" stroke="#34302a" stroke-width=".8"  opacity=".14" stroke-dasharray="4 6"/>
      <line x1="52"  y1="166" x2="174" y2="270" stroke="#e85d04" stroke-width="1"   opacity=".22" stroke-dasharray="4 6"/>
      <line x1="174" y1="166" x2="52"  y2="270" stroke="#34302a" stroke-width=".8"  opacity=".12" stroke-dasharray="4 6"/>

      <!-- Grand engrenage droit — en appui sur la structure -->
      <g class="gear-a" style="transform-origin:300px 148px">
        <circle cx="300" cy="148" r="68"  stroke="#34302a" stroke-width="1.2" opacity=".16"/>
        <circle cx="300" cy="148" r="52"  stroke="#34302a" stroke-width=".8"  opacity=".11"/>
        <circle cx="300" cy="148" r="14"  fill="none" stroke="#e85d04" stroke-width="1.4" opacity=".32"/>
        <circle cx="300" cy="148" r="4"   fill="#e85d04" opacity=".42"/>
        <!-- Dents : 12 -->
        <rect x="294" y="72"  width="12" height="18" rx="2" fill="#34302a" opacity=".22"/>
        <rect x="294" y="210" width="12" height="18" rx="2" fill="#34302a" opacity=".22"/>
        <rect x="218" y="142" width="18" height="12" rx="2" fill="#34302a" opacity=".22"/>
        <rect x="364" y="142" width="18" height="12" rx="2" fill="#34302a" opacity=".22"/>
        <rect x="238" y="93"  width="18" height="12" rx="2" fill="#34302a" opacity=".17" transform="rotate(-45 238 93)"/>
        <rect x="350" y="93"  width="18" height="12" rx="2" fill="#34302a" opacity=".17" transform="rotate(45 350 93)"/>
        <rect x="238" y="191" width="18" height="12" rx="2" fill="#34302a" opacity=".17" transform="rotate(45 238 191)"/>
        <rect x="350" y="191" width="18" height="12" rx="2" fill="#34302a" opacity=".17" transform="rotate(-45 350 191)"/>
        <!-- Rayons internes -->
        <line x1="300" y1="100" x2="300" y2="134" stroke="#34302a" stroke-width=".8" opacity=".14"/>
        <line x1="300" y1="162" x2="300" y2="196" stroke="#34302a" stroke-width=".8" opacity=".14"/>
        <line x1="252" y1="148" x2="286" y2="148" stroke="#34302a" stroke-width=".8" opacity=".14"/>
        <line x1="314" y1="148" x2="348" y2="148" stroke="#34302a" stroke-width=".8" opacity=".14"/>
      </g>

      <!-- Petit engrenage bas-gauche, emboîté dans la structure -->
      <g class="gear-b" style="transform-origin:108px 238px">
        <circle cx="108" cy="238" r="36"  stroke="#34302a" stroke-width="1"   opacity=".14"/>
        <circle cx="108" cy="238" r="26"  stroke="#34302a" stroke-width=".6"  opacity=".09"/>
        <circle cx="108" cy="238" r="7"   fill="none" stroke="#e85d04" stroke-width="1.2" opacity=".28"/>
        <circle cx="108" cy="238" r="2.5" fill="#e85d04" opacity=".38"/>
        <rect x="103" y="196" width="10" height="14" rx="2" fill="#34302a" opacity=".17"/>
        <rect x="103" y="266" width="10" height="14" rx="2" fill="#34302a" opacity=".17"/>
        <rect x="68"  y="233" width="14" height="10" rx="2" fill="#34302a" opacity=".17"/>
        <rect x="138" y="233" width="14" height="10" rx="2" fill="#34302a" opacity=".17"/>
        <rect x="79"  y="206" width="14" height="10" rx="2" fill="#34302a" opacity=".13" transform="rotate(-45 79 206)"/>
        <rect x="129" y="206" width="14" height="10" rx="2" fill="#34302a" opacity=".13" transform="rotate(45 129 206)"/>
        <rect x="79"  y="260" width="14" height="10" rx="2" fill="#34302a" opacity=".13" transform="rotate(45 79 260)"/>
        <rect x="129" y="260" width="14" height="10" rx="2" fill="#34302a" opacity=".13" transform="rotate(-45 129 260)"/>
      </g>

      <!-- Axe de liaison engrenages -->
      <line x1="232" y1="155" x2="144" y2="228" stroke="#e85d04" stroke-width=".8" opacity=".22" stroke-dasharray="3 5"/>

      <!-- Points d'engrenement pulsants -->
      <circle cx="232" cy="155" r="4"   fill="#e85d04" opacity=".38" class="mesh-pulse"/>
      <circle cx="144" cy="228" r="3"   fill="#e85d04" opacity=".30" class="mesh-pulse-b"/>

      <!-- Vis / boulons décoratifs aux intersections de la structure -->
      <circle cx="52"  cy="62"  r="5.5" stroke="#e85d04" stroke-width="1" opacity=".35" fill="#f5f0e8" fill-opacity=".6"/>
      <circle cx="174" cy="62"  r="5.5" stroke="#e85d04" stroke-width="1" opacity=".28" fill="#f5f0e8" fill-opacity=".5"/>
      <circle cx="52"  cy="166" r="5.5" stroke="#e85d04" stroke-width="1" opacity=".32" fill="#f5f0e8" fill-opacity=".6"/>
      <circle cx="174" cy="166" r="5.5" stroke="#e85d04" stroke-width="1" opacity=".28" fill="#f5f0e8" fill-opacity=".5"/>
      <circle cx="52"  cy="270" r="5"   stroke="#34302a" stroke-width=".8" opacity=".22" fill="#f5f0e8" fill-opacity=".4"/>
      <circle cx="174" cy="270" r="5"   stroke="#34302a" stroke-width=".8" opacity=".18" fill="#f5f0e8" fill-opacity=".4"/>
    </svg>

    <a class="back" href="/articles">
      <span class="back-arrow"><svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg></span>
      Articles
    </a>

    <p class="page-eyebrow">Série · Mécanique</p>
    <h1 class="page-titre">Le moteur<br><em>silencieux</em></h1>
    <p class="page-sous">
      Les rouages invisibles qui font tourner les comportements, les systèmes, les relations.
      Pas la surface des choses — ce qui les fait tenir ou se dérégler.
    </p>

    <div class="page-stats">
      <span class="stat"><span class="stat-n">{totalEpisodes}</span><span class="stat-label">note{totalEpisodes > 1 ? 's' : ''}</span></span>
      {nbConsolidés > 0 && <><span class="stat-sep">·</span><span class="stat"><span class="stat-n">{nbConsolidés}</span><span class="stat-label">consolidé{nbConsolidés > 1 ? 's' : ''}</span></span></>}
      {eng > 0 && (
        <><span class="stat-sep">·</span>
        <span class="eng-wrap">
          <span class="eng-niveau">Niveau&nbsp;:</span>
          <span class="eng-indicator">
            <span class={`eng-bar eng-b1${eng >= 1 ? ' on' : ''}`}></span>
            <span class={`eng-bar eng-b2${eng >= 2 ? ' on' : ''}`}></span>
            <span class={`eng-bar eng-b3${eng >= 3 ? ' on' : ''}`}></span>
          </span>
        </span></>
      )}
    </div>
  </header>

  <div class="ornament-sep">
    <div class="orn-line"></div>
    <div class="orn-centre">
      <div class="orn-bolt"></div>
      <span class="orn-label">Les notes</span>
      <div class="orn-bolt"></div>
    </div>
    <div class="orn-line"></div>
  </div>

  <div class="episodes-list">
    {episodes.length === 0 ? (
      <div class="empty-state">
        <span class="empty-glyph">⚙</span>
        <p class="empty-titre">Les notes arrivent</p>
        <p class="empty-desc">Le moteur est en cours d'assemblage.</p>
      </div>
    ) : episodes.map((ep, i) => {
      const stadeInfo = ep.data.stade ? stadeConfig[ep.data.stade] : null;
      const date = ep.data.date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
      const readTime = Math.max(1, Math.round(ep.body.split(/\s+/).length / 200));
      const estDernier = i === episodes.length - 1;
      return (
        <div class="episode-row">
          <div class="episode-fil-wrap">
            <div class="episode-numero">{ep.data.episode ?? i + 1}</div>
            {!estDernier && <div class="episode-trait"></div>}
          </div>
          <a class="episode-card" href={`/articles/${ep.id}`} style={`animation-delay:${0.2 + i * 0.1}s`}>
            <div class="episode-card-meta">
              <span class="episode-date">{date}</span>
              <span class="episode-readtime">· {readTime} min</span>
              {stadeInfo && (
                <span class="badge badge-stade" style={`color:${stadeInfo.color}`}>
                  {stadeInfo.emoji} {stadeInfo.label}
                </span>
              )}
            </div>
            <p class="episode-titre">{ep.data.title}</p>
            {ep.data.description && <p class="episode-desc">{ep.data.description}</p>}
            {ep.data.tags && ep.data.tags.length > 0 && (
              <div class="episode-tags">
                {ep.data.tags.map((t: string) => <span class="episode-tag">{t}</span>)}
              </div>
            )}
            <span class="episode-lire">Lire →</span>
          </a>
        </div>
      );
    })}

    <div class="episode-row">
      <div class="episode-fil-wrap">
        <div class="episode-numero episode-numero--ghost">{totalEpisodes + 1}</div>
      </div>
      <div class="episode-card episode-card--ghost">
        <p class="episode-titre episode-titre--ghost">Prochaine note</p>
        <p class="episode-desc">En cours d'écriture — à venir.</p>
      </div>
    </div>
  </div>

  <div class="invitation-encart">
    <span class="invitation-glyph">⚙</span>
    <p class="invitation-texte">Mécanique explore ce qui se passe sous la surface — les forces, les contraintes, les boucles de rétroaction qui expliquent pourquoi les choses fonctionnent ou lâchent.</p>
  </div>

</div>
</Base>

<style>
  :root {
    /* ── Palette Mécanique : charbon chantier + orange construction ── */
    --mec:        #34302a;           /* charbon dominant — la bande */
    --mec-mid:    #4a4540;           /* charbon intermédiaire */
    --mec-dim:    rgba(52,48,42,.35);
    --mec-bg:     rgba(52,48,42,.055);
    --mec-text:   #1e1c18;
    --orange:     #e85d04;           /* orange chantier — accent */
    --orange-dim: rgba(232,93,4,.32);
    --orange-bg:  rgba(232,93,4,.06);
    --gold:       #e8b832;
    --parch:      #f5f0e8;
    --ink:        #1a1714;
    --ink-soft:   #9a9189;
    --ink-mid:    #7a7068;
    --rule:       #ddd6c8;
    --max:        740px;
  }

  .page-wrap { max-width: var(--max); margin: 0 auto; padding: 0 1.75rem 6rem; }

  /* ── Filigrane ── */
  .page-header { padding: 0 0 2.5rem; position: relative; overflow: visible; opacity: 0; animation: rise .9s .05s ease forwards; }
  .header-filigrane {
    position: absolute; right: -1.5rem; top: .5rem;
    width: 380px; height: auto; pointer-events: none;
    /* Fondu côté gauche pour ne pas empiéter sur le texte */
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 28%, black 80%, transparent 100%);
    mask-image: linear-gradient(to right, transparent 0%, black 28%, black 80%, transparent 100%);
  }
  @media (max-width: 600px) {
    .header-filigrane { width: 200px; top: 2rem; right: -.5rem; opacity: .45; }
  }

  /* Animations engrenages */
  .gear-a  { animation: gear-cw  16s linear infinite; }
  .gear-b  { animation: gear-ccw 11s linear infinite; }
  @keyframes gear-cw  { from{transform:rotate(0deg)}   to{transform:rotate(360deg)}  }
  @keyframes gear-ccw { from{transform:rotate(0deg)}   to{transform:rotate(-360deg)} }
  .mesh-pulse   { animation: mp 2.8s ease-in-out infinite; }
  .mesh-pulse-b { animation: mp 3.4s ease-in-out infinite .6s; }
  @keyframes mp { 0%,100%{opacity:.22} 50%{opacity:.62} }

  /* ── Navigation retour ── */
  .back {
    display: inline-flex; align-items: center; gap: .5rem;
    padding: 2.5rem 0 2rem;
    font-family: 'Mulish', sans-serif; font-size: .6rem; font-weight: 700;
    letter-spacing: .2em; text-transform: uppercase;
    color: var(--ink-soft); text-decoration: none;
    opacity: 0; animation: rise .8s .05s ease forwards;
    transition: color .2s, gap .2s;
  }
  .back:hover { color: var(--mec-text); gap: .7rem; }
  .back-arrow {
    width: 18px; height: 18px;
    border: 1px solid var(--rule); border-radius: 3px;
    display: flex; align-items: center; justify-content: center;
  }
  .back-arrow svg { width: 11px; height: 11px; stroke: currentColor; stroke-width: 2; fill: none; }

  /* ── En-tête de page ── */
  .page-eyebrow {
    font-family: 'Mulish', sans-serif; font-size: .6rem; font-weight: 700;
    letter-spacing: .28em; text-transform: uppercase;
    color: var(--mec-mid); opacity: .75; margin-bottom: 1rem;
  }
  .page-titre {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: clamp(1.8rem, 3.5vw, 2.4rem); font-weight: 700;
    color: var(--ink); line-height: 1.2; letter-spacing: -.02em; margin-bottom: .9rem;
  }
  /* L'italique prend la couleur orange — chaleur chantier */
  .page-titre em { font-style: italic; font-weight: 400; color: var(--orange); }
  .page-sous {
    font-family: 'Mulish', sans-serif; font-size: .875rem; font-weight: 300;
    color: var(--ink-soft); line-height: 1.8; max-width: 52ch; margin-bottom: 1.75rem;
  }

  /* ── Stats ── */
  .page-stats {
    display: flex; align-items: center; gap: .75rem; flex-wrap: wrap;
    opacity: 0; animation: rise .9s .15s ease forwards;
  }
  .stat { display: flex; align-items: baseline; gap: .35rem; }
  .stat-n {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: 1.4rem; font-weight: 700; color: var(--mec); line-height: 1; letter-spacing: -.02em;
  }
  .stat-label {
    font-family: 'Mulish', sans-serif; font-size: .62rem; font-weight: 300;
    letter-spacing: .12em; text-transform: uppercase; color: var(--ink-soft);
  }
  .stat-sep { color: var(--rule); font-size: .9rem; }

  /* ── Indicateur engagement ── */
  .eng-wrap  { display: inline-flex; align-items: center; gap: .32rem; }
  .eng-niveau { font-family: 'Mulish', sans-serif; font-size: .60rem; font-weight: 300; color: var(--ink-soft); opacity: .55; white-space: nowrap; }
  .eng-indicator { display: inline-flex; align-items: flex-end; gap: 4px; }
  .eng-bar { display: inline-block; width: 4px; border-radius: 2px 2px 1px 1px; background: var(--rule); }
  .eng-b1 { height: 6px; } .eng-b2 { height: 10px; } .eng-b3 { height: 14px; }
  .eng-bar.on { background: var(--orange); }

  /* ── Séparateur avec boulons ── */
  .ornament-sep {
    display: flex; align-items: center; gap: 1rem;
    margin: 2rem 0 .5rem;
    opacity: 0; animation: rise .9s .25s ease forwards;
  }
  .orn-line { flex: 1; height: 1px; background: linear-gradient(to right, transparent, var(--rule), transparent); }
  .orn-centre { display: flex; align-items: center; gap: .6rem; }
  /* Petit boulon hexagonal stylisé */
  .orn-bolt {
    width: 7px; height: 7px;
    background: var(--orange); opacity: .55;
    clip-path: polygon(50% 0%, 93% 25%, 93% 75%, 50% 100%, 7% 75%, 7% 25%);
  }
  .orn-label {
    font-family: 'Mulish', sans-serif; font-size: .58rem; font-weight: 700;
    letter-spacing: .25em; text-transform: uppercase; color: var(--mec-mid); opacity: .65;
  }

  /* ── État vide ── */
  .empty-state {
    display: flex; flex-direction: column; align-items: center; gap: .75rem;
    padding: 3rem 1.5rem; text-align: center;
    opacity: 0; animation: rise .9s .3s ease forwards;
  }
  .empty-glyph  { font-size: 2.5rem; opacity: .18; animation: gear-cw 8s linear infinite; display: inline-block; }
  .empty-titre  { font-family: 'Libre Baskerville', Georgia, serif; font-size: 1rem; font-style: italic; color: var(--ink-soft); }
  .empty-desc   { font-family: 'Mulish', sans-serif; font-size: .8rem; font-weight: 300; color: var(--ink-soft); opacity: .7; }

  /* ── Liste des épisodes ── */
  .episodes-list { display: flex; flex-direction: column; padding-top: 1.5rem; }
  .episode-row   { display: flex; gap: 1.75rem; align-items: flex-start; }

  /* Fil conducteur vertical */
  .episode-fil-wrap { display: flex; flex-direction: column; align-items: center; flex-shrink: 0; width: 32px; padding-top: .2rem; }
  .episode-numero {
    width: 28px; height: 28px;
    border: 1px solid var(--mec-dim);
    /* Forme octogonale pour rappeler un boulon/écrou */
    clip-path: polygon(29% 0%, 71% 0%, 100% 29%, 100% 71%, 71% 100%, 29% 100%, 0% 71%, 0% 29%);
    display: flex; align-items: center; justify-content: center;
    font-family: 'Libre Baskerville', Georgia, serif; font-size: .72rem; font-weight: 700;
    color: var(--mec); background: rgba(52,48,42,.07); flex-shrink: 0;
    /* clip-path supprime border, on utilise outline comme border de substitution */
    outline: 1px solid var(--mec-dim);
  }
  .episode-numero--ghost { outline-color: rgba(52,48,42,.18); color: rgba(52,48,42,.38); background: transparent; }
  .episode-trait {
    width: 2px; flex: 1; min-height: 3rem;
    background: repeating-linear-gradient(
      to bottom,
      var(--mec-dim) 0px, var(--mec-dim) 4px,
      transparent 4px, transparent 10px
    );
    margin: .4rem 0;
  }

  /* ── Cartes épisode ── */
  .episode-card {
    flex: 1; display: flex; flex-direction: column; gap: .5rem;
    text-decoration: none; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem;
    border: 1px solid var(--rule); border-radius: 0 6px 6px 0;
    /* Fond très légèrement chaud — parchmin teinté chantier */
    background: rgba(245,240,232,.7);
    opacity: 0; animation: rise .7s ease forwards;
    transition: border-color .22s, background .22s, transform .2s, box-shadow .2s;
    position: relative;
  }
  /* Bande latérale orange animée */
  .episode-card::before {
    content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px;
    background: linear-gradient(to bottom, var(--orange), rgba(232,93,4,.4));
    border-radius: 2px 0 0 2px;
    transform: scaleY(0); transform-origin: top; transition: transform .3s ease; opacity: .85;
  }
  .episode-card:hover {
    border-color: var(--orange-dim);
    background: var(--orange-bg);
    transform: translateX(4px);
    box-shadow: 0 3px 22px rgba(52,48,42,.1), 2px 0 0 0 var(--orange);
  }
  .episode-card:hover::before { transform: scaleY(1); }
  .episode-card--ghost {
    opacity: .28 !important; animation: none;
    border-style: dashed; border-color: var(--mec-dim);
    background: transparent; cursor: default; pointer-events: none;
    border-radius: 6px;
  }

  .episode-card-meta { display: flex; align-items: center; gap: .6rem; flex-wrap: wrap; }
  .episode-date {
    font-family: 'Mulish', sans-serif; font-size: .58rem; font-weight: 300;
    letter-spacing: .14em; text-transform: uppercase; color: var(--ink-soft); opacity: .55;
  }
  .episode-readtime { font-family: 'Mulish', sans-serif; font-size: .58rem; color: var(--ink-soft); opacity: .42; }
  .badge { font-family: 'Mulish', sans-serif; font-size: .5rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; padding: .12rem .38rem; border-radius: 3px; display: inline-flex; align-items: center; gap: .25rem; }
