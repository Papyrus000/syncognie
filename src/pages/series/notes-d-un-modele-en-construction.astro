---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');

const episodes = allArticles
  .filter(a => a.data.serie === "Notes d'un modèle en construction")
  .sort((a, b) => (a.data.episode ?? 0) - (b.data.episode ?? 0));

const totalEpisodes = episodes.length;
const nbPousses   = episodes.filter(e => e.data.stade === 'pousse').length;
const nbGraines   = episodes.filter(e => e.data.stade === 'graine').length;
const nbArbres    = episodes.filter(e => e.data.stade === 'arbre').length;

const stadeConfig: Record<string, { emoji: string; label: string; color: string }> = {
  graine: { emoji: '🌱', label: 'Graine', color: '#5a8a4a' },
  pousse: { emoji: '🌿', label: 'Pousse', color: '#4a7a3a' },
  arbre:  { emoji: '🌳', label: 'Arbre',  color: '#3a6a2a' },
};

function formatDate(date: Date) {
  return date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
}

function formatDateShort(date: Date) {
  return date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long' });
}

function readTime(body: string) {
  return Math.max(1, Math.round(body.split(/\s+/).length / 200));
}

// Extraire les auteurs depuis les tags pour la source de chaque note
const auteursConnus = ['Gottman','Bowlby','Perel','Argyris','Bruner','Korzybski','Watzlawick','Gollwitzer','Kahneman','Damasio','Frankl','Lembke','Rosling','Bronner','Csikszentmihalyi','Berridge','Meadows'];

function sourcesFrom(tags: string[] | undefined): string {
  if (!tags) return '';
  return tags
    .filter(t => auteursConnus.some(a => t.toLowerCase().includes(a.toLowerCase())))
    .slice(0, 3)
    .join(' · ');
}

const hero   = episodes[0] ?? null;
const grille = episodes.slice(1);
---

<Base title="Prismes — Notes d'un modèle en construction · Syncognie" description="Des lectures qui s'enchaînent et se répondent — pour construire, note après note, une façon de lire le comportement humain.">
<div class="page-wrap">

  <!-- ── RETOUR ── -->
  <a class="back" href="/articles">
    <span class="back-arrow"><svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg></span>
    Articles
  </a>

  <!-- ── HEADER ── -->
  <header class="page-header">
    <p class="page-eyebrow">Série · Prismes</p>
    <h1 class="page-titre">Notes d'un modèle <em>en construction</em></h1>

    <div class="phrase-prisme">
      <span class="phrase-glyph">◈</span>
      <p class="phrase-texte">Prismes n'est pas un résumé. C'est un prisme — chaque note fait pivoter la lumière d'un livre pour révéler ce qu'on n'avait pas vu d'abord.</p>
    </div>

    <p class="page-sous">Des lectures qui s'enchaînent et se répondent — pour construire, note après note, une façon de lire le comportement humain.</p>

    <div class="page-stats">
      <div class="stat"><span class="stat-n">{totalEpisodes}</span><span class="stat-label">note{totalEpisodes > 1 ? 's' : ''}</span></div>
      {nbPousses > 0 && (
        <><span class="stat-sep">·</span>
        <div class="stat"><span class="stat-n">{nbPousses}</span><span class="stat-label">pousse{nbPousses > 1 ? 's' : ''}</span></div></>
      )}
      {nbGraines > 0 && (
        <><span class="stat-sep">·</span>
        <div class="stat"><span class="stat-n">{nbGraines}</span><span class="stat-label">graine{nbGraines > 1 ? 's' : ''}</span></div></>
      )}
      {nbArbres > 0 && (
        <><span class="stat-sep">·</span>
        <div class="stat"><span class="stat-n">{nbArbres}</span><span class="stat-label">arbre{nbArbres > 1 ? 's' : ''}</span></div></>
      )}
    </div>
  </header>

  <!-- ── LABEL GRILLE ── -->
  <p class="grille-label">Les notes</p>

  <!-- ── CARTE HERO — note 01 ── -->
  {hero && (() => {
    const stade = hero.data.stade ? stadeConfig[hero.data.stade] : null;
    const src   = sourcesFrom(hero.data.tags);
    const rt    = readTime(hero.body);
    const dt    = formatDateShort(hero.data.date);
    return (
      <a class="carte-hero" href={`/articles/${hero.slug}`}>
        <div class="hero-gnum" aria-hidden="true">01</div>
        <span class="hero-badge">Commencer ici</span>
        <div class="hero-meta">
          {stade && <span class="hero-stade">{stade.emoji} {stade.label}</span>}
          <span>· {rt} min · {dt}</span>
        </div>
        <p class="hero-titre">{hero.data.title}</p>
        {hero.data.description && <p class="hero-desc">{hero.data.description}</p>}
        {src && <p class="hero-src">{src}</p>}
        <span class="hero-lire">Lire →</span>
      </a>
    );
  })()}

  <!-- ── GRILLE notes 02+ ── -->
  <div class="grille">
    {grille.map((ep, i) => {
      const num   = i + 2;
      const stade = ep.data.stade ? stadeConfig[ep.data.stade] : null;
      const src   = sourcesFrom(ep.data.tags);
      const rt    = readTime(ep.body);
      const dt    = formatDateShort(ep.data.date);
      return (
        <a class="carte" href={`/articles/${ep.slug}`} style={`animation-delay:${0.1 + i * 0.08}s`}>
          <div class="c-gnum" aria-hidden="true">{String(num).padStart(2,'0')}</div>
          <div class="c-head">
            <span class="c-num">Note {String(num).padStart(2,'0')}</span>
            {stade && <span class="c-stade">{stade.emoji} {stade.label}</span>}
          </div>
          <p class="c-titre">{ep.data.title}</p>
          {ep.data.description && <p class="c-desc">{ep.data.description}</p>}
          {src && <p class="c-src">{src}</p>}
          <span class="c-time">{rt} min · {dt}</span>
          <span class="c-lire">Lire →</span>
        </a>
      );
    })}

    <!-- carte fantôme "à venir" -->
    <div class="carte carte--ghost" aria-hidden="true">
      <div class="c-gnum">{String(totalEpisodes + 1).padStart(2,'0')}</div>
      <div class="c-head"><span class="c-num">Note {String(totalEpisodes + 1).padStart(2,'0')}</span></div>
      <p class="c-titre c-titre--ghost">Prochaine note</p>
      <p class="c-desc">En cours de lecture — à venir.</p>
    </div>
  </div>

</div>
</Base>

<style>
  /* ── Tokens Prismes ── */
  :root {
    --pri:       #b8922a;
    --pri-dim:   rgba(184,146,42,.28);
    --pri-bg:    rgba(184,146,42,.045);
    --pri-deep:  #8a6438;
    --terra:     #e8905a;
    --terra-dim: rgba(232,144,90,.28);
    --terra-bg:  rgba(232,144,90,.12);
    --hero-bg1:  #2e1208;
    --hero-bg2:  #3d1a0a;
    --hero-bg3:  #4a2210;
    --kraft:     #ece4d4;
    --kraft-h:   #e2d8c4;
    --ink:       #1a1714;
    --ink-soft:  #9a9189;
    --ink-mid:   #7a7068;
    --parch:     #f5f0e8;
    --rule:      #ddd6c8;
    --blue-h:    #3a7fc1;
    --max:       740px;
  }

  .page-wrap { max-width: var(--max); margin: 0 auto; padding: 0 1.75rem 6rem; }

  /* ── Retour ── */
  .back {
    display: inline-flex; align-items: center; gap: .5rem;
    margin: 2rem 0 1.75rem;
    color: var(--ink-soft); font-family: 'Mulish', sans-serif;
    font-size: .62rem; font-weight: 300; letter-spacing: .12em; text-transform: uppercase;
    text-decoration: none; transition: gap .2s, color .2s;
  }
  .back:hover { gap: .7rem; color: var(--ink-mid); }
  .back-arrow {
    width: 18px; height: 18px;
    border: 1px solid var(--rule); border-radius: 3px;
    display: flex; align-items: center; justify-content: center;
  }
  .back-arrow svg { width: 11px; height: 11px; stroke: currentColor; stroke-width: 2; fill: none; }

  /* ── Header ── */
  .page-header {
    padding-bottom: 1.75rem;
    opacity: 0; animation: rise .9s .05s ease forwards;
  }

  .page-eyebrow {
    font-family: 'Mulish', sans-serif; font-size: .58rem; font-weight: 700;
    letter-spacing: .28em; text-transform: uppercase;
    color: var(--pri-deep); opacity: .8; margin-bottom: .9rem;
  }

  .page-titre {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: clamp(1.8rem, 3.8vw, 2.4rem); font-weight: 700;
    color: var(--ink); line-height: 1.15; letter-spacing: -.025em;
    margin-bottom: 1rem;
  }
  .page-titre em { font-style: italic; font-weight: 400; color: var(--pri); }

  /* ── Phrase prisme ── */
  .phrase-prisme {
    display: flex; align-items: flex-start; gap: .65rem;
    margin-bottom: 1.2rem; padding: .85rem 1.1rem;
    border: 1px solid var(--pri-dim);
    border-left: 3px solid rgba(184,146,42,.5);
    border-radius: 0 4px 4px 0;
    background: var(--pri-bg);
  }
  .phrase-glyph { color: var(--pri); opacity: .65; font-size: .8rem; flex-shrink: 0; margin-top: .06rem; }
  .phrase-texte {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: .82rem; font-style: italic; color: var(--ink-mid); line-height: 1.7;
  }

  .page-sous {
    font-family: 'Mulish', sans-serif; font-size: .875rem; font-weight: 300;
    color: var(--ink-soft); line-height: 1.8; max-width: 54ch; margin-bottom: 1.4rem;
  }

  /* ── Stats ── */
  .page-stats {
    display: flex; align-items: center; gap: .7rem; flex-wrap: wrap;
    opacity: 0; animation: rise .9s .15s ease forwards;
  }
  .stat { display: flex; align-items: baseline; gap: .3rem; }
  .stat-n {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: 1.2rem; font-weight: 700; color: var(--pri); line-height: 1; letter-spacing: -.02em;
  }
  .stat-label {
    font-family: 'Mulish', sans-serif; font-size: .58rem; font-weight: 300;
    letter-spacing: .12em; text-transform: uppercase; color: var(--ink-soft);
  }
  .stat-sep { color: var(--rule); }

  /* ── Label grille ── */
  .grille-label {
    font-family: 'Mulish', sans-serif; font-size: .56rem; font-weight: 700;
    letter-spacing: .25em; text-transform: uppercase;
    color: var(--pri-deep); opacity: .55;
    margin: 1.75rem 0 1.1rem;
    opacity: 0; animation: rise .9s .22s ease forwards;
  }

  /* ── CARTE HERO ── */
  .carte-hero {
    position: relative; overflow: hidden;
    padding: 1.5rem 1.5rem 1.35rem;
    border-radius: 12px; margin-bottom: 1.1rem;
    background: linear-gradient(135deg, var(--hero-bg1) 0%, var(--hero-bg2) 60%, var(--hero-bg3) 100%);
    display: flex; flex-direction: column; gap: .42rem;
    text-decoration: none; color: inherit;
    box-shadow: 0 4px 0 rgba(46,18,8,.35), 0 8px 32px rgba(46,18,8,.16);
    transition: transform .2s ease, box-shadow .2s ease;
    opacity: 0; animation: rise .8s .28s ease forwards;
  }
  .carte-hero:hover {
    transform: translateY(-3px);
    box-shadow: 0 7px 0 rgba(46,18,8,.3), 0 18px 40px rgba(46,18,8,.22);
  }
  .carte-hero::after {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
    background: linear-gradient(to right, var(--terra), rgba(232,144,90,.1));
  }
  .hero-gnum {
    position: absolute; bottom: -.5rem; right: .7rem;
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: 6.5rem; font-weight: 700; line-height: 1;
    pointer-events: none; letter-spacing: -.04em;
    color: rgba(255,255,255,.05);
  }
  .hero-badge {
    position: absolute; top: 1.1rem; right: 1.1rem;
    font-family: 'Mulish', sans-serif; font-size: .5rem; font-weight: 700;
    letter-spacing: .14em; text-transform: uppercase;
    color: var(--terra); background: var(--terra-bg);
    border: 1px solid var(--terra-dim); border-radius: 3px; padding: .18rem .5rem;
  }
  .hero-meta {
    font-family: 'Mulish', sans-serif; font-size: .53rem; font-weight: 300;
    color: rgba(245,240,232,.42); display: flex; align-items: center; gap: .35rem;
  }
  .hero-stade { font-weight: 600; }
  .hero-titre {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: 1.2rem; font-style: italic; color: #f5ede8; line-height: 1.3;
    transition: color .2s;
  }
  .carte-hero:hover .hero-titre { color: #fff; }
  .hero-desc {
    font-family: 'Mulish', sans-serif; font-size: .78rem; font-weight: 300;
    color: rgba(245,237,232,.58); line-height: 1.6; max-width: 56ch;
  }
  .hero-src {
    font-family: 'Mulish', sans-serif; font-size: .57rem; font-weight: 500;
    color: var(--terra); opacity: .8;
  }
  .hero-lire {
    font-family: 'Mulish', sans-serif; font-size: .58rem; font-weight: 600;
    letter-spacing: .12em; text-transform: uppercase;
    color: var(--terra); opacity: 0; transform: translateY(3px);
    transition: opacity .2s, transform .2s;
    margin-top: .2rem; display: inline-block;
  }
  .carte-hero:hover .hero-lire { opacity: 1; transform: translateY(0); }

  /* ── GRILLE ── */
  .grille {
    display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;
  }

  /* ── CARTES ORGANIQUES ── */
  .carte {
    background: var(--kraft);
    border-radius: 10px;
    box-shadow: 0 2px 0 rgba(152,112,72,.2), 0 4px 18px rgba(122,88,48,.07);
    padding: 1.25rem 1.2rem 1.1rem;
    display: flex; flex-direction: column; gap: .4rem;
    text-decoration: none; color: inherit;
    position: relative; overflow: hidden;
    transition: transform .2s ease, box-shadow .2s ease;
    opacity: 0; animation: rise .7s ease forwards;
  }
  .carte:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 0 rgba(152,112,72,.18), 0 14px 30px rgba(122,88,48,.12);
    background: var(--kraft-h);
  }
  .carte--ghost {
    opacity: .28 !important; animation: none;
    box-shadow: none;
    border: 1px dashed rgba(152,112,72,.25);
    background: transparent; cursor: default; pointer-events: none;
  }

  .c-gnum {
    position: absolute; bottom: -.5rem; right: .5rem;
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: 5.5rem; font-weight: 700; line-height: 1;
    pointer-events: none; letter-spacing: -.04em;
    color: rgba(184,146,42,.18);
  }
  .c-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: .08rem; }
  .c-num {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: .68rem; font-weight: 700; color: var(--pri);
  }
  .c-stade {
    font-family: 'Mulish', sans-serif; font-size: .5rem; font-weight: 700;
    letter-spacing: .1em; text-transform: uppercase; color: #5a8a4a;
  }
  .c-titre {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: .96rem; font-style: italic; color: var(--ink); line-height: 1.35;
    transition: color .2s;
  }
  .carte:hover .c-titre { color: var(--blue-h); }
  .c-titre--ghost { font-style: normal; color: var(--ink-soft); }
  .c-desc {
    font-family: 'Mulish', sans-serif; font-size: .73rem; font-weight: 300;
    color: var(--ink-mid); line-height: 1.6;
  }
  .c-src {
    font-family: 'Mulish', sans-serif; font-size: .56rem; font-weight: 500;
    color: var(--pri); opacity: .65; margin-top: .04rem;
  }
  .c-time {
    font-family: 'Mulish', sans-serif; font-size: .5rem; font-weight: 300;
    color: var(--ink-soft); margin-top: .12rem;
  }
  .c-lire {
    font-family: 'Mulish', sans-serif; font-size: .57rem; font-weight: 600;
    letter-spacing: .12em; text-transform: uppercase;
    color: var(--pri); opacity: 0; transform: translateY(3px);
    transition: opacity .2s, transform .2s;
    margin-top: auto; padding-top: .3rem; display: inline-block;
  }
  .carte:hover .c-lire { opacity: 1; transform: translateY(0); }

  /* ── Responsive ── */
  @media (max-width: 540px) {
    .grille { grid-template-columns: 1fr; }
    .page-wrap { padding: 0 1rem 4rem; }
    .hero-badge { display: none; }
  }

  @keyframes rise {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
