---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');

const episodes = allArticles
  .filter(a => a.data.serie === "Notes d'un modèle en construction")
  .sort((a, b) => (a.data.episode ?? 0) - (b.data.episode ?? 0));

const totalEpisodes = episodes.length;
const nbConsolidés  = episodes.filter(e => e.data.stade === 'arbre').length;

const stadeConfig: Record<string, { emoji: string; label: string; color: string }> = {
  graine: { emoji: '🌱', label: 'Graine', color: '#2e7d4e' },
  pousse: { emoji: '🌿', label: 'Pousse', color: '#38783c' },
  arbre:  { emoji: '🌳', label: 'Arbre',  color: '#224422' },
};

const engagementRank: Record<string, number> = { pause: 1, lecture: 2, immersion: 3 };
function maxEngagement(arts: typeof allArticles) {
  let max = 0;
  for (const a of arts) {
    const r = engagementRank[a.data.engagement ?? ''] ?? 0;
    if (r > max) max = r;
  }
  return max;
}
const eng = maxEngagement(episodes);

// Extraction des auteurs/concepts cités à travers les tags pour une vue d'ensemble
const allTags = episodes.flatMap(e => e.data.tags ?? []);
const tagFreq = allTags.reduce<Record<string, number>>((acc, t) => {
  acc[t] = (acc[t] ?? 0) + 1;
  return acc;
}, {});
const topTags = Object.entries(tagFreq)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 6)
  .map(([tag]) => tag);
---

<Base title="Prismes — Notes d'un modèle en construction · Syncognie">
<div class="page-wrap">

  <header class="page-header">

    <!-- ══ Filigrane optique : prismes, dispersion, réfraction ══ -->
    <svg class="header-filigrane" viewBox="0 0 460 340" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">

      <!-- Prisme principal — triangle équilatéral -->
      <g class="prisme-a">
        <polygon points="230,42 340,222 120,222"
          stroke="#2d4a7a" stroke-width="1.4" opacity=".22" fill="rgba(45,74,122,.04)"/>
        <!-- Arête interne — axe optique -->
        <line x1="230" y1="42" x2="230" y2="222"
          stroke="#2d4a7a" stroke-width=".7" opacity=".12" stroke-dasharray="3 8"/>
        <!-- Milieux des arêtes -->
        <circle cx="185" cy="132" r="2" fill="#2d4a7a" opacity=".28"/>
        <circle cx="285" cy="132" r="2" fill="#2d4a7a" opacity=".22"/>
        <circle cx="230" cy="222" r="2" fill="#2d4a7a" opacity=".20"/>
      </g>

      <!-- Rayon incident — entrée gauche -->
      <line x1="62" y1="118" x2="184" y2="132"
        stroke="#a08030" stroke-width="1.2" opacity=".32" stroke-dasharray="0"/>
      <!-- Point d'entrée dans le prisme -->
      <circle cx="184" cy="132" r="3.5" fill="#a08030" opacity=".45" class="ray-pulse-a"/>

      <!-- Dispersion à la sortie — rayon refracté en 5 couleurs -->
      <!-- Rouge — déviation maximale -->
      <line x1="285" y1="132" x2="390" y2="98"
        stroke="#c0392b" stroke-width="1.1" opacity=".30" class="ray-red"/>
      <!-- Orange -->
      <line x1="285" y1="132" x2="390" y2="110"
        stroke="#e85d04" stroke-width="1.0" opacity=".30" class="ray-orange"/>
      <!-- Jaune doré -->
      <line x1="285" y1="132" x2="390" y2="122"
        stroke="#c8992a" stroke-width="1.0" opacity=".35" class="ray-yellow"/>
      <!-- Bleu — accent principal Prismes -->
      <line x1="285" y1="132" x2="390" y2="146"
        stroke="#2d6fba" stroke-width="1.2" opacity=".40" class="ray-blue"/>
      <!-- Violet — déviation minimale -->
      <line x1="285" y1="132" x2="390" y2="160"
        stroke="#6a3d8a" stroke-width="1.0" opacity=".28" class="ray-violet"/>

      <!-- Point de sortie — dispersion -->
      <circle cx="285" cy="132" r="3" fill="#2d6fba" opacity=".40" class="ray-pulse-b"/>

      <!-- Halo de dispersion — ellipse douce -->
      <ellipse cx="335" cy="130" rx="50" ry="36"
        fill="none" stroke="#2d6fba" stroke-width=".5" opacity=".10"
        stroke-dasharray="2 7"/>

      <!-- Petit prisme secondaire, en écho — plus bas à droite -->
      <g class="prisme-b" style="opacity:.55">
        <polygon points="370,200 420,282 320,282"
          stroke="#2d4a7a" stroke-width=".9" opacity=".18" fill="rgba(45,74,122,.025)"/>
        <!-- Rayon entrant en miniature -->
        <line x1="318" y1="235" x2="344" y2="241"
          stroke="#a08030" stroke-width=".8" opacity=".22"/>
        <!-- Dispersion miniature -->
        <line x1="396" y1="241" x2="430" y2="226" stroke="#c0392b" stroke-width=".7" opacity=".22"/>
        <line x1="396" y1="241" x2="430" y2="232" stroke="#2d6fba" stroke-width=".7" opacity=".25"/>
        <line x1="396" y1="241" x2="430" y2="250" stroke="#6a3d8a" stroke-width=".6" opacity=".18"/>
      </g>

      <!-- Axe horizontal de lecture — cadre optique -->
      <line x1="50" y1="132" x2="62" y2="132"
        stroke="#a08030" stroke-width=".8" opacity=".28" stroke-dasharray="2 4"/>
      <line x1="390" y1="132" x2="430" y2="132"
        stroke="#2d4a7a" stroke-width=".6" opacity=".15" stroke-dasharray="2 6"/>

      <!-- Graduation — échelle de réfraction gauche -->
      <line x1="44" y1="80"  x2="44" y2="185" stroke="#2d4a7a" stroke-width=".6" opacity=".14"/>
      <line x1="40" y1="80"  x2="48" y2="80"  stroke="#2d4a7a" stroke-width=".6" opacity=".14"/>
      <line x1="40" y1="110" x2="48" y2="110" stroke="#2d4a7a" stroke-width=".5" opacity=".11"/>
      <line x1="40" y1="132" x2="48" y2="132" stroke="#a08030" stroke-width=".7" opacity=".22"/>
      <line x1="40" y1="155" x2="48" y2="155" stroke="#2d4a7a" stroke-width=".5" opacity=".11"/>
      <line x1="40" y1="185" x2="48" y2="185" stroke="#2d4a7a" stroke-width=".6" opacity=".14"/>

      <!-- Petits losanges — points d'articulation conceptuelle -->
      <rect x="226" y="38" width="8" height="8" rx=".5" fill="#2d4a7a" opacity=".22"
        transform="rotate(45 230 42)"/>
      <rect x="116" y="218" width="8" height="8" rx=".5" fill="#2d4a7a" opacity=".18"
        transform="rotate(45 120 222)"/>
      <rect x="336" y="218" width="8" height="8" rx=".5" fill="#2d4a7a" opacity=".18"
        transform="rotate(45 340 222)"/>
    </svg>

    <a class="back" href="/articles">
      <span class="back-arrow"><svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg></span>
      Articles
    </a>

    <p class="page-eyebrow">Série · Prismes</p>
    <h1 class="page-titre">Notes d'un modèle<br><em>en construction</em></h1>
    <p class="page-sous">
      Faire se rencontrer des penseurs qui ne se sont jamais lus.
      Forcer la collision des concepts jusqu'à ce que quelque chose
      d'inattendu apparaisse — une propriété que ni l'un ni l'autre ne contenait seul.
    </p>

    <div class="page-stats">
      <span class="stat"><span class="stat-n">{totalEpisodes}</span><span class="stat-label">note{totalEpisodes > 1 ? 's' : ''}</span></span>
      {nbConsolidés > 0 && (
        <><span class="stat-sep">·</span>
        <span class="stat"><span class="stat-n">{nbConsolidés}</span><span class="stat-label">consolidé{nbConsolidés > 1 ? 's' : ''}</span></span></>
      )}
      {eng > 0 && (
        <><span class="stat-sep">·</span>
        <span class="eng-wrap">
          <span class="eng-niveau">Niveau&nbsp;:</span>
          <span class="eng-indicator">
            <span class={`eng-bar eng-b1${eng >= 1 ? ' on' : ''}`}></span>
            <span class={`eng-bar eng-b2${eng >= 2 ? ' on' : ''}`}></span>
            <span class={`eng-bar eng-b3${eng >= 3 ? ' on' : ''}`}></span>
          </span>
        </span></>
      )}
    </div>
  </header>

  <!-- ══ Bloc d'intention — spécifique à Prismes ══ -->
  <div class="intention-bloc">
    <div class="intention-glyph-wrap">
      <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" class="intention-prisme-ico" aria-hidden="true">
        <polygon points="16,3 27,21 5,21" stroke="#2d6fba" stroke-width="1.4" fill="rgba(45,111,186,.07)"/>
        <line x1="8"  y1="15" x2="5"  y2="21" stroke="#c0392b" stroke-width="1" opacity=".55"/>
        <line x1="27" y1="21" x2="32" y2="17" stroke="#2d6fba" stroke-width="1.1" opacity=".65"/>
        <line x1="27" y1="21" x2="32" y2="21" stroke="#c8992a" stroke-width="1"   opacity=".55"/>
        <line x1="27" y1="21" x2="32" y2="25" stroke="#6a3d8a" stroke-width=".9"  opacity=".50"/>
      </svg>
    </div>
    <div class="intention-texte-wrap">
      <p class="intention-titre">Ce que fait cette série</p>
      <p class="intention-corps">
        Chaque note choisit deux auteurs ou concepts qui s'ignorent — et les place
        face à face. La collision n'est pas arbitraire : elle cherche ce que
        ni l'un ni l'autre ne voit depuis sa position. Les propriétés émergentes,
        quand elles apparaissent, ne sont pas dans les livres.
      </p>
    </div>
  </div>

  <!-- ══ Constellation de thèmes — si des tags existent ══ -->
  {topTags.length > 0 && (
    <div class="constellation-wrap">
      <p class="constellation-label">Territoires traversés</p>
      <div class="constellation-tags">
        {topTags.map((tag, i) => (
          <span class="constellation-tag" style={`animation-delay:${0.4 + i * 0.07}s`}>{tag}</span>
        ))}
      </div>
    </div>
  )}

  <div class="ornament-sep">
    <div class="orn-line"></div>
    <div class="orn-centre">
      <div class="orn-prisme"></div>
      <span class="orn-label">Les notes</span>
      <div class="orn-prisme"></div>
    </div>
    <div class="orn-line"></div>
  </div>

  <!-- ══ Liste des notes ══ -->
  <div class="episodes-list">
    {episodes.length === 0 ? (
      <div class="empty-state">
        <svg class="empty-prisme" viewBox="0 0 60 52" fill="none" xmlns="http://www.w3.org/2000/svg">
          <polygon points="30,4 54,48 6,48" stroke="#2d4a7a" stroke-width="1.2" opacity=".28" fill="rgba(45,74,122,.04)"/>
          <line x1="54" y1="48" x2="62" y2="40" stroke="#c0392b" stroke-width="1" opacity=".35"/>
          <line x1="54" y1="48" x2="62" y2="46" stroke="#2d6fba" stroke-width="1" opacity=".38"/>
          <line x1="54" y1="48" x2="62" y2="54" stroke="#6a3d8a" stroke-width=".9" opacity=".30"/>
        </svg>
        <p class="empty-titre">Les notes arrivent</p>
        <p class="empty-desc">La lumière entre — la dispersion est en cours.</p>
      </div>
    ) : episodes.map((ep, i) => {
      const stadeInfo = ep.data.stade ? stadeConfig[ep.data.stade] : null;
      const date = ep.data.date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
      const readTime = Math.max(1, Math.round(ep.body.split(/\s+/).length / 200));
      const estDernier = i === episodes.length - 1;
      return (
        <div class="episode-row">
          <div class="episode-fil-wrap">
            <!-- Numéro en losange — signature Prismes -->
            <div class="episode-numero">
              <span class="ep-num-inner">{ep.data.episode ?? i + 1}</span>
            </div>
            {!estDernier && <div class="episode-trait"></div>}
          </div>
          <a class="episode-card" href={`/articles/${ep.slug}`} style={`animation-delay:${0.25 + i * 0.12}s`}>
            <!-- Bande spectrale latérale — remplace la barre unie -->
            <div class="card-spectre" aria-hidden="true">
              <div class="spectre-band s-rouge"></div>
              <div class="spectre-band s-or"></div>
              <div class="spectre-band s-bleu"></div>
              <div class="spectre-band s-violet"></div>
            </div>
            <div class="episode-card-meta">
              <span class="episode-date">{date}</span>
              <span class="episode-readtime">· {readTime} min</span>
              {stadeInfo && (
                <span class="badge badge-stade" style={`color:${stadeInfo.color}`}>
                  {stadeInfo.emoji} {stadeInfo.label}
                </span>
              )}
            </div>
            <p class="episode-titre">{ep.data.title}</p>
            {ep.data.description && <p class="episode-desc">{ep.data.description}</p>}
            {ep.data.tags && ep.data.tags.length > 0 && (
              <div class="episode-tags">
                {ep.data.tags.map((t: string) => <span class="episode-tag">{t}</span>)}
              </div>
            )}
            <span class="episode-lire">Lire →</span>
          </a>
        </div>
      );
    })}

    <!-- Note fantôme : prochaine -->
    <div class="episode-row">
      <div class="episode-fil-wrap">
        <div class="episode-numero episode-numero--ghost">
          <span class="ep-num-inner">{totalEpisodes + 1}</span>
        </div>
      </div>
      <div class="episode-card episode-card--ghost">
        <p class="episode-titre episode-titre--ghost">Prochaine note</p>
        <p class="episode-desc">La collision est en cours de préparation — à venir.</p>
      </div>
    </div>
  </div>

  <!-- ══ Encart de mise en garde / invitation ══ -->
  <div class="invitation-encart">
    <div class="invitation-ico">
      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <polygon points="12,2 21,19 3,19" stroke="#2d6fba" stroke-width="1.4" fill="none" opacity=".7"/>
        <line x1="21" y1="19" x2="25" y2="15" stroke="#c0392b" stroke-width="1" opacity=".6"/>
        <line x1="21" y1="19" x2="25" y2="19" stroke="#c8992a" stroke-width="1" opacity=".6"/>
        <line x1="21" y1="19" x2="25" y2="23" stroke="#6a3d8a" stroke-width=".9" opacity=".55"/>
      </svg>
    </div>
    <p class="invitation-texte">
      Prismes n'explique pas — il expose des angles. Le lecteur reconstitue
      la lumière blanche depuis les bandes colorées.
      Chaque note suppose que vous êtes prêt à tenir des contradictions
      en même temps.
    </p>
  </div>

</div>
</Base>

<style>
  :root {
    /* ── Palette Prismes : bleu ardoise profond + dispersion spectrale ── */
    --prisme:       #2d4a7a;           /* bleu nuit — dominant structurel */
    --prisme-mid:   #3a5d96;           /* bleu intermédiaire */
    --prisme-dim:   rgba(45,74,122,.30);
    --prisme-bg:    rgba(45,74,122,.055);
    --prisme-text:  #1a2a45;
    --prisme-acc:   #2d6fba;           /* bleu vif — accent liens et hover */
    --spectre-r:    #c0392b;
    --spectre-o:    #e85d04;
    --spectre-y:    #c8992a;
    --spectre-b:    #2d6fba;
    --spectre-v:    #6a3d8a;
    --gold:         #e8b832;
    --parch:        #f5f0e8;
    --ink:          #1a1714;
    --ink-soft:     #9a9189;
    --ink-mid:      #7a7068;
    --rule:         #ddd6c8;
    --max:          740px;
  }

  .page-wrap { max-width: var(--max); margin: 0 auto; padding: 0 1.75rem 6rem; }

  /* ── Filigrane ── */
  .page-header {
    padding: 0 0 2.5rem;
    position: relative; overflow: visible;
    opacity: 0; animation: rise .9s .05s ease forwards;
  }
  .header-filigrane {
    position: absolute; right: -1.5rem; top: .8rem;
    width: 370px; height: auto; pointer-events: none;
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 20%, black 78%, transparent 100%);
    mask-image: linear-gradient(to right, transparent 0%, black 20%, black 78%, transparent 100%);
  }
  @media (max-width: 600px) {
    .header-filigrane { width: 200px; top: 2.5rem; right: -.5rem; opacity: .38; }
  }

  /* Animations filigrane */
  .prisme-a {
    animation: prisme-hover 6s ease-in-out infinite;
    transform-origin: 230px 132px;
  }
  .prisme-b {
    animation: prisme-hover 8.5s ease-in-out infinite 1.2s;
    transform-origin: 370px 241px;
  }
  @keyframes prisme-hover {
    0%,100% { transform: translateY(0px); opacity: 1; }
    50%      { transform: translateY(-3px); opacity: .85; }
  }
  .ray-pulse-a { animation: rpulse 2.6s ease-in-out infinite; }
  .ray-pulse-b { animation: rpulse 3.2s ease-in-out infinite .7s; }
  @keyframes rpulse { 0%,100%{opacity:.30} 50%{opacity:.65} }

  .ray-red    { animation: ray-appear 3s ease-in-out infinite .0s; }
  .ray-orange { animation: ray-appear 3s ease-in-out infinite .2s; }
  .ray-yellow { animation: ray-appear 3s ease-in-out infinite .4s; }
  .ray-blue   { animation: ray-appear 3s ease-in-out infinite .6s; }
  .ray-violet { animation: ray-appear 3s ease-in-out infinite .8s; }
  @keyframes ray-appear {
    0%,100% { opacity: .18; stroke-width: .9; }
    50%     { opacity: .45; stroke-width: 1.3; }
  }

  /* ── Navigation retour ── */
  .back {
    display: inline-flex; align-items: center; gap: .5rem;
    padding: 2.5rem 0 2rem;
    font-family: 'Mulish', sans-serif; font-size: .6rem; font-weight: 700;
    letter-spacing: .2em; text-transform: uppercase;
    color: var(--ink-soft); text-decoration: none;
    opacity: 0; animation: rise .8s .05s ease forwards;
    transition: color .2s, gap .2s;
  }
  .back:hover { color: var(--prisme-text); gap: .7rem; }
  .back-arrow {
    width: 18px; height: 18px;
    border: 1px solid var(--rule); border-radius: 3px;
    display: flex; align-items: center; justify-content: center;
  }
  .back-arrow svg { width: 11px; height: 11px; stroke: currentColor; stroke-width: 2; fill: none; }

  /* ── En-tête ── */
  .page-eyebrow {
    font-family: 'Mulish', sans-serif; font-size: .6rem; font-weight: 700;
    letter-spacing: .28em; text-transform: uppercase;
    color: var(--prisme-mid); opacity: .8; margin-bottom: 1rem;
  }
  .page-titre {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: clamp(1.8rem, 3.5vw, 2.4rem); font-weight: 700;
    color: var(--ink); line-height: 1.2; letter-spacing: -.02em; margin-bottom: .9rem;
  }
  .page-titre em { font-style: italic; font-weight: 400; color: var(--prisme-acc); }
  .page-sous {
    font-family: 'Mulish', sans-serif; font-size: .875rem; font-weight: 300;
    color: var(--ink-soft); line-height: 1.8; max-width: 52ch; margin-bottom: 1.75rem;
  }

  /* ── Stats ── */
  .page-stats {
    display: flex; align-items: center; gap: .75rem; flex-wrap: wrap;
    opacity: 0; animation: rise .9s .15s ease forwards;
  }
  .stat { display: flex; align-items: baseline; gap: .35rem; }
  .stat-n {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: 1.4rem; font-weight: 700; color: var(--prisme); line-height: 1; letter-spacing: -.02em;
  }
  .stat-label {
    font-family: 'Mulish', sans-serif; font-size: .62rem; font-weight: 300;
    letter-spacing: .12em; text-transform: uppercase; color: var(--ink-soft);
  }
  .stat-sep { color: var(--rule); font-size: .9rem; }

  .eng-wrap  { display: inline-flex; align-items: center; gap: .32rem; }
  .eng-niveau { font-family: 'Mulish', sans-serif; font-size: .60rem; font-weight: 300; color: var(--ink-soft); opacity: .55; white-space: nowrap; }
  .eng-indicator { display: inline-flex; align-items: flex-end; gap: 4px; }
  .eng-bar { display: inline-block; width: 4px; border-radius: 2px 2px 1px 1px; background: var(--rule); }
  .eng-b1 { height: 6px; } .eng-b2 { height: 10px; } .eng-b3 { height: 14px; }
  .eng-bar.on { background: var(--prisme-acc); }

  /* ── Bloc d'intention ── */
  .intention-bloc {
    display: flex; align-items: flex-start; gap: 1.25rem;
    padding: 1.5rem 1.75rem;
    border: 1px solid var(--prisme-dim);
    border-top: 2.5px solid var(--prisme-acc);
    border-radius: 0 0 6px 6px;
    background: var(--prisme-bg);
    margin-bottom: 1.75rem;
    opacity: 0; animation: rise .9s .2s ease forwards;
  }
  .intention-glyph-wrap {
    flex-shrink: 0; margin-top: .15rem;
    animation: prisme-hover 5s ease-in-out infinite;
  }
  .intention-prisme-ico { width: 32px; height: 32px; }
  .intention-titre {
    font-family: 'Mulish', sans-serif; font-size: .6rem; font-weight: 700;
    letter-spacing: .18em; text-transform: uppercase;
    color: var(--prisme-mid); opacity: .75; margin-bottom: .55rem;
  }
  .intention-corps {
    font-family: 'Mulish', sans-serif; font-size: .84rem; font-weight: 300;
    color: var(--ink-mid); line-height: 1.8;
  }

  /* ── Constellation de tags ── */
  .constellation-wrap {
    margin-bottom: 1.75rem;
    opacity: 0; animation: rise .9s .28s ease forwards;
  }
  .constellation-label {
    font-family: 'Mulish', sans-serif; font-size: .58rem; font-weight: 700;
    letter-spacing: .22em; text-transform: uppercase;
    color: var(--ink-soft); opacity: .55; margin-bottom: .65rem;
  }
  .constellation-tags { display: flex; flex-wrap: wrap; gap: .45rem; }
  .constellation-tag {
    font-family: 'Mulish', sans-serif; font-size: .7rem; font-weight: 300;
    color: var(--prisme-mid); opacity: 0;
    padding: .22rem .65rem;
    border: 1px solid var(--prisme-dim);
    border-radius: 20px;
    background: var(--prisme-bg);
    animation: rise .6s ease forwards;
    transition: background .2s, border-color .2s, color .2s;
  }
  .constellation-tag:hover {
    background: rgba(45,111,186,.12);
    border-color: var(--prisme-acc);
    color: var(--prisme-text);
  }

  /* ── Séparateur ── */
  .ornament-sep {
