---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');

const episodes = allArticles
  .filter(a => a.data.serie === "Les rencontres de Nathalie et Élodie")
  .sort((a, b) => (a.data.episode ?? 0) - (b.data.episode ?? 0));

const totalEpisodes = episodes.length;
const nbConsolidés  = episodes.filter(e => e.data.stade === 'arbre').length;

const stadeConfig: Record<string, { emoji: string; label: string; color: string }> = {
  graine: { emoji: '🌱', label: 'Graine', color: '#2e7d4e' },
  pousse: { emoji: '🌿', label: 'Pousse', color: '#38783c' },
  arbre:  { emoji: '🌳', label: 'Arbre',  color: '#224422' },
};

const engagementRank: Record<string, number> = { pause: 1, lecture: 2, immersion: 3 };
function maxEngagement(arts: typeof allArticles) {
  let max = 0;
  for (const a of arts) {
    const r = engagementRank[a.data.engagement ?? ''] ?? 0;
    if (r > max) max = r;
  }
  return max;
}
const eng = maxEngagement(episodes);
---

<Base title="Les rencontres de Nathalie et Élodie — Syncognie">
<div class="page-wrap">

  <header class="page-header" style="position:relative; overflow:visible;">

    <!-- Filigrane deux cercles de dialogue -->
    <svg class="header-filigrane" viewBox="0 0 420 320" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <circle cx="155" cy="160" r="90"  stroke="#3a9fd8" stroke-width=".7" stroke-dasharray="3 9" opacity=".18" class="dial-a"/>
      <circle cx="155" cy="160" r="55"  stroke="#3a9fd8" stroke-width="1"  opacity=".12" class="dial-a-inner"/>
      <circle cx="265" cy="160" r="90"  stroke="#1a5a8a" stroke-width=".7" stroke-dasharray="3 9" opacity=".15" class="dial-b"/>
      <circle cx="265" cy="160" r="55"  stroke="#3a9fd8" stroke-width="1"  opacity=".10" class="dial-b-inner"/>
      <ellipse cx="210" cy="160" rx="28" ry="50" fill="#3a9fd8" opacity=".045"/>
      <line x1="100" y1="160" x2="320" y2="160" stroke="#3a9fd8" stroke-width=".6" opacity=".15" stroke-dasharray="2 8"/>
      <circle cx="155" cy="160" r="4"   fill="#3a9fd8" opacity=".38" class="node-a"/>
      <circle cx="265" cy="160" r="4"   fill="#1a5a8a" opacity=".35" class="node-b"/>
      <circle cx="210" cy="160" r="5.5" fill="#3a9fd8" opacity=".28" class="node-c"/>
      <circle cx="210" cy="160" r="2.5" fill="#f5f0e8" opacity=".6"/>
      <circle cx="155" cy="160" r="14"  fill="none" stroke="#3a9fd8" stroke-width=".8" opacity=".10" class="node-a"/>
      <circle cx="265" cy="160" r="14"  fill="none" stroke="#1a5a8a" stroke-width=".8" opacity=".08" class="node-b"/>
      <circle cx="155" cy="100" r="2.5" fill="#3a9fd8" opacity=".22" class="node-b"/>
      <circle cx="265" cy="220" r="2.5" fill="#1a5a8a" opacity=".22" class="node-a"/>
      <line x1="155" y1="160" x2="155" y2="100" stroke="#3a9fd8" stroke-width=".5" opacity=".12"/>
      <line x1="265" y1="160" x2="265" y2="220" stroke="#1a5a8a" stroke-width=".5" opacity=".10"/>
    </svg>

    <a class="back" href="/articles">
      <span class="back-arrow"><svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg></span>
      Articles
    </a>

    <p class="page-eyebrow">Série · Récit</p>
    <h1 class="page-titre">Les rencontres de<br><em>Nathalie et Élodie</em></h1>
    <p class="page-sous">
      Deux femmes, une terrasse, des livres qu'elles n'ont pas lus ensemble.
      Les idées émergent du vécu, jamais posées frontalement —
      la science traverse la conversation sans l'écraser.
    </p>

    <div class="page-stats">
      <span class="stat"><span class="stat-n">{totalEpisodes}</span><span class="stat-label">épisode{totalEpisodes > 1 ? 's' : ''}</span></span>
      <span class="stat-sep">·</span>
      <span class="stat"><span class="stat-n">2</span><span class="stat-label">voix</span></span>
      {nbConsolidés > 0 && <><span class="stat-sep">·</span><span class="stat"><span class="stat-n">{nbConsolidés}</span><span class="stat-label">consolidé{nbConsolidés > 1 ? 's' : ''}</span></span></>}
      {eng > 0 && <><span class="stat-sep">·</span><span class="eng-wrap"><span class="eng-niveau">Niveau&nbsp;:</span><span class="eng-indicator"><span class={`eng-bar eng-b1${eng >= 1 ? ' on' : ''}`}></span><span class={`eng-bar eng-b2${eng >= 2 ? ' on' : ''}`}></span><span class={`eng-bar eng-b3${eng >= 3 ? ' on' : ''}`}></span></span></span></>}
    </div>
  </header>

  <!-- PERSONNAGES -->
  <div class="personnages-wrap">
    <div class="personnage-card">
      <div class="personnage-initiale personnage-initiale--e">É</div>
      <div class="personnage-info">
        <p class="personnage-nom">Élodie</p>
        <p class="personnage-desc">32 ans · Conseil en communication · Analytique, précise, lâche le contrôle par éclats</p>
      </div>
    </div>
    <div class="personnage-et">et</div>
    <div class="personnage-card">
      <div class="personnage-initiale personnage-initiale--n">N</div>
      <div class="personnage-info">
        <p class="personnage-nom">Nathalie</p>
        <p class="personnage-desc">39 ans · Travailleuse sociale · Ancrée dans le concret, ironie douce, regard systémique</p>
      </div>
    </div>
  </div>

  <div class="ornament-sep">
    <div class="orn-line"></div>
    <div class="orn-centre"><div class="orn-diamond"></div><span class="orn-label">Les épisodes</span><div class="orn-diamond"></div></div>
    <div class="orn-line"></div>
  </div>

  <div class="episodes-list">
    {episodes.map((ep, i) => {
      const stadeInfo = ep.data.stade ? stadeConfig[ep.data.stade] : null;
      const date = ep.data.date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
      const readTime = Math.max(1, Math.round(ep.body.split(/\s+/).length / 200));
      const estDernier = i === episodes.length - 1;
      return (
        <div class="episode-row">
          <div class="episode-fil-wrap">
            <div class="episode-numero">{ep.data.episode ?? i + 1}</div>
            {!estDernier && <div class="episode-trait"></div>}
          </div>
          <a class="episode-card" href={`/articles/${ep.slug}`} style={`animation-delay:${0.2 + i * 0.1}s`}>
            <div class="episode-card-meta">
              <span class="episode-date">{date}</span>
              {stadeInfo && <span class="badge badge-stade" style={`background:color-mix(in srgb,${stadeInfo.color} 8%,transparent);color:${stadeInfo.color};border:1px solid color-mix(in srgb,${stadeInfo.color} 22%,transparent)`}><span>{stadeInfo.emoji}</span><span>{stadeInfo.label}</span></span>}
              {ep.data.statut === 'en-cours' && <span class="badge badge-encours">En cours</span>}
              <span class="episode-readtime">{readTime} min</span>
            </div>
            <p class="episode-titre">{ep.data.title}</p>
            {ep.data.description && <p class="episode-desc">{ep.data.description}</p>}
            {ep.data.tags && ep.data.tags.length > 0 && <div class="episode-tags">{ep.data.tags.slice(0, 4).map((tag: string) => <span class="episode-tag">{tag}</span>)}</div>}
            <span class="episode-lire">Lire le dialogue →</span>
          </a>
        </div>
      );
    })}
  </div>

  <div class="invitation-encart">
    <span class="invitation-glyph">◈</span>
    <p class="invitation-texte">Une série vivante — les épisodes s'ajoutent au fil du temps, au rythme des rencontres et des questions qui surgissent.</p>
  </div>

</div>
</Base>

<style>
  :root {
    --blue: #3a9fd8; --blue-deep: #1a5a8a; --blue-bg: rgba(58,159,216,.06); --blue-dim: rgba(58,159,216,.28);
    --gold: #e8b832; --terra: #8b5e3c; --blue-link: #3a9fd8;
    --parch: #f5f0e8; --ink: #1a1714; --ink-soft: #9a9189; --ink-mid: #7a7068; --rule: #ddd6c8; --max: 740px;
  }
  .page-wrap { max-width: var(--max); margin: 0 auto; padding: 0 1.75rem 6rem; }

  .header-filigrane { position: absolute; right: -1rem; top: 1.5rem; width: 340px; height: auto; pointer-events: none; }
  @media (max-width: 600px) { .header-filigrane { width: 180px; top: 2rem; right: -.5rem; opacity: .5; } }

  .dial-a       { animation: dial-rot-a 18s linear infinite; transform-origin: 155px 160px; }
  .dial-b       { animation: dial-rot-b 22s linear infinite; transform-origin: 265px 160px; }
  .dial-a-inner { animation: dial-rot-b 14s linear infinite; transform-origin: 155px 160px; }
  .dial-b-inner { animation: dial-rot-a 16s linear infinite; transform-origin: 265px 160px; }
  @keyframes dial-rot-a { from{stroke-dashoffset:0} to{stroke-dashoffset:-60} }
  @keyframes dial-rot-b { from{stroke-dashoffset:0} to{stroke-dashoffset:60} }
  .node-a { animation: nodep 3s   ease-in-out infinite; }
  .node-b { animation: nodep 3.6s ease-in-out infinite .5s; }
  .node-c { animation: nodep 4s   ease-in-out infinite 1s; }
  @keyframes nodep { 0%,100%{opacity:.2} 50%{opacity:.48} }

  .back { display: inline-flex; align-items: center; gap: .5rem; padding: 2.5rem 0 2rem; font-family: 'Mulish', sans-serif; font-size: .6rem; font-weight: 700; letter-spacing: .2em; text-transform: uppercase; color: var(--ink-soft); text-decoration: none; opacity: 0; animation: rise .8s .05s ease forwards; transition: color .2s, gap .2s; }
  .back:hover { color: var(--blue-deep); gap: .7rem; }
  .back-arrow { width: 18px; height: 18px; border: 1px solid var(--rule); border-radius: 3px; display: flex; align-items: center; justify-content: center; }
  .back-arrow svg { width: 11px; height: 11px; stroke: currentColor; stroke-width: 2; fill: none; }

  .page-header { padding: 0 0 2.5rem; opacity: 0; animation: rise .9s .05s ease forwards; }
  .page-eyebrow { font-family: 'Mulish', sans-serif; font-size: .6rem; font-weight: 700; letter-spacing: .28em; text-transform: uppercase; color: var(--blue-deep); opacity: .8; margin-bottom: 1rem; }
  .page-titre { font-family: 'Libre Baskerville', Georgia, serif; font-size: clamp(1.8rem, 3.5vw, 2.4rem); font-weight: 700; color: var(--ink); line-height: 1.2; letter-spacing: -.02em; margin-bottom: .9rem; }
  .page-titre em { font-style: italic; font-weight: 400; color: var(--blue); }
  .page-sous { font-family: 'Mulish', sans-serif; font-size: .875rem; font-weight: 300; color: var(--ink-soft); line-height: 1.8; max-width: 52ch; margin-bottom: 1.75rem; }

  .page-stats { display: flex; align-items: center; gap: .75rem; flex-wrap: wrap; opacity: 0; animation: rise .9s .15s ease forwards; }
  .stat { display: flex; align-items: baseline; gap: .35rem; }
  .stat-n { font-family: 'Libre Baskerville', Georgia, serif; font-size: 1.4rem; font-weight: 700; color: var(--blue); line-height: 1; letter-spacing: -.02em; }
  .stat-label { font-family: 'Mulish', sans-serif; font-size: .62rem; font-weight: 300; letter-spacing: .12em; text-transform: uppercase; color: var(--ink-soft); }
  .stat-sep { color: var(--rule); font-size: .9rem; }

  .eng-wrap { display: inline-flex; align-items: center; gap: .32rem; }
  .eng-niveau { font-family: 'Mulish', sans-serif; font-size: .60rem; font-weight: 300; color: var(--ink-soft); opacity: .55; white-space: nowrap; }
  .eng-indicator { display: inline-flex; align-items: flex-end; gap: 4px; }
  .eng-bar { display: inline-block; width: 4px; border-radius: 2px 2px 1px 1px; background: var(--rule); }
  .eng-b1 { height: 6px; } .eng-b2 { height: 10px; } .eng-b3 { height: 14px; }
  .eng-bar.on { background: var(--blue); }

  /* PERSONNAGES */
  .personnages-wrap { display: flex; align-items: center; gap: 1.5rem; margin-bottom: 2rem; padding: 1.25rem 1.5rem; border: 1px solid var(--blue-dim); border-top: 2.5px solid var(--blue); border-radius: 0 0 6px 6px; background: var(--blue-bg); opacity: 0; animation: rise .9s .2s ease forwards; }
  .personnage-card { display: flex; align-items: flex-start; gap: .85rem; flex: 1; }
  .personnage-initiale { width: 44px; height: 44px; border-radius: 50%; border: 1.5px solid; display: flex; align-items: center; justify-content: center; font-family: 'Libre Baskerville', Georgia, serif; font-size: 1rem; font-weight: 700; flex-shrink: 0; }
  .personnage-initiale--e { color: var(--blue); border-color: var(--blue-dim); background: rgba(58,159,216,.08); }
  .personnage-initiale--n { color: var(--blue-deep); border-color: rgba(26,90,138,.25); background: rgba(26,90,138,.07); }
  .personnage-nom { font-family: 'Libre Baskerville', Georgia, serif; font-size: .9rem; font-weight: 700; color: var(--ink); margin-bottom: .2rem; }
  .personnage-desc { font-family: 'Mulish', sans-serif; font-size: .72rem; font-weight: 300; color: var(--ink-soft); line-height: 1.55; }
  .personnage-et { font-family: 'Libre Baskerville', Georgia, serif; font-size: .8rem; font-style: italic; color: var(--ink-soft); opacity: .4; flex-shrink: 0; }

  .ornament-sep { display: flex; align-items: center; gap: 1rem; margin: 0 0 .5rem; opacity: 0; animation: rise .9s .3s ease forwards; }
  .orn-line { flex: 1; height: 1px; background: linear-gradient(to right, transparent, var(--rule), transparent); }
  .orn-centre { display: flex; align-items: center; gap: .55rem; }
  .orn-diamond { width: 5px; height: 5px; background: var(--blue); opacity: .5; transform: rotate(45deg); }
  .orn-label { font-family: 'Mulish', sans-serif; font-size: .58rem; font-weight: 700; letter-spacing: .25em; text-transform: uppercase; color: var(--blue-deep); opacity: .6; }

  .episodes-list { display: flex; flex-direction: column; padding-top: 1.5rem; }
  .episode-row { display: flex; gap: 1.75rem; align-items: flex-start; }
  .episode-fil-wrap { display: flex; flex-direction: column; align-items: center; flex-shrink: 0; width: 32px; padding-top: .2rem; }
  .episode-numero { width: 28px; height: 28px; border: 1px solid var(--blue-dim); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: 'Libre Baskerville', Georgia, serif; font-size: .72rem; font-weight: 700; color: var(--blue); background: rgba(58,159,216,.07); flex-shrink: 0; }
  .episode-trait { width: 1px; flex: 1; min-height: 3rem; background: linear-gradient(to bottom, rgba(58,159,216,.25), transparent); margin: .4rem 0; }

  .episode-card { flex: 1; display: flex; flex-direction: column; gap: .5rem; text-decoration: none; padding: 1.25rem 1.5rem; margin-bottom: 1.25rem; border: 1px solid var(--rule); border-radius: 6px; background: rgba(245,250,255,.5); opacity: 0; animation: rise .7s ease forwards; transition: border-color .2s, background .2s, transform .2s, box-shadow .2s; position: relative; }
  .episode-card::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 2px; background: var(--blue); border-radius: 2px 0 0 2px; transform: scaleY(0); transform-origin: top; transition: transform .28s ease; opacity: .7; }
  .episode-card:hover { border-color: var(--blue-dim); background: rgba(58,159,216,.05); transform: translateX(3px); box-shadow: 0 2px 18px rgba(58,159,216,.09); }
  .episode-card:hover::before { transform: scaleY(1); }

  .episode-card-meta { display: flex; align-items: center; gap: .6rem; flex-wrap: wrap; }
  .episode-date { font-family: 'Mulish', sans-serif; font-size: .58rem; font-weight: 300; letter-spacing: .14em; text-transform: uppercase; color: var(--ink-soft); opacity: .55; }
  .episode-readtime { font-family: 'Mulish', sans-serif; font-size: .58rem; color: var(--ink-soft); opacity: .45; }
  .badge { font-family: 'Mulish', sans-serif; font-size: .5rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; padding: .12rem .38rem; border-radius: 3px; display: inline-flex; align-items: center; gap: .25rem; }
  .badge-encours { background: rgba(58,159,216,.1); color: var(--blue-deep); border: 1px solid rgba(58,159,216,.25); }

  .episode-titre { font-family: 'Libre Baskerville', Georgia, serif; font-size: 1rem; font-weight: 400; font-style: italic; color: var(--ink); line-height: 1.4; transition: color .2s; }
  .episode-card:hover .episode-titre { color: var(--blue-deep); }
  .episode-desc { font-family: 'Mulish', sans-serif; font-size: .82rem; font-weight: 300; color: var(--ink-soft); line-height: 1.65; max-width: 60ch; }
  .episode-tags { display: flex; flex-wrap: wrap; gap: .35rem; margin-top: .1rem; }
  .episode-tag { font-family: 'Mulish', sans-serif; font-size: .58rem; color: var(--ink-soft); opacity: .55; padding: .1rem .45rem; border: 1px solid var(--rule); border-radius: 3px; transition: opacity .2s, border-color .2s; }
  .episode-card:hover .episode-tag { opacity: .75; border-color: rgba(58,159,216,.28); }
  .episode-lire { font-family: 'Mulish', sans-serif; font-size: .62rem; font-weight: 600; letter-spacing: .12em; text-transform: uppercase; color: var(--blue-link); opacity: 0; transform: translateX(-4px); transition: opacity .2s, transform .2s; margin-top: .2rem; display: inline-block; }
  .episode-card:hover .episode-lire { opacity: 1; transform: translateX(0); }

  .invitation-encart { display: flex; align-items: flex-start; gap: .75rem; margin-top: 2.5rem; padding: 1rem 1.25rem; border: 1px solid var(--blue-dim); border-left: 3px solid var(--blue-dim); border-radius: 0 4px 4px 0; background: var(--blue-bg); opacity: 0; animation: rise .9s .6s ease forwards; }
  .invitation-glyph { color: var(--blue); opacity: .6; font-size: .8rem; flex-shrink: 0; margin-top: .1rem; }
  .invitation-texte { font-family: 'Mulish', sans-serif; font-size: .8rem; font-weight: 300; font-style: italic; color: var(--ink-mid); line-height: 1.7; }

  @media (max-width: 600px) { .episode-row { gap: 1rem; } .personnages-wrap { flex-direction: column; gap: 1rem; } .personnage-et { align-self: flex-start; padding-left: .5rem; } .page-wrap { padding: 0 1rem 4rem; } }
  @keyframes rise { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
</style>
