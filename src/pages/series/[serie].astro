---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('articles');

  // Grouper par serie
  const seriesMap = new Map<string, typeof articles>();
  for (const article of articles) {
    if (article.data.serie) {
      const key = article.data.serie;
      if (!seriesMap.has(key)) seriesMap.set(key, []);
      seriesMap.get(key)!.push(article);
    }
  }

  // Générer un slug URL propre depuis le nom de la série
  function toSlug(str: string) {
    return str
      .toLowerCase()
      .normalize('NFD').replace(/[\u0300-\u036f]/g, '')
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-|-$/g, '');
  }

  return Array.from(seriesMap.entries()).map(([serieName, episodes]) => ({
    params: { serie: toSlug(serieName) },
    props: {
      serieName,
      episodes: episodes.sort((a, b) => (a.data.episode ?? 0) - (b.data.episode ?? 0)),
    },
  }));
}

const { serieName, episodes } = Astro.props;

const totalEpisodes = episodes.length;
const stades = episodes.map(e => e.data.stade).filter(Boolean);
const stadeConfig: Record<string, { emoji: string; label: string; color: string }> = {
  graine: { emoji: '🌱', label: 'Graine', color: '#2e7d4e' },
  pousse: { emoji: '🌿', label: 'Pousse', color: '#38783c' },
  arbre:  { emoji: '🌳', label: 'Arbre',  color: '#224422' },
};

// Personnages récurrents détectés depuis les descriptions
const personnagesDetectes = ['Nathalie', 'Élodie'];
---

<Base title={`${serieName} — Syncognie`}>
  <Header />

  <div class="page-wrap">

    <!-- EN-TÊTE -->
    <header class="page-header">

      <!-- Filigrane : deux cercles qui se répondent — évoque le dialogue -->
      <svg class="header-filigrane" viewBox="0 0 420 320" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <!-- Cercle gauche — premier locuteur -->
        <circle cx="155" cy="160" r="90"
          stroke="#8b5e3c" stroke-width=".7"
          stroke-dasharray="3 9"
          opacity=".14"
          class="dial-a"/>
        <circle cx="155" cy="160" r="55"
          stroke="#c4993a" stroke-width="1"
          opacity=".1"
          class="dial-a-inner"/>
        <!-- Cercle droit — second locuteur -->
        <circle cx="265" cy="160" r="90"
          stroke="#8b5e3c" stroke-width=".7"
          stroke-dasharray="3 9"
          opacity=".14"
          class="dial-b"/>
        <circle cx="265" cy="160" r="55"
          stroke="#c4993a" stroke-width="1"
          opacity=".1"
          class="dial-b-inner"/>
        <!-- Zone d'intersection — là où les idées se rencontrent -->
        <ellipse cx="210" cy="160" rx="28" ry="50"
          fill="#c4993a" opacity=".035"/>
        <!-- Ligne de connexion centrale -->
        <line x1="100" y1="160" x2="320" y2="160"
          stroke="#c4993a" stroke-width=".6"
          opacity=".12"
          stroke-dasharray="2 8"/>
        <!-- Points nodaux -->
        <circle cx="155" cy="160" r="4" fill="#c4993a" opacity=".3" class="node-pulse-a"/>
        <circle cx="265" cy="160" r="4" fill="#8b5e3c" opacity=".3" class="node-pulse-b"/>
        <circle cx="210" cy="160" r="5.5" fill="#c4993a" opacity=".22" class="node-center"/>
        <circle cx="210" cy="160" r="2.5" fill="#f5f0e8" opacity=".6"/>
        <!-- Halos -->
        <circle cx="155" cy="160" r="14" fill="none" stroke="#c4993a" stroke-width=".8" opacity=".08" class="node-pulse-a"/>
        <circle cx="265" cy="160" r="14" fill="none" stroke="#8b5e3c" stroke-width=".8" opacity=".08" class="node-pulse-b"/>
        <!-- Petits satellites -->
        <circle cx="155" cy="100" r="2.5" fill="#c4993a" opacity=".2" class="node-pulse-b"/>
        <circle cx="265" cy="220" r="2.5" fill="#8b5e3c" opacity=".2" class="node-pulse-a"/>
        <line x1="155" y1="160" x2="155" y2="100" stroke="#c4993a" stroke-width=".5" opacity=".1"/>
        <line x1="265" y1="160" x2="265" y2="220" stroke="#8b5e3c" stroke-width=".5" opacity=".1"/>
      </svg>

      <a class="back" href="/articles">
        <span class="back-arrow">
          <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
        </span>
        Articles
      </a>

      <p class="page-eyebrow">Série · Récits</p>
      <h1 class="page-titre">{serieName}</h1>

      <p class="page-sous">
        Une série de dialogues entre deux femmes — Nathalie et Élodie —
        qui se retrouvent en terrasse pour penser à voix haute.
        Les idées émergent du vécu, jamais posées frontalement.
      </p>

      <div class="page-stats">
        <span class="stat">
          <span class="stat-n">{totalEpisodes}</span>
          <span class="stat-label">épisode{totalEpisodes > 1 ? 's' : ''}</span>
        </span>
        <span class="stat-sep">·</span>
        <span class="stat">
          <span class="stat-n">{personnagesDetectes.length}</span>
          <span class="stat-label">voix</span>
        </span>
        <span class="stat-sep">·</span>
        <span class="stat">
          <span class="stat-n">{episodes.filter(e => e.data.stade === 'arbre').length || '—'}</span>
          <span class="stat-label">consolidé{episodes.filter(e => e.data.stade === 'arbre').length > 1 ? 's' : ''}</span>
        </span>
      </div>
    </header>

    <!-- PERSONNAGES -->
    <div class="personnages-wrap">
      <div class="personnage-card">
        <div class="personnage-initiale" style="color:#c4993a;border-color:rgba(196,153,58,.25)">É</div>
        <div class="personnage-info">
          <p class="personnage-nom">Élodie</p>
          <p class="personnage-desc">32 ans · Conseil en communication · Analytique, précise, lâche le contrôle par éclats</p>
        </div>
      </div>
      <div class="personnage-et">et</div>
      <div class="personnage-card">
        <div class="personnage-initiale" style="color:#8b5e3c;border-color:rgba(139,94,60,.25)">N</div>
        <div class="personnage-info">
          <p class="personnage-nom">Nathalie</p>
          <p class="personnage-desc">38 ans · Travailleuse sociale · Ancrée dans le concret, ironie douce, regard systémique</p>
        </div>
      </div>
    </div>

    <!-- SÉPARATEUR -->
    <div class="ornament-sep">
      <div class="orn-line"></div>
      <div class="orn-centre">
        <div class="orn-diamond"></div>
        <span class="orn-label">Les épisodes</span>
        <div class="orn-diamond"></div>
      </div>
      <div class="orn-line"></div>
    </div>

    <!-- LISTE ÉPISODES -->
    <div class="episodes-list">
      {episodes.map((ep, i) => {
        const stadeInfo = ep.data.stade ? stadeConfig[ep.data.stade] : null;
        const date = ep.data.date.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
        const wordCount = ep.body.split(/\s+/).length;
        const readTime = Math.max(1, Math.round(wordCount / 200));
        const estDernier = i === episodes.length - 1;

        return (
          <div class="episode-row">
            <!-- Fil vertical -->
            <div class="episode-fil-wrap">
              <div class="episode-numero">{ep.data.episode ?? i + 1}</div>
              {!estDernier && <div class="episode-trait"></div>}
            </div>

            <!-- Contenu -->
            <a class="episode-card" href={`/articles/${ep.slug}`} style={`animation-delay:${0.2 + i * 0.1}s`}>
              <div class="episode-card-meta">
                <span class="episode-date">{date}</span>
                {stadeInfo && (
                  <span class="badge badge-stade"
                    style={`background:color-mix(in srgb,${stadeInfo.color} 8%,transparent);color:${stadeInfo.color};border:1px solid color-mix(in srgb,${stadeInfo.color} 22%,transparent)`}
                  >
                    <span>{stadeInfo.emoji}</span><span>{stadeInfo.label}</span>
                  </span>
                )}
                <span class="episode-readtime">{readTime} min</span>
              </div>

              <p class="episode-titre">{ep.data.title}</p>

              {ep.data.description && (
                <p class="episode-desc">{ep.data.description}</p>
              )}

              {ep.data.tags && ep.data.tags.length > 0 && (
                <div class="episode-tags">
                  {ep.data.tags.slice(0, 4).map((tag: string) => (
                    <span class="episode-tag">{tag}</span>
                  ))}
                </div>
              )}

              <span class="episode-lire">Lire le dialogue →</span>
            </a>
          </div>
        );
      })}
    </div>

    <!-- ENCART BAS : invitation -->
    <div class="invitation-encart">
      <span class="invitation-glyph">◈</span>
      <p class="invitation-texte">
        Une série vivante — les épisodes s'ajoutent au fil du temps,
        au rythme des rencontres et des questions qui surgissent.
      </p>
    </div>

  </div>

  <Footer />
</Base>

<style>
  .page-wrap {
    max-width: var(--max);
    margin: 0 auto;
    padding: 0 1.75rem 6rem;
  }

  /* ── RETOUR ── */
  .back {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    padding: 2.5rem 0 2rem;
    font-family: 'Mulish', sans-serif;
    font-size: .6rem; font-weight: 700;
    letter-spacing: .2em; text-transform: uppercase;
    color: var(--ink-soft); text-decoration: none;
    opacity: 0; animation: rise .8s .05s ease forwards;
    transition: color .2s, gap .2s;
  }
  .back:hover { color: var(--accent); gap: .7rem; }
  .back-arrow {
    width: 18px; height: 18px;
    border: 1px solid var(--rule); border-radius: 3px;
    display: flex; align-items: center; justify-content: center;
    transition: border-color .2s, background .2s; flex-shrink: 0;
  }
  .back:hover .back-arrow { border-color: var(--accent); background: rgba(139,94,60,.06); }
  .back-arrow svg { width: 10px; height: 10px; stroke: currentColor; fill: none; stroke-width: 2; }

  /* ── EN-TÊTE ── */
  .page-header {
    padding: 0 0 2.5rem;
    position: relative;
    overflow: visible;
    opacity: 0;
    animation: rise .9s .08s ease forwards;
  }

  .page-eyebrow {
    font-family: 'Mulish', sans-serif;
    font-size: .6rem; font-weight: 300;
    letter-spacing: .32em; text-transform: uppercase;
    color: var(--accent); opacity: .7;
    margin-bottom: .9rem;
    position: relative; z-index: 1;
  }

  .page-titre {
    font-size: clamp(1.5rem, 3vw, 2.1rem);
    font-weight: 700; font-style: italic;
    color: var(--ink);
    line-height: 1.2; letter-spacing: -.02em;
    margin-bottom: .9rem;
    position: relative; z-index: 1;
  }

  .page-sous {
    font-family: 'Mulish', sans-serif;
    font-size: .875rem; font-weight: 300;
    color: var(--ink-soft); line-height: 1.85;
    max-width: 52ch; margin-bottom: 1.75rem;
    position: relative; z-index: 1;
  }

  .page-stats {
    display: flex; align-items: baseline; gap: .75rem;
    position: relative; z-index: 1;
  }
  .stat { display: flex; align-items: baseline; gap: .35rem; }
  .stat-n {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: 1.4rem; font-weight: 700;
    color: var(--blue-slate, #6b7fb8);
    line-height: 1; letter-spacing: -.02em;
  }
  .stat-label {
    font-family: 'Mulish', sans-serif;
    font-size: .62rem; font-weight: 300;
    letter-spacing: .12em; text-transform: uppercase;
    color: var(--ink-soft);
  }
  .stat-sep { color: var(--rule); font-size: .9rem; }

  /* ── FILIGRANE ── */
  .header-filigrane {
    position: absolute;
    top: 50%; right: -60px;
    transform: translateY(-50%);
    width: 360px; height: 260px;
    pointer-events: none; z-index: 0;
  }
  @media (max-width: 600px) { .header-filigrane { display: none; } }

  .dial-a       { animation: dial-spin-a 28s linear infinite; transform-origin: 155px 160px; }
  .dial-b       { animation: dial-spin-b 34s linear infinite; transform-origin: 265px 160px; }
  .dial-a-inner { animation: fil-p 7s ease-in-out infinite; }
  .dial-b-inner { animation: fil-p 7s ease-in-out infinite; animation-delay: 2s; }

  @keyframes dial-spin-a { to { transform: rotate(360deg); } }
  @keyframes dial-spin-b { to { transform: rotate(-360deg); } }

  .node-pulse-a { animation: fil-p 5s ease-in-out infinite; }
  .node-pulse-b { animation: fil-p 5s ease-in-out infinite; animation-delay: 1.5s; }
  .node-center  { animation: fil-p 4s ease-in-out infinite; }

  @keyframes fil-p {
    0%, 100% { opacity: .2; }
    50%       { opacity: .55; }
  }

  /* ── PERSONNAGES ── */
  .personnages-wrap {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 2.5rem;
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--rule);
    border-radius: 6px;
    background: rgba(245,240,232,.5);
    opacity: 0;
    animation: rise .9s .2s ease forwards;
    flex-wrap: wrap;
  }

  .personnage-card {
    display: flex;
    align-items: center;
    gap: .9rem;
    flex: 1;
    min-width: 200px;
  }

  .personnage-initiale {
    width: 38px; height: 38px;
    border: 1px solid;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: 1rem; font-weight: 700;
    flex-shrink: 0;
  }

  .personnage-nom {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: .9rem; font-weight: 700;
    color: var(--ink);
    margin-bottom: .2rem;
  }

  .personnage-desc {
    font-family: 'Mulish', sans-serif;
    font-size: .72rem; font-weight: 300;
    color: var(--ink-soft);
    line-height: 1.55;
  }

  .personnage-et {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: .8rem; font-style: italic;
    color: var(--ink-soft); opacity: .4;
    flex-shrink: 0;
  }

  /* ── SÉPARATEUR ── */
  .ornament-sep {
    display: flex; align-items: center; gap: 1rem;
    margin-bottom: .5rem;
    opacity: 0; animation: rise .9s .3s ease forwards;
  }
  .orn-line { flex: 1; height: 1px; background: linear-gradient(to right, transparent, var(--rule), transparent); }
  .orn-centre { display: flex; align-items: center; gap: .55rem; }
  .orn-diamond { width: 5px; height: 5px; background: var(--rule); transform: rotate(45deg); }
  .orn-label {
    font-family: 'Mulish', sans-serif;
    font-size: .58rem; font-weight: 700;
    letter-spacing: .25em; text-transform: uppercase;
    color: var(--ink-soft); opacity: .45;
  }

  /* ── LISTE ÉPISODES ── */
  .episodes-list {
    display: flex;
    flex-direction: column;
    padding-top: 1.5rem;
  }

  .episode-row {
    display: flex;
    gap: 1.75rem;
    align-items: flex-start;
  }

  /* Fil vertical + numéro */
  .episode-fil-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
    width: 32px;
    padding-top: .2rem;
  }

  .episode-numero {
    width: 28px; height: 28px;
    border: 1px solid rgba(196,153,58,.3);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: .72rem; font-weight: 700;
    color: #c4993a; opacity: .8;
    flex-shrink: 0;
    background: rgba(196,153,58,.05);
  }

  .episode-trait {
    width: 1px;
    flex: 1;
    min-height: 3rem;
    background: linear-gradient(to bottom, rgba(196,153,58,.2), transparent);
    margin: .4rem 0;
  }

  /* Carte épisode */
  .episode-card {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: .5rem;
    text-decoration: none;
    padding: 1.25rem 1.5rem;
    margin-bottom: 1.25rem;
    border: 1px solid var(--rule);
    border-radius: 6px;
    background: rgba(245,240,232,.4);
    opacity: 0;
    animation: rise .7s ease forwards;
    transition: border-color .2s, background .2s, transform .2s;
    position: relative;
  }

  .episode-card::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 2px;
    background: #c4993a;
    border-radius: 2px 0 0 2px;
    transform: scaleY(0);
    transform-origin: top;
    transition: transform .28s ease;
    opacity: .6;
  }

  .episode-card:hover {
    border-color: rgba(196,153,58,.3);
    background: rgba(245,240,232,.7);
    transform: translateX(3px);
  }

  .episode-card:hover::before { transform: scaleY(1); }

  .episode-card-meta {
    display: flex;
    align-items: center;
    gap: .6rem;
    flex-wrap: wrap;
  }

  .episode-date {
    font-family: 'Mulish', sans-serif;
    font-size: .58rem; font-weight: 300;
    letter-spacing: .14em; text-transform: uppercase;
    color: var(--ink-soft); opacity: .55;
  }

  .episode-readtime {
    font-family: 'Mulish', sans-serif;
    font-size: .58rem; font-weight: 400;
    color: var(--ink-soft); opacity: .45;
  }

  .badge {
    font-family: 'Mulish', sans-serif;
    font-size: .5rem; font-weight: 700;
    letter-spacing: .12em; text-transform: uppercase;
    padding: .12rem .38rem; border-radius: 3px;
    display: inline-flex; align-items: center; gap: .25rem;
  }

  .badge-stade { font-size: .5rem; }

  .episode-titre {
    font-family: 'Libre Baskerville', Georgia, serif;
    font-size: 1rem; font-weight: 400; font-style: italic;
    color: var(--ink);
    line-height: 1.4;
    transition: color .2s;
  }

  .episode-card:hover .episode-titre { color: var(--accent); }

  .episode-desc {
    font-family: 'Mulish', sans-serif;
    font-size: .82rem; font-weight: 300;
    color: var(--ink-soft); line-height: 1.65;
    max-width: 60ch;
  }

  .episode-tags {
    display: flex;
    flex-wrap: wrap;
    gap: .35rem;
    margin-top: .1rem;
  }

  .episode-tag {
    font-family: 'Mulish', sans-serif;
    font-size: .58rem; font-weight: 400;
    color: var(--ink-soft); opacity: .55;
    padding: .1rem .45rem;
    border: 1px solid var(--rule);
    border-radius: 3px;
    background: transparent;
    transition: opacity .2s, border-color .2s;
  }

  .episode-card:hover .episode-tag {
    opacity: .75;
    border-color: rgba(196,153,58,.25);
  }

  .episode-lire {
    font-family: 'Mulish', sans-serif;
    font-size: .62rem; font-weight: 600;
    letter-spacing: .12em; text-transform: uppercase;
    color: #148EFF;
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity .2s, transform .2s;
    margin-top: .2rem;
    display: inline-block;
  }

  .episode-card:hover .episode-lire {
    opacity: 1;
    transform: translateX(0);
  }

  /* ── INVITATION ── */
  .invitation-encart {
    display: flex;
    align-items: flex-start;
    gap: .75rem;
    margin-top: 2.5rem;
    padding: 1rem 1.25rem;
    border: 1px dashed rgba(139,94,60,.2);
    border-radius: 6px;
    background: rgba(139,94,60,.02);
    opacity: 0;
    animation: rise .9s .6s ease forwards;
  }

  .invitation-glyph {
    color: var(--accent);
    opacity: .4;
    font-size: .8rem;
    flex-shrink: 0;
    margin-top: .1rem;
  }

  .invitation-texte {
    font-family: 'Mulish', sans-serif;
    font-size: .8rem; font-weight: 300; font-style: italic;
    color: var(--ink-soft); line-height: 1.7; opacity: .65;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 600px) {
    .episode-row { gap: 1rem; }
    .personnages-wrap { flex-direction: column; gap: 1rem; }
    .personnage-et { align-self: flex-start; padding-left: .5rem; }
  }

  @keyframes rise {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
