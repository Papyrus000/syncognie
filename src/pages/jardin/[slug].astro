---
// src/pages/jardin/[slug].astro
import Base from '../../layouts/Base.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { computeStade, computeMoss, ageText, STADE_META } from '../../lib/jardin';

export async function getStaticPaths() {
  const entries = await getCollection('jardin');
  return entries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props { entry: CollectionEntry<'jardin'>; }
const { entry } = Astro.props;
const { Content } = await entry.render();

const { title, date, modifie, tags, stade: forcedStade, description } = entry.data;
const refDate = modifie || date;
const stade = computeStade(refDate, forcedStade);
const meta = STADE_META[stade];
const mossIntensity = computeMoss(refDate, stade);

const dateStr = date?.toLocaleDateString('fr-FR', {
  weekday: 'long', day: 'numeric', month: 'long', year: 'numeric'
});
---

<Base title={`${title} · Jardin · Syncognie`} description={description}>

  <style>
    :root {
      --j-seed:    #9a7a20;
      --j-sprout:  #4a8a30;
      --j-tree:    #2a6820;
      --j-dormant: #6a5a40;
    }

    /* Bande couleur en haut selon stade */
    .stade-ribbon {
      height: 3px; width: 100%;
    }
    .r-graine  { background: linear-gradient(90deg, var(--j-seed),    transparent 60%); }
    .r-pousse  { background: linear-gradient(90deg, var(--j-sprout),  transparent 60%); }
    .r-arbre   { background: linear-gradient(90deg, var(--j-tree),    transparent 60%); }
    .r-dormant { background: linear-gradient(90deg, var(--j-dormant), transparent 60%); opacity: .5; }

    .article-wrap {
      max-width: 680px;
      margin: 0 auto;
      padding: 3rem 2rem 5rem;
      animation: rise .45s ease both;
    }

    /* Fil d'Ariane */
    .breadcrumb {
      display: flex; align-items: center; gap: .5rem;
      margin-bottom: 2rem;
      font-family: 'Mulish', sans-serif;
      font-size: .62rem; font-weight: 300;
      letter-spacing: .1em;
      color: rgba(245,240,232,.3);
    }
    .breadcrumb a {
      color: rgba(245,240,232,.3); text-decoration: none;
      transition: color .2s;
    }
    .breadcrumb a:hover { color: rgba(245,240,232,.65); }
    .breadcrumb-sep { opacity: .3; }

    /* Meta */
    .article-meta {
      display: flex; align-items: center; gap: .8rem;
      margin-bottom: 1.5rem; flex-wrap: wrap;
    }

    .stade-badge {
      display: flex; align-items: center; gap: .3rem;
      font-family: 'Mulish', sans-serif;
      font-size: .6rem; font-weight: 300;
      letter-spacing: .12em; text-transform: uppercase;
      padding: .2rem .6rem; border-radius: 2px; border: 1px solid;
    }
    .b-graine  { color: var(--j-seed);    border-color: rgba(154,122,32,.3);  background: rgba(154,122,32,.06); }
    .b-pousse  { color: var(--j-sprout);  border-color: rgba(74,138,48,.3);   background: rgba(74,138,48,.06); }
    .b-arbre   { color: var(--j-tree);    border-color: rgba(42,104,32,.35);  background: rgba(42,104,32,.07); }
    .b-dormant { color: var(--j-dormant); border-color: rgba(106,90,64,.3);   background: rgba(106,90,64,.06); }

    .meta-date {
      font-family: 'Mulish', sans-serif;
      font-size: .62rem; font-weight: 300;
      letter-spacing: .06em;
      color: rgba(245,240,232,.3);
    }
    .meta-age {
      font-family: 'Mulish', sans-serif;
      font-size: .6rem;
      color: rgba(245,240,232,.2);
      font-style: italic;
    }

    h1.article-title {
      font-family: 'Libre Baskerville', Georgia, serif;
      font-size: clamp(1.6rem, 4vw, 2.4rem);
      font-weight: 400; line-height: 1.2;
      color: #f5f0e8;
      margin-bottom: .6rem;
    }

    .article-desc {
      font-family: 'Libre Baskerville', serif;
      font-style: italic; font-size: .95rem;
      color: rgba(245,240,232,.45); line-height: 1.65;
      margin-bottom: 1.5rem;
    }

    .article-tags {
      display: flex; flex-wrap: wrap; gap: .35rem;
      margin-bottom: 2rem;
    }
    .tag {
      font-family: 'Mulish', sans-serif;
      font-size: .58rem; font-weight: 300; letter-spacing: .08em;
      padding: .18rem .5rem; border-radius: 2px;
      background: rgba(245,240,232,.04);
      color: rgba(245,240,232,.3);
      border: 1px solid rgba(245,240,232,.07);
    }

    .divider {
      height: 1px;
      background: linear-gradient(90deg, rgba(245,240,232,.1), transparent);
      margin-bottom: 2.5rem;
    }

    /* ── Corps Markdown ── */
    .article-body {
      font-family: 'Libre Baskerville', serif;
      font-size: 1.05rem; line-height: 1.85;
      color: rgba(245,240,232,.78);
    }
    .dormant-body { color: rgba(245,240,232,.45); }

    .article-body :global(h1),
    .article-body :global(h2),
    .article-body :global(h3) {
      font-family: 'Libre Baskerville', serif;
      font-weight: 400; color: #f5f0e8;
      margin: 2rem 0 .7rem; line-height: 1.3;
    }
    .article-body :global(h1) { font-size: 1.5rem; }
    .article-body :global(h2) {
      font-size: 1.2rem;
      border-bottom: 1px solid rgba(245,240,232,.07);
      padding-bottom: .4rem;
    }
    .article-body :global(h3) { font-size: 1rem; font-style: italic; color: var(--gold); }

    .article-body :global(p) { margin-bottom: 1.1rem; }
    .article-body :global(strong) { color: #f5f0e8; font-weight: 700; }
    .article-body :global(em) { color: var(--gold-text); font-style: italic; }

    .article-body :global(blockquote) {
      border-left: 2px solid rgba(232,184,50,.3);
      padding: .4rem 0 .4rem 1.2rem;
      margin: 1.5rem 0;
      font-style: italic;
      color: rgba(245,240,232,.5);
    }

    .article-body :global(ul),
    .article-body :global(ol) {
      padding-left: 1.5rem; margin-bottom: 1rem;
    }
    .article-body :global(li) { margin-bottom: .35rem; }

    .article-body :global(code) {
      font-family: 'Mulish', monospace;
      font-size: .82rem;
      background: rgba(245,240,232,.06);
      padding: .1rem .4rem; border-radius: 2px;
      color: rgba(245,240,232,.75);
    }
    .article-body :global(pre) {
      background: rgba(0,0,0,.3);
      border: 1px solid rgba(245,240,232,.07);
      border-radius: 4px; padding: 1rem 1.2rem;
      overflow-x: auto; margin-bottom: 1.2rem;
    }
    .article-body :global(pre code) { background: none; padding: 0; }

    .article-body :global(hr) {
      border: none; height: 1px;
      background: rgba(245,240,232,.08);
      margin: 2rem 0;
    }

    .article-body :global(a) {
      color: var(--link);
      text-decoration: underline;
      text-decoration-color: rgba(58,159,216,.3);
      transition: text-decoration-color .2s;
    }
    .article-body :global(a:hover) {
      text-decoration-color: var(--link);
    }

    /* Mousse note dormante sur l'article */
    .dormant-notice {
      display: flex; align-items: center; gap: .6rem;
      margin-bottom: 2rem; padding: .7rem 1rem;
      background: rgba(106,90,64,.08);
      border: 1px solid rgba(106,90,64,.2);
      border-radius: 3px;
      font-family: 'Mulish', sans-serif;
      font-size: .72rem; font-weight: 300;
      color: rgba(245,240,232,.35);
      letter-spacing: .04em;
    }

    @media (max-width: 600px) {
      .article-wrap { padding: 2rem 1.2rem 4rem; }
    }
  </style>

  <div class={`stade-ribbon r-${stade}`}></div>

  <article class="article-wrap">

    <div class="breadcrumb">
      <a href="/jardin">Jardin</a>
      <span class="breadcrumb-sep">·</span>
      <span>{meta.icon} {meta.label}</span>
    </div>

    <div class="article-meta">
      <div class={`stade-badge b-${stade}`}>
        <span>{meta.icon}</span>
        <span>{meta.label}</span>
      </div>
      {dateStr && <span class="meta-date">{dateStr}</span>}
      <span class="meta-age">{ageText(refDate)}</span>
    </div>

    <h1 class="article-title">{title}</h1>

    {description && <p class="article-desc">{description}</p>}

    {tags && tags.length > 0 && (
      <div class="article-tags">
        {tags.map(tag => <span class="tag">{tag}</span>)}
      </div>
    )}

    <div class="divider"></div>

    {stade === 'dormant' && (
      <div class="dormant-notice">
        💤 Cette note est en veille depuis longtemps. Elle se couvre doucement de mousse numérique.
      </div>
    )}

    <div class={`article-body${stade === 'dormant' ? ' dormant-body' : ''}`}>
      <Content />
    </div>

  </article>

</Base>
