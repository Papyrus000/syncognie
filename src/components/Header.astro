---
const currentPath = Astro.url.pathname;
---

<header class="topbar">
  <a href="/" class="topbar-logo" aria-label="Syncognie — accueil">
<div class="logo-icon">
  <div class="logo-dot"></div>
</div>
    <span class="topbar-name">syncognie</span>
  </a>

  <nav class="topbar-nav">
    <a href="/fenetres" class={`topbar-link ${currentPath.startsWith('/fenetres') ? 'active' : ''}`}>
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
        <rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/>
      </svg>
      Fenêtres
    </a>
    <a href="/carte" class={`topbar-link ${currentPath === '/carte' ? 'active' : ''}`}>
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
        <circle cx="12" cy="5" r="2"/><circle cx="5" cy="19" r="2"/><circle cx="19" cy="19" r="2"/>
        <line x1="12" y1="7" x2="7" y2="17"/><line x1="12" y1="7" x2="17" y2="17"/>
      </svg>
      Carte
    </a>
    <a href="/outils" class={`topbar-link ${currentPath === '/outils' ? 'active' : ''}`}>
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
        <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
      </svg>
      Outils
    </a>
    <a href="/apropos" class={`topbar-link ${currentPath === '/apropos' ? 'active' : ''}`}>
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
        <circle cx="12" cy="7" r="4"/>
      </svg>
      À propos
    </a>
    <a href="/contact" class={`topbar-link ${currentPath === '/contact' ? 'active' : ''}`}>
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2-2-2z"/>
        <polyline points="22,6 12,12 2,6"/>
      </svg>
      Contact
    </a>
  </nav>
</header>

<style>
  .topbar {
    position: sticky;
    top: 0;
    z-index: 100;
    width: 100%;
    background: #1a1714;
    border-bottom: 1px solid rgba(245, 240, 232, 0.06);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1.75rem;
    height: 52px;
  }

  .topbar-logo {
    display: flex;
    align-items: center;
    gap: .6rem;
    text-decoration: none;
  }

.logo-icon {
  width: 30px;
  height: 30px;
  border-radius: 50%;
  border: 1.5px solid rgba(245, 240, 232, .15);
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.logo-icon::after {
  content: '';
  position: absolute;
  inset: -1.5px;
  border-radius: 50%;
  border: 1.5px solid transparent;
  border-top-color: #c4993a;
  border-left-color: rgba(196, 153, 58, .3);
  animation: logo-spin 4s linear infinite;
}

.logo-dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: rgba(245, 240, 232, .5);
  animation: logo-orbit 3.5s ease-in-out infinite;
}

@keyframes logo-spin {
  to { transform: rotate(360deg); }
}

@keyframes logo-orbit {
  0%, 100% { transform: translateY(-5px) translateX(1px); opacity: .45; }
  50%       { transform: translateY(5px) translateX(-1px); opacity: .9; }
}

  .topbar-name {
    font-family: 'Mulish', sans-serif;
    font-size: .72rem;
    font-weight: 300;
    letter-spacing: .28em;
    color: #f5f0e8;
    opacity: .85;
    transition: opacity .2s;
  }

  .topbar-logo:hover .topbar-name { opacity: 1; }

  .topbar-nav {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .topbar-link {
    display: flex;
    align-items: center;
    gap: .4rem;
    font-family: 'Mulish', sans-serif;
    font-size: .68rem;
    font-weight: 300;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: rgba(245, 240, 232, .75);
    text-decoration: none;
    transition: color .2s;
  }

.topbar-link:hover,
.topbar-link.active { color: #1eff00; }

  .topbar-link svg { opacity: .7; transition: opacity .2s; }
  .topbar-link:hover svg,
  .topbar-link.active svg { opacity: 1; }

  @media (max-width: 600px) {
    .topbar-name { display: none; }
    .topbar-nav { gap: 1rem; }
    .topbar-link span { display: none; }
  }
</style>