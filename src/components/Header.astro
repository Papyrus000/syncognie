---
const currentPath = Astro.url.pathname;
---

<header class="topbar" id="site-header">
  <a href="/" class="topbar-logo" aria-label="Syncognie — accueil">
    <div class="logo-icon">
      <div class="logo-dot"></div>
    </div>
    <span class="topbar-name">syncognie</span>
  </a>

  <nav class="topbar-nav" aria-label="Navigation principale">
    <div class="nav-primary">
      <a href="/vies" class={`topbar-link topbar-link--primary ${currentPath.startsWith('/vies') ? 'active' : ''}`}>
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        Vies
      </a>
      <a href="/cartes" class={`topbar-link topbar-link--primary ${currentPath.startsWith('/cartes') ? 'active' : ''}`}>
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
          <polygon points="3 11 22 2 13 21 11 13 3 11"/>
        </svg>
        Cartes
      </a>
      <!-- Atelier — position 3, badge pill signature -->
      <a href="/atelier" class={`topbar-link topbar-link--primary topbar-link--atelier ${currentPath.startsWith('/atelier') ? 'active' : ''}`}>
        <span class="atelier-pill">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 12l-8.5 8.5a2.121 2.121 0 0 1-3-3L12 9"/><path d="M17.64 15L22 10.36"/><path d="M20.91 11.7a2.5 2.5 0 1 0-3.61-3.46l1.06 1.06a1 1 0 0 1 0 1.41l-1.4 1.4a1 1 0 0 1-1.42 0l-1.06-1.06a2.5 2.5 0 0 0 3.46 3.61z"/>
          </svg>
          Atelier
        </span>
      </a>
    </div>
    <div class="nav-sep" aria-hidden="true"></div>
    <div class="nav-secondary">
      <a href="/journal" class={`topbar-link topbar-link--secondary ${currentPath.startsWith('/journal') ? 'active' : ''}`}>
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
          <path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
        </svg>
        Journal
      </a>
      <a href="/outils" class={`topbar-link topbar-link--secondary ${currentPath.startsWith('/outils') ? 'active' : ''}`}>
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
          <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
        </svg>
        Outils
      </a>
      <a href="/planches" class={`topbar-link topbar-link--secondary ${currentPath.startsWith('/planches') ? 'active' : ''}`}>
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
          <rect x="3" y="3" width="7" height="7" rx="1"/>
          <rect x="14" y="3" width="7" height="7" rx="1"/>
          <rect x="3" y="14" width="7" height="7" rx="1"/>
          <rect x="14" y="14" width="7" height="7" rx="1"/>
        </svg>
        Planches
      </a>
      <a href="/apropos" class={`topbar-link topbar-link--secondary ${currentPath === '/apropos' ? 'active' : ''}`}>
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
          <circle cx="12" cy="7" r="4"/>
        </svg>
        À propos
      </a>
      <a href="/contact" class={`topbar-link topbar-link--secondary ${currentPath === '/contact' ? 'active' : ''}`}>
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2-2-2z"/>
          <polyline points="22,6 12,12 2,6"/>
        </svg>
        Contact
      </a>
    </div>
  </nav>

  <button class="hamburger" id="hamburger" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="mobile-menu">
    <span class="ham-bar"></span>
    <span class="ham-bar"></span>
    <span class="ham-bar"></span>
  </button>
</header>

<div class="mobile-menu" id="mobile-menu" aria-hidden="true">
  <nav class="mobile-nav" aria-label="Navigation mobile">
    <a href="/vies" class={`mobile-link mobile-link--primary ${currentPath.startsWith('/vies') ? 'active' : ''}`}>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
      </svg>
      Vies
    </a>
    <a href="/cartes" class={`mobile-link mobile-link--primary ${currentPath.startsWith('/cartes') ? 'active' : ''}`}>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
        <polygon points="3 11 22 2 13 21 11 13 3 11"/>
      </svg>
      Cartes
    </a>
    <!-- Atelier — position 3 mobile, badge pill -->
    <a href="/atelier" class={`mobile-link mobile-link--primary mobile-link--atelier ${currentPath.startsWith('/atelier') ? 'active' : ''}`}>
      <span class="atelier-pill atelier-pill--mobile">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 12l-8.5 8.5a2.121 2.121 0 0 1-3-3L12 9"/><path d="M17.64 15L22 10.36"/><path d="M20.91 11.7a2.5 2.5 0 1 0-3.61-3.46l1.06 1.06a1 1 0 0 1 0 1.41l-1.4 1.4a1 1 0 0 1-1.42 0l-1.06-1.06a2.5 2.5 0 0 0 3.46 3.61z"/>
        </svg>
        Atelier
      </span>
    </a>
    <div class="mobile-sep" aria-hidden="true"></div>
    <a href="/journal" class={`mobile-link ${currentPath.startsWith('/journal') ? 'active' : ''}`}>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
        <path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
      </svg>
      Journal
    </a>
    <a href="/outils" class={`mobile-link ${currentPath.startsWith('/outils') ? 'active' : ''}`}>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
        <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
      </svg>
      Outils
    </a>
    <a href="/planches" class={`mobile-link ${currentPath.startsWith('/planches') ? 'active' : ''}`}>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
        <rect x="3" y="3" width="7" height="7" rx="1"/>
        <rect x="14" y="3" width="7" height="7" rx="1"/>
        <rect x="3" y="14" width="7" height="7" rx="1"/>
        <rect x="14" y="14" width="7" height="7" rx="1"/>
      </svg>
      Planches
    </a>
    <a href="/apropos" class={`mobile-link ${currentPath === '/apropos' ? 'active' : ''}`}>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
        <circle cx="12" cy="7" r="4"/>
      </svg>
      À propos
    </a>
    <a href="/contact" class={`mobile-link ${currentPath === '/contact' ? 'active' : ''}`}>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
        <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2-2-2z"/>
        <polyline points="22,6 12,12 2,6"/>
      </svg>
      Contact
    </a>
  </nav>
</div>

<div class="mobile-overlay" id="mobile-overlay"></div>

<style>
  .topbar {
    position: sticky; top: 0; z-index: 100;
    width: 100%; background: #1a1714;
    border-bottom: 1px solid rgba(245,240,232,.06);
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 1.75rem; height: 52px;
  }
  .topbar-logo {
    display: flex; align-items: center; gap: .6rem;
    text-decoration: none; flex-shrink: 0;
  }
  .logo-icon {
    width: 30px; height: 30px; border-radius: 50%;
    border: 1.5px solid rgba(245,240,232,.15);
    position: relative; display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .logo-icon::after {
    content: ''; position: absolute; inset: -1.5px; border-radius: 50%;
    border: 1.5px solid transparent;
    border-top-color: #c4993a; border-left-color: rgba(196,153,58,.3);
    animation: logo-spin 4s linear infinite;
  }
  .logo-dot {
    width: 5px; height: 5px; border-radius: 50%;
    background: rgba(245,240,232,.5);
    animation: logo-orbit 3.5s ease-in-out infinite;
  }
  @keyframes logo-spin  { to { transform: rotate(360deg); } }
  @keyframes logo-orbit {
    0%,100% { transform: translateY(-5px) translateX(1px);  opacity: .45; }
    50%      { transform: translateY(5px)  translateX(-1px); opacity: .9; }
  }
  .topbar-name {
    font-family: 'Mulish', sans-serif; font-size: .72rem; font-weight: 300;
    letter-spacing: .28em; color: #f5f0e8; opacity: .85; transition: opacity .2s;
  }
  .topbar-logo:hover .topbar-name { opacity: 1; }

  /* NAV DESKTOP */
  .topbar-nav { display: flex; align-items: center; gap: 0; }
  .nav-primary { display: flex; align-items: center; gap: 1.4rem; }
  .nav-secondary { display: flex; align-items: center; gap: 1.1rem; }
  .nav-sep {
    width: 1px; height: 18px;
    background: rgba(245,240,232,.15);
    margin: 0 1.1rem;
    flex-shrink: 0;
  }
  .topbar-link {
    display: flex; align-items: center; gap: .4rem;
    font-family: 'Mulish', sans-serif; font-weight: 300;
    letter-spacing: .18em; text-transform: uppercase;
    color: rgba(245,240,232,.65); text-decoration: none;
    transition: color .2s; white-space: nowrap;
  }
  .topbar-link--primary { font-size: .72rem; font-weight: 400; }
  .topbar-link--secondary { font-size: .62rem; }
  .topbar-link:hover, .topbar-link.active { color: #e8b832; }
  .topbar-link svg { opacity: .6; flex-shrink: 0; transition: opacity .2s; }
  .topbar-link:hover svg, .topbar-link.active svg { opacity: 1; }

  /* ATELIER — badge pill signature */
  .topbar-link--atelier {
    color: rgba(245,240,232,.65);
    transition: none;
  }
  .topbar-link--atelier:hover,
  .topbar-link--atelier.active { color: rgba(245,240,232,.65); }

  .atelier-pill {
    display: inline-flex; align-items: center; gap: .35rem;
    background: linear-gradient(140deg, #e8923a 0%, #c96820 100%);
    color: #fff;
    font-family: 'Mulish', sans-serif; font-size: .67rem; font-weight: 700;
    letter-spacing: .2em; text-transform: uppercase;
    padding: .28rem .65rem .28rem .52rem;
    border-radius: 5px;
    border: 1px solid rgba(255,255,255,.1);
    box-shadow:
      0 1px 4px rgba(0,0,0,.3),
      inset 0 1px 0 rgba(255,255,255,.18);
    transition:
      background .2s ease,
      box-shadow .2s ease,
      transform .18s ease,
      border-color .2s ease,
      color .2s ease;
    will-change: transform, box-shadow;
  }
  .atelier-pill svg {
    flex-shrink: 0; opacity: .9;
    transition: opacity .18s ease, transform .18s ease;
  }

  /* HOVER — le pill s'allume, monte d'1px, halo chaud */
  .topbar-link--atelier:hover .atelier-pill {
    background: linear-gradient(140deg, #f0a050 0%, #d97830 100%);
    border-color: rgba(255,200,100,.2);
    box-shadow:
      0 4px 12px rgba(0,0,0,.25),
      0 0 18px rgba(230,130,40,.3),
      inset 0 1px 0 rgba(255,255,255,.22);
    transform: translateY(-1px);
    color: #fff;
  }
  .topbar-link--atelier:hover .atelier-pill svg {
    opacity: 1;
    transform: rotate(-5deg) scale(1.1);
  }

  /* ACTIF — vert terminal, rappel direct de la page Atelier */
  .topbar-link--atelier.active .atelier-pill {
    background: linear-gradient(140deg, #4a8a42 0%, #2e6228 100%);
    border-color: rgba(122,189,110,.3);
    color: #c8f0c0;
    box-shadow:
      0 1px 4px rgba(0,0,0,.35),
      0 0 14px rgba(122,189,110,.2),
      0 0 0 1px rgba(122,189,110,.15),
      inset 0 1px 0 rgba(255,255,255,.1);
    transform: translateY(0);
  }
  .topbar-link--atelier.active .atelier-pill svg {
    opacity: .9;
    transform: none;
  }

  /* Pill mobile */
  .atelier-pill--mobile {
    font-size: .75rem; padding: .32rem .75rem .32rem .6rem; border-radius: 6px;
  }
  .mobile-link--atelier { color: rgba(245,240,232,.75); }
  .mobile-link--atelier:hover,
  .mobile-link--atelier.active {
    color: rgba(245,240,232,.75);
    background: transparent;
    border-left-color: transparent;
  }
  .mobile-link--atelier:hover .atelier-pill--mobile {
    background: linear-gradient(140deg, #f0a050 0%, #d97830 100%);
    box-shadow: 0 2px 12px rgba(220,130,40,.3), inset 0 1px 0 rgba(255,255,255,.2);
  }
  .mobile-link--atelier.active .atelier-pill--mobile {
    background: linear-gradient(140deg, #4a8a42 0%, #2e6228 100%);
    border-color: rgba(122,189,110,.3);
    color: #c8f0c0;
    box-shadow:
      0 0 12px rgba(122,189,110,.2),
      0 0 0 1px rgba(122,189,110,.15),
      inset 0 1px 0 rgba(255,255,255,.1);
  }
  .mobile-link--atelier.active {
    border-left-color: #7abd6e;
    background: rgba(122,189,110,.05);
  }

  /* HAMBURGER */
  .hamburger {
    display: none; flex-direction: column; justify-content: center;
    align-items: center; gap: 5px;
    width: 36px; height: 36px; background: transparent;
    border: 1px solid rgba(245,240,232,.12); border-radius: 4px;
    cursor: pointer; padding: 0; flex-shrink: 0;
    transition: border-color .2s;
  }
  .hamburger:hover { border-color: rgba(196,153,58,.4); }
  .ham-bar {
    display: block; width: 18px; height: 1.5px;
    background: rgba(245,240,232,.75); border-radius: 2px;
    transition: transform .25s ease, opacity .2s ease, width .25s ease;
    transform-origin: center;
  }
  .hamburger.is-open .ham-bar:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .hamburger.is-open .ham-bar:nth-child(2) { opacity: 0; width: 0; }
  .hamburger.is-open .ham-bar:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  /* MENU MOBILE */
  .mobile-menu {
    display: none; position: fixed;
    top: 52px; right: 0;
    width: min(280px, 85vw); height: calc(100dvh - 52px);
    background: #1a1714;
    border-left: 1px solid rgba(245,240,232,.07);
    z-index: 99; padding: 1rem 0;
    transform: translateX(100%);
    transition: transform .3s cubic-bezier(.4,0,.2,1);
    overflow-y: auto;
  }
  .mobile-menu.is-open { transform: translateX(0); }
  .mobile-nav { display: flex; flex-direction: column; }
  .mobile-link {
    display: flex; align-items: center; gap: .85rem;
    padding: 1rem 1.75rem;
    font-family: 'Mulish', sans-serif; font-size: .8rem; font-weight: 300;
    letter-spacing: .16em; text-transform: uppercase;
    color: rgba(245,240,232,.55); text-decoration: none;
    border-left: 2px solid transparent;
    transition: color .2s, background .2s, border-color .2s;
  }
  .mobile-link:hover, .mobile-link.active {
    color: #e8b832; background: rgba(232,184,50,.05); border-left-color: #e8b832;
  }
  .mobile-link--primary { font-size: .84rem; font-weight: 400; color: rgba(245,240,232,.75); }
  .mobile-sep {
    height: 1px; margin: .5rem 1.75rem;
    background: rgba(245,240,232,.08);
  }
  .mobile-link svg { opacity: .55; flex-shrink: 0; transition: opacity .2s; }
  .mobile-link:hover svg, .mobile-link.active svg { opacity: 1; }

  /* OVERLAY */
  .mobile-overlay {
    display: none; position: fixed; inset: 0; top: 52px;
    background: rgba(0,0,0,.55); z-index: 98;
    opacity: 0; transition: opacity .3s ease; cursor: pointer;
    pointer-events: none;
  }
  .mobile-overlay.is-open { opacity: 1; pointer-events: auto; }

  /* RESPONSIVE */
  @media (max-width: 700px) {
    .topbar-nav     { display: none; }
    .hamburger      { display: flex; }
    .mobile-menu    { display: block; }
    .mobile-overlay { display: block; }
  }
  @media (max-width: 400px) { .topbar { padding: 0 1rem; } }
</style>

<script>
(function () {
  const btn     = document.getElementById('hamburger');
  const menu    = document.getElementById('mobile-menu');
  const overlay = document.getElementById('mobile-overlay');
  if (!btn || !menu || !overlay) return;

  function open() {
    btn.classList.add('is-open');
    menu.classList.add('is-open');
    overlay.classList.add('is-open');
    btn.setAttribute('aria-expanded', 'true');
    menu.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function close() {
    btn.classList.remove('is-open');
    menu.classList.remove('is-open');
    overlay.classList.remove('is-open');
    btn.setAttribute('aria-expanded', 'false');
    menu.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  btn.addEventListener('click', () => btn.classList.contains('is-open') ? close() : open());
  overlay.addEventListener('click', close);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') close(); });
  menu.querySelectorAll('.mobile-link').forEach(l => l.addEventListener('click', close));
})();
</script>
