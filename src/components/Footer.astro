---
const version = 'v0.2.5';
const currentPath = Astro.url.pathname;
---

<footer class="site-footer" role="contentinfo">
  <div class="footer-inner">

    <div class="footer-top">
      <nav class="footer-nav" aria-label="Navigation secondaire">
        <div class="footer-nav-group">
          <span class="footer-group-label">Explorer</span>
          <a href="/vies"   class={`footer-link ${currentPath.startsWith('/vies')   ? 'footer-link--active' : ''}`}>Vies</a>
          <a href="/cartes" class={`footer-link ${currentPath.startsWith('/cartes') ? 'footer-link--active' : ''}`}>Cartes</a>
          <a href="/outils" class={`footer-link ${currentPath.startsWith('/outils') ? 'footer-link--active' : ''}`}>Outils</a>
        </div>
        <div class="footer-nav-group">
          <span class="footer-group-label">À propos</span>
          <a href="/apropos"  class={`footer-link ${currentPath === '/apropos'  ? 'footer-link--active' : ''}`}>À propos</a>
          <a href="/contact"  class={`footer-link ${currentPath === '/contact'  ? 'footer-link--active' : ''}`}>Contact</a>
          <a href="/stades"   class={`footer-link ${currentPath === '/stades'   ? 'footer-link--active' : ''}`}>Stades</a>
        </div>
        <div class="footer-nav-group">
          <span class="footer-group-label">Archives</span>
          <a href="/articles" class={`footer-link ${currentPath.startsWith('/articles') || currentPath.startsWith('/series') ? 'footer-link--active' : ''}`}>Tous les articles</a>
          <a href="/notes"    class={`footer-link ${currentPath === '/notes'    ? 'footer-link--active' : ''}`}>Journal de genèse</a>
          <a href="/carte"    class={`footer-link ${currentPath === '/carte'    ? 'footer-link--active' : ''}`}>Carte du site</a>
        </div>
      </nav>

      <div class="footer-disclaimer">
        <span class="footer-disclaimer-symbol">✦</span>
        <p class="footer-disclaimer-text">
          Syncognie est un jardin numérique qui évolue, pas une clinique.<br />
          Son créateur est un curieux qui lit, croise, se trompe et recommence.<br />
          Les IA coopèrent à la réflexion, au code et à l'écriture du site.<br />
          Ce que tu trouves ici ne sont pas des conseils mais des pistes pour réfléchir et s'interroger.
        </p>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="footer-signature">
        <span class="footer-logo-text">syncognie</span>
        <span class="footer-tagline">Synergie · Cognition · Dialogue</span>
      </div>
      <div class="footer-copy">
        © {new Date().getFullYear()} Syncognie
        <span class="footer-version">{version}</span>
      </div>
    </div>

  </div>
</footer>

<style>
  /* ── Footer ── */
  .site-footer {
    background:
      radial-gradient(ellipse 55% 80px at 50% 0%, rgba(232,184,50,.07) 0%, transparent 100%),
      linear-gradient(to bottom, transparent 0px, #1a1714 72px);
    background-color: #1a1714;
    margin-top: 4rem;
  }

  .footer-inner {
    max-width: var(--max, 740px);
    margin: 0 auto;
    padding: 3.5rem 1.75rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 3rem;
    align-items: start;
  }

  .footer-nav {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .footer-nav-group {
    display: flex;
    flex-direction: column;
    gap: .45rem;
  }

  .footer-group-label {
    font-family: 'Mulish', sans-serif;
    font-size: .625rem;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: rgba(245,240,232,.3);
    margin-bottom: .15rem;
  }

  .footer-link {
    font-family: 'Mulish', sans-serif;
    font-size: .78rem;
    font-weight: 300;
    letter-spacing: .06em;
    color: rgba(245,240,232,.5);
    text-decoration: none;
    transition: color .18s;
    width: fit-content;
  }
  .footer-link:hover   { color: #e8b832; }
  .footer-link--active { color: rgba(245,240,232,.85); }

  .footer-disclaimer {
    display: flex;
    align-items: baseline;
    gap: .5rem;
    max-width: 17rem;
    opacity: .4;
    transition: opacity .3s;
  }
  .footer-disclaimer:hover {
    opacity: .75;
  }

  .footer-disclaimer-symbol {
    font-size: .55rem;
    color: #e8b832;
    flex-shrink: 0;
    margin-top: .15rem;
  }

  .footer-disclaimer-text {
    font-family: 'Mulish', sans-serif;
    font-size: .7rem;
    font-weight: 300;
    letter-spacing: .04em;
    line-height: 1.75;
    color: rgba(245,240,232,.75);
    margin: 0;
    font-style: italic;
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-signature {
    display: flex;
    flex-direction: column;
    gap: .2rem;
  }

  .footer-logo-text {
    font-family: 'Mulish', sans-serif;
    font-size: .72rem;
    font-weight: 400;
    letter-spacing: .28em;
    color: #f5f0e8;
    opacity: .85;
  }

  .footer-tagline {
    font-family: 'Mulish', sans-serif;
    font-size: .69rem;
    font-weight: 300;
    letter-spacing: .12em;
    color: rgba(245,240,232,.35);
  }

  .footer-copy {
    font-family: 'Mulish', sans-serif;
    font-size: .72rem;
    font-weight: 300;
    letter-spacing: .06em;
    color: rgba(245,240,232,.35);
    display: flex;
    align-items: center;
    gap: .55rem;
  }

  .footer-version {
    font-size: .65rem;
  }

  @media (max-width: 680px) {
    .footer-top {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .footer-disclaimer {
      max-width: 100%;
    }
  }

  @media (max-width: 560px) {
    .footer-nav {
      grid-template-columns: 1fr 1fr;
    }
    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: .75rem;
    }
  }

  @media (max-width: 380px) {
    .footer-nav { grid-template-columns: 1fr; }
    .footer-inner { padding: 1.75rem 1rem 1.5rem; }
  }
</style>
