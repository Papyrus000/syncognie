---
const version = 'v0.2.2';
---
<footer class="site-footer">
  © 2026 Syncognie · <span class="version">{version}</span>
</footer>

<style>
  .site-footer {
    max-width: var(--max);
    margin: 0 auto;
    padding: 2rem 1.75rem 3rem;
    border-top: 1px solid var(--rule);
    font-family: 'Mulish', sans-serif;
    font-size: .78rem;
    font-weight: 300;
    letter-spacing: .1em;
    color: var(--ink-soft);
    text-align: center;
  }
  .version { opacity: .45; }
</style>
