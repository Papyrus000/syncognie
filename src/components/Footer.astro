---
const version = 'v0.2.5';
const currentPath = Astro.url.pathname;
---

<footer class="site-footer" role="contentinfo">

  <div class="footer-inner">

    <nav class="footer-nav" aria-label="Navigation secondaire">
      <div class="footer-nav-group">
        <span class="footer-group-label">Explorer</span>
        <a href="/vies"   class={`footer-link ${currentPath.startsWith('/vies')   ? 'footer-link--active' : ''}`}>Vies</a>
        <a href="/cartes" class={`footer-link ${currentPath.startsWith('/cartes') ? 'footer-link--active' : ''}`}>Cartes</a>
        <a href="/outils" class={`footer-link ${currentPath.startsWith('/outils') ? 'footer-link--active' : ''}`}>Outils</a>
      </div>
      <div class="footer-nav-group">
        <span class="footer-group-label">À propos</span>
        <a href="/apropos"  class={`footer-link ${currentPath === '/apropos'  ? 'footer-link--active' : ''}`}>À propos</a>
        <a href="/contact"  class={`footer-link ${currentPath === '/contact'  ? 'footer-link--active' : ''}`}>Contact</a>
        <a href="/stades"   class={`footer-link ${currentPath === '/stades'   ? 'footer-link--active' : ''}`}>Stades</a>
      </div>
      <div class="footer-nav-group">
        <span class="footer-group-label">Archive</span>
        <a href="/articles" class={`footer-link ${currentPath.startsWith('/articles') || currentPath.startsWith('/series') ? 'footer-link--active' : ''}`}>Tous les articles</a>
        <a href="/journal"  class={`footer-link ${currentPath === '/journal'  ? 'footer-link--active' : ''}`}>Journal de genèse</a>
        <a href="/carte"    class={`footer-link ${currentPath === '/carte'    ? 'footer-link--active' : ''}`}>Carte du site</a>
      </div>
    </nav>

    <div class="footer-bottom">
      <div class="footer-signature">
        <span class="footer-logo-text">syncognie</span>
        <span class="footer-tagline">Synergie · Cognition · Dialogue</span>
      </div>
      <div class="footer-copy">
        © {new Date().getFullYear()} Syncognie
        <span class="footer-version">{version}</span>
      </div>
    </div>

  </div>

</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--rule);
    margin-top: 4rem;
  }

  .footer-inner {
    max-width: var(--max, 740px);
    margin: 0 auto;
    padding: 2.2rem 1.75rem 2rem;
  }

  /* Navigation en groupes */
  .footer-nav {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .footer-nav-group {
    display: flex;
    flex-direction: column;
    gap: .45rem;
  }

  .footer-group-label {
    font-family: 'Mulish', sans-serif;
    font-size: .625rem;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: .15rem;
  }

  .footer-link {
    font-family: 'Mulish', sans-serif;
    font-size: .78rem;
    font-weight: 300;
    letter-spacing: .06em;
    color: var(--ink-soft);
    text-decoration: none;
    transition: color .18s;
    width: fit-content;
  }
  .footer-link:hover       { color: var(--accent); }
  .footer-link--active     { color: var(--ink-mid); }

  /* Bas de footer */
  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--rule);
    flex-wrap: wrap;
  }

  .footer-signature {
    display: flex;
    flex-direction: column;
    gap: .2rem;
  }

  .footer-logo-text {
    font-family: 'Mulish', sans-serif;
    font-size: .72rem;
    font-weight: 400;
    letter-spacing: .28em;
    color: var(--ink);
  }

  .footer-tagline {
    font-family: 'Mulish', sans-serif;
    font-size: .69rem;
    font-weight: 300;
    letter-spacing: .12em;
    color: var(--ink-soft);
    opacity: .65;
  }

  .footer-copy {
    font-family: 'Mulish', sans-serif;
    font-size: .72rem;
    font-weight: 300;
    letter-spacing: .06em;
    color: var(--ink-soft);
    opacity: .7;
    display: flex;
    align-items: center;
    gap: .55rem;
  }

  .footer-version {
    font-size: .65rem;
  }

  @media (max-width: 560px) {
    .footer-nav {
      grid-template-columns: 1fr 1fr;
    }
    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: .75rem;
    }
  }

  @media (max-width: 380px) {
    .footer-nav { grid-template-columns: 1fr; }
    .footer-inner { padding: 1.75rem 1rem 1.5rem; }
  }
</style>
