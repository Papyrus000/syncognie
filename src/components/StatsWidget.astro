---
// StatsWidget.astro v4 — src/components/StatsWidget.astro
---

<button class="sw-dot" id="swDot" aria-label="Ouvrir le carnet de bord" aria-expanded="false" aria-controls="swPanel">
  <span class="sw-dot-core" aria-hidden="true"></span>
</button>

<div class="sw-panel" id="swPanel" role="dialog" aria-label="Carnet de bord" aria-hidden="true">
  <header class="sw-panel-header">
    <span class="sw-panel-title">carnet de bord</span>
    <button class="sw-panel-close" id="swClose" aria-label="Fermer">✕</button>
  </header>

  <section class="sw-block">
    <p class="sw-block-label">nuancier émotionnel</p>
    <div class="sw-block-body" id="swNuancierBody">
      <p class="sw-empty">Aucune session jouée</p>
    </div>
  </section>

  <div class="sw-divider" aria-hidden="true"></div>

  <section class="sw-block">
    <p class="sw-block-label">temps sur le site</p>
    <div class="sw-block-body">
      <p class="sw-stat-line">
        <span class="sw-stat-value" id="swTime">—</span>
        <span class="sw-stat-unit">de lecture</span>
      </p>
      <p class="sw-stat-sub" id="swLastVisit"></p>
    </div>
  </section>

  <div class="sw-divider" aria-hidden="true"></div>

  <section class="sw-block">
    <p class="sw-block-label">articles lus</p>
    <div class="sw-block-body">
      <p class="sw-stat-line">
        <span class="sw-stat-value" id="swArticlesCount">0</span>
        <span class="sw-stat-unit" id="swArticlesUnit">article</span>
      </p>
      <p class="sw-stat-sub" id="swLastArticle"></p>
    </div>
  </section>

  <footer class="sw-panel-footer">
    <span>syncognie · jardin numérique</span>
  </footer>
</div>

<script is:inline>
(function () {
  var KEY = 'syncognie_stats_v1';

  function defaultStats() {
    return {
      nuancier: { sessions: [], bestScore: 0, bestTotal: 10, totalCorrect: 0, totalAnswered: 0, cartographiees: [] },
      time:     { totalSeconds: 0, lastVisit: null, sessionStart: null },
      articles: { read: [], lastRead: null }
    };
  }

  function readStats() {
    try {
      var raw = localStorage.getItem(KEY);
      if (!raw) return defaultStats();
      var p = JSON.parse(raw);
      var d = defaultStats();
      return {
        nuancier: Object.assign({}, d.nuancier, p.nuancier || {}),
        time:     Object.assign({}, d.time,     p.time     || {}),
        articles: Object.assign({}, d.articles, p.articles || {})
      };
    } catch(e) { return defaultStats(); }
  }

  function writeStats(s) {
    try { localStorage.setItem(KEY, JSON.stringify(s)); } catch(e) {}
  }

  function formatTime(sec) {
    if (sec < 60) return '< 1 min';
    var h   = Math.floor(sec / 3600);
    var min = Math.floor((sec % 3600) / 60);
    if (h > 0) return h + 'h' + (min > 0 ? ' ' + min + ' min' : '');
    return min + ' min';
  }

  function avgScore(s) {
    var tot = s.nuancier.totalAnswered;
    if (tot === 0) return null;
    return Math.round((s.nuancier.totalCorrect / tot) * 10 * 10) / 10;
  }

  function startSession() {
    var s = readStats();
    s.time.lastVisit    = new Date().toISOString();
    s.time.sessionStart = new Date().toISOString();
    writeStats(s);
  }

  function endSession() {
    var s = readStats();
    if (!s.time.sessionStart) return;
    var elapsed = Math.floor((Date.now() - new Date(s.time.sessionStart).getTime()) / 1000);
    s.time.totalSeconds += Math.min(elapsed, 1800);
    s.time.sessionStart  = null;
    writeStats(s);
  }

  startSession();

  // ── Écoute la lecture d'un article ──
  window.addEventListener('article:read', function (e) {
    var slug = e.detail && e.detail.slug;
    if (!slug) return;
    var s = readStats();
    if (!s.articles.read) s.articles.read = [];
    if (s.articles.read.indexOf(slug) === -1) {
      s.articles.read.push(slug);
      s.articles.lastRead = slug;
      writeStats(s);
    }
  });

  // ── Écoute temps réel des émotions correctement identifiées ──
  window.addEventListener('nuancier:emotion-unlocked', function (e) {
    var emotion = e.detail && e.detail.emotion;
    if (!emotion) return;
    var s = readStats();
    if (!s.nuancier.cartographiees) s.nuancier.cartographiees = [];
    if (s.nuancier.cartographiees.indexOf(emotion) === -1) {
      s.nuancier.cartographiees.push(emotion);
      s.nuancier.derniereCartographiee = emotion;
      writeStats(s);
      // Re-render le panneau si ouvert
      if (document.getElementById('swPanel').classList.contains('sw-panel--open')) {
        renderPanel();
      }
    }
  });

  document.addEventListener('visibilitychange', function () {
    if (document.hidden) endSession(); else startSession();
  });
  window.addEventListener('beforeunload', endSession);
  setInterval(function () { endSession(); startSession(); }, 5 * 60 * 1000);

  window.saveNuancierSession = function (score, total) {
    var s = readStats();
    s.nuancier.sessions.push({ date: new Date().toISOString(), score: score, total: total });
    s.nuancier.totalCorrect  += score;
    s.nuancier.totalAnswered += total;
    if (score > s.nuancier.bestScore) {
      s.nuancier.bestScore = score;
      s.nuancier.bestTotal = total;
    }
    writeStats(s);
  };

  function renderPanel() {
    var s        = readStats();
    var nuBody   = document.getElementById('swNuancierBody');
    var sessions = s.nuancier.sessions || [];
    var avg      = avgScore(s);
    var cartographiees = s.nuancier.cartographiees || [];
    var total    = s.nuancier.emotionTotal || (window.__NU_TOTAL_EMOTIONS__) || cartographiees.length || 1;
    var derniere = s.nuancier.derniereCartographiee || null;

    if (sessions.length === 0 && cartographiees.length === 0) {
      nuBody.innerHTML = '<p class="sw-empty">Aucune session jouée</p>';
    } else {
      var plural = sessions.length > 1 ? 's' : '';
      var cartoCount = cartographiees.length;
      var cartoPct   = Math.round((cartoCount / total) * 100);

      // Nombre de segments de la mini-barre (10 blocs)
      var filled  = Math.round((cartoCount / total) * 10);
      var barHTML = '';
      for (var i = 0; i < 10; i++) {
        barHTML += '<span class="sw-carto-seg' + (i < filled ? ' sw-carto-seg--on' : '') + '"></span>';
      }

      var cartoSub = derniere
        ? '<p class="sw-carto-derniere">dernière\u00a0: ' + derniere + '</p>'
        : (sessions.length > 0 && cartoCount === 0
            ? '<p class="sw-carto-derniere">jouez pour commencer à cartographier</p>'
            : '');

      nuBody.innerHTML =
        // Sessions + pills score
        (sessions.length > 0
          ? '<p class="sw-stat-line">' +
              '<span class="sw-stat-value">' + sessions.length + '</span>' +
              ' <span class="sw-stat-unit">session' + plural + '</span>' +
            '</p>' +
            '<div class="sw-nu-row">' +
              '<div class="sw-nu-pill">' +
                '<span class="sw-nu-pill-label">meilleur</span>' +
                '<span class="sw-nu-pill-val">' + s.nuancier.bestScore +
                  ' <span class="sw-nu-pill-total">/ ' + s.nuancier.bestTotal + '</span></span>' +
              '</div>' +
              '<div class="sw-nu-pill">' +
                '<span class="sw-nu-pill-label">moyenne</span>' +
                '<span class="sw-nu-pill-val">' + (avg !== null ? avg : '—') +
                  ' <span class="sw-nu-pill-total">/ 10</span></span>' +
              '</div>' +
            '</div>'
          : '') +
        // Bloc cartographie — toujours affiché dès qu'il y a sessions ou cartographiees
        '<div class="sw-carto-block">' +
          '<div class="sw-carto-header">' +
            '<span class="sw-carto-label">cartographiées</span>' +
            '<span class="sw-carto-count">' + cartoCount + '\u2009/\u2009' + total + '</span>' +
          '</div>' +
          '<div class="sw-carto-bar">' + barHTML + '</div>' +
          cartoSub +
        '</div>';
    }

    document.getElementById('swTime').textContent = formatTime(s.time.totalSeconds);
    var lastVisitEl = document.getElementById('swLastVisit');
    if (s.time.lastVisit) {
      var diff = Math.floor((Date.now() - new Date(s.time.lastVisit).getTime()) / 86400000);
      if (diff === 0)      lastVisitEl.textContent = "Dernière visite : aujourd'hui";
      else if (diff === 1) lastVisitEl.textContent = 'Dernière visite : hier';
      else                 lastVisitEl.textContent = 'Dernière visite : il y a ' + diff + ' jours';
    }

    var count = (s.articles.read || []).length;
    document.getElementById('swArticlesCount').textContent = String(count);
    document.getElementById('swArticlesUnit').textContent  = count > 1 ? 'articles' : 'article';
    var lastArtEl = document.getElementById('swLastArticle');
    if (s.articles.lastRead) {
      var label = s.articles.lastRead.replace(/^/(carnet|journal)//, '').replace(/-/g, ' ');
      lastArtEl.textContent = 'Dernier : ' + label;
    }
  }

  var dot   = document.getElementById('swDot');
  var panel = document.getElementById('swPanel');
  var close = document.getElementById('swClose');

  // ── Thème selon contexte : atelier (sombre) vs reste du site (clair) ──
  var isAtelier = window.location.pathname.startsWith('/atelier');
  panel.classList.add(isAtelier ? 'sw-theme--dark' : 'sw-theme--light');

  function openPanel() {
    renderPanel();
    panel.classList.add('sw-panel--open');
    panel.setAttribute('aria-hidden', 'false');
    dot.setAttribute('aria-expanded', 'true');
    dot.classList.add('sw-dot--active');
  }

  function closePanel() {
    panel.classList.remove('sw-panel--open');
    panel.setAttribute('aria-hidden', 'true');
    dot.setAttribute('aria-expanded', 'false');
    dot.classList.remove('sw-dot--active');
  }

  dot.addEventListener('click', function (e) {
    e.stopPropagation();
    panel.classList.contains('sw-panel--open') ? closePanel() : openPanel();
  });
  close.addEventListener('click', closePanel);

  document.addEventListener('click', function (e) {
    if (panel.classList.contains('sw-panel--open') && !panel.contains(e.target) && e.target !== dot) {
      closePanel();
    }
  });

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closePanel();
  });

})();
</script>

<style is:global>
  /* ── Dot — visible, solide, harmonieux ── */
  .sw-dot {
    position: fixed;
    bottom: 1.6rem;
    left: 1.6rem;
    z-index: 200;
    width: 22px;
    height: 22px;
    padding: 0;
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .sw-dot-core {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    /* Orangé ambré plein — visible sur orange clair ET sur brun foncé */
    background: #c87530;
    box-shadow: 0 0 0 2px rgba(200, 117, 48, 0.25);
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
  }
  .sw-dot:hover .sw-dot-core {
    background: #e08a3a;
    box-shadow: 0 0 0 3px rgba(224, 138, 58, 0.3);
  }
  .sw-dot--active .sw-dot-core {
    background: #f5a623;
    box-shadow: 0 0 0 3px rgba(245, 166, 35, 0.35);
    transform: scale(1.15);
  }

  /* ── Panneau translucide — fond conservé ── */
  .sw-panel {
    position: fixed;
    bottom: 3rem;
    left: 1.6rem;
    z-index: 199;
    width: 272px;

    /* Translucide identique aux cartes, conservé */
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);

    border: 1px solid rgba(245, 166, 35, 0.28);
    border-top: 2px solid rgba(245, 166, 35, 0.5);
    border-radius: 14px;

    box-shadow:
      inset 3px 0 0 rgba(245, 166, 35, 0.3),
      0 0 0 1px rgba(245, 166, 35, 0.08),
      0 4px 24px rgba(0, 0, 0, 0.4),
      0 0 40px rgba(245, 166, 35, 0.06),
      0 0 80px 20px rgba(245, 166, 35, 0.03);

    opacity: 0;
    transform: translateY(10px) scale(0.96);
    pointer-events: none;
    transition: opacity 0.22s cubic-bezier(0.22,1,0.36,1), transform 0.22s cubic-bezier(0.22,1,0.36,1);
  }
  .sw-panel--open { opacity: 1; transform: translateY(0) scale(1); pointer-events: auto; }

  /* ── Header ── */
  .sw-panel-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.9rem 1.1rem 0.7rem;
    border-bottom: 1px solid rgba(245, 166, 35, 0.15);
  }
  .sw-panel-title {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    /* couleur gérée par sw-theme--dark / sw-theme--light */
  }
  .sw-panel-close {
    background: none; border: none; cursor: pointer;
    font-size: 0.75rem;
    padding: 2px 6px; border-radius: 4px;
    transition: color 0.15s; line-height: 1;
    /* couleur gérée par sw-theme--dark / sw-theme--light */
  }

  /* ── Blocs ── */
  .sw-block { padding: 1rem 1.1rem 0.9rem; }

  .sw-block-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.62rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 0.65rem;
    /* couleur gérée par sw-theme--dark / sw-theme--light */
  }

  .sw-divider { height: 1px; background: rgba(245, 166, 35, 0.15); margin: 0 1.1rem; }

  /* ── Stats ── */
  .sw-stat-line { display: flex; align-items: baseline; gap: 0.5rem; line-height: 1.2; }

  .sw-stat-value {
    font-family: "Mulish", sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.01em;
    /* couleur gérée par sw-theme--dark / sw-theme--light */
  }

  .sw-stat-unit {
    font-family: "Mulish", sans-serif;
    font-size: 0.88rem;
    font-weight: 400;
    line-height: 1.3;
    margin-left: 0.25rem;
    /* couleur gérée par sw-theme--dark / sw-theme--light */
  }

  .sw-stat-sub {
    font-family: "Mulish", sans-serif;
    font-size: 0.72rem;
    font-weight: 300;
    margin-top: 0.28rem;
    line-height: 1.4;
    /* couleur gérée par sw-theme--dark / sw-theme--light */
  }

  .sw-empty {
    font-family: "Libre Baskerville", Georgia, serif;
    font-size: 0.82rem;
    font-style: italic;
    line-height: 1.5;
    /* couleur gérée par sw-theme--dark / sw-theme--light */
  }

  /* ── Pills nuancier ── */
  .sw-nu-row { display: flex; gap: 0.55rem; margin-top: 0.7rem; }

  .sw-nu-pill {
    flex: 1;
    background: rgba(245, 166, 35, 0.08);
    border: 1px solid rgba(245, 166, 35, 0.22);
    border-radius: 10px;
    padding: 0.5rem 0.65rem;
    display: flex; flex-direction: column; gap: 0.25rem;
  }

  .sw-nu-pill-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.58rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    /* couleur gérée par sw-theme--dark / sw-theme--light */
  }

  .sw-nu-pill-val {
    font-family: "Libre Baskerville", Georgia, serif;
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1;
    display: flex;
    align-items: baseline;
    gap: 0.2rem;
    /* couleur gérée par sw-theme--dark / sw-theme--light */
  }

  .sw-nu-pill-total {
    font-family: "Mulish", sans-serif;
    font-size: 0.7rem;
    font-weight: 400;
    letter-spacing: 0.02em;
    /* couleur gérée par sw-theme--dark / sw-theme--light */
  }

  /* ── Bloc cartographie ── */
  .sw-carto-block {
    margin-top: 0.75rem;
    padding-top: 0.65rem;
    border-top: 1px solid rgba(245, 166, 35, 0.1);
  }
  /* Quand sw-carto-block est le premier enfant (pas de pills au-dessus) */
  .sw-carto-block:first-child {
    margin-top: 0;
    padding-top: 0;
    border-top: none;
  }

  .sw-carto-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.45rem;
  }

  .sw-carto-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.58rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    /* couleur gérée par sw-theme--dark / sw-theme--light */
  }

  .sw-carto-count {
    font-family: "Mulish", sans-serif;
    font-size: 0.82rem;
    font-weight: 700;
    /* couleur gérée par sw-theme--dark / sw-theme--light */
  }

  .sw-carto-bar {
    display: flex;
    gap: 3px;
    margin-bottom: 0.4rem;
  }

  .sw-carto-seg {
    flex: 1;
    height: 5px;
    border-radius: 2px;
    background: rgba(245, 166, 35, 0.12);
    transition: background 0.3s ease;
  }

  .sw-carto-seg--on {
    background: linear-gradient(90deg, #e85d20, #f5a623);
    box-shadow: 0 0 4px rgba(245, 166, 35, 0.35);
  }

  .sw-carto-derniere {
    font-family: "Mulish", sans-serif;
    font-size: 0.72rem;
    font-style: italic;
    margin-top: 0.2rem;
    /* couleur gérée par sw-theme--dark / sw-theme--light */
  }

  /* ── Footer ── */
  .sw-panel-footer {
    padding: 0.55rem 1.1rem 0.85rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.58rem;
    letter-spacing: 0.07em;
    border-top: 1px solid rgba(245, 166, 35, 0.1);
    margin-top: 0.15rem;
    /* couleur gérée par sw-theme--dark / sw-theme--light */
  }

  /* ══════════════════════════════════════════════
     THÈME ATELIER (fond sombre/orangé) — défaut
     ══════════════════════════════════════════════ */
  .sw-theme--dark .sw-panel-title     { color: rgba(255, 245, 220, 0.9); }
  .sw-theme--dark .sw-panel-close     { color: rgba(255, 245, 220, 0.35); }
  .sw-theme--dark .sw-panel-close:hover { color: rgba(255, 245, 220, 0.75); }
  .sw-theme--dark .sw-block-label     { color: rgba(255, 220, 160, 0.85); }
  .sw-theme--dark .sw-stat-value      { color: rgba(255, 245, 220, 0.95); }
  .sw-theme--dark .sw-stat-unit       { color: rgba(255, 235, 190, 0.65); }
  .sw-theme--dark .sw-stat-sub        { color: rgba(255, 235, 190, 0.5); }
  .sw-theme--dark .sw-empty           { color: rgba(255, 235, 190, 0.75); }
  .sw-theme--dark .sw-nu-pill-label   { color: rgba(255, 215, 110, 1); }
  .sw-theme--dark .sw-nu-pill-val     { color: rgba(255, 245, 220, 0.95); }
  .sw-theme--dark .sw-nu-pill-total   { color: rgba(255, 235, 190, 0.75); }
  .sw-theme--dark .sw-carto-label     { color: rgba(255, 215, 110, 1); }
  .sw-theme--dark .sw-carto-count     { color: rgba(255, 245, 220, 0.9); }
  .sw-theme--dark .sw-carto-derniere  { color: rgba(255, 235, 190, 0.55); }
  .sw-theme--dark .sw-panel-footer    { color: rgba(255, 235, 190, 0.28); }

  /* ══════════════════════════════════════════════
     THÈME SITE (fond crème #f5f0e8) — hors atelier
     ══════════════════════════════════════════════ */
  .sw-theme--light .sw-panel-title     { color: rgba(60, 40, 15, 0.85); }
  .sw-theme--light .sw-panel-close     { color: rgba(90, 60, 25, 0.35); }
  .sw-theme--light .sw-panel-close:hover { color: rgba(90, 60, 25, 0.75); }
  .sw-theme--light .sw-block-label     { color: rgba(160, 90, 20, 0.85); }
  .sw-theme--light .sw-stat-value      { color: rgba(40, 25, 10, 0.92); }
  .sw-theme--light .sw-stat-unit       { color: rgba(100, 65, 25, 0.70); }
  .sw-theme--light .sw-stat-sub        { color: rgba(100, 65, 25, 0.55); }
  .sw-theme--light .sw-empty           { color: rgba(100, 65, 25, 0.60); }
  .sw-theme--light .sw-nu-pill-label   { color: rgba(160, 90, 20, 0.80); }
  .sw-theme--light .sw-nu-pill-val     { color: rgba(40, 25, 10, 0.90); }
  .sw-theme--light .sw-nu-pill-total   { color: rgba(100, 65, 25, 0.65); }
  .sw-theme--light .sw-carto-label     { color: rgba(160, 90, 20, 0.80); }
  .sw-theme--light .sw-carto-count     { color: rgba(40, 25, 10, 0.88); }
  .sw-theme--light .sw-carto-derniere  { color: rgba(100, 65, 25, 0.60); }
  .sw-theme--light .sw-panel-footer    { color: rgba(90, 60, 25, 0.35); }

  /* ── Mobile ── */
  @media (max-width: 480px) {
    .sw-dot  { bottom: 1.1rem; left: 1.1rem; }
    .sw-panel { bottom: 2.5rem; left: 1rem; width: calc(100vw - 2rem); max-width: 300px; }
  }
</style>
